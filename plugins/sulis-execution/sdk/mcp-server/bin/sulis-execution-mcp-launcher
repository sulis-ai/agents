#!/bin/sh
# Robust launcher for the sulis-execution-mcp MCP server.
#
# Why this exists: the bare console-script entry-point `sulis-execution-mcp`
# relies on the user's shell PATH containing the Python install's bin/.
# On macOS, Claude Code launched from Finder / Spotlight / Launchpad
# inherits launchctl's minimal PATH (/usr/bin:/bin:/usr/sbin:/sbin) and
# CANNOT see pyenv shims or user-local bin/ directories. This breaks
# the MCP server spawn — the user sees "1 error during load" with no
# obvious cause.
#
# This launcher tries multiple Python interpreters in priority order
# and execs the first one that can import sulis_execution_mcp. The
# install requirement (pip install -e sdk/mcp-server/) is unchanged —
# this just makes finding the install robust against PATH quirks.

set -e

# Candidate python interpreters, most-likely first.
# Order matters: pyenv-managed pythons typically come first since this
# is a developer-oriented tool; system / Homebrew pythons fall back.
CANDIDATES="
  python3
  python3.12
  python3.11
  python3.10
  ${HOME}/.pyenv/shims/python3
  ${HOME}/.pyenv/versions/3.12.12/bin/python3
  /usr/local/bin/python3
  /opt/homebrew/bin/python3
  /usr/bin/python3
"

# Try each candidate; exec the first one that can import the package.
for py in $CANDIDATES; do
  # Expand variables (HOME etc.); skip empties; check executable
  py_resolved=$(eval echo "$py")
  if [ -x "$py_resolved" ] || command -v "$py_resolved" >/dev/null 2>&1; then
    if "$py_resolved" -c "import sulis_execution_mcp" >/dev/null 2>&1; then
      exec "$py_resolved" -m sulis_execution_mcp "$@"
    fi
  fi
done

# No python found with the package importable — emit a diagnostic to
# stderr so the user sees it in Claude Code's plugin error display.
cat >&2 <<EOF
sulis-execution-mcp launcher: could not find a Python interpreter with
sulis_execution_mcp installed.

Tried (in priority order):
$CANDIDATES

Fix:
  1. Confirm the package is installed:
       pip show sulis-execution-mcp
  2. If not, install it from this plugin:
       pip install -e "\$CLAUDE_PLUGIN_ROOT/sdk/mcp-server/"
  3. If installed but this launcher still can't find it, ensure the
     Python with the install on its sys.path is in one of the
     candidate paths above. You can also bypass this launcher by
     editing .mcp.json's "command" to the absolute path of your
     Python install (e.g., /Users/<name>/.pyenv/versions/3.12.X/bin/sulis-execution-mcp).

See plugins/sulis-execution/sdk/docs/troubleshooting/verify-mcp-autoload.md
for the full diagnostic guide.
EOF

exit 1
