{
  "name": "@sulis-ai/execution",
  "version": "0.2.3",
  "description": "Typed TypeScript SDK for the sulis-execution plugin's CLI tools (wpx-pipeline, wpx-train, sulis-change, etc.)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Iain Niven-Bowling",
  "repository": {
    "type": "git",
    "url": "https://github.com/sulis-ai/agents"
  },
  "keywords": [
    "sulis-ai",
    "sulis-execution",
    "wpx",
    "sdk",
    "agent-consumable"
  ],
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.11.0"
  }
}
