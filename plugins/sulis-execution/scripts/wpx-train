#!/usr/bin/env python3
"""wpx-train — batched merge queue (Steps 8b/9/10 per-batch).

Per-batch sibling of wpx-pipeline. Discovers eligible Work Packages
from INDEX.md + origin branches + per-WP CI status (no separate queue
file — see ADR-212 D6 amended). When the train fires, it packs eligible
WPs into batches, rebases each branch independently onto current dev,
runs bundled-tip CI, sequential squash-merges into dev, then one
deploy/health/smoke per batch. Per-WP security review stays per-WP
(Step 11) — the train doesn't collapse it.

Subcommands:

  queue-list           List eligible (and ineligible-with-reason) WPs.
                       Read-only; runs the discovery algorithm and
                       prints the result.

  queue-add            Force-include a WP in the next train despite
                       red CI or other ineligibility. Writes a marker
                       to train-overrides.yaml.

  queue-remove         Hold a WP back from the next train. Writes a
                       hold marker to train-overrides.yaml.

  status               Read-only summary: eligible count, trigger
                       state, last train result.

  doctor               Diagnose drift: WPs marked step-7-complete with
                       missing branches; orphan origin branches not in
                       INDEX.md; etc.

  run                  Fire the train. (Phase 2 — not yet implemented
                       in v0.11.0 skeleton; will be added in Phase 2.)

Eligibility (per ADR-212 D6 amended):
  1. status == step-7-complete                         (or force-include)
  2. branch exists on origin
  3. branch CI is green                                (or force-include)
  4. all depends_on WPs have status == done
  5. WP is not hold-overridden

Outputs structured JSON to stdout. Exit codes: 0 success, 1 expected
failure (e.g. nothing eligible + no force), 2 internal error.
"""

from __future__ import annotations

import argparse
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
_SCRIPTS_DIR = Path(__file__).parent

from _wpxlib import (  # noqa: E402
    CI_DEFAULT_CAP,
    CI_DEFAULT_INTERVAL,
    DEPLOY_DEFAULT_CAP,
    DEPLOY_DEFAULT_INTERVAL,
    HEALTH_DEFAULT_CAP,
    TRAIN_BLOCKED_STATUS,
    EligibilityResult,
    TrainOverrides,
    WPRow,
    _gh_branch_sha,
    _gh_ref_sha,
    _join_health_url,
    _log,
    _merge_squash,
    _poll_ci,
    _poll_deploy,
    _poll_health,
    _run_smoke,
    add_common_args,
    check_train_trigger,
    cli_main,
    clone_repo_to_temp,
    compute_culprit_heuristic,
    emit_error,
    emit_internal_error,
    emit_ok,
    emit_result,
    find_eligible_branches,
    flip_index_status_via_cli,
    pack_batches,
    parse_index_md,
    paths_from_args,
    read_overrides,
    PatchesAlreadyAppliedError,
    rebase_branch_in_clone,
    restore_branch_with_guard,
    revert_train_on_dev,
    write_overrides,
    write_train_blocker,
    write_train_run_record,
    write_wp_blocker_via_cli,
)


# --- Helpers shared across subcommands ----------------------------------

def _resolve_repo(args: argparse.Namespace) -> str:
    repo = args.repo or os.environ.get("GITHUB_REPOSITORY")
    if not repo:
        emit_error(
            "Could not determine GitHub repo (--repo or $GITHUB_REPOSITORY)"
        )
    return repo


def _eligibility_to_dict(e: EligibilityResult) -> dict:
    return {
        "wp": e.wp,
        "branch": e.branch,
        "eligible": e.eligible,
        "reason": e.reason,
        "primitive": e.primitive,
        "forced": e.forced,
    }


# --- Subcommand: queue-list ---------------------------------------------

def cmd_queue_list(args: argparse.Namespace) -> None:
    """Run the eligibility algorithm and print eligible + ineligible WPs."""
    paths = paths_from_args(args)
    repo = _resolve_repo(args)

    if not paths.index_md.exists():
        emit_error(
            f"INDEX.md not found at {paths.index_md}",
            context={"hint": "Has /sea:decompose been run for this project?"},
        )

    wps = parse_index_md(paths.index_md)
    overrides = read_overrides(paths.train_overrides)
    results = find_eligible_branches(wps, repo, paths.wp_dir, overrides)

    eligible = [r for r in results if r.eligible]
    ineligible = [r for r in results if not r.eligible]

    emit_ok(data={
        "project": args.project,
        "index_md": str(paths.index_md),
        "eligible_count": len(eligible),
        "ineligible_count": len(ineligible),
        "eligible": [_eligibility_to_dict(e) for e in eligible],
        "ineligible": [_eligibility_to_dict(e) for e in ineligible],
        "overrides": {
            "includes": overrides.includes,
            "holds": overrides.holds,
        },
    })


# --- Subcommand: queue-add (force-include override) ---------------------

def cmd_queue_add(args: argparse.Namespace) -> None:
    """Force-include a WP in the next train run.

    Use cases:
      - CI is red but the failure is unrelated to this WP and the
        founder wants to bundle anyway
      - WP status is not step-7-complete but the founder wants to ship
        the current branch state (rare; usually means a manual workflow
        bypassed the status update)

    Writes to .architecture/{project}/train-overrides.yaml.
    """
    paths = paths_from_args(args)
    overrides = read_overrides(paths.train_overrides)

    if args.wp in overrides.includes:
        emit_ok(data={
            "wp": args.wp,
            "action": "noop",
            "reason": f"{args.wp} already in includes",
        })

    # If WP was previously held, clear the hold before adding to includes
    if args.wp in overrides.holds:
        overrides.holds.remove(args.wp)

    overrides.includes.append(args.wp)
    write_overrides(paths.train_overrides, overrides)

    emit_ok(data={
        "wp": args.wp,
        "action": "force_include_added",
        "overrides_path": str(paths.train_overrides),
        "includes": overrides.includes,
        "holds": overrides.holds,
    })


# --- Subcommand: queue-remove (hold override) ---------------------------

def cmd_queue_remove(args: argparse.Namespace) -> None:
    """Hold a WP back from the next train run.

    Use cases:
      - WP is step-7-complete and CI-green but the founder wants to
        ship it solo (will run wpx-pipeline directly afterwards)
      - WP needs investigation but the founder doesn't want to flip
        INDEX status to step-7-blocked yet

    Writes to .architecture/{project}/train-overrides.yaml.
    """
    paths = paths_from_args(args)
    overrides = read_overrides(paths.train_overrides)

    if args.wp in overrides.holds:
        emit_ok(data={
            "wp": args.wp,
            "action": "noop",
            "reason": f"{args.wp} already on hold",
        })

    # If WP was force-included, clear that before adding the hold
    if args.wp in overrides.includes:
        overrides.includes.remove(args.wp)

    overrides.holds.append(args.wp)
    write_overrides(paths.train_overrides, overrides)

    emit_ok(data={
        "wp": args.wp,
        "action": "hold_added",
        "overrides_path": str(paths.train_overrides),
        "includes": overrides.includes,
        "holds": overrides.holds,
    })


# --- Subcommand: status -------------------------------------------------

def cmd_status(args: argparse.Namespace) -> None:
    """Read-only summary of train state."""
    paths = paths_from_args(args)
    repo = _resolve_repo(args)

    if not paths.index_md.exists():
        emit_error(f"INDEX.md not found at {paths.index_md}")

    wps = parse_index_md(paths.index_md)
    overrides = read_overrides(paths.train_overrides)
    results = find_eligible_branches(wps, repo, paths.wp_dir, overrides)

    eligible = [r for r in results if r.eligible]

    # Most recent train run, if any
    last_train_run = None
    if paths.train_runs_dir.exists():
        runs = sorted(paths.train_runs_dir.glob("train-*.yaml"))
        if runs:
            last_train_run = str(runs[-1])

    # Trigger preview
    trigger_state = "not_ready"
    trigger_reason = f"{len(eligible)} eligible (need ≥3 for size trigger)"
    if len(eligible) >= 3:
        trigger_state = "ready_size"
        trigger_reason = f"{len(eligible)} eligible (size trigger met)"
    elif len(eligible) >= 1:
        # Staleness check is Phase 2 — for now just note we have ≥1
        trigger_state = "waiting"
        trigger_reason = f"{len(eligible)} eligible; staleness check pending in Phase 2"

    emit_ok(data={
        "project": args.project,
        "eligible_count": len(eligible),
        "eligible_wps": [r.wp for r in eligible],
        "ineligible_count": sum(1 for r in results if not r.eligible),
        "overrides": {
            "includes": overrides.includes,
            "holds": overrides.holds,
        },
        "trigger_state": trigger_state,
        "trigger_reason": trigger_reason,
        "last_train_run": last_train_run,
    })


# --- Subcommand: doctor (drift diagnosis) -------------------------------

def cmd_doctor(args: argparse.Namespace) -> None:
    """Diagnose drift between INDEX.md, WP files, and origin branches."""
    paths = paths_from_args(args)
    repo = _resolve_repo(args)

    issues: list[dict] = []

    if not paths.index_md.exists():
        emit_error(f"INDEX.md not found at {paths.index_md}")

    wps = parse_index_md(paths.index_md)
    by_id = {wp.id: wp for wp in wps}

    # Check: every WP in INDEX.md has a matching WP file
    for wp in wps:
        try:
            paths.wp_file(wp.id)
        except (FileNotFoundError, ValueError) as exc:
            issues.append({
                "kind": "wp_file_missing",
                "wp": wp.id,
                "detail": str(exc),
            })

    # Check: every WP at step-7-complete has dependencies satisfied
    for wp in wps:
        if wp.status != "step-7-complete":
            continue
        for dep_id in wp.depends_on:
            dep = by_id.get(dep_id)
            if dep is None:
                issues.append({
                    "kind": "depends_on_unknown_wp",
                    "wp": wp.id,
                    "detail": f"depends on {dep_id} which is not in INDEX.md",
                })
            elif dep.status != "done":
                issues.append({
                    "kind": "depends_on_unmerged",
                    "wp": wp.id,
                    "detail": f"depends on {dep_id} (status: {dep.status})",
                })

    # Note: orphan-branch detection (branches on origin not in INDEX.md)
    # would require listing all origin branches. Skipped in Phase 1 for
    # cost reasons — gh api repos/{repo}/branches paginates and can be
    # large. Surface this as a future doctor extension.

    emit_ok(data={
        "project": args.project,
        "issue_count": len(issues),
        "issues": issues,
        "note_orphan_branches": "skipped in Phase 1 (cost); see doctor source",
    })


# --- Subcommand: run (happy path) ---------------------------------------

import shutil  # noqa: E402  (deferred to here to keep top-of-file imports clean)
import tempfile  # noqa: E402


def _handle_post_merge_failure(
    *,
    record: dict,
    bundle: list[dict],
    reason: str,
    clone_dir: Path,
    repo: str,
    paths,
    train_id: str,
    failure_text: str = "",
) -> None:
    """Revert the train + restore branches + write BLOCKER + flip statuses.

    Called when deploy / health / smoke fails after merges have landed.
    Emits the final result and exits (does not return).
    """
    _log(f"POST-MERGE FAILURE: {reason}. Reverting + restoring.")

    # Revert the merges on dev (single wrapper commit)
    revert_ok, revert_msg = revert_train_on_dev(
        repo, clone_dir, bundle, reason, train_id,
    )

    # Restore each branch to its pre_train_sha (with force-push guard)
    restore_log: list[dict] = []
    for entry in bundle:
        if not entry.get("merge_sha_on_dev"):
            continue  # never merged; nothing to restore
        ok, msg = restore_branch_with_guard(
            repo, clone_dir,
            entry["branch"],
            entry["pre_train_sha"],
            entry["rebased_to_sha"],
        )
        restore_log.append({
            "wp": entry["wp"], "branch": entry["branch"],
            "restored": ok, "detail": msg,
        })

    # Flip all bundled WPs to step-7-blocked
    for entry in bundle:
        flip_index_status_via_cli(
            _SCRIPTS_DIR, paths, entry["wp"], TRAIN_BLOCKED_STATUS,
        )

    # Heuristic culprit + train BLOCKER
    culprit = compute_culprit_heuristic(bundle, clone_dir, failure_text or reason)
    train_blocker_path = write_train_blocker(
        paths, train_id, reason, bundle,
        suspected_wp_id=culprit,
        evidence=failure_text or reason,
    )

    record["outcome"] = "blocker"
    record["outcome_reason"] = reason
    record["revert"] = {"ok": revert_ok, "detail": revert_msg}
    record["restore_log"] = restore_log
    record["train_blocker_path"] = str(train_blocker_path)
    record["suspected_culprit"] = culprit
    write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
    emit_result(record, exit_code=1)


def cmd_run(args: argparse.Namespace) -> None:  # noqa: C901 (clear orchestration)
    """Fire the train. Picks up eligible WPs, packs into batches, rebases,
    runs bundled-tip CI, sequential-merges to dev, one deploy/health/smoke.

    Happy path only (Phase 2). Failure handling (rebase conflicts,
    bundled-tip CI red, post-merge deploy/smoke fail with revert + branch
    restoration) is implemented in Phase 3.
    """
    paths = paths_from_args(args)
    repo = _resolve_repo(args)

    if not paths.index_md.exists():
        emit_error(f"INDEX.md not found at {paths.index_md}")

    # Discovery (re-uses Phase 1 algorithm)
    wps = parse_index_md(paths.index_md)
    overrides = read_overrides(paths.train_overrides)
    results = find_eligible_branches(wps, repo, paths.wp_dir, overrides)
    eligible = [r for r in results if r.eligible]

    # Trigger check
    should_fire, trigger_reason = check_train_trigger(eligible, force=args.force)
    if not should_fire:
        emit_ok(data={
            "outcome": "not_triggered",
            "trigger_reason": trigger_reason,
            "eligible_count": len(eligible),
            "eligible_wps": [r.wp for r in eligible],
        })

    # Pack batches (Phase 2: ship the first batch; later trains pick up rest)
    batches = pack_batches(eligible, max_per_batch=args.max_batch_size)
    if not batches:
        emit_ok(data={"outcome": "nothing_to_pack", "eligible_count": 0})
    batch = batches[0]

    # Train metadata
    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H%M%SZ")
    train_id = f"train-{timestamp}"
    started_at = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    record: dict = {
        "train_id": train_id,
        "started_at": started_at,
        "outcome": "pending",
        "batch_size": len(batch),
        "bundle": [],
        "deploy_url": None,
        "deploy_workflow_run": None,
        "health_status": None,
        "smoke_verdict": None,
    }

    # Sandbox clone — reused across all rebases in this train
    clone_dir = Path(tempfile.mkdtemp(prefix=f"wpx-train-{train_id}-"))

    try:
        _log(f"{train_id}: trigger={trigger_reason}; batch_size={len(batch)}; "
             f"WPs={[e.wp for e in batch]}")
        clone_repo_to_temp(repo, clone_dir)

        # Step: rebase chain. Each branch is rebased onto the previous
        # rebased branch's HEAD (sequential rebase). If a branch's rebase
        # conflicts, remove it from the batch, flip its status to
        # step-7-blocked, write a per-WP BLOCKER, and continue with the
        # remaining branches (Phase 3 D7-rebase-conflict failure mode).
        bundle: list[dict] = []
        rebase_failures: list[dict] = []
        # Base for rebase chain: per CW-04, when inside a change worktree,
        # the caller passes --base-branch to ship WPs to the change branch
        # rather than directly to dev.
        base_branch = args.base_branch or "dev"
        onto_sha = _gh_ref_sha(repo, base_branch)
        for e in batch:
            try:
                pre_train_sha = _gh_branch_sha(repo, e.branch)
            except RuntimeError as exc:
                _log(f"WARN: could not fetch pre_train_sha for {e.branch}: {exc}")
                rebase_failures.append({"wp": e.wp, "branch": e.branch,
                                         "reason": str(exc)})
                continue
            _log(f"Rebasing {e.branch} onto {onto_sha[:8]} (pre={pre_train_sha[:8]})")
            try:
                rebased_sha = rebase_branch_in_clone(
                    clone_dir, e.branch, onto_sha, base_branch=base_branch,
                )
            except PatchesAlreadyAppliedError as exc:
                # v0.15.3 — branch's patches already in base history (typically
                # post-revert). Emit a specific BLOCKER with the manual git
                # revert command so the founder can recover deterministically.
                _log(f"PATCHES ALREADY APPLIED: {e.branch} → {exc}")
                flip_ok, flip_err = flip_index_status_via_cli(
                    _SCRIPTS_DIR, paths, e.wp, TRAIN_BLOCKED_STATUS,
                )
                applied_short = ", ".join(s[:8] for s in exc.applied_shas)
                blocker_ok, blocker_err = write_wp_blocker_via_cli(
                    _SCRIPTS_DIR, paths, e.wp,
                    title=f"Patches already in {exc.base_branch} during {train_id}",
                    observation=(
                        f"git cherry shows {len(exc.applied_shas)} of this "
                        f"WP's commits are already present in "
                        f"origin/{exc.base_branch}: {applied_short}. "
                        f"git rebase would silently drop them; GitHub's merge "
                        f"endpoint would then return 204 No Content."
                    ),
                    root_cause=(
                        "An earlier train likely shipped this WP, then "
                        "reverted (via _handle_post_merge_failure or a manual "
                        "revert commit). The revert neutralised the content "
                        "but the original squash-merge commits remain in "
                        f"{exc.base_branch}'s graph. Re-shipping the branch "
                        "as-is is impossible without first restoring the "
                        "content."
                    ),
                    plain_english=(
                        "This work's changes are already in the codebase's "
                        "history — likely from an earlier shipment that was "
                        "reverted. Trying to ship it again now would silently "
                        "skip it. To recover, find the revert commit on "
                        f"{exc.base_branch} and revert THAT (which brings the "
                        "content back); then mark this WP done directly."
                    ),
                    suggested_next=(
                        f"On {exc.base_branch}: identify the revert commit "
                        f"(e.g. `git log --oneline {exc.base_branch} | grep "
                        f"-i Revert`); run `git revert -m 1 <revert_sha>` "
                        "to restore the content; push; then flip this WP "
                        "to done via `wpx-index flip-status --to done "
                        "--expected step-7-complete`."
                    ),
                )
                rebase_failures.append({
                    "wp": e.wp,
                    "branch": e.branch,
                    "reason": "patches_already_applied",
                    "applied_shas": exc.applied_shas,
                    "index_flipped": flip_ok,
                })
                continue
            except RuntimeError as exc:
                _log(f"REBASE CONFLICT: {e.branch} → {exc}")
                # Flip INDEX status; write per-WP BLOCKER; continue
                flip_ok, flip_err = flip_index_status_via_cli(
                    _SCRIPTS_DIR, paths, e.wp, TRAIN_BLOCKED_STATUS,
                )
                blocker_ok, blocker_err = write_wp_blocker_via_cli(
                    _SCRIPTS_DIR, paths, e.wp,
                    title=f"Rebase conflict during {train_id}",
                    observation=str(exc),
                    root_cause=(
                        "git rebase failed when stacking onto the previous "
                        "rebased branch in the train. Likely a merge "
                        "conflict against a sibling WP's changes."
                    ),
                    plain_english=(
                        f"This WP's branch couldn't be cleanly rebased on "
                        f"top of the other WPs in the train (their changes "
                        f"conflict). The other WPs are continuing. Resolve "
                        f"the conflict locally, push, then flip this WP "
                        f"back to step-7-complete."
                    ),
                    suggested_next=(
                        "Pull origin/dev, rebase this branch, resolve "
                        "conflicts, push. Then re-flip INDEX status."
                    ),
                )
                rebase_failures.append({
                    "wp": e.wp,
                    "branch": e.branch,
                    "reason": str(exc),
                    "index_flipped": flip_ok,
                    "blocker_written": blocker_ok,
                })
                continue
            bundle.append({
                "wp": e.wp,
                "branch": e.branch,
                "pre_train_sha": pre_train_sha,
                "rebased_to_sha": rebased_sha,
                "merge_sha_on_dev": None,
            })
            onto_sha = rebased_sha

        # If every branch failed to rebase, the train can't continue
        if not bundle:
            record["outcome"] = "blocker"
            record["outcome_reason"] = (
                f"all {len(batch)} branches failed to rebase; see per-WP BLOCKERs"
            )
            record["rebase_failures"] = rebase_failures
            write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
            emit_result(record, exit_code=1)

        record["bundle"] = bundle
        record["rebase_failures"] = rebase_failures
        bundle_tip_branch = bundle[-1]["branch"]

        # Step: bundled-tip CI
        ci_interval = args.ci_poll_interval or CI_DEFAULT_INTERVAL
        _log(f"Bundled-tip CI: polling {bundle_tip_branch}")
        ci_verdict = _poll_ci(repo, bundle_tip_branch, ci_interval, CI_DEFAULT_CAP)
        if ci_verdict != "green":
            # Bundle-CI failed → no merge. Flip all in-bundle WPs to
            # step-7-blocked and write a train BLOCKER with the file-overlap
            # heuristic naming the likely culprit. (Phase 3 D7 / CI fail mode.)
            _log(f"BUNDLED-TIP CI {ci_verdict}: blocking all {len(bundle)} WPs")
            reason = f"bundled-tip CI {ci_verdict} on {bundle_tip_branch}"

            culprit = compute_culprit_heuristic(bundle, clone_dir, reason)
            for entry in bundle:
                flip_index_status_via_cli(
                    _SCRIPTS_DIR, paths, entry["wp"], TRAIN_BLOCKED_STATUS,
                )
            train_blocker_path = write_train_blocker(
                paths, train_id, reason, bundle,
                suspected_wp_id=culprit,
                evidence=f"CI verdict: {ci_verdict} on branch {bundle_tip_branch}",
            )
            record["outcome"] = "blocker"
            record["outcome_reason"] = reason
            record["train_blocker_path"] = str(train_blocker_path)
            record["suspected_culprit"] = culprit
            write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
            emit_result(record, exit_code=1)

        # Step: sequential squash-merge
        final_merge_sha = None
        for entry in bundle:
            _log(f"Squash-merging {entry['wp']} ({entry['branch']}) to dev")
            sha = _merge_squash(repo, entry["branch"], entry["wp"],
                                base_branch=base_branch)
            entry["merge_sha_on_dev"] = sha
            final_merge_sha = sha
        record["bundle"] = bundle  # refresh with merge_sha_on_dev populated

        # Step: deploy poll
        deploy_interval = args.deploy_poll_interval or DEPLOY_DEFAULT_INTERVAL
        deploy_cap = args.deploy_cap or DEPLOY_DEFAULT_CAP
        _log(f"Polling deploy '{args.deploy_workflow}' for {final_merge_sha[:8]} "
             f"(interval={deploy_interval}s, cap={deploy_cap}s)")
        deploy_verdict, deploy_url = _poll_deploy(
            repo, args.deploy_workflow, final_merge_sha,
            deploy_interval, deploy_cap,
        )
        record["deploy_url"] = deploy_url
        if deploy_verdict != "green":
            _handle_post_merge_failure(
                record=record, bundle=bundle,
                reason=f"deploy {deploy_verdict}",
                clone_dir=clone_dir, repo=repo, paths=paths,
                train_id=train_id,
                failure_text=f"Deploy workflow result: {deploy_verdict}",
            )

        # Step: health check (optional — only if staging URL provided)
        if args.staging_url:
            health_path = args.health_path or "/"
            health_url = _join_health_url(args.staging_url, health_path)
            _log(f"Health check: {health_url}")
            health = _poll_health(health_url, HEALTH_DEFAULT_CAP)
            record["health_status"] = health
            if health != "healthy":
                _handle_post_merge_failure(
                    record=record, bundle=bundle,
                    reason=f"health check failed at {health_url}",
                    clone_dir=clone_dir, repo=repo, paths=paths,
                    train_id=train_id,
                    failure_text=f"Health check: {health} at {health_url}",
                )
        else:
            record["health_status"] = "skipped (no --staging-url)"

        # Step: smoke test (optional — only if smoke cmd provided)
        if args.smoke_cmd:
            _log("Running smoke test")
            smoke_verdict, smoke_out = _run_smoke(args.smoke_cmd, clone_dir)
            record["smoke_verdict"] = smoke_verdict
            if not smoke_verdict.startswith("PASS"):
                _handle_post_merge_failure(
                    record=record, bundle=bundle,
                    reason=f"smoke {smoke_verdict}",
                    clone_dir=clone_dir, repo=repo, paths=paths,
                    train_id=train_id,
                    failure_text=f"Smoke output:\n{smoke_out}",
                )
        else:
            record["smoke_verdict"] = "skipped (no --smoke-cmd)"

        # Train complete — write record + emit success
        record["outcome"] = "success"
        record["completed_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
        emit_result({
            "train_id": train_id,
            "outcome": "success",
            "wps_shipped": [e.wp for e in batch],
            "deploy_url": deploy_url,
            "final_merge_sha": final_merge_sha,
            "record_path": str(paths.train_runs_dir / f"{train_id}.yaml"),
        }, exit_code=0)

    except RuntimeError as exc:
        record["outcome"] = "error"
        record["outcome_reason"] = f"internal: {exc}"
        record["completed_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        try:
            write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
        except Exception:  # noqa: BLE001
            pass
        emit_result(record, exit_code=2)
    except SystemExit:
        raise
    except Exception as exc:  # noqa: BLE001
        emit_internal_error(exc)
    finally:
        shutil.rmtree(clone_dir, ignore_errors=True)


# --- argparse -----------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description=(
            "Batched merge queue (per-batch sibling of wpx-pipeline). "
            "Discovers eligible WPs from INDEX.md + origin + CI status. "
            "v0.11.0 skeleton — queue + status + doctor are functional; "
            "run lands in v0.12.0+."
        ),
    )
    sub = parser.add_subparsers(dest="subcommand", required=True)

    def _common(p: argparse.ArgumentParser) -> None:
        add_common_args(p)
        p.add_argument("--repo", default=None,
                       help="GitHub repo (org/name); defaults to $GITHUB_REPOSITORY")

    p_list = sub.add_parser("queue-list", help="List eligible + ineligible WPs")
    _common(p_list)

    p_add = sub.add_parser("queue-add", help="Force-include a WP in next train")
    _common(p_add)
    p_add.add_argument("--wp", required=True, help="WP ID (e.g. WP-AUTO-018)")
    p_add.add_argument("--reason", default="", help="Optional human reason (recorded but not enforced)")

    p_remove = sub.add_parser("queue-remove", help="Hold a WP back from next train")
    _common(p_remove)
    p_remove.add_argument("--wp", required=True, help="WP ID (e.g. WP-AUTO-018)")
    p_remove.add_argument("--reason", default="", help="Optional human reason")

    p_status = sub.add_parser("status", help="Read-only summary of train state")
    _common(p_status)

    p_doctor = sub.add_parser("doctor", help="Diagnose drift (missing branches, unmet deps, etc.)")
    _common(p_doctor)

    p_run = sub.add_parser("run", help="Fire the train (happy path; failure handling in Phase 3)")
    _common(p_run)
    p_run.add_argument("--force", action="store_true",
                       help="Bypass size/staleness trigger")
    p_run.add_argument("--deploy-workflow", required=True,
                       help="Deploy workflow name (e.g. 'Deploy to Dev Environment')")
    p_run.add_argument("--staging-url", default=None,
                       help="Staging URL for health check (optional)")
    p_run.add_argument(
        "--health-path", default="",
        help="HTTP path to use for the health check (default /)",
    )
    p_run.add_argument("--smoke-cmd", default="",
                       help="Smoke test shell command (run after health check)")
    p_run.add_argument("--ci-poll-interval", type=int, default=None,
                       help=f"CI poll interval (s, default {CI_DEFAULT_INTERVAL})")
    p_run.add_argument("--deploy-poll-interval", type=int, default=None,
                       help=f"Deploy poll interval (s, default {DEPLOY_DEFAULT_INTERVAL})")
    p_run.add_argument("--deploy-cap", type=int, default=None,
                       help=f"Max total deploy-poll time before declaring failure "
                            f"(s, default {DEPLOY_DEFAULT_CAP}). Raise for slow "
                            f"deploys to avoid ADR-212 revert on a still-running deploy.")
    p_run.add_argument("--max-batch-size", type=int, default=5,
                       help="Cap WPs per batch (default 5)")
    p_run.add_argument("--base-branch", default=None,
                       help="Base ref for rebase + merge target (default: dev). "
                            "Per CW-04, when run inside a change worktree, "
                            "callers pass the change branch name so WPs ship "
                            "to the change branch rather than directly to dev.")

    return parser


HANDLERS = {
    "queue-list": cmd_queue_list,
    "queue-add": cmd_queue_add,
    "queue-remove": cmd_queue_remove,
    "status": cmd_status,
    "doctor": cmd_doctor,
    "run": cmd_run,
}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
