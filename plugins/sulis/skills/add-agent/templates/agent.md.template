---
name: {{agent-name-kebab-case}}
description: {{Dispatch trigger — one or two sentences. The parent agent (Sulis, orchestrator, user-facing CLI) scans this to decide whether to route. Name the role + conditions to dispatch + (optional) hard constraints on scope. Founder-facing or both: use ONLY user-facing vocabulary.}}
user_invocable: {{true | false — true if founder can invoke via `claude --agent {{agent-name}}`; false default per Claude Code}}
model: {{haiku | sonnet | opus | omit (inherit) — haiku for routing/classification, sonnet for most specialists, opus for coordinator agents with long-context conversational work}}
tools: {{[Read, Edit, Bash, Agent] | * (inherit-all)}}  # per principle of least privilege
standards:
  input: [REFERENTIAL_INTEGRITY_STANDARD]
  processing: [CRITICAL_THINKING_STANDARD{{, DECOMPOSITION_PROCEDURE if decomposition-heavy}}]
  output: [CRITICAL_THINKING_STANDARD{{, TONE_STANDARD, COACHING_STANDARD if founder-facing or both}}]
verification_spiral:
  tier: {{light | standard | heavy}}  # heavy for coordinator/founder-facing; light only with justification
  template_base: {{LIGHT_TIER_DEFAULT | STANDARD_TIER_DEFAULT | HEAVY_TIER_DEFAULT}}
  custom_dimensions: []  # add domain-specific dimensions here per SPIRAL_TEMPLATES "Declaring a Custom Spiral"
related_skills:
  - relationship: depends_on  # depends_on / optional_input / related_to / supersedes per REFERENTIAL_INTEGRITY_STANDARD
    skill: {{e.g., ../skills/run-wp, ../../sulis/agents/engineering-architect}}
    notes: {{semantic context for this relationship}}
register:  # required if Audience is founder-facing or both; omit for operator-facing or agent-internal
  founder_mode: default
  technical_mode:
    shape: {{json_envelope | markdown_with_paths | diff | raw_tool_output | structured_summary}}
    triggers: [intent, --raw, /sulis:jargon]
