#!/usr/bin/env python3
"""sulis-emit-credential — emit a Credential entity (foundation).

CLI-direct mode only. The actual secret value never enters Sulis-code;
`--token-ref` is a URI pointing at the platform's Secret Manager (see
SPEC-006 sensitive-field handling). For local-dev today, token_ref is a
`secret://...` URI.

Usage:
    sulis-emit-credential --holder dna:actor:<ulid>
                          --kind <oauth|api-key|service-account|certificate|password|mfa-token|webhook-signing-key|other>
                          --token-ref secret://...
                          [--state <active|expired|revoked|rotated>]
                          [--issuer X] [--scope X]
                          [--issued-at <iso>] [--expires-at <iso>]
                          [--base-dir <dir>] [--domain <domain>] [--repo-root <dir>]
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _credential_emission import emit_credential  # noqa: E402
from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402


def _resolve_repo_root(explicit: str | None) -> Path:
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _ok(data: dict) -> int:
    print(json.dumps({"ok": True, "data": data}, indent=2))
    return 0


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(description="Emit a Credential entity (foundation).")
    parser.add_argument("--holder", required=True, help="dna:actor:<ulid>")
    parser.add_argument("--kind", required=True)
    parser.add_argument("--token-ref", required=True, help="opaque ref to the secret (e.g. secret://...)")
    parser.add_argument("--state", default="active")
    parser.add_argument("--issuer", default="")
    parser.add_argument("--scope", default="")
    parser.add_argument("--issued-at", default=None)
    parser.add_argument("--expires-at", default=None)
    parser.add_argument("--base-dir")
    parser.add_argument("--domain", default="foundation")
    parser.add_argument("--repo-root")
    args = parser.parse_args()

    repo_root = _resolve_repo_root(args.repo_root)
    base_dir = (
        Path(args.base_dir).resolve()
        if args.base_dir
        else repo_root / ".brain" / "instances"
    )
    adapter = LocalFileEntityAdapter(base_dir=base_dir, domain=args.domain)

    try:
        cred = emit_credential(
            repo=adapter,
            holder=args.holder,
            kind=args.kind,
            token_ref=args.token_ref,
            state=args.state,
            issuer=args.issuer,
            scope=args.scope,
            issued_at=args.issued_at,
            expires_at=args.expires_at,
        )
    except ValueError as exc:
        return _err(str(exc))
    except EntityValidationError as exc:
        return _err(str(exc))

    ulid = cred["id"].rsplit(":", 1)[-1]
    path = base_dir / args.domain / "credential" / f"{ulid}.jsonld"
    return _ok({
        "count": 1,
        "entities": [{"id": cred["id"], "path": str(path)}],
    })


if __name__ == "__main__":
    sys.exit(main())
