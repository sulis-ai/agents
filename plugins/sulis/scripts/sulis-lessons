#!/usr/bin/env python3
"""sulis-lessons — capture post-ship lessons as durable GitHub issues (#43).

Reads a structured lessons JSON, deduplicates against the open `lesson`-
labelled issues already on the repo, and raises a `lesson` issue for each new
actionable lesson (disposition SEA / TASK). FIX-NOW / FIXED / note lessons are
skipped (the commit is the record, or it's digest-only). Degrades cleanly to
"no issues created" when `gh` is unavailable or the remote isn't GitHub — the
calling skill still writes the narrative digest.

Subcommand:
  capture --lessons-file <path.json> [--repo owner/name] [--dry-run]

The deterministic triage/dedup lives in `_lessons.py`; this script is the gh
glue. Exit codes: 0 success, 1 user/data error, 2 internal error.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
from _lessons import (  # noqa: E402
    lesson_issue_body,
    lesson_issue_title,
    lesson_labels,
    partition_lessons,
)
from _wpxlib import cli_main, emit_error, emit_ok  # noqa: E402


def _run(cmd: list[str], cwd: Path | None = None) -> tuple[int, str, str]:
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, cwd=cwd)  # noqa: S603
    except FileNotFoundError:
        return 127, "", f"{cmd[0]} not found on PATH"
    return proc.returncode, proc.stdout, proc.stderr


def _gh_available() -> bool:
    rc, _, _ = _run(["gh", "auth", "status"])
    return rc == 0


def _existing_lesson_titles(repo: str | None) -> list[str]:
    # Use `--search` (GraphQL backend, immediate) rather than `--label` (REST
    # filter index, eventually-consistent). The label filter could miss
    # issues created seconds earlier, causing the dedup scan to fail silently
    # and re-create the same issue. The search expression `label:lesson
    # is:open` covers both filters in one query (#23).
    cmd = ["gh", "issue", "list", "--search", "label:lesson is:open",
           "--limit", "200", "--json", "title"]
    if repo:
        cmd += ["--repo", repo]
    rc, out, _ = _run(cmd)
    if rc != 0:
        return []
    try:
        return [row.get("title", "") for row in json.loads(out)]
    except (json.JSONDecodeError, AttributeError):
        return []


def _ensure_lesson_label(repo: str | None) -> None:
    cmd = ["gh", "label", "create", "lesson", "--color", "fbca04",
           "--description", "Captured by /sulis:capture-lessons", "--force"]
    if repo:
        cmd += ["--repo", repo]
    _run(cmd)  # best-effort; --force is idempotent. Failure → create may warn.


def _create_issue(lesson: dict, repo: str | None) -> tuple[bool, str]:
    cmd = ["gh", "issue", "create",
           "--title", lesson_issue_title(lesson),
           "--body", lesson_issue_body(lesson)]
    for label in lesson_labels(lesson.get("disposition", "")):
        cmd += ["--label", label]
    if repo:
        cmd += ["--repo", repo]
    rc, out, err = _run(cmd)
    if rc != 0:
        return False, (err or out).strip()
    return True, out.strip()  # gh prints the new issue URL


def _load_lessons(path: Path) -> list[dict]:
    data = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(data, list):
        raise ValueError("lessons file must be a JSON array of lesson objects")
    return data


def cmd_capture(args: argparse.Namespace) -> None:
    lessons_file = Path(args.lessons_file)
    if not lessons_file.exists():
        emit_error(f"lessons file not found: {lessons_file}")
    try:
        lessons = _load_lessons(lessons_file)
    except (json.JSONDecodeError, ValueError) as exc:
        emit_error(f"could not parse lessons file: {exc}")
        return  # for type checker

    # Degrade cleanly when we can't reach GitHub — the skill still writes the
    # narrative digest; we just create no issues.
    if not _gh_available():
        partition = partition_lessons(lessons, existing_issue_titles=[])
        emit_ok(data={
            "degraded": True,
            "reason": "gh unavailable or not authenticated",
            "created": [],
            "would_create": [l["title"] for l in partition["to_create"]],
            "duplicates": [l["title"] for l in partition["duplicates"]],
            "skipped": [l["title"] for l in partition["skipped"]],
        })
        return

    existing = _existing_lesson_titles(args.repo)
    partition = partition_lessons(lessons, existing_issue_titles=existing)

    if args.dry_run:
        emit_ok(data={
            "dry_run": True,
            "would_create": [l["title"] for l in partition["to_create"]],
            "duplicates": [l["title"] for l in partition["duplicates"]],
            "skipped": [l["title"] for l in partition["skipped"]],
        })
        return

    if partition["to_create"]:
        _ensure_lesson_label(args.repo)

    created: list[dict] = []
    errors: list[dict] = []
    for lesson in partition["to_create"]:
        ok, result = _create_issue(lesson, args.repo)
        if ok:
            created.append({"title": lesson["title"], "url": result})
        else:
            errors.append({"title": lesson["title"], "error": result})

    emit_ok(data={
        "degraded": False,
        "created": created,
        "errors": errors,
        "duplicates": [l["title"] for l in partition["duplicates"]],
        "skipped": [l["title"] for l in partition["skipped"]],
    })


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Capture lessons as GitHub issues")
    sub = parser.add_subparsers(dest="subcommand", required=True)
    p_cap = sub.add_parser("capture", help="Raise GitHub issues for actionable lessons")
    p_cap.add_argument("--lessons-file", required=True,
                       help="Path to a JSON array of {id,title,body,disposition}")
    p_cap.add_argument("--repo", default=None,
                       help="GitHub OWNER/REPO (defaults to the current remote)")
    p_cap.add_argument("--dry-run", action="store_true",
                       help="Compute the partition; create no issues")
    return parser


HANDLERS = {"capture": cmd_capture}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
