#!/usr/bin/env python3
"""wpx-train — batched merge queue (Steps 8b/9/10 per-batch).

Per-batch sibling of wpx-pipeline. Discovers eligible Work Packages
from INDEX.md + origin branches + per-WP CI status (no separate queue
file — see ADR-212 D6 amended). When the train fires, it packs eligible
WPs into batches, rebases each branch independently onto current dev,
runs bundled-tip CI, sequential squash-merges into dev, then one
deploy/health/smoke per batch. Per-WP security review stays per-WP
(Step 11) — the train doesn't collapse it.

Subcommands:

  queue-list           List eligible (and ineligible-with-reason) WPs.
                       Read-only; runs the discovery algorithm and
                       prints the result.

  queue-add            Force-include a WP in the next train despite
                       red CI or other ineligibility. Writes a marker
                       to train-overrides.yaml.

  queue-remove         Hold a WP back from the next train. Writes a
                       hold marker to train-overrides.yaml.

  status               Read-only summary: eligible count, trigger
                       state, last train result.

  doctor               Diagnose drift: WPs marked step-7-complete with
                       missing branches; orphan origin branches not in
                       INDEX.md; etc.

  run                  Fire the train. (Phase 2 — not yet implemented
                       in v0.11.0 skeleton; will be added in Phase 2.)

Eligibility (per ADR-212 D6 amended):
  1. status == step-7-complete                         (or force-include)
  2. branch exists on origin
  3. branch CI is green                                (or force-include)
  4. all depends_on WPs have status == done
  5. WP is not hold-overridden

Outputs structured JSON to stdout. Exit codes: 0 success, 1 expected
failure (e.g. nothing eligible + no force), 2 internal error.
"""

from __future__ import annotations

import argparse
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
_SCRIPTS_DIR = Path(__file__).parent

from _wpxlib import (  # noqa: E402
    CI_DEFAULT_CAP,
    CI_DEFAULT_INTERVAL,
    DEPLOY_DEFAULT_CAP,
    DEPLOY_DEFAULT_INTERVAL,
    HEALTH_DEFAULT_CAP,
    TRAIN_BLOCKED_STATUS,
    TRAIN_DONE_STATUS,
    TRAIN_ELIGIBLE_STATUS,
    CommitResult,
    EligibilityResult,
    PlanResult,
    TrainOverrides,
    VerifyResult,
    WPRow,
    _gh_branch_sha,
    _gh_ref_sha,
    _join_health_url,
    _log,
    _merge_squash,
    _poll_ci,
    _poll_deploy,
    _poll_health,
    _run_smoke,
    add_common_args,
    back_integrate_change_branch,
    check_train_trigger,
    cli_main,
    clone_repo_to_temp,
    compute_culprit_heuristic,
    emit_error,
    emit_internal_error,
    emit_ok,
    emit_result,
    find_eligible_branches,
    find_wp_merge_sha,
    is_sha_on_branch,
    flip_index_status_via_cli,
    pack_batches,
    parse_index_md,
    paths_from_args,
    read_overrides,
    PatchesAlreadyAppliedError,
    TrainLock,
    cleanup_train_state,
    init_train_state,
    list_train_runs,
    read_train_run_record,
    read_train_state,
    rebase_branch_in_clone,
    render_train_state_plain_english,
    train_state_path,
    update_train_phase,
    update_wp_phase_outcome,
    restore_branch_with_guard,
    revert_train_on_dev,
    write_overrides,
    write_train_blocker,
    write_train_run_record,
    write_wp_blocker_via_cli,
)


# --- Helpers shared across subcommands ----------------------------------

def _resolve_repo(args: argparse.Namespace) -> str:
    repo = args.repo or os.environ.get("GITHUB_REPOSITORY")
    if not repo:
        emit_error(
            "Could not determine GitHub repo (--repo or $GITHUB_REPOSITORY)"
        )
    return repo


def _eligibility_to_dict(e: EligibilityResult) -> dict:
    return {
        "wp": e.wp,
        "branch": e.branch,
        "eligible": e.eligible,
        "reason": e.reason,
        "primitive": e.primitive,
        "forced": e.forced,
    }


# --- Subcommand: queue-list ---------------------------------------------

def cmd_queue_list(args: argparse.Namespace) -> None:
    """Run the eligibility algorithm and print eligible + ineligible WPs."""
    paths = paths_from_args(args)
    repo = _resolve_repo(args)

    if not paths.index_md.exists():
        emit_error(
            f"INDEX.md not found at {paths.index_md}",
            context={"hint": "Has /sulis:plan-work been run for this project?"},
        )

    wps = parse_index_md(paths.index_md)
    overrides = read_overrides(paths.train_overrides)
    # HD-008 — pass paths so eligibility uses computed status
    # (origin git state + train records), not the stored INDEX cell.
    results = find_eligible_branches(
        wps, repo, paths.wp_dir, overrides,
        strict_ci=getattr(args, "strict_ci", False),
        paths=paths,
        base_branch=getattr(args, "base_branch", None) or "dev",
    )

    eligible = [r for r in results if r.eligible]
    ineligible = [r for r in results if not r.eligible]

    emit_ok(data={
        "project": args.project,
        "index_md": str(paths.index_md),
        "eligible_count": len(eligible),
        "ineligible_count": len(ineligible),
        "eligible": [_eligibility_to_dict(e) for e in eligible],
        "ineligible": [_eligibility_to_dict(e) for e in ineligible],
        "overrides": {
            "includes": overrides.includes,
            "holds": overrides.holds,
        },
    })


# --- Subcommand: queue-add (force-include override) ---------------------

def cmd_queue_add(args: argparse.Namespace) -> None:
    """Force-include a WP in the next train run.

    Use cases:
      - CI is red but the failure is unrelated to this WP and the
        founder wants to bundle anyway
      - WP status is not step-7-complete but the founder wants to ship
        the current branch state (rare; usually means a manual workflow
        bypassed the status update)

    Writes to .architecture/{project}/train-overrides.yaml.
    """
    paths = paths_from_args(args)
    overrides = read_overrides(paths.train_overrides)

    if args.wp in overrides.includes:
        emit_ok(data={
            "wp": args.wp,
            "action": "noop",
            "reason": f"{args.wp} already in includes",
        })

    # If WP was previously held, clear the hold before adding to includes
    if args.wp in overrides.holds:
        overrides.holds.remove(args.wp)

    overrides.includes.append(args.wp)
    write_overrides(paths.train_overrides, overrides)

    emit_ok(data={
        "wp": args.wp,
        "action": "force_include_added",
        "overrides_path": str(paths.train_overrides),
        "includes": overrides.includes,
        "holds": overrides.holds,
    })


# --- Subcommand: queue-remove (hold override) ---------------------------

def cmd_queue_remove(args: argparse.Namespace) -> None:
    """Hold a WP back from the next train run.

    Use cases:
      - WP is step-7-complete and CI-green but the founder wants to
        ship it solo (will run wpx-pipeline directly afterwards)
      - WP needs investigation but the founder doesn't want to flip
        INDEX status to step-7-blocked yet

    Writes to .architecture/{project}/train-overrides.yaml.
    """
    paths = paths_from_args(args)
    overrides = read_overrides(paths.train_overrides)

    if args.wp in overrides.holds:
        emit_ok(data={
            "wp": args.wp,
            "action": "noop",
            "reason": f"{args.wp} already on hold",
        })

    # If WP was force-included, clear that before adding the hold
    if args.wp in overrides.includes:
        overrides.includes.remove(args.wp)

    overrides.holds.append(args.wp)
    write_overrides(paths.train_overrides, overrides)

    emit_ok(data={
        "wp": args.wp,
        "action": "hold_added",
        "overrides_path": str(paths.train_overrides),
        "includes": overrides.includes,
        "holds": overrides.holds,
    })


# --- Subcommand: status -------------------------------------------------

def cmd_status(args: argparse.Namespace) -> None:
    """Read-only summary of train state."""
    paths = paths_from_args(args)
    repo = _resolve_repo(args)

    if not paths.index_md.exists():
        emit_error(f"INDEX.md not found at {paths.index_md}")

    wps = parse_index_md(paths.index_md)
    overrides = read_overrides(paths.train_overrides)
    # HD-008 — pass paths so the status snapshot reflects authoritative
    # state (origin + train records), not the stored INDEX cell.
    results = find_eligible_branches(
        wps, repo, paths.wp_dir, overrides,
        strict_ci=getattr(args, "strict_ci", False),
        paths=paths,
        base_branch=getattr(args, "base_branch", None) or "dev",
    )

    eligible = [r for r in results if r.eligible]

    # Most recent train run, if any
    last_train_run = None
    if paths.train_runs_dir.exists():
        runs = sorted(paths.train_runs_dir.glob("train-*.yaml"))
        if runs:
            last_train_run = str(runs[-1])

    # Trigger preview
    trigger_state = "not_ready"
    trigger_reason = f"{len(eligible)} eligible (need ≥3 for size trigger)"
    if len(eligible) >= 3:
        trigger_state = "ready_size"
        trigger_reason = f"{len(eligible)} eligible (size trigger met)"
    elif len(eligible) >= 1:
        # Staleness check is Phase 2 — for now just note we have ≥1
        trigger_state = "waiting"
        trigger_reason = f"{len(eligible)} eligible; staleness check pending in Phase 2"

    emit_ok(data={
        "project": args.project,
        "eligible_count": len(eligible),
        "eligible_wps": [r.wp for r in eligible],
        "ineligible_count": sum(1 for r in results if not r.eligible),
        "overrides": {
            "includes": overrides.includes,
            "holds": overrides.holds,
        },
        "trigger_state": trigger_state,
        "trigger_reason": trigger_reason,
        "last_train_run": last_train_run,
    })


# --- Subcommand: doctor (drift diagnosis) -------------------------------

def cmd_skip_wp(args: argparse.Namespace) -> None:
    """Drop one WP from a paused train's bundle (v0.19.0c).

    The dropped WP is flipped to step-7-held (founder-paused; can be
    re-included in a future train manually or via train-overrides.yaml).
    The state file is updated to reflect the smaller bundle.

    Pragmatic implementation: this command MUTATES THE STATE only. It
    does NOT auto-resume the train — the founder calls `wpx-train
    resume <id>` next to fire the smaller bundle.

    Use case: a paused train has 5 WPs, 1 of which is genuinely broken.
    Skip that WP; resume continues with the other 4.

    For pre-merge paused: dropping is clean (no merge happened).
    For post-merge paused: dropping after the WP has been merged is
    a no-op for the merge (it's already on dev) — this command just
    removes the WP from the bundle for any subsequent resume's
    consideration. The merge stays on dev.
    """
    paths = paths_from_args(args)
    state_path = train_state_path(paths.train_runs_dir, args.train_id)

    if not state_path.exists():
        emit_error(
            f"Train {args.train_id!r} has no in-flight state file at "
            f"{state_path}. skip-wp only operates on in-flight (paused) "
            f"trains."
        )
        return

    try:
        state = read_train_state(state_path)
    except RuntimeError as exc:
        emit_error(str(exc))
        return

    if state.get("phase") in ("success", "failed", "aborted"):
        emit_error(
            f"Train {args.train_id!r} is in terminal phase "
            f"{state.get('phase')!r}; can't skip-wp on a terminal train."
        )
        return

    bundle = state.get("bundle", [])
    target_entry = None
    for entry in bundle:
        if entry.get("wp") == args.wp:
            target_entry = entry
            break
    if target_entry is None:
        emit_error(
            f"WP {args.wp!r} not in train {args.train_id!r}'s bundle "
            f"({[e.get('wp') for e in bundle]}). Inspect via `wpx-train "
            f"inspect {args.train_id}` to see the actual bundle."
        )
        return

    try:
        lock = TrainLock(paths.train_runs_dir, args.train_id)
        lock.__enter__()
    except RuntimeError as exc:
        emit_error(str(exc))
        return

    try:
        # Flip the skipped WP to step-7-held (founder-paused)
        flip_ok, flip_err = flip_index_status_via_cli(
            _SCRIPTS_DIR, paths, args.wp, TRAIN_HELD_STATUS,
        )
        # Remove from state bundle
        state["bundle"] = [e for e in bundle if e.get("wp") != args.wp]
        from _wpxlib import write_train_state  # noqa: E402
        write_train_state(state_path, state)
    finally:
        lock.__exit__(None, None, None)

    emit_ok(data={
        "train_id": args.train_id,
        "skipped_wp": args.wp,
        "index_flipped": flip_ok,
        "remaining_bundle": [e.get("wp") for e in state["bundle"]],
        "next_step": (
            f"Run `wpx-train resume {args.train_id}` to fire the "
            f"smaller bundle."
        ),
    })


def cmd_retry_wp(args: argparse.Namespace) -> None:
    """Clear one WP's per-phase outcomes within a paused train (v0.19.0c).

    Pragmatic implementation: mutates state. Clears the named WP's
    `phase_outcomes` dict so when the train is next resumed, that WP
    is treated as fresh (rebase + CI + merge re-attempted).

    Use case: a paused train has a WP whose specific issue was
    transient (CI flake on its individual branch, network blip during
    its rebase). The founder retries just that WP — the others keep
    their progress.

    For v0.19.0c (pragmatic): this command mutates state but does NOT
    re-execute. The founder calls `wpx-train resume <id>` after, which
    re-fires the train; the retried WP is in the eligible bundle
    again with its phase_outcomes cleared.

    Limitation: in the current re-fire-based resume (v0.19.0a), the
    ENTIRE train re-fires — there's no "retry just this WP" surgical
    re-execution. That comes with the deferred full per-phase cmd_run
    factoring. Until then, retry-wp is meaningful only in combination
    with skip-wp on the WPs that DON'T need retrying.
    """
    paths = paths_from_args(args)
    state_path = train_state_path(paths.train_runs_dir, args.train_id)

    if not state_path.exists():
        emit_error(
            f"Train {args.train_id!r} has no in-flight state file. "
            f"retry-wp only operates on in-flight (paused) trains."
        )
        return

    try:
        state = read_train_state(state_path)
    except RuntimeError as exc:
        emit_error(str(exc))
        return

    if state.get("phase") in ("success", "failed", "aborted"):
        emit_error(
            f"Train {args.train_id!r} is in terminal phase "
            f"{state.get('phase')!r}; can't retry-wp on a terminal train."
        )
        return

    bundle = state.get("bundle", [])
    target = None
    for entry in bundle:
        if entry.get("wp") == args.wp:
            target = entry
            break
    if target is None:
        emit_error(
            f"WP {args.wp!r} not in train {args.train_id!r}'s bundle "
            f"({[e.get('wp') for e in bundle]})."
        )
        return

    try:
        lock = TrainLock(paths.train_runs_dir, args.train_id)
        lock.__enter__()
    except RuntimeError as exc:
        emit_error(str(exc))
        return

    try:
        cleared = target.get("phase_outcomes", {})
        target["phase_outcomes"] = {}
        # Restore step-7-complete if the WP was flipped to step-7-blocked
        flip_ok, _ = flip_index_status_via_cli(
            _SCRIPTS_DIR, paths, args.wp, TRAIN_ELIGIBLE_STATUS,
        )
        from _wpxlib import write_train_state  # noqa: E402
        write_train_state(state_path, state)
    finally:
        lock.__exit__(None, None, None)

    emit_ok(data={
        "train_id": args.train_id,
        "retry_wp": args.wp,
        "cleared_outcomes": list(cleared.keys()) if cleared else [],
        "index_restored_to": TRAIN_ELIGIBLE_STATUS,
        "next_step": (
            f"Run `wpx-train resume {args.train_id}` to re-fire the "
            f"train with {args.wp}'s outcomes cleared."
        ),
    })


def cmd_abort(args: argparse.Namespace) -> None:
    """Abort a paused or in-flight train (v0.19.0b).

    Phase-aware abort:

    - **Pre-merge phases** (pending, rebasing, ci_running, paused
      without `merging` in phase history): no merges have landed.
      Restore the bundled WP branches to their pre_train_sha via
      restore_branch_with_guard (v0.15.2; handles auto-deleted
      branches too). Flip WPs to step-7-held (founder-paused;
      explicitly distinct from step-7-blocked). Mark state=aborted.

    - **Post-merge phases** (merging mid-batch, deploying, verifying,
      paused with `merging` in history): merges are on dev. Run the
      ADR-212 revert path — single wrapper-revert commit, restore
      branches, flip WPs to step-7-blocked, write train BLOCKER.
      Mark state=aborted.

    - **Terminal phases** (success, failed, aborted): error — nothing
      to abort.

    Both paths cleanup the in-flight state file after writing the
    historical .yaml record + the audit-trail state=aborted entry.
    """
    paths = paths_from_args(args)
    repo = _resolve_repo(args)
    state_path = train_state_path(paths.train_runs_dir, args.train_id)

    if not state_path.exists():
        emit_error(
            f"Train {args.train_id!r} has no in-flight state file. "
            f"If you need to undo a terminal train, use the git revert "
            f"workflow manually — `wpx-train abort` only acts on "
            f"in-flight states."
        )
        return

    try:
        state = read_train_state(state_path)
    except RuntimeError as exc:
        emit_error(str(exc))
        return

    phase = state.get("phase")
    if phase in ("success", "failed", "aborted"):
        emit_error(
            f"Train {args.train_id!r} is in terminal phase {phase!r}; "
            f"nothing to abort."
        )
        return

    # Determine pre-merge vs post-merge from phase_history
    phase_history = state.get("phase_history", [])
    phases_seen = {e.get("phase") for e in phase_history}
    is_post_merge = "merging" in phases_seen or phase == "merging"

    _log(f"ABORTING train {args.train_id} (phase={phase}, "
         f"post_merge={is_post_merge})")

    try:
        lock = TrainLock(paths.train_runs_dir, args.train_id)
        lock.__enter__()
    except RuntimeError as exc:
        emit_error(str(exc))
        return

    abort_result: dict = {
        "train_id": args.train_id,
        "phase_at_abort": phase,
        "post_merge": is_post_merge,
        "restore_log": [],
        "wps_flipped": [],
    }

    try:
        bundle = state.get("bundle", [])

        if is_post_merge:
            # Post-merge: ADR-212 revert path
            import tempfile as _tempfile
            from _wpxlib import (  # noqa: E402
                clone_repo_to_temp,
                compute_culprit_heuristic,
                revert_train_on_dev,
                restore_branch_with_guard,
                write_train_blocker,
            )
            clone_dir = Path(_tempfile.mkdtemp(
                prefix=f"wpx-abort-{args.train_id}-",
            ))
            try:
                clone_repo_to_temp(repo, clone_dir)
                reason = (
                    f"Train aborted by founder via `wpx-train abort` "
                    f"at phase {phase}"
                )
                # Revert + restore + flip
                revert_ok, revert_msg = revert_train_on_dev(
                    repo, clone_dir, bundle, reason, args.train_id,
                )
                abort_result["revert"] = {"ok": revert_ok, "detail": revert_msg}
                for entry in bundle:
                    if entry.get("merge_sha_on_dev"):
                        ok, msg = restore_branch_with_guard(
                            repo, clone_dir,
                            entry["branch"],
                            entry["pre_train_sha"],
                            entry.get("rebased_to_sha") or entry["pre_train_sha"],
                        )
                        abort_result["restore_log"].append({
                            "wp": entry["wp"],
                            "branch": entry["branch"],
                            "restored": ok,
                            "detail": msg,
                        })
                # Flip WPs to step-7-blocked (post-merge convention)
                for entry in bundle:
                    flip_index_status_via_cli(
                        _SCRIPTS_DIR, paths, entry["wp"], TRAIN_BLOCKED_STATUS,
                    )
                    abort_result["wps_flipped"].append(
                        {"wp": entry["wp"], "to": TRAIN_BLOCKED_STATUS}
                    )
                # Write train BLOCKER
                culprit = compute_culprit_heuristic(bundle, clone_dir, reason)
                blocker_path = write_train_blocker(
                    paths, args.train_id, reason, bundle,
                    suspected_wp_id=culprit,
                    evidence=f"Founder-initiated abort at phase {phase}",
                )
                abort_result["train_blocker_path"] = str(blocker_path)
                abort_result["suspected_culprit"] = culprit
            finally:
                import shutil as _shutil
                _shutil.rmtree(clone_dir, ignore_errors=True)
        else:
            # Pre-merge: restore branches + flip to step-7-held
            from _wpxlib import restore_branch_with_guard  # noqa: E402
            import tempfile as _tempfile
            from _wpxlib import clone_repo_to_temp  # noqa: E402
            clone_dir = Path(_tempfile.mkdtemp(
                prefix=f"wpx-abort-{args.train_id}-",
            ))
            try:
                clone_repo_to_temp(repo, clone_dir)
                for entry in bundle:
                    if entry.get("rebased_to_sha"):
                        ok, msg = restore_branch_with_guard(
                            repo, clone_dir,
                            entry["branch"],
                            entry["pre_train_sha"],
                            entry["rebased_to_sha"],
                        )
                        abort_result["restore_log"].append({
                            "wp": entry["wp"],
                            "branch": entry["branch"],
                            "restored": ok,
                            "detail": msg,
                        })
                # Flip WPs to step-7-held (pre-merge convention — founder
                # explicitly chose to pause; distinct from step-7-blocked
                # which signals a system-detected failure)
                for entry in bundle:
                    flip_index_status_via_cli(
                        _SCRIPTS_DIR, paths, entry["wp"], TRAIN_HELD_STATUS,
                    )
                    abort_result["wps_flipped"].append(
                        {"wp": entry["wp"], "to": TRAIN_HELD_STATUS}
                    )
            finally:
                import shutil as _shutil
                _shutil.rmtree(clone_dir, ignore_errors=True)

        # Mark state=aborted and write the historical .yaml record
        update_train_phase(
            state_path, "aborted",
            pause_reason=f"Founder-initiated abort at phase {phase}",
            recovery_hint=(
                "Train aborted. Affected WPs flipped to " +
                (
                    f"{TRAIN_BLOCKED_STATUS} (post-merge; ADR-212 revert ran)"
                    if is_post_merge
                    else f"{TRAIN_HELD_STATUS} (pre-merge; branches restored)"
                ) + ". Inspect via `wpx-train inspect " + args.train_id + "`."
            ),
        )

        record = {
            "train_id": args.train_id,
            "started_at": state.get("started_at"),
            "completed_at": state.get("completed_at"),
            "outcome": "aborted",
            "outcome_reason": f"founder-initiated abort at phase {phase}",
            "batch_size": len(bundle),
            "bundle": bundle,
            "deploy_url": None,
            "deploy_workflow_run": None,
            "health_status": None,
            "smoke_verdict": None,
        }
        if is_post_merge:
            record["revert"] = abort_result.get("revert")
            record["restore_log"] = abort_result["restore_log"]
            record["train_blocker_path"] = abort_result.get("train_blocker_path")
            record["suspected_culprit"] = abort_result.get("suspected_culprit")

        write_train_run_record(
            paths.train_runs_dir / f"{args.train_id}.yaml", record,
        )
        cleanup_train_state(paths.train_runs_dir, args.train_id)

    finally:
        lock.__exit__(None, None, None)

    abort_result["outcome"] = "aborted"
    emit_ok(data=abort_result)


def cmd_resume(args: argparse.Namespace) -> None:
    """Resume a paused train (v0.19.0a).

    Reads the train's state file and dispatches based on the paused phase:

    - **Pre-merge paused** (rebasing, ci_running): no merges have landed.
      Safe to redo from scratch. Cleans up the state file, flips bundled
      WPs back to step-7-complete (in case the prior failure-handler
      blocked them), then re-invokes cmd_run with the args captured in
      the state file. From the founder's perspective: paused → fix
      issue → `wpx-train resume <id>` → train re-fires with same args.

    - **Post-merge paused** (deploying, verifying): merges are on dev;
      can't just start over. v0.19.0a emits a clear "use abort" error
      pointing at the post-merge recovery path. The full post-merge
      resume (re-poll deploy / re-run smoke) lands when a real need
      surfaces; until then, founders use `wpx-train abort` (Phase 3.2)
      to invoke the ADR-212 revert, or manually flip WPs to done if
      production is actually fine.

    - **Terminal phases** (success, failed, aborted): error — nothing to
      resume.
    """
    paths = paths_from_args(args)
    state_path = train_state_path(paths.train_runs_dir, args.train_id)

    if not state_path.exists():
        emit_error(
            f"Train {args.train_id!r} has no in-flight state file at "
            f"{state_path}. Either it never started, or it completed "
            f"and the state file was cleaned up. Run `wpx-train inspect "
            f"{args.train_id}` to see the historical record."
        )
        return

    try:
        state = read_train_state(state_path)
    except RuntimeError as exc:
        emit_error(str(exc))
        return

    phase = state.get("phase")
    if phase in ("success", "failed", "aborted"):
        emit_error(
            f"Train {args.train_id!r} is in terminal phase {phase!r}; "
            f"nothing to resume. Inspect via `wpx-train inspect "
            f"{args.train_id}`; start a fresh train via `wpx-train run`."
        )
        return

    if phase in ("merging", "deploying", "verifying", "verifying_gates"):
        gate_hint = (
            f"  • If you're here because the train paused at the gate "
            f"boundary (phase=verifying_gates from HD-007 --enable-gate-"
            f"handoff): run `wpx-train mark-gates-complete --train-id "
            f"{args.train_id}` after Step 10.5 + Step 11 dispatch "
            f"completes (use --critical-found if a CRITICAL surfaced).\n"
            if phase == "verifying_gates" else ""
        )
        emit_error(
            f"Train {args.train_id!r} is paused at phase {phase!r}, "
            f"AFTER merges landed on dev. Post-merge resume isn't "
            f"available. Options:\n"
            f"{gate_hint}"
            f"  • If production is healthy (deploy completed, smoke green): "
            f"manually flip the merged WPs to done via `wpx-index "
            f"flip-status --to done --expected step-7-complete`.\n"
            f"  • If production is broken: `wpx-train abort {args.train_id}` "
            f"to invoke ADR-212 revert.\n"
            f"  • Inspect via `wpx-train inspect {args.train_id}` to see "
            f"the recovery_hint for this specific failure."
        )
        return

    # Pre-merge resume (phase in pending/rebasing/ci_running/paused-pre-merge)
    _log(f"RESUMING train {args.train_id} from phase {phase!r}")

    # Hold the lock for the resume operation
    try:
        lock = TrainLock(paths.train_runs_dir, args.train_id)
        lock.__enter__()
    except RuntimeError as exc:
        emit_error(str(exc))
        return

    try:
        # Restore any WPs that got flipped to step-7-blocked by the
        # prior failure handler (so they're eligible again).
        for entry in state.get("bundle", []):
            wp = entry.get("wp")
            if wp:
                flip_index_status_via_cli(
                    _SCRIPTS_DIR, paths, wp, TRAIN_ELIGIBLE_STATUS,
                )

        # Mark state as aborted before re-running cmd_run (which will
        # create a fresh state file with a new train_id). The old
        # train_id's audit trail is preserved as the .yaml record.
        update_train_phase(
            state_path, "aborted",
            pause_reason="Superseded by resume (re-fired with same args)",
            recovery_hint=(
                f"This train was resumed; a fresh train was fired with "
                f"the same arguments. See newer train via `wpx-train "
                f"inspect` (no --train-id)."
            ),
        )
        # Preserve the historical .yaml record before cleanup
        record = {
            "train_id": args.train_id,
            "started_at": state.get("started_at"),
            "completed_at": state.get("completed_at"),
            "outcome": "aborted",
            "outcome_reason": "superseded by resume",
            "batch_size": len(state.get("bundle", [])),
            "bundle": state.get("bundle", []),
            "deploy_url": None,
            "deploy_workflow_run": None,
            "health_status": None,
            "smoke_verdict": None,
        }
        write_train_run_record(
            paths.train_runs_dir / f"{args.train_id}.yaml", record,
        )
        cleanup_train_state(paths.train_runs_dir, args.train_id)
    finally:
        lock.__exit__(None, None, None)

    # Re-derive the cmd_run args from state["args"], merge with CLI args
    # (allows --deploy-cap override on resume), and re-invoke cmd_run.
    saved_args = state.get("args", {})
    _log(f"Re-firing train with args: {saved_args}")

    # Build a fresh args namespace combining saved + current
    import argparse as _argparse
    fresh_args = _argparse.Namespace(**vars(args))
    for key, value in saved_args.items():
        if not hasattr(fresh_args, key) or getattr(fresh_args, key) is None:
            setattr(fresh_args, key, value)
    # Ensure required args are populated (deploy_workflow especially)
    if not getattr(fresh_args, "deploy_workflow", None):
        emit_error(
            f"Cannot resume: deploy_workflow missing from train state "
            f"and not provided on CLI. Pass --deploy-workflow explicitly."
        )
        return

    # Recursive call into cmd_run — fires a fresh train with the same args
    cmd_run(fresh_args)


def cmd_inspect(args: argparse.Namespace) -> None:
    """Read-only inspection of train state.

    - With --train-id: render the train's in-flight state (or terminal
      .yaml record if state file is gone). Plain English by default;
      --json for machine-readable.
    - Without --train-id: list recent trains (most recent first) with
      their phase + start time. Always JSON when --json is set.
    """
    paths = paths_from_args(args)

    if args.train_id:
        state_path = train_state_path(paths.train_runs_dir, args.train_id)
        # Prefer in-flight state file; fall back to historical .yaml record
        if state_path.exists():
            try:
                state = read_train_state(state_path)
            except RuntimeError as exc:
                emit_error(str(exc))
                return
        else:
            # Check for terminal YAML record
            yaml_path = paths.train_runs_dir / f"{args.train_id}.yaml"
            if not yaml_path.exists():
                emit_error(
                    f"Train {args.train_id!r} not found. "
                    f"No in-flight state at {state_path} and no historical "
                    f"record at {yaml_path}. "
                    f"Run `wpx-train inspect` (no --train-id) to list "
                    f"recent trains."
                )
                return
            # Terminal trains: minimal synthetic state from the YAML record
            state = _synthesise_state_from_yaml_record(yaml_path, args.train_id)

        if args.json:
            emit_ok(data=state)
        else:
            # Plain-English to stdout, exit 0
            print(render_train_state_plain_english(state))
            sys.exit(0)
        return

    # No --train-id: list recent trains
    runs = list_train_runs(paths.train_runs_dir)
    if args.json:
        emit_ok(data={"runs": runs, "count": len(runs)})
        return
    if not runs:
        print(f"No trains found in {paths.train_runs_dir}")
        sys.exit(0)
    print(f"Recent trains in {paths.train_runs_dir} ({len(runs)} total):")
    for r in runs[:20]:
        status = (
            f"phase: {r['phase']} (paused: {r['pause_reason']})"
            if r.get("pause_reason")
            else f"phase: {r['phase']}"
        )
        flight = " [in-flight]" if r.get("in_flight") else ""
        print(f"  - {r['train_id']}: {status}{flight}")
        print(f"    started: {r.get('started_at') or '?'}")
    if len(runs) > 20:
        print(f"  ... and {len(runs) - 20} older trains")
    sys.exit(0)


def _synthesise_state_from_yaml_record(yaml_path, train_id: str) -> dict:
    """Build a minimal state dict from a terminal .yaml record.

    Used by `inspect <id>` when the state file has been cleaned up
    (terminal phase) but the historical record exists. Returns a dict
    with the same keys render_train_state_plain_english needs.
    """
    record_text = yaml_path.read_text(encoding="utf-8")
    state: dict = {"train_id": train_id, "bundle": [], "phase_history": []}
    for line in record_text.splitlines():
        if ":" not in line or line.startswith("  "):
            continue
        key, _, val = line.partition(":")
        key = key.strip()
        val = val.strip().strip('"')
        if key in ("started_at", "completed_at", "outcome", "outcome_reason"):
            state[key] = val if val != "null" else None
    state["phase"] = state.get("outcome") or "unknown"
    state["pause_reason"] = state.get("outcome_reason")
    return state


def cmd_doctor(args: argparse.Namespace) -> None:
    """Diagnose drift between INDEX.md, WP files, and origin branches."""
    paths = paths_from_args(args)
    repo = _resolve_repo(args)

    issues: list[dict] = []

    if not paths.index_md.exists():
        emit_error(f"INDEX.md not found at {paths.index_md}")

    # Verbose normalisations: doctor reports short-name resolutions so the
    # founder knows their INDEX uses shorthand (and can choose to rewrite
    # to full IDs for clarity).
    wps = parse_index_md(paths.index_md, verbose_normalisations=True)
    by_id = {wp.id: wp for wp in wps}

    # Check: every WP in INDEX.md has a matching WP file
    for wp in wps:
        try:
            paths.wp_file(wp.id)
        except (FileNotFoundError, ValueError) as exc:
            issues.append({
                "kind": "wp_file_missing",
                "wp": wp.id,
                "detail": str(exc),
            })

    # Check: every WP at step-7-complete has dependencies satisfied
    for wp in wps:
        if wp.status != "step-7-complete":
            continue
        for dep_id in wp.depends_on:
            dep = by_id.get(dep_id)
            if dep is None:
                issues.append({
                    "kind": "depends_on_unknown_wp",
                    "wp": wp.id,
                    "detail": f"depends on {dep_id} which is not in INDEX.md",
                })
            elif dep.status != "done":
                issues.append({
                    "kind": "depends_on_unmerged",
                    "wp": wp.id,
                    "detail": f"depends on {dep_id} (status: {dep.status})",
                })

    # v0.21.2 — INDEX status drift detection. For each WP with status=done,
    # confirm its merge SHA is actually present in origin/<base_branch>'s
    # history. Drift surfaces if a WP was: (a) manually flipped to done
    # without ever shipping via train; (b) shipped via train then reverted
    # without status being unflipped; (c) shipped via wpx-pipeline (legacy);
    # (d) corrupted state from an external operation.
    #
    # HD-008 note: the doctor deliberately uses the lower-level
    # ``find_wp_merge_sha`` + ``is_sha_on_branch`` primitives rather than
    # going through ``compute_wp_status`` for the done case. Reason:
    # ``compute_wp_status`` is conservative — when ``is_sha_on_branch``
    # fails (transient API error) it falls back to the stored cell so
    # eligibility decisions don't oscillate on network blips. The doctor
    # WANTS to distinguish "API error" from "SHA is not on dev" so it
    # only reports drift in the latter case. Pre-HD-008 the doctor's
    # explicit two-step check already gave us this; HD-008's migration
    # of eligibility doesn't change that.
    #
    # ``compute_wp_status`` remains the right tool for the eligibility
    # checks (where transient-error tolerance is correct), and for any
    # future per-WP status report; the doctor's deliberate use of the
    # explicit primitives is documented here so a future maintainer
    # doesn't "simplify" this into a compute_wp_status call and
    # accidentally make drift detection silent on network errors.
    #
    # Detection only — does NOT auto-reconcile. Founder uses
    # `wpx-index flip-status --wp WP-NNN --to step-7-blocked --expected done`
    # per-WP after reviewing each case. The per-WP CAS check (--expected)
    # is the safety primitive; bulk auto-flip would bypass it.
    base_branch = getattr(args, "base_branch", None) or "dev"
    for wp in wps:
        if wp.status != TRAIN_DONE_STATUS:
            continue
        merge_sha = find_wp_merge_sha(paths.train_runs_dir, wp.id)
        if merge_sha is None:
            issues.append({
                "kind": "status_drift_done_no_merge_history",
                "wp": wp.id,
                "detail": (
                    f"INDEX says done but no merge SHA in any train-runs "
                    f"record. Possible causes: shipped via wpx-pipeline "
                    f"(legacy per-WP path; harmless) OR manually flipped "
                    f"without train OR state lost. To reconcile if needed: "
                    f"`wpx-index flip-status --wp {wp.id} --project "
                    f"{args.project} --to step-7-blocked --expected done`."
                ),
            })
            continue
        if not is_sha_on_branch(repo, merge_sha, base_branch):
            issues.append({
                "kind": "status_drift_done_not_on_dev",
                "wp": wp.id,
                "detail": (
                    f"INDEX says done but merge SHA {merge_sha[:8]} not "
                    f"reachable from origin/{base_branch} (reverted or "
                    f"never pushed). To reconcile: confirm via `git log "
                    f"origin/{base_branch} | grep {merge_sha[:8]}` (should "
                    f"be empty); then `wpx-index flip-status --wp {wp.id} "
                    f"--project {args.project} --to step-7-blocked "
                    f"--expected done`."
                ),
            })

    # Note: orphan-branch detection (branches on origin not in INDEX.md)
    # would require listing all origin branches. Skipped in Phase 1 for
    # cost reasons — gh api repos/{repo}/branches paginates and can be
    # large. Surface this as a future doctor extension.

    emit_ok(data={
        "project": args.project,
        "issue_count": len(issues),
        "issues": issues,
        "note_orphan_branches": "skipped in Phase 1 (cost); see doctor source",
    })


# --- Subcommand: run (happy path) ---------------------------------------

import shutil  # noqa: E402  (deferred to here to keep top-of-file imports clean)
import tempfile  # noqa: E402


def _pause_train_state(
    *,
    paths,
    train_id: str,
    record: dict,
    pause_reason: str,
    recovery_hint: str,
    bundle: list[dict],
    write_yaml: bool = True,
) -> None:
    """Transition the train to phase=paused (v0.18.0+).

    Non-fatal failures (bundled-tip CI flake, deploy timeout) route here
    instead of `_handle_post_merge_failure`. The state file is updated;
    no revert happens; no INDEX flip. The founder can inspect the
    train and decide whether to resume (Phase 3.1; once the WP-S2-LOADER
    behind it lands), abort (Phase 3.2), or just leave it.

    Exits the process with exit code 1 to signal "needs attention",
    but the founder workflow is:
        wpx-train inspect <train_id>      # see what happened
        ... investigate / fix ...
        wpx-train resume <train_id>       # continue (when Phase 3.1 lands)
        wpx-train abort <train_id>        # unwind (when Phase 3.2 lands)

    Today (v0.18.0): inspect works. Resume + abort ship in v0.19.0;
    until then the founder uses the existing manual recovery paths
    (which the recovery_hint string should describe).
    """
    _log(f"PAUSED: {pause_reason}. State written; no auto-revert.")
    state_path = train_state_path(paths.train_runs_dir, train_id)
    if state_path.exists():
        update_train_phase(
            state_path, "paused",
            pause_reason=pause_reason,
            recovery_hint=recovery_hint,
        )
    record["outcome"] = "paused"
    record["outcome_reason"] = pause_reason
    record["recovery_hint"] = recovery_hint
    if write_yaml:
        write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
    emit_result(record, exit_code=1)


def _handle_post_merge_failure(
    *,
    record: dict,
    bundle: list[dict],
    reason: str,
    clone_dir: Path,
    repo: str,
    paths,
    train_id: str,
    failure_text: str = "",
) -> None:
    """Revert the train + restore branches + write BLOCKER + flip statuses.

    Called when deploy / health / smoke fails after merges have landed.
    Emits the final result and exits (does not return).
    """
    _log(f"POST-MERGE FAILURE: {reason}. Reverting + restoring.")

    # Revert the merges on dev (single wrapper commit)
    revert_ok, revert_msg = revert_train_on_dev(
        repo, clone_dir, bundle, reason, train_id,
    )

    # Restore each branch to its pre_train_sha (with force-push guard)
    restore_log: list[dict] = []
    for entry in bundle:
        if not entry.get("merge_sha_on_dev"):
            continue  # never merged; nothing to restore
        ok, msg = restore_branch_with_guard(
            repo, clone_dir,
            entry["branch"],
            entry["pre_train_sha"],
            entry["rebased_to_sha"],
        )
        restore_log.append({
            "wp": entry["wp"], "branch": entry["branch"],
            "restored": ok, "detail": msg,
        })

    # Flip all bundled WPs to step-7-blocked
    for entry in bundle:
        flip_index_status_via_cli(
            _SCRIPTS_DIR, paths, entry["wp"], TRAIN_BLOCKED_STATUS,
        )

    # Heuristic culprit + train BLOCKER
    culprit = compute_culprit_heuristic(bundle, clone_dir, failure_text or reason)
    train_blocker_path = write_train_blocker(
        paths, train_id, reason, bundle,
        suspected_wp_id=culprit,
        evidence=failure_text or reason,
    )

    record["outcome"] = "blocker"
    record["outcome_reason"] = reason
    record["revert"] = {"ok": revert_ok, "detail": revert_msg}
    record["restore_log"] = restore_log
    record["train_blocker_path"] = str(train_blocker_path)
    record["suspected_culprit"] = culprit
    write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
    # v0.18.0+ — terminal failure (revert ran). Update state to phase=failed
    # then clean up the in-flight state file; the .yaml record is the
    # historical archive from here.
    state_path = train_state_path(paths.train_runs_dir, train_id)
    if state_path.exists():
        try:
            update_train_phase(
                state_path, "failed",
                pause_reason=reason,
                recovery_hint=(
                    "Train failed after merges landed; ADR-212 revert ran. "
                    "Affected WPs flipped to step-7-blocked + BLOCKER written. "
                    f"See BLOCKER at {train_blocker_path}."
                ),
            )
        except Exception:  # noqa: BLE001
            pass  # best-effort; the .yaml record is the source of truth
        cleanup_train_state(paths.train_runs_dir, train_id)
    emit_result(record, exit_code=1)


def _plan_phase(
    *,
    args: argparse.Namespace,
    paths,
    repo: str,
    train_id: str,
    batch: list,
    base_branch: str,
    clone_dir: Path,
    record: dict,
) -> PlanResult:
    """HD-001 plan phase — read-only against the base branch.

    Clone the repo, sequential-rebase every batch branch onto the previous
    rebased tip, run bundled-tip CI. No squash-merges to the base branch
    happen here — that's the commit phase.

    Force-pushes to feature branches (the rebased tips) DO happen here.
    Those branches are train-owned; the base branch is untouched.

    Returns PlanResult on success. On non-fatal failures (rebase conflicts
    that drop some-but-not-all branches, bundled-tip CI red/timeout) the
    function calls _pause_train_state or emits a blocker — both terminate
    the process via emit_result, so the caller never sees a None return.
    """
    update_train_phase(
        train_state_path(paths.train_runs_dir, train_id), "rebasing",
    )
    clone_repo_to_temp(repo, clone_dir)

    bundle: list[dict] = []
    rebase_failures: list[dict] = []
    onto_sha = _gh_ref_sha(repo, base_branch)
    for e in batch:
        try:
            pre_train_sha = _gh_branch_sha(repo, e.branch)
        except RuntimeError as exc:
            _log(f"WARN: could not fetch pre_train_sha for {e.branch}: {exc}")
            rebase_failures.append({"wp": e.wp, "branch": e.branch,
                                     "reason": str(exc)})
            continue
        _log(f"Rebasing {e.branch} onto {onto_sha[:8]} (pre={pre_train_sha[:8]})")
        try:
            rebased_sha = rebase_branch_in_clone(
                clone_dir, e.branch, onto_sha, base_branch=base_branch,
            )
        except PatchesAlreadyAppliedError as exc:
            # v0.15.3 — branch's patches already in base history (typically
            # post-revert). Emit a specific BLOCKER with the manual git
            # revert command so the founder can recover deterministically.
            _log(f"PATCHES ALREADY APPLIED: {e.branch} → {exc}")
            flip_ok, _ = flip_index_status_via_cli(
                _SCRIPTS_DIR, paths, e.wp, TRAIN_BLOCKED_STATUS,
            )
            applied_short = ", ".join(s[:8] for s in exc.applied_shas)
            write_wp_blocker_via_cli(
                _SCRIPTS_DIR, paths, e.wp,
                title=f"Patches already in {exc.base_branch} during {train_id}",
                observation=(
                    f"git cherry shows {len(exc.applied_shas)} of this "
                    f"WP's commits are already present in "
                    f"origin/{exc.base_branch}: {applied_short}. "
                    f"git rebase would silently drop them; GitHub's merge "
                    f"endpoint would then return 204 No Content."
                ),
                root_cause=(
                    "An earlier train likely shipped this WP, then "
                    "reverted (via _handle_post_merge_failure or a manual "
                    "revert commit). The revert neutralised the content "
                    "but the original squash-merge commits remain in "
                    f"{exc.base_branch}'s graph. Re-shipping the branch "
                    "as-is is impossible without first restoring the "
                    "content."
                ),
                plain_english=(
                    "This work's changes are already in the codebase's "
                    "history — likely from an earlier shipment that was "
                    "reverted. Trying to ship it again now would silently "
                    "skip it. To recover, find the revert commit on "
                    f"{exc.base_branch} and revert THAT (which brings the "
                    "content back); then mark this WP done directly."
                ),
                suggested_next=(
                    f"On {exc.base_branch}: identify the revert commit "
                    f"(e.g. `git log --oneline {exc.base_branch} | grep "
                    f"-i Revert`); run `git revert -m 1 <revert_sha>` "
                    "to restore the content; push; then flip this WP "
                    "to done via `wpx-index flip-status --to done "
                    "--expected step-7-complete`."
                ),
            )
            rebase_failures.append({
                "wp": e.wp,
                "branch": e.branch,
                "reason": "patches_already_applied",
                "applied_shas": exc.applied_shas,
                "index_flipped": flip_ok,
            })
            continue
        except RuntimeError as exc:
            _log(f"REBASE CONFLICT: {e.branch} → {exc}")
            flip_ok, _ = flip_index_status_via_cli(
                _SCRIPTS_DIR, paths, e.wp, TRAIN_BLOCKED_STATUS,
            )
            blocker_ok, _ = write_wp_blocker_via_cli(
                _SCRIPTS_DIR, paths, e.wp,
                title=f"Rebase conflict during {train_id}",
                observation=str(exc),
                root_cause=(
                    "git rebase failed when stacking onto the previous "
                    "rebased branch in the train. Likely a merge "
                    "conflict against a sibling WP's changes."
                ),
                plain_english=(
                    f"This WP's branch couldn't be cleanly rebased on "
                    f"top of the other WPs in the train (their changes "
                    f"conflict). The other WPs are continuing. Resolve "
                    f"the conflict locally, push, then flip this WP "
                    f"back to step-7-complete."
                ),
                suggested_next=(
                    "Pull origin/dev, rebase this branch, resolve "
                    "conflicts, push. Then re-flip INDEX status."
                ),
            )
            rebase_failures.append({
                "wp": e.wp,
                "branch": e.branch,
                "reason": str(exc),
                "index_flipped": flip_ok,
                "blocker_written": blocker_ok,
            })
            continue
        bundle.append({
            "wp": e.wp,
            "branch": e.branch,
            "pre_train_sha": pre_train_sha,
            "rebased_to_sha": rebased_sha,
            "merge_sha_on_dev": None,
        })
        onto_sha = rebased_sha

    # If every branch failed to rebase, the train can't continue
    if not bundle:
        record["outcome"] = "blocker"
        record["outcome_reason"] = (
            f"all {len(batch)} branches failed to rebase; see per-WP BLOCKERs"
        )
        record["rebase_failures"] = rebase_failures
        write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
        emit_result(record, exit_code=1)

    record["bundle"] = bundle
    record["rebase_failures"] = rebase_failures
    bundle_tip_branch = bundle[-1]["branch"]

    update_train_phase(
        train_state_path(paths.train_runs_dir, train_id), "ci_running",
    )

    ci_interval = args.ci_poll_interval or CI_DEFAULT_INTERVAL
    _log(f"Bundled-tip CI: polling {bundle_tip_branch}")
    ci_verdict = _poll_ci(repo, bundle_tip_branch, ci_interval, CI_DEFAULT_CAP)
    if ci_verdict != "green":
        # v0.18.0+ — bundled-tip CI red/timeout is a NON-FATAL pre-merge
        # failure. Route to paused. _pause_train_state terminates via
        # emit_result; the caller never sees this code path return.
        culprit = compute_culprit_heuristic(bundle, clone_dir,
                                           f"bundled-tip CI {ci_verdict}")
        reason = f"bundled-tip CI {ci_verdict} on {bundle_tip_branch}"
        hint = (
            f"Bundled-tip CI is {ci_verdict}. Likely culprit "
            f"(file-overlap heuristic): {culprit or '<no signal>'}. "
            f"Inspect via `wpx-train inspect {train_id}`. "
            f"Once you've identified + fixed the failing branch, run "
            f"`wpx-train resume {train_id}`. "
            f"To unwind the rebases + free the WPs back to step-7-complete, "
            f"`wpx-train abort {train_id}`."
        )
        record["bundle"] = bundle
        record["suspected_culprit"] = culprit
        _pause_train_state(
            paths=paths, train_id=train_id, record=record,
            pause_reason=reason, recovery_hint=hint, bundle=bundle,
        )

    return PlanResult(
        bundle=bundle,
        base_branch=base_branch,
        bundle_tip_branch=bundle_tip_branch,
        ci_verdict=ci_verdict,
        rebase_failures=rebase_failures,
    )


def _commit_via_rebase_loop(
    *,
    args: argparse.Namespace,
    paths,
    repo: str,
    train_id: str,
    plan: PlanResult,
    record: dict,
    clone_dir: Path,
) -> CommitResult:
    """Legacy commit strategy — today's sequential squash-merge loop.

    HD-003: each per-entry merge is wrapped in try/except so a failure on
    entry N — after entries 1..N-1 landed on the base branch — routes
    through the ADR-212 revert path with the partial bundle. The outer
    handler writes outcome=error and exits without reverting, which would
    leave the base in a half-state. _handle_post_merge_failure already
    filters the bundle to merged entries (those with a populated
    merge_sha_on_dev), so passing the partial bundle here is correct.
    """
    merge_shas: dict[str, str] = {}
    final_merge_sha = None
    for entry in plan.bundle:
        _log(f"Squash-merging {entry['wp']} ({entry['branch']}) to {plan.base_branch}")
        try:
            sha = _merge_squash(repo, entry["branch"], entry["wp"],
                                base_branch=plan.base_branch)
        except Exception as exc:  # noqa: BLE001
            _log(
                f"MERGE FAILURE: {entry['wp']} ({entry['branch']}) "
                f"failed mid-batch: {exc}"
            )
            record["bundle"] = plan.bundle
            _handle_post_merge_failure(
                record=record, bundle=plan.bundle,
                reason=f"merge of {entry['wp']} failed: {exc}",
                clone_dir=clone_dir, repo=repo, paths=paths,
                train_id=train_id,
                failure_text=(
                    f"_merge_squash raised on {entry['wp']} "
                    f"({entry['branch']}): {exc}"
                ),
            )
        entry["merge_sha_on_dev"] = sha
        merge_shas[entry["wp"]] = sha
        final_merge_sha = sha

    return CommitResult(
        merge_shas=merge_shas,
        final_merge_sha=final_merge_sha,
    )


def _commit_phase(
    *,
    args: argparse.Namespace,
    paths,
    repo: str,
    train_id: str,
    plan: PlanResult,
    record: dict,
    clone_dir: Path,
) -> CommitResult:
    """HD-001 commit phase — only phase that mutates the base branch.

    Strategy dispatcher: the merge-queue spike's PARTIAL recommendation
    introduces a second strategy `_commit_via_merge_queue` in a follow-up
    delta. Today there is only `legacy` (the sequential squash-merge loop).
    The dispatcher's RuntimeError on unknown strategy is the explicit
    extension seam.
    """
    update_train_phase(
        train_state_path(paths.train_runs_dir, train_id), "merging",
    )

    strategy = getattr(args, "commit_strategy", None) or "legacy"
    if strategy == "legacy":
        result = _commit_via_rebase_loop(
            args=args, paths=paths, repo=repo, train_id=train_id,
            plan=plan, record=record, clone_dir=clone_dir,
        )
    else:
        raise RuntimeError(
            f"Unknown commit strategy {strategy!r}; expected 'legacy' "
            f"(follow-up delta adds 'mq')."
        )

    record["bundle"] = plan.bundle  # refresh with merge_sha_on_dev populated
    return result


def _verify_phase(
    *,
    args: argparse.Namespace,
    paths,
    repo: str,
    train_id: str,
    plan: PlanResult,
    commit: CommitResult,
    record: dict,
    clone_dir: Path,
) -> VerifyResult:
    """HD-001 verify phase — deploy poll + health + smoke.

    HD-007: when args.enable_gate_handoff is set, this phase reports the
    `ready_for_gates=True` boundary on success. cmd_run then transitions
    state to the new `verifying_gates` phase and emits outcome=awaiting_gates
    instead of terminal success. The calling LLM session dispatches
    Step 10.5 + Step 11 and invokes `wpx-train mark-gates-complete` to
    finalise.

    When --enable-gate-handoff is NOT set, behaviour is unchanged — the
    function returns ready_for_gates=False and cmd_run goes to terminal
    success.
    """
    update_train_phase(
        train_state_path(paths.train_runs_dir, train_id), "deploying",
    )

    deploy_interval = args.deploy_poll_interval or DEPLOY_DEFAULT_INTERVAL
    deploy_cap = args.deploy_cap or DEPLOY_DEFAULT_CAP
    _log(
        f"Polling deploy '{args.deploy_workflow}' for "
        f"{commit.final_merge_sha[:8]} "
        f"(interval={deploy_interval}s, cap={deploy_cap}s)"
    )
    deploy_verdict, deploy_url = _poll_deploy(
        repo, args.deploy_workflow, commit.final_merge_sha,
        deploy_interval, deploy_cap,
    )
    record["deploy_url"] = deploy_url
    if deploy_verdict == "timeout":
        hint = (
            f"Deploy poll timed out after {deploy_cap}s. The deploy may "
            f"still be in progress. Check {deploy_url} for the current "
            f"status. If completed: `wpx-train resume {train_id}` "
            f"will continue to verify. If it failed: `wpx-train abort "
            f"{train_id}` to run the ADR-212 revert. Or raise --deploy-cap "
            f"and re-run via the manual `wpx-train run --strict-ci` "
            f"escape hatch."
        )
        record["bundle"] = plan.bundle
        _pause_train_state(
            paths=paths, train_id=train_id, record=record,
            pause_reason=f"deploy poll timeout after {deploy_cap}s",
            recovery_hint=hint, bundle=plan.bundle,
        )
    if deploy_verdict != "green":
        _handle_post_merge_failure(
            record=record, bundle=plan.bundle,
            reason=f"deploy {deploy_verdict}",
            clone_dir=clone_dir, repo=repo, paths=paths,
            train_id=train_id,
            failure_text=f"Deploy workflow result: {deploy_verdict}",
        )

    update_train_phase(
        train_state_path(paths.train_runs_dir, train_id), "verifying",
    )

    # Health check (optional)
    if args.staging_url:
        health_path = args.health_path or "/"
        health_url = _join_health_url(args.staging_url, health_path)
        _log(f"Health check: {health_url}")
        health = _poll_health(health_url, HEALTH_DEFAULT_CAP)
        record["health_status"] = health
        if health != "healthy":
            _handle_post_merge_failure(
                record=record, bundle=plan.bundle,
                reason=f"health check failed at {health_url}",
                clone_dir=clone_dir, repo=repo, paths=paths,
                train_id=train_id,
                failure_text=f"Health check: {health} at {health_url}",
            )
    else:
        health = "skipped (no --staging-url)"
        record["health_status"] = health

    # Smoke (optional)
    if args.smoke_cmd:
        _log("Running smoke test")
        smoke_verdict, smoke_out = _run_smoke(args.smoke_cmd, clone_dir)
        record["smoke_verdict"] = smoke_verdict
        if not smoke_verdict.startswith("PASS"):
            _handle_post_merge_failure(
                record=record, bundle=plan.bundle,
                reason=f"smoke {smoke_verdict}",
                clone_dir=clone_dir, repo=repo, paths=paths,
                train_id=train_id,
                failure_text=f"Smoke output:\n{smoke_out}",
            )
    else:
        smoke_verdict = "skipped (no --smoke-cmd)"
        record["smoke_verdict"] = smoke_verdict

    return VerifyResult(
        deploy_url=deploy_url,
        deploy_verdict=deploy_verdict,
        health_status=health,
        smoke_verdict=smoke_verdict,
        ready_for_gates=bool(getattr(args, "enable_gate_handoff", False)),
    )


def _finalise_success(
    *,
    paths,
    train_id: str,
    batch: list,
    plan: PlanResult,
    commit: CommitResult,
    verify: VerifyResult,
    record: dict,
) -> None:
    """Terminal success path — write the YAML record, clean up the state
    file, emit the success envelope.

    Exits the process via emit_result (raises SystemExit). Does not return.
    """
    update_train_phase(
        train_state_path(paths.train_runs_dir, train_id), "success",
    )
    record["outcome"] = "success"
    record["completed_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
    cleanup_train_state(paths.train_runs_dir, train_id)
    emit_result({
        "train_id": train_id,
        "outcome": "success",
        "wps_shipped": [e.wp for e in batch],
        "deploy_url": verify.deploy_url,
        "final_merge_sha": commit.final_merge_sha,
        "record_path": str(paths.train_runs_dir / f"{train_id}.yaml"),
    }, exit_code=0)


def _finalise_awaiting_gates(
    *,
    paths,
    train_id: str,
    batch: list,
    plan: PlanResult,
    commit: CommitResult,
    verify: VerifyResult,
    record: dict,
) -> None:
    """HD-007 gate-handoff path — verify phase complete; Step 10.5 + 11
    pending. Transitions to phase=verifying_gates and emits a clear
    handoff envelope so the calling LLM session knows what to dispatch.

    Exit code 0 — this is success-pending-gates, not failure.
    """
    bundle_start_sha = plan.bundle[0].get("pre_train_sha") if plan.bundle else None
    update_train_phase(
        train_state_path(paths.train_runs_dir, train_id), "verifying_gates",
        pause_reason="Step 10.5 + Step 11 pending (gate handoff to calling session)",
        recovery_hint=(
            "Calling session: dispatch /sulis:code-review against the diff "
            "range in `gate_handoff.diff_range`, then per-WP security "
            "review for every WP in `gate_handoff.wps`. When both gates "
            f"complete clean, run `wpx-train mark-gates-complete --train-id "
            f"{train_id}` to finalise the train to success. If a CRITICAL "
            f"finding surfaces, pass `--critical-found` to mark the train "
            f"as gate-blocked (BLOCKERs are written by the gate dispatchers; "
            f"mark-gates-complete just records the train outcome)."
        ),
    )
    record["outcome"] = "awaiting_gates"
    record["awaiting_gates_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
    emit_result({
        "train_id": train_id,
        "outcome": "awaiting_gates",
        "phase": "verifying_gates",
        "wps_shipped": [e.wp for e in batch],
        "deploy_url": verify.deploy_url,
        "final_merge_sha": commit.final_merge_sha,
        "record_path": str(paths.train_runs_dir / f"{train_id}.yaml"),
        "gate_handoff": {
            "batch_start_sha": bundle_start_sha,
            "batch_end_sha": commit.final_merge_sha,
            "diff_range": (
                f"{bundle_start_sha}..{commit.final_merge_sha}"
                if bundle_start_sha else commit.final_merge_sha
            ),
            "wps": [e.wp for e in batch],
            "next_action": (
                "Calling session: dispatch Step 10.5 (sea:code-review against "
                "diff_range) + Step 11 (per-WP security review for each WP); "
                f"then `wpx-train mark-gates-complete --train-id {train_id}` "
                "to finalise."
            ),
        },
    }, exit_code=0)


def cmd_run(args: argparse.Namespace) -> None:
    """Fire the train — thin orchestrator over plan / commit / verify phases.

    HD-001 split the previous monolithic body into _plan_phase (read-only
    against the base branch), _commit_phase (the only phase that mutates
    the base — strategy dispatcher: today legacy sequential rebase loop;
    follow-up adds merge-queue strategy), and _verify_phase (deploy +
    health + smoke + HD-007 gate-handoff boundary).

    Each phase function either returns its dataclass result or terminates
    the process via the existing failure handlers (_pause_train_state for
    non-fatal pauses; _handle_post_merge_failure for ADR-212 revert).
    cmd_run never sees a None return — control either flows through all
    three phases to _finalise_success / _finalise_awaiting_gates, or
    SystemExit propagates from a failure handler.
    """
    paths = paths_from_args(args)
    repo = _resolve_repo(args)

    if not paths.index_md.exists():
        emit_error(f"INDEX.md not found at {paths.index_md}")

    # Discovery
    wps = parse_index_md(paths.index_md)
    overrides = read_overrides(paths.train_overrides)
    # HD-008 — computed status drives eligibility + dep-merged checks.
    # Reverts and missing-from-dev cases now block downstream WPs from
    # boarding a train on a false done signal.
    results = find_eligible_branches(
        wps, repo, paths.wp_dir, overrides,
        strict_ci=getattr(args, "strict_ci", False),
        paths=paths,
        base_branch=getattr(args, "base_branch", None) or "dev",
    )
    eligible = [r for r in results if r.eligible]

    should_fire, trigger_reason = check_train_trigger(eligible, force=args.force)
    if not should_fire:
        emit_ok(data={
            "outcome": "not_triggered",
            "trigger_reason": trigger_reason,
            "eligible_count": len(eligible),
            "eligible_wps": [r.wp for r in eligible],
        })

    batches = pack_batches(eligible, max_per_batch=args.max_batch_size)
    if not batches:
        emit_ok(data={"outcome": "nothing_to_pack", "eligible_count": 0})
    batch = batches[0]

    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H%M%SZ")
    train_id = f"train-{timestamp}"
    started_at = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    record: dict = {
        "train_id": train_id,
        "started_at": started_at,
        "outcome": "pending",
        "batch_size": len(batch),
        "bundle": [],
        "deploy_url": None,
        "deploy_workflow_run": None,
        "health_status": None,
        "smoke_verdict": None,
    }

    # Per CW-04: callers inside a change worktree pass --base-branch to
    # ship to the change branch rather than directly to dev.
    base_branch = args.base_branch or "dev"

    args_repr = {
        "project": args.project,
        "repo_root": str(paths.repo_root),
        "repo": args.repo,
        "deploy_workflow": args.deploy_workflow,
        "staging_url": getattr(args, "staging_url", None),
        "smoke_cmd": getattr(args, "smoke_cmd", ""),
        "base_branch": base_branch,
        "force": getattr(args, "force", False),
        "strict_ci": getattr(args, "strict_ci", False),
        "enable_gate_handoff": getattr(args, "enable_gate_handoff", False),
    }
    initial_bundle = [
        {"wp": e.wp, "branch": e.branch, "pre_train_sha": None}
        for e in batch
    ]
    init_train_state(paths.train_runs_dir, train_id, initial_bundle, args_repr)

    clone_dir = Path(tempfile.mkdtemp(prefix=f"wpx-train-{train_id}-"))

    try:
        _log(f"{train_id}: trigger={trigger_reason}; batch_size={len(batch)}; "
             f"WPs={[e.wp for e in batch]}")

        # Step 0: arrival check (Phase 5 #6 — change-as-primitive build).
        # Per lifecycle.md Step 0 + CW-04 auto back-integration: if running
        # in a change context, ensure the change branch is current with dev
        # BEFORE the train begins touching things. Defence in depth — the
        # active driver is Step 12.5 after the batch lands.
        # Skipped if not in a change context (--change-worktree-path unset,
        # or --base-branch doesn't start with "change/" — CW-05 trivial
        # carve-out OR direct-to-dev shipping).
        change_worktree_path = getattr(args, "change_worktree_path", None)
        if change_worktree_path and base_branch.startswith("change/"):
            _log(f"{train_id}: Step 0 arrival check — back-integrating {base_branch} from origin/dev")
            arrival = back_integrate_change_branch(
                Path(change_worktree_path),
                base_branch,
                dev_ref="origin/dev",
            )
            record["step_0_arrival_check"] = arrival["status"]
            if arrival["status"] == "merge_conflict":
                files_summary = ", ".join(arrival["files"][:3]) + (
                    f" (+ {len(arrival['files']) - 3} more)" if len(arrival["files"]) > 3 else ""
                )
                record.update(
                    outcome="blocker",
                    outcome_reason=(
                        f"Step 0: change branch back-integration conflict in {files_summary}. "
                        f"Per CW-04, do not auto-resolve — founder picks resolve / defer / abort."
                    ),
                    completed_at=datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
                )
                write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
                emit_result(record, exit_code=1)
            elif arrival["status"] in ("fetch_failed", "internal_error"):
                record.update(
                    outcome="blocker",
                    outcome_reason=f"Step 0 {arrival['status']}: {arrival.get('error', '')}",
                    completed_at=datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
                )
                write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
                emit_result(record, exit_code=1)
            elif arrival["status"] == "merged_ok":
                _log(f"{train_id}: Step 0: merged {arrival.get('merged_commits', '?')} commits from origin/dev into {base_branch}")
            else:
                _log(f"{train_id}: Step 0: {base_branch} already current with origin/dev")
        else:
            record["step_0_arrival_check"] = "skipped"

        plan = _plan_phase(
            args=args, paths=paths, repo=repo, train_id=train_id,
            batch=batch, base_branch=base_branch, clone_dir=clone_dir,
            record=record,
        )
        commit = _commit_phase(
            args=args, paths=paths, repo=repo, train_id=train_id,
            plan=plan, record=record, clone_dir=clone_dir,
        )
        verify = _verify_phase(
            args=args, paths=paths, repo=repo, train_id=train_id,
            plan=plan, commit=commit, record=record, clone_dir=clone_dir,
        )
        if verify.ready_for_gates:
            _finalise_awaiting_gates(
                paths=paths, train_id=train_id, batch=batch,
                plan=plan, commit=commit, verify=verify, record=record,
            )
        else:
            _finalise_success(
                paths=paths, train_id=train_id, batch=batch,
                plan=plan, commit=commit, verify=verify, record=record,
            )

        # Step 12.5: post-batch back-integration (Phase 5 #6 — change-as-
        # primitive build). After the train successfully merges the batch
        # into the change branch, back-integrate the change branch from
        # dev. Active driver — keeps the change branch within one batch
        # of dev. Conflict here is non-blocking: the batch already merged
        # successfully; founder resolves at next Step 0.
        # Note: _finalise_success / _finalise_awaiting_gates do NOT raise
        # SystemExit on the success path — they update record + return.
        # cmd_run exits via record propagation, so we run Step 12.5
        # AFTER the finalise calls but BEFORE the function returns.
        if change_worktree_path and base_branch.startswith("change/"):
            _log(f"{train_id}: Step 12.5 post-batch back-integration of {base_branch} from origin/dev")
            post_batch = back_integrate_change_branch(
                Path(change_worktree_path),
                base_branch,
                dev_ref="origin/dev",
            )
            record["step_12_5_back_integration"] = post_batch["status"]
            if post_batch["status"] == "merge_conflict":
                files_summary = ", ".join(post_batch["files"][:3]) + (
                    f" (+ {len(post_batch['files']) - 3} more)" if len(post_batch["files"]) > 3 else ""
                )
                _log(
                    f"WARNING: {train_id}: Step 12.5 conflict in {files_summary}. "
                    f"Batch merged successfully but change branch is now stale. "
                    f"Founder action needed at next Step 0."
                )
                record["step_12_5_conflict_files"] = post_batch["files"]
            elif post_batch["status"] in ("fetch_failed", "internal_error"):
                _log(
                    f"WARNING: {train_id}: Step 12.5 {post_batch['status']}: "
                    f"{post_batch.get('error', '')}. Continuing — defence in depth at next Step 0."
                )
            elif post_batch["status"] == "merged_ok":
                _log(f"{train_id}: Step 12.5: merged {post_batch.get('merged_commits', '?')} commits from origin/dev into {base_branch}")
            else:
                _log(f"{train_id}: Step 12.5: {base_branch} already current with origin/dev")
        else:
            record["step_12_5_back_integration"] = "skipped"

    except RuntimeError as exc:
        record["outcome"] = "error"
        record["outcome_reason"] = f"internal: {exc}"
        record["completed_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        try:
            write_train_run_record(paths.train_runs_dir / f"{train_id}.yaml", record)
        except Exception:  # noqa: BLE001
            pass
        emit_result(record, exit_code=2)
    except SystemExit:
        raise
    except Exception as exc:  # noqa: BLE001
        emit_internal_error(exc)
    finally:
        shutil.rmtree(clone_dir, ignore_errors=True)


def cmd_mark_gates_complete(args: argparse.Namespace) -> None:
    """HD-007 — signal that Step 10.5 + Step 11 have completed for a train
    in phase=verifying_gates. Transitions to terminal success (or failed,
    when --critical-found is set).

    This is the calling LLM session's complement to cmd_run's gate handoff:
    cmd_run pauses at the gate boundary; the session dispatches Step 10.5
    + Step 11; the session invokes this subcommand to finalise. No git
    operations, no shell-outs, no agent dispatch — just a state-machine
    transition + record write.
    """
    paths = paths_from_args(args)
    state_path = train_state_path(paths.train_runs_dir, args.train_id)

    if not state_path.exists():
        emit_error(
            f"Train {args.train_id!r} has no in-flight state file at "
            f"{state_path}. Either it never started, it already completed, "
            f"or its state file was cleaned up. Run `wpx-train inspect "
            f"{args.train_id}` to see the historical record."
        )
        return

    try:
        state = read_train_state(state_path)
    except RuntimeError as exc:
        emit_error(str(exc))
        return

    phase = state.get("phase")
    if phase != "verifying_gates":
        emit_error(
            f"Train {args.train_id!r} is in phase {phase!r}; expected "
            f"verifying_gates. mark-gates-complete only finalises trains "
            f"that paused at the gate handoff boundary (via cmd_run with "
            f"--enable-gate-handoff). Inspect via `wpx-train inspect "
            f"{args.train_id}`."
        )
        return

    record_path = paths.train_runs_dir / f"{args.train_id}.yaml"
    # HD-010 — read the existing awaiting-gates record stub (written by
    # _finalise_awaiting_gates) and merge into it, rather than truncating
    # to a 2-field stub on every successful mark-gates-complete call.
    # read_train_run_record raises OSError/ValueError on parse failure;
    # callers MUST handle (the previous bare-except swallowed ImportError
    # and produced silent data loss on bundle / deploy_url / final_merge_sha
    # / started_at / batch_size).
    record: dict = read_train_run_record(record_path)

    completed_at = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    if args.critical_found:
        # Calling session dispatched gates; one or more CRITICAL findings
        # surfaced. The gate dispatchers already wrote BLOCKERs for the
        # affected WPs (their existing CRITICAL-handling code paths).
        # The train's job here is just to record the gate-failure outcome
        # and transition to phase=failed.
        reason = "Gate found CRITICAL finding(s)"
        if args.gate_findings:
            reason = f"{reason}; see {args.gate_findings}"
        update_train_phase(
            state_path, "failed",
            pause_reason=reason,
            recovery_hint=(
                "Step 10.5 or Step 11 surfaced one or more CRITICAL findings. "
                "The gate dispatchers already wrote per-WP BLOCKERs and "
                "drafted remediation WPs. The train is recorded as failed; "
                "no ADR-212 revert was run because production is live and "
                "the founder owns the remediation cycle (next train picks "
                "up the remediation WPs)."
            ),
        )
        record["outcome"] = "gate_blocker"
        record["outcome_reason"] = reason
        record["completed_at"] = completed_at
        if args.gate_findings:
            record["gate_findings_path"] = args.gate_findings
        write_train_run_record(record_path, record)
        cleanup_train_state(paths.train_runs_dir, args.train_id)
        emit_result({
            "train_id": args.train_id,
            "outcome": "gate_blocker",
            "phase": "failed",
            "record_path": str(record_path),
        }, exit_code=1)
        return

    # Clean gate verdict: transition to terminal success.
    update_train_phase(state_path, "success")
    record["outcome"] = "success"
    record["completed_at"] = completed_at
    if args.gate_findings:
        record["gate_findings_path"] = args.gate_findings
    write_train_run_record(record_path, record)
    cleanup_train_state(paths.train_runs_dir, args.train_id)
    emit_result({
        "train_id": args.train_id,
        "outcome": "success",
        "phase": "success",
        "record_path": str(record_path),
    }, exit_code=0)


# --- argparse -----------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description=(
            "Batched merge queue (per-batch sibling of wpx-pipeline). "
            "Discovers eligible WPs from INDEX.md + origin + CI status. "
            "v0.11.0 skeleton — queue + status + doctor are functional; "
            "run lands in v0.12.0+."
        ),
    )
    sub = parser.add_subparsers(dest="subcommand", required=True)

    def _common(p: argparse.ArgumentParser) -> None:
        add_common_args(p)
        p.add_argument("--repo", default=None,
                       help="GitHub repo (org/name); defaults to $GITHUB_REPOSITORY")

    p_list = sub.add_parser("queue-list", help="List eligible + ineligible WPs")
    _common(p_list)
    p_list.add_argument(
        "--strict-ci", action="store_true",
        help="Also require per-WP branch CI green before eligibility. "
             "Default (v0.18.0+): optimistic — branch CI is informational only; "
             "the bundled-tip CI gate at Step 8 is the real gate.",
    )

    p_add = sub.add_parser("queue-add", help="Force-include a WP in next train")
    _common(p_add)
    p_add.add_argument("--wp", required=True, help="WP ID (e.g. WP-AUTO-018)")
    p_add.add_argument("--reason", default="", help="Optional human reason (recorded but not enforced)")

    p_remove = sub.add_parser("queue-remove", help="Hold a WP back from next train")
    _common(p_remove)
    p_remove.add_argument("--wp", required=True, help="WP ID (e.g. WP-AUTO-018)")
    p_remove.add_argument("--reason", default="", help="Optional human reason")

    p_status = sub.add_parser("status", help="Read-only summary of train state")
    _common(p_status)
    p_status.add_argument(
        "--strict-ci", action="store_true",
        help="Compute eligibility with the v0.11.0 strict CI gate. "
             "Default (v0.18.0+): optimistic — eligibility doesn't require "
             "per-WP CI green; the bundled-tip CI is the real gate.",
    )

    p_inspect = sub.add_parser("inspect", help="Inspect a train's in-flight or historical state")
    _common(p_inspect)
    p_inspect.add_argument(
        "--train-id", default=None,
        help="Train ID to inspect (e.g., train-2026-05-22T123000Z). "
             "Omit to list recent trains.",
    )
    p_inspect.add_argument(
        "--json", action="store_true",
        help="Emit machine-readable JSON (default: founder-friendly plain English)",
    )

    p_abort = sub.add_parser(
        "abort",
        help="Abort a paused or in-flight train (revert if post-merge; restore if pre-merge)",
    )
    _common(p_abort)
    p_abort.add_argument(
        "--train-id", required=True,
        help="Train ID to abort (from wpx-train inspect).",
    )

    p_skip_wp = sub.add_parser(
        "skip-wp",
        help="Drop one WP from a paused train's bundle; flip to step-7-held",
    )
    _common(p_skip_wp)
    p_skip_wp.add_argument("--train-id", required=True, help="Train ID")
    p_skip_wp.add_argument("--wp", required=True, help="WP ID to drop")

    p_retry_wp = sub.add_parser(
        "retry-wp",
        help="Clear one WP's per-phase outcomes in a paused train (for next resume)",
    )
    _common(p_retry_wp)
    p_retry_wp.add_argument("--train-id", required=True, help="Train ID")
    p_retry_wp.add_argument("--wp", required=True, help="WP ID to retry")

    p_resume = sub.add_parser(
        "resume",
        help="Resume a paused train (re-fires the train with same args after the founder's fix)",
    )
    _common(p_resume)
    p_resume.add_argument(
        "--train-id", required=True,
        help="Train ID to resume (e.g., train-2026-05-22T123000Z). "
             "Get from `wpx-train inspect`.",
    )
    # Pre-merge resume re-invokes cmd_run; allow CLI overrides for any
    # arg cmd_run would accept (deploy_workflow, staging_url, etc.).
    # The state's saved args provide defaults; CLI values win when set.
    p_resume.add_argument("--deploy-workflow", default=None,
                          help="Override deploy workflow (default: from state)")
    p_resume.add_argument("--staging-url", default=None,
                          help="Override staging URL (default: from state)")
    p_resume.add_argument("--health-path", default="",
                          help="Override health path (default: from state)")
    p_resume.add_argument("--smoke-cmd", default="",
                          help="Override smoke command (default: from state)")
    p_resume.add_argument("--ci-poll-interval", type=int, default=None,
                          help="Override CI poll interval")
    p_resume.add_argument("--deploy-poll-interval", type=int, default=None,
                          help="Override deploy poll interval")
    p_resume.add_argument("--deploy-cap", type=int, default=None,
                          help="Override deploy poll cap (s)")
    p_resume.add_argument("--max-batch-size", type=int, default=5,
                          help="Cap WPs per batch (default 5)")
    p_resume.add_argument("--base-branch", default=None,
                          help="Override base branch (default: from state)")
    # --repo is provided by _common (above)
    p_resume.add_argument("--force", action="store_true",
                          help="Bypass size/staleness trigger on re-fire")
    p_resume.add_argument("--strict-ci", action="store_true",
                          help="Use strict-CI eligibility on re-fire")

    p_doctor = sub.add_parser("doctor", help="Diagnose drift (missing branches, unmet deps, etc.)")
    _common(p_doctor)

    p_run = sub.add_parser("run", help="Fire the train (happy path; failure handling in Phase 3)")
    _common(p_run)
    p_run.add_argument("--force", action="store_true",
                       help="Bypass size/staleness trigger")
    p_run.add_argument(
        "--strict-ci", action="store_true",
        help="Strict eligibility — require per-WP branch CI green before "
             "including a WP in the batch. Default (v0.18.0+): optimistic — "
             "bundled-tip CI at Step 8 is the gate; per-WP CI is informational. "
             "Strict mode preserves the v0.11.0 behaviour for callers that want "
             "pre-batch confidence on individual branches.",
    )
    p_run.add_argument("--deploy-workflow", required=True,
                       help="Deploy workflow name (e.g. 'Deploy to Dev Environment')")
    p_run.add_argument("--staging-url", default=None,
                       help="Staging URL for health check (optional)")
    p_run.add_argument(
        "--health-path", default="",
        help="HTTP path to use for the health check (default /)",
    )
    p_run.add_argument("--smoke-cmd", default="",
                       help="Smoke test shell command (run after health check)")
    p_run.add_argument("--ci-poll-interval", type=int, default=None,
                       help=f"CI poll interval (s, default {CI_DEFAULT_INTERVAL})")
    p_run.add_argument("--deploy-poll-interval", type=int, default=None,
                       help=f"Deploy poll interval (s, default {DEPLOY_DEFAULT_INTERVAL})")
    p_run.add_argument("--deploy-cap", type=int, default=None,
                       help=f"Max total deploy-poll time before declaring failure "
                            f"(s, default {DEPLOY_DEFAULT_CAP}). Raise for slow "
                            f"deploys to avoid ADR-212 revert on a still-running deploy.")
    p_run.add_argument("--max-batch-size", type=int, default=5,
                       help="Cap WPs per batch (default 5)")
    p_run.add_argument("--base-branch", default=None,
                       help="Base ref for rebase + merge target (default: dev). "
                            "Per CW-04, when run inside a change worktree, "
                            "callers pass the change branch name so WPs ship "
                            "to the change branch rather than directly to dev.")
    p_run.add_argument(
        "--change-worktree-path", default=None,
        help="Path to the parent change worktree (per CW-04). When set + "
             "--base-branch starts with 'change/', the train runs Step 0 "
             "(arrival check — back-integrate change branch from dev) "
             "before the plan phase, and Step 12.5 (post-batch back-"
             "integration) after _finalise_success / _finalise_awaiting_"
             "gates. Both are no-ops when the change branch is already "
             "current. Conflicts at Step 0 → BLOCKER (exit 1) with the "
             "CW-04 three-option dialog; conflicts at Step 12.5 → WARNING "
             "(the batch already merged successfully; founder resolves at "
             "next Step 0). When unset, both steps are skipped (backward-"
             "compatible with pre-Phase-5 callers and with the CW-05 "
             "trivial-change carve-out).",
    )
    p_run.add_argument(
        "--enable-gate-handoff", action="store_true",
        help="HD-007: stop at the verifying_gates phase boundary after "
             "deploy/health/smoke complete green. Emits outcome=awaiting_gates "
             "(exit 0) with a gate_handoff envelope describing the batch diff "
             "range + wps_shipped for Step 10.5 + Step 11. Calling session "
             "dispatches the gates and then invokes `wpx-train mark-gates-"
             "complete --train-id <id>` to finalise. Default: off (legacy "
             "path — goes directly to terminal success after smoke).",
    )

    p_mgc = sub.add_parser(
        "mark-gates-complete",
        help=("HD-007: finalise a train paused at verifying_gates. "
              "Calling session invokes after Step 10.5 + Step 11 dispatch "
              "completes."),
    )
    _common(p_mgc)
    p_mgc.add_argument("--train-id", required=True,
                       help="Train ID to finalise (must be in phase=verifying_gates)")
    p_mgc.add_argument(
        "--gate-findings", default=None,
        help="Optional path to gate findings artifact (e.g. code-review bundle). "
             "Recorded in the train YAML for posterity.",
    )
    p_mgc.add_argument(
        "--critical-found", action="store_true",
        help="A CRITICAL finding surfaced in Step 10.5 or Step 11. Records "
             "the train as gate_blocker (phase=failed) without running the "
             "ADR-212 revert; the gate dispatcher already wrote BLOCKERs "
             "and drafted remediation WPs.",
    )

    return parser


HANDLERS = {
    "queue-list": cmd_queue_list,
    "queue-add": cmd_queue_add,
    "queue-remove": cmd_queue_remove,
    "status": cmd_status,
    "inspect": cmd_inspect,
    "resume": cmd_resume,
    "abort": cmd_abort,
    "skip-wp": cmd_skip_wp,
    "retry-wp": cmd_retry_wp,
    "doctor": cmd_doctor,
    "run": cmd_run,
    "mark-gates-complete": cmd_mark_gates_complete,
}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
