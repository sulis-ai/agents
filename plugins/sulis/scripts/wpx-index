#!/usr/bin/env python3
"""wpx-index — manage INDEX.md (status flips, ready set, config).

Subcommands:
  flip-status           Change a WP's status (e.g. in_progress → done).
  list-ready            List ready WPs (status: pending, deps satisfied).
  read-config           Read project config (max_parallel, etc.).
  propagate-blocked     Mark transitively-dependent WPs as dependency_blocked.
  set-status            Force a specific status on a WP.
  lint                  Fail loudly if INDEX.md's WP table header drifted
                        from the canonical `| ID | Title | ... |` form (#60).

Exit codes: 0 success, 1 user/data error, 2 internal error.
"""

from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
from _wpxlib import (  # noqa: E402
    CANONICAL_WP_STATUSES,
    add_common_args,
    cli_main,
    compute_wp_status,
    current_change_scope,
    emit_error,
    emit_ok,
    interaction_flow_exercised,
    is_interaction_contract_wp,
    is_visual_contract_wp,
    parse_index_md,
    parse_md_table,
    paths_from_args,
    read_frontmatter,
    resolve_wp_columns,
    validate_cross_kind_contract_wiring,
    validate_frontend_wp_visual_contract,
    validate_wp_index_header,
    validate_wp_status,
    visual_contract_signed_off,
)
from _wpxlib import _normalise_wp_reference  # noqa: E402  (#50 frontmatter deps)

# Argparse choice lists for status flags derive from the one canonical set
# (L-03) so flip-status / add-wp can never drift from the validator again.
_STATUS_CHOICES = sorted(CANONICAL_WP_STATUSES)


# INDEX.md structure (simplified):
#
# ## Orchestrator Config
# max_parallel: 3
#
# ## Work Packages
#
# | ID | Title | Primitive | Status | Depends | Blocks | Token | TDD § |
# |--- | ...  |
# | WP-001 | ... | Create | pending | — | WP-002 | 5k | 2.1 |
#
# The script parses the WP table and updates status cells.


def _read_index(args: argparse.Namespace) -> str:
    paths = paths_from_args(args)
    if not paths.index_md.exists():
        raise FileNotFoundError(f"INDEX.md not found: {paths.index_md}")
    return paths.index_md.read_text(encoding="utf-8")


def _write_index(args: argparse.Namespace, text: str) -> None:
    paths = paths_from_args(args)
    paths.index_md.write_text(text, encoding="utf-8")


def _read_config(text: str) -> dict[str, str]:
    """Extract Orchestrator Config block (if present)."""
    pattern = re.compile(
        r"^## Orchestrator Config\s*\n(.+?)(?=\n##\s|\Z)",
        re.MULTILINE | re.DOTALL,
    )
    match = pattern.search(text)
    if not match:
        return {}
    body = match.group(1)
    config: dict[str, str] = {}
    for line in body.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or line.startswith("```"):
            continue
        if ":" in line:
            key, _, value = line.partition(":")
            config[key.strip()] = value.strip()
    return config


def _find_wp_table(text: str) -> tuple[int, int, str]:
    """Find the WP table in INDEX.md (heading- and column-aware).

    Resolution order (v0.10.5+):

    1. First-class: a table immediately following a heading matching
       `## Work Packages` (case-insensitive; allows "Work Package").
       This is the canonical location SEA's decompose template puts
       the WP table.

    2. Fallback: any `| ID |`-headed Markdown table whose header row
       ALSO includes BOTH `Status` and `Primitive` columns. These
       two columns are unique to the WP table; the primitive-summary
       table (which has `Group | Count`) doesn't have them.

    3. Last resort: the first `| ID |`-headed table. Emits a stderr
       warning that the WP table couldn't be identified by heading
       or columns (helps diagnose unusual INDEX.md layouts).

    The previous v0.9.0..v0.10.4 implementation took only path #3,
    which broke for any INDEX.md that had a non-WP `| ID |` table
    (e.g., a primitive-summary table) before the WP table.
    """
    # Path 1: heading-anchored ("## Work Packages" → next table)
    heading_re = re.compile(
        r"^##\s+Work\s+Packages?\s*$",
        re.MULTILINE | re.IGNORECASE,
    )
    h_match = heading_re.search(text)
    if h_match:
        # Find the first | ID |-headed table after the heading
        table_re = re.compile(
            r"(^\|\s*ID\s*\|[^\n]+\n\|[^\n]+\n(?:\|[^\n]*\n)*)",
            re.MULTILINE,
        )
        t_match = table_re.search(text, pos=h_match.end())
        if t_match:
            return t_match.start(), t_match.end(), t_match.group(1)

    # Path 2: column-aware (find any | ID | table whose headers also
    # have Status + Primitive)
    table_re = re.compile(
        r"(^\|\s*ID\s*\|[^\n]+\n\|[^\n]+\n(?:\|[^\n]*\n)*)",
        re.MULTILINE,
    )
    for t_match in table_re.finditer(text):
        # Inspect the header row (first line of the match)
        header_line = t_match.group(1).split("\n", 1)[0]
        # Lowercase + split on |
        cols = [c.strip().lower() for c in header_line.strip("|").split("|")]
        if "status" in cols and "primitive" in cols:
            return t_match.start(), t_match.end(), t_match.group(1)

    # Path 3: last-resort first match (with warning)
    first = table_re.search(text)
    if first:
        sys.stderr.write(
            "wpx-index: warning — found a `| ID |` table but it lacks "
            "Status + Primitive columns and isn't anchored to a "
            "`## Work Packages` heading. Treating it as the WP table; "
            "verify INDEX.md layout if this seems wrong.\n"
        )
        return first.start(), first.end(), first.group(1)

    raise ValueError("Could not find WP table in INDEX.md (no | ID | header)")


def _find_all_wp_tables(text: str) -> list[tuple[int, int, str]]:
    """Every WP status sub-table in document order (#50).

    Multi-table-aware sibling of ``_find_wp_table``. Contract-first
    decompose produces one WP sub-table per kind (Data contracts /
    Visual contracts / Backend / Frontend / Integration), each with
    its own column set. Returns each ``| ID |``-headed table that has
    a ``Status`` column (which is what distinguishes a WP table from
    the wrap-audit or primitive-distribution tables).

    A single-table INDEX yields a 1-element list, so callers that
    iterate behave byte-identically to the old single-table path.
    """
    table_re = re.compile(
        r"(^\|\s*ID\s*\|[^\n]+\n\|[^\n]+\n(?:\|[^\n]*\n)*)",
        re.MULTILINE,
    )
    out: list[tuple[int, int, str]] = []
    for m in table_re.finditer(text):
        header_line = m.group(1).split("\n", 1)[0]
        cols = [c.strip().lower() for c in header_line.strip("|").split("|")]
        if "status" in cols:
            out.append((m.start(), m.end(), m.group(1)))
    return out


def _collect_status_across_tables(text: str) -> dict[str, str]:
    """Map WP-ID → live status across ALL WP sub-tables (#50).

    Live status is the INDEX cell (written by flip-status); this reads
    it from every sub-table so list-ready / propagate-blocked see the
    whole project, not just the first table."""
    status_by_id: dict[str, str] = {}
    for _, _, table_text in _find_all_wp_tables(text):
        table = parse_md_table(table_text)
        cols = resolve_wp_columns(table.headers)
        if "id" not in cols or "status" not in cols:
            continue
        for row in table.rows:
            if cols["id"] >= len(row):
                continue
            wp_id = row[cols["id"]].strip()
            if not wp_id:
                continue
            if cols["status"] < len(row):
                status_by_id[wp_id] = row[cols["status"]].strip()
    return status_by_id


def _rewrite_status_summary(text: str) -> str:
    """Recompute counts in the `## Status Summary` table from current WP cells.

    #143: flip-status updated the WP row but left the summary stale, so the
    summary drifted from the row truth. The fix recomputes the summary
    atomically with the row write.

    Preserves the existing summary table's row order + status set (some
    projects track a narrow set — pending/in_progress/done/blocked — others
    extend); only the Count column is rewritten. Silently no-ops when no
    summary section exists.
    """
    hd_re = re.compile(r"^##\s+Status\s+Summary\s*$", re.MULTILINE | re.IGNORECASE)
    m_hd = hd_re.search(text)
    if not m_hd:
        return text
    # Find the next | Status | Count |-headed table after the heading.
    tbl_re = re.compile(
        r"(^\|\s*Status\s*\|\s*Count\s*\|[^\n]*\n\|[^\n]+\n(?:\|[^\n]*\n)*)",
        re.MULTILINE | re.IGNORECASE,
    )
    m_tbl = tbl_re.search(text, pos=m_hd.end())
    if not m_tbl:
        return text
    table_text = m_tbl.group(1)
    table = parse_md_table(table_text)
    if not table.headers:
        return text
    # Locate Status / Count columns case-insensitively (allows extra columns
    # like Notes after Count).
    headers_lower = [h.strip().lower() for h in table.headers]
    try:
        status_idx = headers_lower.index("status")
        count_idx = headers_lower.index("count")
    except ValueError:
        return text

    # Recount across all WP sub-tables — the row cells are the source of truth.
    counts: dict[str, int] = {}
    for _, _, sub in _find_all_wp_tables(text):
        sub_tbl = parse_md_table(sub)
        sub_cols = resolve_wp_columns(sub_tbl.headers)
        if "status" not in sub_cols:
            continue
        si = sub_cols["status"]
        for row in sub_tbl.rows:
            if si < len(row):
                s = row[si].strip()
                if s:
                    counts[s] = counts.get(s, 0) + 1

    # Update only the rows already present (preserve the project's chosen
    # summary scope — don't append unseen statuses).
    changed = False
    for row in table.rows:
        if status_idx >= len(row) or count_idx >= len(row):
            continue
        status = row[status_idx].strip()
        new_count = str(counts.get(status, 0))
        if row[count_idx].strip() != new_count:
            row[count_idx] = new_count
            changed = True
    if not changed:
        return text
    new_table = table.render() + "\n"
    return text[:m_tbl.start()] + new_table + text[m_tbl.end():]


def _load_deps_from_frontmatter(
    args: argparse.Namespace, known_wps: set[str],
) -> dict[str, list[str]]:
    """Map WP-ID → list of full dep IDs from each WP file's ``dependsOn``
    frontmatter (#50).

    Frontmatter ``dependsOn`` is the complete, uniform, kind-agnostic
    executable-dependency set — unlike the INDEX dep columns, which are
    heterogeneous per kind (the visual-contract sub-table carries a
    "Data contract" column that is informational pairing, NOT a
    readiness dependency; VC WPs correctly have ``dependsOn: []``).

    Returns a dict keyed ONLY by the WPs that actually have a file —
    a WP absent from the filesystem is OMITTED (not mapped to ``[]``).
    This is load-bearing: callers must distinguish "this WP has a file,
    its deps are []" from "this WP has no file, fall back to the table
    cell". Mapping a fileless WP to ``[]`` would silently make it appear
    ready before its deps are done (#50 review finding).
    """
    paths = paths_from_args(args)
    wp_dir = paths.wp_dir
    if not wp_dir.exists():
        return {}
    deps_by_id: dict[str, list[str]] = {}
    for wp_file in sorted(wp_dir.glob("WP-*.md")):
        fm = read_frontmatter(wp_file)
        wp_id = str(fm.get("id") or "").strip()
        if not wp_id:
            continue
        raw = fm.get("dependsOn") or []
        if isinstance(raw, str):
            raw = [d.strip() for d in re.split(r"[,\s]+", raw) if d.strip()]
        deps: list[str] = []
        for dep in raw:
            dep = str(dep).strip()
            if not dep:
                continue
            resolved, _ = _normalise_wp_reference(dep, known_wps)
            deps.append(resolved)
        deps_by_id[wp_id] = deps
    return deps_by_id


def _resolve_deps(
    args: argparse.Namespace, text: str, known_wps: set[str],
) -> dict[str, list[str]]:
    """Per-WP dependency resolution (#50 + review hardening).

    For each WP: use its frontmatter ``dependsOn`` (the canonical,
    complete, kind-agnostic source) when the WP file exists; otherwise
    fall back to its per-table "depends" column. NEVER silently treats
    a WP's deps as empty just because its file is missing — a fileless
    WP uses the table cell, which is conservative (a WP listed in the
    INDEX with table deps stays constrained rather than wrongly
    becoming ready).

    This handles the partial-existence case (some WP files present,
    others not — e.g. mid-migration) correctly: each WP resolves
    independently from the best available source.
    """
    fm_deps = _load_deps_from_frontmatter(args, known_wps)
    table_deps: dict[str, list[str]] = {}
    for _, _, table_text in _find_all_wp_tables(text):
        table_deps.update(_deps_from_table(table_text))
    resolved: dict[str, list[str]] = {}
    for wp_id in known_wps:
        if wp_id in fm_deps:
            resolved[wp_id] = fm_deps[wp_id]
        else:
            resolved[wp_id] = table_deps.get(wp_id, [])
    return resolved


def _deps_from_table(table_text: str) -> dict[str, list[str]]:
    """Fallback dep source: parse the per-table "depends" column.

    Used only when frontmatter is unavailable (no WP files). Preserves
    the single-table back-compat path for INDEX-only fixtures."""
    deps_by_id: dict[str, list[str]] = {}
    table = parse_md_table(table_text)
    cols = resolve_wp_columns(table.headers)
    if "id" not in cols or "depends" not in cols:
        return deps_by_id
    for row in table.rows:
        if cols["id"] >= len(row):
            continue
        wp_id = row[cols["id"]].strip()
        if not wp_id:
            continue
        deps_cell = row[cols["depends"]].strip() if cols["depends"] < len(row) else ""
        if deps_cell in ("—", "-", "", "None", "[]"):
            deps_by_id[wp_id] = []
        else:
            deps_by_id[wp_id] = [
                d.strip() for d in re.split(r"[, ]+", deps_cell) if d.strip()
            ]
    return deps_by_id


def _enforce_visual_contract_signoff_on_done(args: argparse.Namespace) -> None:
    """#45 / UXD-14 runtime gate — a visual-contract WP cannot be flipped to
    `done` until its mockup is signed off. No-op for any other WP / status.

    Because frontend WPs `dependsOn` the contract WP (Phase 1 write-time gate)
    and list-ready only releases deps that are `done`, refusing this flip keeps
    the frontend work undispatchable until the founder has signed off.
    """
    if args.to != "done":
        return
    paths = paths_from_args(args)
    try:
        wp_path = paths.wp_file(args.wp)
    except (FileNotFoundError, ValueError):
        return  # no WP file → not a checkable visual-contract WP
    fm = read_frontmatter(wp_path)
    if not is_visual_contract_wp(fm):
        return
    err = visual_contract_signed_off(fm)
    if err is not None:
        emit_error(f"{args.wp}: {err}")


def _enforce_interaction_flow_on_done(args: argparse.Namespace) -> None:
    """CH-01KT9H runtime gate — an interaction-contract WP cannot be flipped to
    `done` until its multi-step flow's exercise evidence is recorded. No-op for
    any other WP / status. Direct sibling of
    :func:`_enforce_visual_contract_signoff_on_done`.

    The gate trusts the recorded evidence (`exercised_at` / `exercised_by` /
    `exercised_attestation`) and does NOT re-run the flow (ADR-003).
    """
    if args.to != "done":
        return
    paths = paths_from_args(args)
    try:
        wp_path = paths.wp_file(args.wp)
    except (FileNotFoundError, ValueError):
        return  # no WP file → not a checkable interaction-contract WP
    fm = read_frontmatter(wp_path)
    if not is_interaction_contract_wp(fm):
        return
    err = interaction_flow_exercised(fm)
    if err is not None:
        emit_error(f"{args.wp}: {err}")


def cmd_flip_status(args: argparse.Namespace) -> None:
    # Both done-gates run at this single chokepoint. They are independent and
    # order-insensitive: each fires only for the contract_type its predicate
    # matches (visual vs interaction), so an ordinary WP is a double no-op —
    # the regression-safety guarantee that ordinary flips behave exactly as
    # before. A WP that is somehow both kinds is gated by both.
    _enforce_visual_contract_signoff_on_done(args)
    _enforce_interaction_flow_on_done(args)
    text = _read_index(args)

    # Iterate ALL WP sub-tables (#50). The contract-first decompose
    # produces one table per kind; the target WP lives in exactly one.
    # Find it, flip its status cell, rewrite only that sub-table.
    tables = _find_all_wp_tables(text)
    if not tables:
        # Fall back to the legacy single-table finder for an INDEX whose
        # WP table doesn't carry a Status header (older fixtures).
        start, end, table_text = _find_wp_table(text)
        tables = [(start, end, table_text)]

    for start, end, table_text in tables:
        table = parse_md_table(table_text)
        cols = resolve_wp_columns(table.headers)
        if "id" not in cols or "status" not in cols:
            continue
        id_idx, status_idx = cols["id"], cols["status"]
        found = False
        for row in table.rows:
            if id_idx < len(row) and row[id_idx].strip() == args.wp:
                if status_idx < len(row):
                    actual = row[status_idx].strip()
                    # #142 idempotence — when the row is already at the
                    # target status, the flip is a no-op success regardless
                    # of --expected. This makes wpx-step12 wrap (which
                    # passes --to done --expected in_progress) safe to
                    # replay after a partial earlier run.
                    if actual == args.to:
                        emit_ok(data={
                            "wp": args.wp,
                            "status": args.to,
                            "already": True,
                        })
                        return
                    if args.expected and actual != args.expected:
                        emit_error(
                            f"WP {args.wp} status is '{actual}', "
                            f"expected '{args.expected}'"
                        )
                    row[status_idx] = args.to
                    found = True
        if found:
            new_table = table.render() + "\n"
            text = text[:start] + new_table + text[end:]
            # #143: recompute the Status Summary atomically with the row
            # write so the summary table doesn't drift from the cells.
            text = _rewrite_status_summary(text)
            _write_index(args, text)
            emit_ok(data={"wp": args.wp, "status": args.to})
            return

    emit_error(f"WP {args.wp} not found in INDEX.md")


def cmd_set_status(args: argparse.Namespace) -> None:
    # Alias for flip-status without --expected
    args.expected = None
    cmd_flip_status(args)


def cmd_list_ready(args: argparse.Namespace) -> None:
    text = _read_index(args)

    # Status: live INDEX cells across ALL WP sub-tables (#50).
    status_by_id = _collect_status_across_tables(text)
    if not status_by_id:
        emit_error("INDEX.md has no WP table with ID + Status columns")

    # Dependencies: per-WP — frontmatter `dependsOn` (canonical) when the
    # WP file exists, else the per-table dep column (#50 + review). The
    # INDEX dep columns are heterogeneous display variants (the
    # visual-contract "Data contract" column is informational pairing,
    # not a readiness dependency), so frontmatter is preferred; the
    # table fallback covers WPs absent from the filesystem without
    # silently treating their deps as empty.
    depends_by_id = _resolve_deps(args, text, set(status_by_id))

    ready: list[str] = []
    for wp_id, status in status_by_id.items():
        if status != "pending":
            continue
        deps = depends_by_id.get(wp_id, [])
        if all(status_by_id.get(d) == "done" for d in deps):
            ready.append(wp_id)
    ready.sort()  # deterministic order; caller can pick lowest

    max_parallel = int(_read_config(text).get("max_parallel", 3))
    emit_ok(data={
        "ready": ready,
        "max_parallel": max_parallel,
        "total_pending": sum(1 for s in status_by_id.values() if s == "pending"),
        "total_done": sum(1 for s in status_by_id.values() if s == "done"),
        "total_blocked": sum(1 for s in status_by_id.values() if s == "blocked"),
        "total_in_progress": sum(1 for s in status_by_id.values() if s == "in_progress"),
    })


def cmd_read_config(args: argparse.Namespace) -> None:
    text = _read_index(args)
    config = _read_config(text)
    emit_ok(data={"config": config})


def cmd_propagate_blocked(args: argparse.Namespace) -> None:
    text = _read_index(args)

    # Status + deps span ALL WP sub-tables (#50). Status from the live
    # INDEX cells; deps from frontmatter (uniform) with a per-table
    # fallback for pure-INDEX fixtures.
    status_map = _collect_status_across_tables(text)
    depends_map = _resolve_deps(args, text, set(status_map))

    # BFS: starting from args.wp, find all WPs that (transitively) depend on it
    transitively_dependent: set[str] = set()
    queue = [args.wp]
    while queue:
        current = queue.pop()
        for wp_id, deps in depends_map.items():
            if current in deps and wp_id not in transitively_dependent:
                transitively_dependent.add(wp_id)
                queue.append(wp_id)

    # Mark each transitively-dependent pending WP as dependency_blocked,
    # writing into whichever sub-table the WP lives in. Process sub-table
    # spans in REVERSE document order so splicing a later table can't
    # shift the (start, end) offsets of an earlier one.
    flipped: list[str] = []
    for start, end, table_text in reversed(_find_all_wp_tables(text)):
        table = parse_md_table(table_text)
        cols = resolve_wp_columns(table.headers)
        if "id" not in cols or "status" not in cols:
            continue
        changed = False
        for row in table.rows:
            if cols["id"] >= len(row):
                continue
            wp_id = row[cols["id"]].strip()
            if (wp_id in transitively_dependent
                    and status_map.get(wp_id) == "pending"
                    and cols["status"] < len(row)):
                row[cols["status"]] = "dependency_blocked"
                flipped.append(wp_id)
                changed = True
        if changed:
            new_table = table.render() + "\n"
            text = text[:start] + new_table + text[end:]

    if flipped:
        _write_index(args, text)
    flipped.sort()
    emit_ok(data={"blocker_wp": args.wp, "flipped_to_dependency_blocked": flipped})


# ─────────────────────────────────────────────────────────────────────────
# add-wp / sync-auto-drafts (v0.10.3)
# ─────────────────────────────────────────────────────────────────────────


def _cells_from_frontmatter(fm: dict, wp_id: str) -> list[str]:
    """Build the 8 row cells from a parsed WP frontmatter dict.

    Column order matches the canonical WP table header:
      | ID | Title | Primitive | Status | Depends | Blocks | Token | TDD § |
    """
    def _esc(value: str) -> str:
        return str(value).replace("|", "\\|")

    def _list_cell(value) -> str:
        if not value:
            return "—"
        if isinstance(value, list):
            items = [str(v).strip() for v in value if str(v).strip()]
            return _esc(", ".join(items)) if items else "—"
        return _esc(str(value).strip()) if str(value).strip() else "—"

    title = fm.get("title", "")
    primitive = fm.get("primitive", "")
    status = fm.get("status", "auto-draft")
    # L-03 loud write-time validator — reject a drifted status (`ready`/`todo`/
    # a typo) here, at the single chokepoint both add-wp and sync-auto-drafts
    # flow through, instead of letting it vanish silently from list-ready.
    status_error = validate_wp_status(str(status))
    if status_error is not None:
        raise ValueError(f"{wp_id}: {status_error}")
    # #45 / UXD-14 write-time gate — a kind: frontend WP cannot enter the INDEX
    # unless it declares (and dependsOn) its visual-contract WP. Same loud-
    # refusal chokepoint as the status guard above.
    vc_error = validate_frontend_wp_visual_contract(fm)
    if vc_error is not None:
        raise ValueError(f"{wp_id}: {vc_error}")
    depends = _list_cell(fm.get("dependsOn"))
    blocks = _list_cell(fm.get("blocks"))
    # token estimate may be a scalar string ("1k", "?") or a dict (input/output Nk)
    token_raw = fm.get("estimated_token_cost") or fm.get("token", "")
    if isinstance(token_raw, dict):
        # Common shape from SEA WP templates: {input: "1k", output: "1k"}
        token = (
            f"{token_raw.get('input', '?')}/"
            f"{token_raw.get('output', '?')}"
        )
    else:
        token = str(token_raw).strip() if str(token_raw).strip() else "?"
    tdd = fm.get("tdd_section") or "—"
    return [
        _esc(wp_id),
        _esc(title),
        _esc(primitive),
        _esc(status),
        depends,
        blocks,
        _esc(token),
        _esc(str(tdd)),
    ]


def _append_wp_row(text: str, cells: list[str]) -> str:
    """Append a new row to the WP table in INDEX.md text. Returns new text."""
    start, end, table_text = _find_wp_table(text)
    table = parse_md_table(table_text)
    table.rows.append(cells)
    new_table = table.render() + "\n"
    return text[:start] + new_table + text[end:]


def _index_has_wp(text: str, wp_id: str) -> bool:
    """True if INDEX.md's WP table contains a row with this WP ID."""
    try:
        _, _, table_text = _find_wp_table(text)
    except ValueError:
        return False
    table = parse_md_table(table_text)
    try:
        id_idx = next(i for i, h in enumerate(table.headers) if h.lower() == "id")
    except StopIteration:
        return False
    for row in table.rows:
        if id_idx < len(row) and row[id_idx].strip() == wp_id:
            return True
    return False


def cmd_add_wp(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    text = _read_index(args)

    # Reject duplicates
    if _index_has_wp(text, args.wp):
        emit_error(
            f"WP {args.wp} is already in INDEX. Use flip-status / set-status "
            f"to change an existing row."
        )

    if args.from_wp_file:
        # Read the WP file's frontmatter
        try:
            wp_path = paths.wp_file(args.wp)
        except (FileNotFoundError, ValueError) as e:
            emit_error(f"--from-wp-file: {e}")
            return  # for type checker
        from _wpxlib import read_frontmatter  # local import to avoid top-clutter
        fm = read_frontmatter(wp_path)
        if not fm.get("id"):
            emit_error(f"--from-wp-file: {wp_path} has no `id` in frontmatter")
        if fm.get("id") != args.wp:
            emit_error(
                f"--from-wp-file: frontmatter id={fm.get('id')!r} "
                f"does not match --wp={args.wp}"
            )
        try:
            cells = _cells_from_frontmatter(fm, args.wp)
        except ValueError as e:
            emit_error(str(e))
            return  # for type checker
    else:
        # Explicit-fields mode
        if not args.title or not args.primitive:
            emit_error(
                "--title and --primitive are required when --from-wp-file is not set"
            )
        fm = {
            "id": args.wp,
            "title": args.title,
            "primitive": args.primitive,
            "status": args.status,
            "dependsOn": args.depends_on.split(",") if args.depends_on else [],
            "blocks": args.blocks.split(",") if args.blocks else [],
            "estimated_token_cost": args.token_estimate or "?",
        }
        if args.tdd:
            fm["tdd_section"] = args.tdd
        try:
            cells = _cells_from_frontmatter(fm, args.wp)
        except ValueError as e:
            emit_error(str(e))
            return  # for type checker

    new_text = _append_wp_row(text, cells)
    _write_index(args, new_text)

    # Compute the new row index for diagnostic output
    _, _, table_text = _find_wp_table(new_text)
    table = parse_md_table(table_text)
    emit_ok(data={
        "wp": args.wp,
        "title": cells[1].replace("\\|", "|"),
        "status": cells[3].replace("\\|", "|"),
        "row_index": len(table.rows),
    })


def cmd_sync_auto_drafts(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    text = _read_index(args)

    from _wpxlib import read_frontmatter  # local import

    added: list[str] = []
    skipped: list[str] = []
    errors: list[dict] = []

    candidates = sorted(paths.wp_dir.glob("WP-AUTO-*.md"))
    # Filter out dot-prefixed / BLOCKER- per WpxPaths.wp_file convention
    candidates = [
        p for p in candidates
        if not p.name.startswith(".") and not p.name.startswith("BLOCKER-")
    ]
    total_found = len(candidates)

    for wp_path in candidates:
        try:
            fm = read_frontmatter(wp_path)
            wp_id = fm.get("id")
            if not wp_id:
                errors.append({
                    "path": str(wp_path),
                    "error": "no `id` in frontmatter",
                })
                continue
            if _index_has_wp(text, str(wp_id)):
                skipped.append(str(wp_id))
                continue
            cells = _cells_from_frontmatter(fm, str(wp_id))
            text = _append_wp_row(text, cells)
            added.append(str(wp_id))
        except Exception as e:  # noqa: BLE001
            errors.append({"path": str(wp_path), "error": str(e)})

    if added:
        _write_index(args, text)

    emit_ok(data={
        "added": added,
        "skipped": skipped,
        "errors": errors,
        "total_found": total_found,
    })


def cmd_audit_contracts(args: argparse.Namespace) -> None:
    """#48 — graph-level data-contract structural check over the WP set.

    Reads every WP file's frontmatter (kind / contract_type / dependsOn),
    runs `validate_cross_kind_contract_wiring`, and fails loudly on any
    violation (so plan-work's decompose validation + CI can gate on it). The
    symmetric partner to the per-WP visual-contract gate.
    """
    paths = paths_from_args(args)
    candidates = sorted(paths.wp_dir.glob("WP-*.md"))
    candidates = [
        p for p in candidates
        if not p.name.startswith(".") and not p.name.startswith("BLOCKER-")
    ]
    wps: list[dict] = []
    for wp_path in candidates:
        try:
            fm = read_frontmatter(wp_path)
        except Exception:  # noqa: BLE001 — a malformed WP is a different check's job
            continue
        if fm.get("id"):
            wps.append(fm)

    violations = validate_cross_kind_contract_wiring(wps)
    if violations:
        emit_error(
            "data-contract wiring violations (#48 / CF-05):\n  - "
            + "\n  - ".join(violations),
            context={"violations": violations, "wp_count": len(wps)},
        )
    emit_ok(data={"violations": [], "wp_count": len(wps)})


def _roundtrip_accounting(
    args: argparse.Namespace, text: str,
) -> tuple[dict[str, str], list[str], set[str]]:
    """Run the EXACT parse `list-ready` runs against ``text`` and report
    what the real builder consumer sees (WP-001).

    Reuses ``_collect_status_across_tables`` + ``_resolve_deps`` — the same
    helpers ``cmd_list_ready`` calls — so the gate can never disagree with
    ``list-ready`` about what counts as a runnable INDEX (EP-03 single
    source of truth). It MUST NOT re-implement INDEX parsing.

    Returns ``(status_by_id, pending, unaccounted)``:

    * ``status_by_id`` — WP-ID → live status across every WP sub-table.
      Empty means the consumer can parse no WP table at all.
    * ``pending`` — the authored ``pending`` WP-IDs.
    * ``unaccounted`` — authored ``pending`` WPs the consumer cannot see at
      all. A pending WP is "accounted for" when the consumer SEES it —
      whether it is immediately ready (all deps done) or dependency-blocked
      (≥1 dep not done); either way ``list-ready`` will surface it. The
      failure mode is the consumer being *blind* to a pending WP, NOT the
      consumer reporting it as not-yet-ready (Contract invariant 2). Because
      ``_resolve_deps`` is keyed over the same WP set, every pending WP is
      seen, so this is empty in practice — it is computed (not assumed) so
      the gate names any future divergence rather than silently passing.
    """
    status_by_id = _collect_status_across_tables(text)
    pending = [wp for wp, status in status_by_id.items() if status == "pending"]
    depends_by_id = _resolve_deps(args, text, set(status_by_id))
    seen = set(depends_by_id)
    unaccounted = {wp for wp in pending if wp not in seen}
    return status_by_id, pending, unaccounted


def cmd_lint(args: argparse.Namespace) -> None:
    """#60/#218/#222/#233 — fail loudly when the decompose gate's INDEX is
    not actually runnable by the real builder consumer.

    Two checks, run in order, both BLOCKING (non-zero exit) so plan-work's
    existing Step 9.5 wiring ("lint non-zero exit = decompose NOT done")
    enforces them for free:

    1. **Header shape** (``validate_wp_index_header``, keyed off the SAME
       regex ``parse_index_md`` uses). A drifted header (e.g.
       ``| WP | Title | kind | Primitive | ... |``) is invisible to the
       run-all loop and fails silently mid-run; this turns it surgical.

    2. **List-ready round-trip** (WP-001). The header check is a *proxy* —
       it is blind to a canonical-header INDEX whose Status cells are all
       ``ready``/``blocked`` (never ``pending``): the consumer then returns
       an empty pending set and the break surfaces mid-build. So after the
       header passes, drive the REAL consumer: run the exact parse
       ``list-ready`` runs (``_collect_status_across_tables`` +
       ``_resolve_deps``, via ``_roundtrip_accounting``) and assert every
       authored ``pending`` WP is accounted for (ready ∪ dependency-blocked).
       A 0-WP / parse-fail result while WPs exist is BLOCKING.
    """
    text = _read_index(args)

    # (1) header-shape check — keep, runs first.
    error = validate_wp_index_header(text)
    if error is not None:
        emit_error(error)

    # (2) round-trip: what does the real builder consumer actually see?
    status_by_id, pending, unaccounted = _roundtrip_accounting(args, text)

    if not status_by_id:
        emit_error(
            "INDEX.md has a canonical header but no WP rows the builder can "
            "read (its ID/Status cells parse to nothing). The decompose is "
            "not done — author the WP rows under the canonical header."
        )

    if not pending:
        emit_error(
            "INDEX.md has WP rows but none are `pending` — every Status cell "
            "is already `ready`/`blocked`/`done`, so the builder sees no work "
            "to run. The decompose is not done — author the to-do list with "
            "`pending` WPs."
        )

    if unaccounted:
        names = ", ".join(sorted(unaccounted))
        emit_error(
            f"INDEX.md has `pending` WPs the builder cannot account for: "
            f"{names}. The decompose is not done — fix the WP table so every "
            f"pending WP is readable by the to-do tracker."
        )

    emit_ok(data={
        "header": "canonical",
        "round_trip": "ok",
        "pending": len(pending),
        "accounted": len(pending) - len(unaccounted),
    })


# ─────────────────────────────────────────────────────────────────────────
# HD-008 — wpx-index status (read-only computed view)
# ─────────────────────────────────────────────────────────────────────────


# States the system can derive from authoritative sources. When a WP's
# stored cell reports one of these AND the computed value disagrees,
# THAT is drift (in the sense `wpx-train doctor` reports). Operator-set
# states (pending, in_progress, auto-draft, cancelled, etc.) are not
# in this set — they have no authoritative-state correlate to disagree
# with.
_COMPUTED_ELIGIBLE_STATUSES: frozenset[str] = frozenset({
    "done", "step-7-shipping", "step-7-complete",
})


def _is_drift(stored: str, computed: str) -> bool:
    """True iff stored ≠ computed AND at least one is in the
    computed-eligible set.

    A disagreement on operator-only states (e.g., stored=pending vs
    computed=pending) is not drift. A disagreement on
    done-vs-step-7-complete IS drift (the work moved off dev, or never
    landed). The doctor uses the same rule for issue classification.
    """
    if stored == computed:
        return False
    return (stored in _COMPUTED_ELIGIBLE_STATUSES) or (
        computed in _COMPUTED_ELIGIBLE_STATUSES
    )


def _build_status_entry(
    wp_id: str,
    stored: str,
    *,
    paths,
    repo: str,
    base_branch: str,
    mode: str,
    change_scope: str | None = None,
) -> dict:
    """Build one {wp, stored, computed, drift} entry per mode.

    Modes:
      - "stored"   → returns {wp, stored} (no network).
      - "computed" → returns {wp, computed} (uses compute_wp_status).
      - "both"     → returns {wp, stored, computed, drift}.

    ``change_scope`` (ADR-001) is threaded to ``compute_wp_status`` so the
    branch-existence check is confined to this change's ``wp/{scope}/``
    namespace; ``None`` = legacy ``feat/...`` resolution. Resolved once by the
    caller (``cmd_status``) and passed in, so a per-WP loop makes no repeated
    change-context lookups.
    """
    entry: dict = {"wp": wp_id}
    if mode == "stored":
        entry["stored"] = stored
        return entry
    computed = compute_wp_status(
        wp_id, paths, repo, base_branch, stored_status=stored,
        change_scope=change_scope,
    )
    if mode == "computed":
        entry["computed"] = computed
        return entry
    # both
    entry["stored"] = stored
    entry["computed"] = computed
    entry["drift"] = _is_drift(stored, computed)
    return entry


def cmd_status(args: argparse.Namespace) -> None:
    """Report stored / computed / drift status for one or all WPs.

    Read-only. Uses ``compute_wp_status`` for the computed view. The
    stored view is the INDEX.md cell. Drift is reported when the two
    disagree on a status in the computed-eligible set.

    Repo defaults from --repo or, when absent, the project's git
    ``origin`` (when --mode requires it). For --mode stored, --repo
    is optional (no API calls are made).
    """
    mode = args.mode
    if mode not in ("stored", "computed", "both"):
        emit_error(f"--mode must be stored|computed|both, got {mode!r}")

    paths = paths_from_args(args)
    if not paths.index_md.exists():
        emit_error(f"INDEX.md not found at {paths.index_md}")

    repo = args.repo or ""
    base_branch = args.base_branch or "dev"
    if mode != "stored" and not repo:
        emit_error(
            "--repo is required for --mode computed|both "
            "(format: OWNER/REPO)"
        )

    wps = parse_index_md(paths.index_md)
    by_id = {wp.id: wp for wp in wps}

    # ADR-001: resolve the branch-naming scope once for the whole command, so
    # the per-WP loop below makes no repeated change-context lookups. None when
    # run outside a change → legacy feat/... resolution.
    change_scope = current_change_scope(paths.repo_root)

    if args.wp:
        if args.wp not in by_id:
            emit_error(f"WP {args.wp} not found in INDEX.md")
        wp = by_id[args.wp]
        entry = _build_status_entry(
            wp.id, wp.status,
            paths=paths, repo=repo, base_branch=base_branch, mode=mode,
            change_scope=change_scope,
        )
        emit_ok(data=entry)
        return

    # --all
    entries: list[dict] = []
    for wp in wps:
        entry = _build_status_entry(
            wp.id, wp.status,
            paths=paths, repo=repo, base_branch=base_branch, mode=mode,
            change_scope=change_scope,
        )
        if args.show_disagreements_only and not entry.get("drift", False):
            continue
        entries.append(entry)

    emit_ok(data={
        "mode": mode,
        "base_branch": base_branch,
        "total_wps": len(wps),
        "reported": len(entries),
        "entries": entries,
    })


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Manage INDEX.md")
    sub = parser.add_subparsers(dest="subcommand", required=True)

    p_flip = sub.add_parser("flip-status", help="Change a WP's status (with check)")
    add_common_args(p_flip)
    p_flip.add_argument("--wp", required=True)
    p_flip.add_argument("--to", required=True, choices=_STATUS_CHOICES)
    p_flip.add_argument("--expected", default=None,
                        help="Expected current status (atomic check)")

    p_set = sub.add_parser("set-status", help="Force a WP's status (no check)")
    add_common_args(p_set)
    p_set.add_argument("--wp", required=True)
    p_set.add_argument("--to", required=True)

    p_list = sub.add_parser("list-ready", help="List ready WPs")
    add_common_args(p_list)

    p_config = sub.add_parser("read-config", help="Read Orchestrator Config")
    add_common_args(p_config)

    p_prop = sub.add_parser("propagate-blocked",
                            help="Mark transitively dependent WPs as dependency_blocked")
    add_common_args(p_prop)
    p_prop.add_argument("--wp", required=True, help="The blocked WP ID")

    p_add = sub.add_parser(
        "add-wp",
        help="Insert a new WP row into INDEX.md (idempotent: rejects duplicates)",
    )
    add_common_args(p_add)
    p_add.add_argument("--wp", required=True, help="The WP ID to add")
    p_add.add_argument(
        "--from-wp-file", action="store_true",
        help="Read fields from the WP file's frontmatter (recommended)",
    )
    p_add.add_argument("--title", default=None,
                       help="WP title (required if --from-wp-file is not set)")
    p_add.add_argument("--primitive", default=None,
                       help="Change primitive (required if --from-wp-file is not set)")
    p_add.add_argument(
        "--status", default="auto-draft", choices=_STATUS_CHOICES,
        help="Initial status (default: auto-draft)",
    )
    p_add.add_argument("--depends-on", default="",
                       help="Comma-separated dependsOn WP IDs (or empty)")
    p_add.add_argument("--blocks", default="",
                       help="Comma-separated blocks WP IDs (or empty)")
    p_add.add_argument("--token-estimate", default="?",
                       help="Token estimate cell value (default: ?)")
    p_add.add_argument("--tdd", default=None,
                       help="TDD § reference (default: —)")

    p_sync = sub.add_parser(
        "sync-auto-drafts",
        help="Scan work-packages/ for orphaned WP-AUTO-*.md files; "
             "add any missing from INDEX. Idempotent.",
    )
    add_common_args(p_sync)

    p_audit = sub.add_parser(
        "audit-contracts",
        help="Graph-level data-contract wiring check (#48 / CF-05): a "
             "cross-kind WP set must have a data-contract WP and route "
             "cross-kind deps through it. Fails on violation.",
    )
    add_common_args(p_audit)

    p_lint = sub.add_parser(
        "lint",
        help="Fail loudly (#60) if INDEX.md's WP table header drifted from "
             "the canonical `| ID | Title | Primitive | Status | Depends On "
             "| Blocks |` form. Run at decompose time so a drifted header "
             "fails surgically instead of vanishing silently mid-run-all.",
    )
    add_common_args(p_lint)

    # HD-008 — read-only computed-status view.
    p_status = sub.add_parser(
        "status",
        help="Report stored / computed / drift status (read-only; HD-008).",
    )
    add_common_args(p_status)
    p_status_grp = p_status.add_mutually_exclusive_group(required=True)
    p_status_grp.add_argument(
        "--wp", default=None,
        help="Report status for a single WP (returns one entry).",
    )
    p_status_grp.add_argument(
        "--all", dest="all_wps", action="store_true",
        help="Report status for every WP in INDEX.md.",
    )
    p_status.add_argument(
        "--mode", default="both",
        choices=["stored", "computed", "both"],
        help="stored: cache only (no network). computed: derived from "
             "origin + train-runs. both (default): stored + computed + "
             "drift flag.",
    )
    p_status.add_argument(
        "--repo", default=None,
        help="GitHub OWNER/REPO slug (required for --mode computed|both).",
    )
    p_status.add_argument(
        "--base-branch", default="dev",
        help="Branch to check merge-SHA reachability against (default: dev).",
    )
    p_status.add_argument(
        "--show-disagreements-only", action="store_true",
        help="With --all + --mode both, report only WPs where stored "
             "and computed disagree on a computed-eligible state.",
    )

    return parser


HANDLERS = {
    "flip-status": cmd_flip_status,
    "set-status": cmd_set_status,
    "list-ready": cmd_list_ready,
    "read-config": cmd_read_config,
    "propagate-blocked": cmd_propagate_blocked,
    "add-wp": cmd_add_wp,
    "sync-auto-drafts": cmd_sync_auto_drafts,
    "audit-contracts": cmd_audit_contracts,
    "lint": cmd_lint,
    "status": cmd_status,
}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
