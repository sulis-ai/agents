#!/usr/bin/env python3
"""sulis-emit-requirements — emit Requirement entities from an SRD file.

The CLI surface for the second entity emission (n=2). Pairs with
`sulis-emit-decision` (from CH-01KSWB). A single call emits N Requirement
entities — one per `**FR-NN: ...**` / `**NFR-NN: ...**` block detected.

Usage:
    sulis-emit-requirements --from-srd <path>
                            [--base-dir <dir>]
                            [--domain <domain>]
                            [--repo-root <dir>]

Defaults:
    --base-dir   <repo-root>/.brain/instances
    --domain     product-development
    --repo-root  `git rev-parse --show-toplevel` (or `cwd` if not a git repo)

Output (JSON to stdout, marketplace convention):
    success: {"ok": true, "data": {"from_srd", "count", "requirements": [...]}}
    failure: {"ok": false, "error": "<reason>"}

Each item in `requirements`: {"id", "path"} — the emitted entity id and
the on-disk `.jsonld` location.

Exit code: 0 on success (including 0-requirement SRDs); 1 on failure.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402
from _requirement_emission import emit_requirements_from_srd  # noqa: E402


def _resolve_repo_root(explicit: str | None) -> Path:
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _ok(data: dict) -> int:
    print(json.dumps({"ok": True, "data": data}, indent=2))
    return 0


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Emit Requirement entities from an SRD file.",
    )
    parser.add_argument(
        "--from-srd", required=True,
        help="path to the SRD markdown file",
    )
    parser.add_argument(
        "--base-dir",
        help="instance base directory (default: <repo-root>/.brain/instances)",
    )
    parser.add_argument(
        "--domain", default="product-development",
        help="entity-schema domain (default: product-development)",
    )
    parser.add_argument(
        "--repo-root",
        help="repo root (default: git toplevel, or cwd if not a git repo)",
    )
    args = parser.parse_args()

    srd_path = Path(args.from_srd).resolve()
    if not srd_path.exists():
        return _err(f"SRD not found: {srd_path}")

    repo_root = _resolve_repo_root(args.repo_root)
    base_dir = (
        Path(args.base_dir).resolve()
        if args.base_dir
        else repo_root / ".brain" / "instances"
    )

    adapter = LocalFileEntityAdapter(base_dir=base_dir, domain=args.domain)

    try:
        requirements = emit_requirements_from_srd(srd_path, adapter)
    except EntityValidationError as exc:
        return _err(str(exc))
    except FileNotFoundError as exc:
        return _err(str(exc))

    entries: list[dict] = []
    for req in requirements:
        ulid = req["id"].rsplit(":", 1)[-1]
        path = base_dir / args.domain / "requirement" / f"{ulid}.jsonld"
        entries.append({"id": req["id"], "path": str(path)})

    return _ok({
        "from_srd": str(srd_path),
        "count": len(entries),
        "requirements": entries,
    })


if __name__ == "__main__":
    sys.exit(main())
