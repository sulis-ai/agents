#!/usr/bin/env python3
"""sulis-emit-finding — emit Finding entity (single or bulk from register).

Modes:
  Single:  sulis-emit-finding --kind X --severity Y --summary "..." [--observed-in "..."]
  Bulk:    sulis-emit-finding --from-register <findings-register.md>

Defaults: domain=product-development, base-dir=<repo-root>/.brain/instances.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402
from _finding_emission import (  # noqa: E402
    emit_finding,
    emit_findings_from_register,
)


def _resolve_repo_root(explicit: str | None) -> Path:
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _ok(data: dict) -> int:
    print(json.dumps({"ok": True, "data": data}, indent=2))
    return 0


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(description="Emit a Finding entity (single or bulk).")
    parser.add_argument("--from-register", help="path to legacy findings-register.md (bulk mode)")
    parser.add_argument("--kind", help="finding kind (single mode)")
    parser.add_argument("--severity", help="finding severity (single mode)")
    parser.add_argument("--summary", help="finding summary (single mode)")
    parser.add_argument("--observed-in", default="", help="locator: file:line / URL / component id")
    parser.add_argument("--base-dir")
    parser.add_argument("--domain", default="product-development")
    parser.add_argument("--repo-root")
    args = parser.parse_args()

    repo_root = _resolve_repo_root(args.repo_root)
    base_dir = Path(args.base_dir).resolve() if args.base_dir else repo_root / ".brain" / "instances"
    adapter = LocalFileEntityAdapter(base_dir=base_dir, domain=args.domain)

    findings: list[dict] = []
    try:
        if args.from_register:
            register_path = Path(args.from_register).resolve()
            if not register_path.exists():
                return _err(f"register not found: {register_path}")
            findings = emit_findings_from_register(register_path, adapter)
        else:
            if not (args.kind and args.severity and args.summary):
                return _err("single mode requires --kind, --severity, --summary")
            findings = [emit_finding(
                repo=adapter,
                kind=args.kind,
                severity=args.severity,
                summary=args.summary,
                observed_in=args.observed_in,
            )]
    except ValueError as exc:
        return _err(str(exc))
    except EntityValidationError as exc:
        return _err(str(exc))
    except FileNotFoundError as exc:
        return _err(str(exc))

    entries = [
        {"id": f["id"], "path": str(base_dir / args.domain / "finding" / f"{f['id'].rsplit(':', 1)[-1]}.jsonld")}
        for f in findings
    ]
    return _ok({"count": len(entries), "entities": entries})


if __name__ == "__main__":
    sys.exit(main())
