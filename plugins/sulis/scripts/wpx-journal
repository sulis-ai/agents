#!/usr/bin/env python3
"""wpx-journal — manage the per-WP executor journal.

The journal lives at .architecture/<project>/work-packages/.executor-<wp>.md
and tracks step transitions, self-heal attempts, pre-flight checks, the
executor's Step 1.5 plan, and post-deploy verification per WP.

Subcommands:
  init                  Create a new journal for a WP.
  start-step            Record the start of a lifecycle step.
  complete-step         Record the completion of a lifecycle step.
  record-attempt        Record a self-heal attempt + outcome.
  record-preflight      Record a pre-flight tooling check + status.
  record-postdeploy     Record post-deploy verification verdict.
  seed-plan             Populate the Step 1.5 plan from --approach + --plan-json.
  mark-plan-item        Flip a plan item's status (with atomic --expected check).
  add-plan-item         Append a new plan item mid-run.
  read                  Read a specific field/section from the journal.

All subcommands take --wp WP-NNN and --project <slug>.

Exit codes: 0 success, 1 user/data error, 2 internal error.
"""

from __future__ import annotations

import argparse
import sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
from _wpxlib import (  # noqa: E402
    MdTable,
    WpxPaths,
    add_common_args,
    cli_main,
    emit_error,
    emit_ok,
    find_section,
    parse_md_table,
    paths_from_args,
    replace_section,
)


JOURNAL_TEMPLATE = """\
# Executor journal — {wp}

> Started: {started}
> Lifecycle step: 1
> Status: in_progress

## Pre-flight checks

| Tool / Check | Status | Fallback |
|---|---|---|

## Plan

**Approach.** (Not yet seeded. The executor's Step 1.5 calls
`wpx-journal seed-plan` with an approach summary and a structured
item list before Step 2 begins.)

| # | Item | Step | Status | Notes |
|---:|---|---|---|---|

## Step trace

| Step | Started | Completed | Outcome |
|---:|---|---|---|

## Self-heal attempts

| Step | Attempt | Failure (1-line summary) | Root cause | Change applied | Outcome |
|---:|---:|---|---|---|---|

## Post-deploy verification

(Not yet recorded — Step 11 fills this in.)

## Notes

"""


# Plan item status enum (validated by mark-plan-item and add-plan-item).
PLAN_STATUSES = ("pending", "in-progress", "done", "skipped")


def _now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _read_journal(paths: WpxPaths, wp: str) -> str:
    j = paths.journal(wp)
    if not j.exists():
        raise FileNotFoundError(f"Journal not found: {j}")
    return j.read_text(encoding="utf-8")


def _write_journal(paths: WpxPaths, wp: str, text: str) -> None:
    j = paths.journal(wp)
    j.parent.mkdir(parents=True, exist_ok=True)
    j.write_text(text, encoding="utf-8")


# ────────────────────────────────────────────────────────────────────────


def _format_step(step: float) -> str:
    """Render a step number without trailing .0 for integer values.

    The --step argument accepts float (v0.20.1+) so half-steps like 6.5
    work for the executor's code-review gate. Integer values must still
    render as "6", not "6.0", to match existing journal entries written
    before the float migration.
    """
    if step == int(step):
        return str(int(step))
    return str(step)


def _read_step_trace(text: str) -> MdTable:
    """Read the ## Step trace section's table.

    Returns a populated MdTable when rows exist, or an empty-but-shaped
    table otherwise. Shared by every step-trace-dependent command so they
    parse the trace identically.
    """
    start, end = find_section(text, "## Step trace")
    section = text[start:end]
    table_text = "\n".join(
        ln for ln in section.splitlines()[1:] if ln.startswith("|")
    )
    if table_text.strip():
        return parse_md_table(table_text)
    return MdTable(
        headers=["Step", "Started", "Completed", "Outcome"],
        alignments=["---:", "---", "---", "---"],
        rows=[],
    )


def _find_step_row(table: MdTable, step: float) -> list[str] | None:
    """Return the trace row whose first cell matches `step`, or None."""
    target = _format_step(step)
    for row in table.rows:
        if row and row[0].strip() == target:
            return row
    return None


def _require_step_started(table: MdTable, step: float) -> list[str]:
    """Return the trace row for `step`, or fail loudly if it is missing.

    Every step-trace-dependent command (complete-step, record-attempt)
    presumes a prior `start-step --step N` row. A skipped `start-step`
    means the executor's journal bookkeeping silently drifted; surfacing
    it the moment the next dependent call runs (rather than pages later,
    or never) is the point of #63. Single shared check — never duplicated
    per command — so the loud-failure behaviour stays consistent.
    """
    row = _find_step_row(table, step)
    if row is None:
        emit_error(
            f"Step {_format_step(step)} not started in journal. "
            f"Call `start-step --step {_format_step(step)}` first."
        )
    return row  # type: ignore[return-value]  # emit_error sys.exits on None


def cmd_init(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    j = paths.journal(args.wp)
    if j.exists() and not args.force:
        emit_error(
            f"Journal already exists: {j}. Use --force to overwrite.",
            context={"path": str(j)},
        )
    text = JOURNAL_TEMPLATE.format(wp=args.wp, started=_now())
    _write_journal(paths, args.wp, text)
    emit_ok(data={"path": str(j)})


def cmd_start_step(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    text = _read_journal(paths, args.wp)
    # Find the Step trace table and add a new row with Started timestamp.
    start, end = find_section(text, "## Step trace")
    table = _read_step_trace(text)
    # Refuse a duplicate start for the same step.
    if _find_step_row(table, args.step) is not None:
        emit_error(
            f"Step {args.step} already started in journal "
            f"(row found in Step trace)."
        )
    table.rows.append([_format_step(args.step), _now(), "(in flight)", "—"])
    new_section = "## Step trace\n\n" + table.render() + "\n\n"
    text = text[:start] + new_section + text[end:]
    # Also update the "Lifecycle step:" header line
    text = _update_header(text, "Lifecycle step", _format_step(args.step))
    _write_journal(paths, args.wp, text)
    emit_ok(data={"wp": args.wp, "step": args.step, "started_at": _now()})


def cmd_complete_step(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    text = _read_journal(paths, args.wp)
    start, end = find_section(text, "## Step trace")
    table = _read_step_trace(text)
    # Fail loudly if the prerequisite start-step row is missing.
    row = _require_step_started(table, args.step)
    row[2] = _now()
    row[3] = args.outcome
    new_section = "## Step trace\n\n" + table.render() + "\n\n"
    text = text[:start] + new_section + text[end:]
    _write_journal(paths, args.wp, text)
    emit_ok(data={"wp": args.wp, "step": args.step, "completed_at": _now()})


def cmd_record_attempt(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    text = _read_journal(paths, args.wp)
    # A self-heal attempt presumes the step it heals was started. Fail
    # loudly if the prerequisite start-step row is missing, consistent
    # with complete-step (#63) — an orphan attempt row is a silent
    # journal-drift signal we never want to write.
    _require_step_started(_read_step_trace(text), args.step)
    start, end = find_section(text, "## Self-heal attempts")
    section = text[start:end]
    table_text = "\n".join(
        ln for ln in section.splitlines()[1:] if ln.startswith("|")
    )
    table = parse_md_table(table_text) if table_text.strip() else MdTable(
        headers=[
            "Step", "Attempt", "Failure (1-line summary)",
            "Root cause", "Change applied", "Outcome",
        ],
        alignments=["---:", "---:", "---", "---", "---", "---"],
        rows=[],
    )
    table.rows.append([
        _format_step(args.step), str(args.attempt), args.failure,
        args.root_cause, args.change, args.outcome,
    ])
    new_section = "## Self-heal attempts\n\n" + table.render() + "\n\n"
    text = text[:start] + new_section + text[end:]
    _write_journal(paths, args.wp, text)
    emit_ok(data={"wp": args.wp, "step": args.step, "attempt": args.attempt})


def cmd_record_preflight(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    text = _read_journal(paths, args.wp)
    start, end = find_section(text, "## Pre-flight checks")
    section = text[start:end]
    table_text = "\n".join(
        ln for ln in section.splitlines()[1:] if ln.startswith("|")
    )
    table = parse_md_table(table_text) if table_text.strip() else MdTable(
        headers=["Tool / Check", "Status", "Fallback"],
        alignments=["---", "---", "---"],
        rows=[],
    )
    table.rows.append([args.tool, args.status, args.fallback or "—"])
    new_section = "## Pre-flight checks\n\n" + table.render() + "\n\n"
    text = text[:start] + new_section + text[end:]
    _write_journal(paths, args.wp, text)
    emit_ok(data={"wp": args.wp, "tool": args.tool, "status": args.status})


def cmd_record_postdeploy(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    text = _read_journal(paths, args.wp)
    new_section_body = f"""\
Security-reviewer verdict: {args.verdict}
Recorded at: {_now()}
"""
    if args.findings_json:
        new_section_body += f"\nFindings detail (JSON):\n```json\n{args.findings_json}\n```\n"
    text = replace_section(text, "## Post-deploy verification", "\n" + new_section_body + "\n")
    _write_journal(paths, args.wp, text)
    emit_ok(data={"wp": args.wp, "verdict": args.verdict})


def _read_plan_table(text: str) -> MdTable:
    """Read the ## Plan section's item table (without the approach paragraph)."""
    start, end = find_section(text, "## Plan")
    table_text = "\n".join(
        ln for ln in text[start:end].splitlines() if ln.startswith("|")
    )
    if table_text.strip():
        return parse_md_table(table_text)
    return MdTable(
        headers=["#", "Item", "Step", "Status", "Notes"],
        alignments=["---:", "---", "---", "---", "---"],
        rows=[],
    )


def _read_plan_approach(text: str) -> str:
    """Return the approach paragraph (the **Approach.** line + any trailing prose)."""
    start, end = find_section(text, "## Plan")
    section = text[start:end]
    # Take everything between the heading line and the first '|' table line
    lines_after_heading = section.split("\n", 1)[1] if "\n" in section else ""
    approach_lines: list[str] = []
    for ln in lines_after_heading.splitlines():
        if ln.startswith("|"):
            break
        approach_lines.append(ln)
    return "\n".join(approach_lines).strip()


def _write_plan_section(text: str, approach: str, table: MdTable) -> str:
    """Replace the ## Plan section with a fresh approach + table."""
    body = f"\n**Approach.** {approach}\n\n" + table.render() + "\n\n"
    return replace_section(text, "## Plan", body)


def cmd_seed_plan(args: argparse.Namespace) -> None:
    import json as _json
    paths = paths_from_args(args)
    text = _read_journal(paths, args.wp)

    # Disallow re-seeding when items already exist (use add-plan-item or
    # mark-plan-item for incremental changes; --force overrides for testing).
    existing = _read_plan_table(text)
    if existing.rows and not args.force:
        emit_error(
            f"Plan already seeded ({len(existing.rows)} items). "
            f"Use mark-plan-item / add-plan-item for incremental changes, "
            f"or pass --force to re-seed."
        )

    # Parse --plan-json (literal JSON, or @/path/to/file.json)
    raw = args.plan_json
    if raw.startswith("@"):
        raw = Path(raw[1:]).read_text(encoding="utf-8")
    try:
        items = _json.loads(raw)
    except _json.JSONDecodeError as e:
        emit_error(f"Invalid --plan-json: {e}")
        return  # for type-checker; emit_error sys.exits

    if not isinstance(items, list) or not items:
        emit_error("--plan-json must be a non-empty JSON list of item objects.")

    table = MdTable(
        headers=["#", "Item", "Step", "Status", "Notes"],
        alignments=["---:", "---", "---", "---", "---"],
        rows=[],
    )
    for idx, raw_item in enumerate(items, start=1):
        if not isinstance(raw_item, dict):
            emit_error(f"--plan-json item {idx} is not an object: {raw_item!r}")
        desc = raw_item.get("description")
        step = raw_item.get("step")
        notes = raw_item.get("notes", "")
        if not desc or not step:
            emit_error(
                f"--plan-json item {idx} missing 'description' or 'step': "
                f"{raw_item!r}"
            )
        # Escape | characters in cells so they don't break the Markdown table
        desc_cell = str(desc).replace("|", "\\|")
        step_cell = str(step).replace("|", "\\|")
        notes_cell = str(notes).replace("|", "\\|") if notes else "—"
        table.rows.append([str(idx), desc_cell, step_cell, "pending", notes_cell])

    text = _write_plan_section(text, args.approach, table)
    _write_journal(paths, args.wp, text)
    emit_ok(data={
        "wp": args.wp,
        "approach": args.approach,
        "item_count": len(table.rows),
    })


def cmd_mark_plan_item(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    text = _read_journal(paths, args.wp)
    table = _read_plan_table(text)
    if not table.rows:
        emit_error(
            "Plan is empty. Call `seed-plan` first before `mark-plan-item`."
        )

    if args.status not in PLAN_STATUSES:
        emit_error(
            f"Invalid --status '{args.status}'. "
            f"Must be one of: {', '.join(PLAN_STATUSES)}"
        )

    found = False
    for row in table.rows:
        if row and row[0].strip() == str(args.item):
            current = row[3].strip()
            if args.expected and current != args.expected:
                emit_error(
                    f"Plan item {args.item} status is '{current}', "
                    f"expected '{args.expected}'."
                )
            row[3] = args.status
            if args.notes:
                # Replace Notes column (escape pipes)
                row[4] = args.notes.replace("|", "\\|")
            found = True
            break
    if not found:
        emit_error(f"Plan item {args.item} not found in journal.")

    approach = _read_plan_approach(text).removeprefix("**Approach.**").strip()
    text = _write_plan_section(text, approach, table)
    _write_journal(paths, args.wp, text)
    emit_ok(data={
        "wp": args.wp, "item": args.item, "status": args.status,
    })


def cmd_add_plan_item(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    text = _read_journal(paths, args.wp)
    table = _read_plan_table(text)
    # Next item ID = max existing + 1 (or 1 if empty)
    existing_ids = []
    for row in table.rows:
        try:
            existing_ids.append(int(row[0].strip()))
        except (ValueError, IndexError):
            continue
    next_id = max(existing_ids) + 1 if existing_ids else 1

    desc_cell = args.description.replace("|", "\\|")
    step_cell = args.step.replace("|", "\\|")
    notes_cell = (args.notes or "—").replace("|", "\\|")
    table.rows.append([str(next_id), desc_cell, step_cell, "pending", notes_cell])

    approach = _read_plan_approach(text).removeprefix("**Approach.**").strip()
    text = _write_plan_section(text, approach, table)
    _write_journal(paths, args.wp, text)
    emit_ok(data={
        "wp": args.wp, "item": next_id, "description": args.description,
        "step": args.step, "status": "pending",
    })


def cmd_read(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    text = _read_journal(paths, args.wp)

    field = args.field

    # Header fields
    if field in ("status", "lifecycle-step", "started"):
        value = _read_header(text, field.replace("-", " ").title()
                             if field == "lifecycle-step" else field.title())
        emit_ok(data={"field": field, "value": value})

    # Step-N status (returns 'in_progress', 'completed', or 'not_started')
    if field.startswith("step-") and field.endswith("-status"):
        step_num = field.removeprefix("step-").removesuffix("-status")
        start, end = find_section(text, "## Step trace")
        table_text = "\n".join(
            ln for ln in text[start:end].splitlines()[1:] if ln.startswith("|")
        )
        table = parse_md_table(table_text)
        for row in table.rows:
            if row and row[0].strip() == step_num:
                if row[2].strip() in ("(in flight)", "—", ""):
                    emit_ok(data={"field": field, "value": "in_progress"})
                emit_ok(data={
                    "field": field, "value": "completed",
                    "completed_at": row[2].strip(),
                    "outcome": row[3].strip() if len(row) > 3 else "",
                })
        emit_ok(data={"field": field, "value": "not_started"})

    # Step trace, all rows
    if field == "step-trace":
        start, end = find_section(text, "## Step trace")
        table_text = "\n".join(
            ln for ln in text[start:end].splitlines()[1:] if ln.startswith("|")
        )
        table = parse_md_table(table_text)
        rows = []
        for row in table.rows:
            if len(row) >= 4:
                rows.append({
                    "step": row[0].strip(),
                    "started": row[1].strip(),
                    "completed": row[2].strip(),
                    "outcome": row[3].strip(),
                })
        emit_ok(data={"field": field, "value": rows})

    # Post-deploy verification (full section body)
    if field == "post-deploy-verification":
        start, end = find_section(text, "## Post-deploy verification")
        section_body = text[start:end].split("\n", 1)[1].strip()
        emit_ok(data={"field": field, "value": section_body})

    # Pre-flight checks
    if field == "preflight":
        start, end = find_section(text, "## Pre-flight checks")
        table_text = "\n".join(
            ln for ln in text[start:end].splitlines()[1:] if ln.startswith("|")
        )
        table = parse_md_table(table_text)
        rows = []
        for row in table.rows:
            if len(row) >= 3:
                rows.append({
                    "tool": row[0].strip(),
                    "status": row[1].strip(),
                    "fallback": row[2].strip(),
                })
        emit_ok(data={"field": field, "value": rows})

    # Plan (approach + structured items)
    if field == "plan":
        table = _read_plan_table(text)
        approach_raw = _read_plan_approach(text)
        # Strip the **Approach.** prefix if present
        approach = approach_raw
        if approach.startswith("**Approach.**"):
            approach = approach[len("**Approach.**"):].strip()
        items = []
        for row in table.rows:
            if len(row) >= 4:
                items.append({
                    "item": row[0].strip(),
                    "description": row[1].strip().replace("\\|", "|"),
                    "step": row[2].strip().replace("\\|", "|"),
                    "status": row[3].strip(),
                    "notes": (row[4].strip().replace("\\|", "|")
                              if len(row) > 4 else ""),
                })
        emit_ok(data={
            "field": field,
            "value": {"approach": approach, "items": items},
        })

    emit_error(f"Unknown field: {field}")


# ────────────────────────────────────────────────────────────────────────


def _update_header(text: str, header_name: str, value: str) -> str:
    import re
    pattern = re.compile(rf"^(>\s*{re.escape(header_name)}:\s*).*$", re.MULTILINE)
    if pattern.search(text):
        return pattern.sub(rf"\g<1>{value}", text, count=1)
    return text


def _read_header(text: str, header_name: str) -> str:
    import re
    pattern = re.compile(rf"^>\s*{re.escape(header_name)}:\s*(.*)$", re.MULTILINE)
    match = pattern.search(text)
    return match.group(1).strip() if match else ""


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Manage the per-WP executor journal."
    )
    sub = parser.add_subparsers(dest="subcommand", required=True)

    p_init = sub.add_parser("init", help="Create a new journal")
    add_common_args(p_init)
    p_init.add_argument("--wp", required=True)
    p_init.add_argument("--force", action="store_true",
                        help="Overwrite existing journal")

    p_start = sub.add_parser("start-step", help="Record start of a step")
    add_common_args(p_start)
    p_start.add_argument("--wp", required=True)
    # v0.20.1+: accept float (e.g. 6.5) for half-steps. Was type=int —
    # which rejected --step 6.5 with an unfriendly argparse error and
    # may have driven executors to skip /code-review (Step 6.5) entirely.
    p_start.add_argument("--step", required=True, type=float)

    p_complete = sub.add_parser("complete-step", help="Record completion of a step")
    add_common_args(p_complete)
    p_complete.add_argument("--wp", required=True)
    p_complete.add_argument("--step", required=True, type=float)
    p_complete.add_argument("--outcome", required=True,
                            help="One-line outcome (e.g. 'success: 3 tests')")

    p_attempt = sub.add_parser("record-attempt",
                               help="Record a self-heal attempt")
    add_common_args(p_attempt)
    p_attempt.add_argument("--wp", required=True)
    p_attempt.add_argument("--step", required=True, type=float)
    p_attempt.add_argument("--attempt", required=True, type=int)
    p_attempt.add_argument("--failure", required=True,
                           help="One-line failure summary")
    p_attempt.add_argument("--root-cause", required=True)
    p_attempt.add_argument("--change", required=True,
                           help="Change applied")
    p_attempt.add_argument("--outcome", required=True,
                           help="passed | still-failing")

    p_preflight = sub.add_parser("record-preflight",
                                 help="Record a pre-flight tooling check")
    add_common_args(p_preflight)
    p_preflight.add_argument("--wp", required=True)
    p_preflight.add_argument("--tool", required=True,
                             help="Tool name (e.g. 'gh', 'coverage')")
    p_preflight.add_argument("--status", required=True,
                             help="present | absent")
    p_preflight.add_argument("--fallback", default=None,
                             help="Fallback strategy if absent")

    p_postdeploy = sub.add_parser("record-postdeploy",
                                  help="Record Step 11 post-deploy verification")
    add_common_args(p_postdeploy)
    p_postdeploy.add_argument("--wp", required=True)
    p_postdeploy.add_argument("--verdict", required=True,
                              help="PASS | N CONCERN | N ADVISORY | CRITICAL")
    p_postdeploy.add_argument("--findings-json", default=None,
                              help="Optional JSON blob with detailed findings")

    p_seed = sub.add_parser("seed-plan",
                            help="Populate the Step 1.5 plan section")
    add_common_args(p_seed)
    p_seed.add_argument("--wp", required=True)
    p_seed.add_argument("--approach", required=True,
                        help="2-3 sentence summary of the executor's mental model")
    p_seed.add_argument("--plan-json", required=True,
                        help="JSON list of item objects {description, step, "
                             "notes?} or @/path/to/file.json")
    p_seed.add_argument("--force", action="store_true",
                        help="Re-seed even if items already exist (testing)")

    p_mark = sub.add_parser("mark-plan-item",
                            help="Flip a plan item's status")
    add_common_args(p_mark)
    p_mark.add_argument("--wp", required=True)
    p_mark.add_argument("--item", required=True, type=int,
                        help="Item number (1-indexed)")
    p_mark.add_argument("--status", required=True,
                        choices=list(PLAN_STATUSES),
                        help="pending | in-progress | done | skipped")
    p_mark.add_argument("--expected", default=None,
                        help="Atomic check: expected current status")
    p_mark.add_argument("--notes", default=None,
                        help="Overwrite the Notes column (optional)")

    p_add = sub.add_parser("add-plan-item",
                           help="Append a new plan item mid-run")
    add_common_args(p_add)
    p_add.add_argument("--wp", required=True)
    p_add.add_argument("--description", required=True,
                       help="Plan item description")
    p_add.add_argument("--step", required=True,
                       help="Step assignment (e.g. '2 (RED)', '3 (GREEN)')")
    p_add.add_argument("--notes", default=None,
                       help="Optional Notes column value")

    p_read = sub.add_parser("read", help="Read a field from the journal")
    add_common_args(p_read)
    p_read.add_argument("--wp", required=True)
    p_read.add_argument("--field", required=True,
                        help="status | lifecycle-step | step-trace | "
                             "step-N-status | post-deploy-verification | "
                             "preflight | plan")

    return parser


HANDLERS = {
    "init": cmd_init,
    "start-step": cmd_start_step,
    "complete-step": cmd_complete_step,
    "record-attempt": cmd_record_attempt,
    "record-preflight": cmd_record_preflight,
    "record-postdeploy": cmd_record_postdeploy,
    "seed-plan": cmd_seed_plan,
    "mark-plan-item": cmd_mark_plan_item,
    "add-plan-item": cmd_add_plan_item,
    "read": cmd_read,
}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
