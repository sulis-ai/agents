#!/usr/bin/env python3
"""sulis-verify-acceptance — run a change's verification Scenarios against a
standing app, and report plain green/red.

The founder-runnable front door to the testable-state gate. Given a Scenario
and a target (local | deployed), it stands the journey's steps against the app
and reports whether each passed — in plain English a non-technical founder
reads — plus a machine envelope.

Two journey sources: a hand-built `--bundle` JSON (the v1 input), or, with
`--scenario <id>`, loaded straight from the emitted brain graph (the Scenario
authored at `/sulis:specify` + emitted by `sulis-author-scenario`) — closing
the author → emit → run loop with no hand-built file.

Exit code: 0 = gate passes (every Scenario passed, or deferred-with-need);
1 = blocked (a step failed, or a manual check is unconfirmed); 2 = invocation
error (no target URL, unreadable bundle).

The target base URL + the local standup recipe come from the repo-contract
(`commands.standup`/`seed`, `targets.{local,deployed}`). Stdlib only (+ pyyaml
to read the contract). Python 3.11-safe.
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from _acceptance_gate import format_gate_message, gate_decision  # noqa: E402
from _run_contract import resolve_run_contract, target_url  # noqa: E402
from _scenario_graph_load import JourneyNotFound, load_scenario_journey  # noqa: E402
from _scenario_evidence import emit_scenario_evidence  # noqa: E402
from _scenario_runner import (  # noqa: E402
    format_founder_summary,
    run_bundle,
    run_scenario,
)
from _scenario_runtime import driver_for_step  # noqa: E402  (#171)


def _journey_needs_target_url(
    steps_by_id: dict, tools_by_id: dict, ordered_step_ids: list,
) -> bool:
    """True iff any step in the ordered journey resolves to ``http_call``.

    #171 — a scenario whose every step is a subprocess (or human, or no-op)
    needs no HTTP target URL. Before, the acceptance gate refused to run on
    a no-app repo (plugin / library / published-artifact) with no
    ``targets.local`` even when the journey never dereferenced one. Only
    require the URL when at least one step's driver is ``http_call``.
    """
    for sid in ordered_step_ids:
        step = steps_by_id.get(sid)
        if step is None:
            continue
        if driver_for_step(step, tools_by_id) == "http_call":
            return True
    return False


def _read_repo_contract(repo_root: str) -> dict:
    path = Path(repo_root) / ".sulis" / "repo-contract.yml"
    if not path.is_file():
        return {}
    try:
        import yaml

        return yaml.safe_load(path.read_text(encoding="utf-8")) or {}
    except Exception:
        return {}


def main(argv=None) -> int:
    p = argparse.ArgumentParser(
        prog="sulis-verify-acceptance",
        description="Run a change's verification Scenarios against a standing app.",
    )
    src = p.add_mutually_exclusive_group(required=True)
    src.add_argument("--bundle",
                     help="JSON bundle: {scenario, workflow, steps[], tools[]} (v1 input)")
    src.add_argument("--scenario",
                     help="scenario id to load from the brain graph (--from-graph mode)")
    p.add_argument("--base-dir",
                   help="brain store dir for --scenario (default {repo-root}/.brain/instances)")
    p.add_argument("--target", default="local", choices=["local", "deployed"],
                   help="which leg to run against (default: local)")
    p.add_argument("--repo-root", default=".",
                   help="repo root holding .sulis/repo-contract.yml (targets + standup)")
    p.add_argument("--available-artifacts", default="",
                   help="comma list of available needs/credentials (others defer)")
    p.add_argument("--json", action="store_true", help="emit the machine envelope")
    p.add_argument("--no-emit-evidence", dest="emit_evidence", action="store_false",
                   help="don't deposit a TestRun/TestResult for this run "
                        "(--scenario mode only; default: emit so the "
                        "requirement-coverage gate sees the Scenario route)")
    p.set_defaults(emit_evidence=True)
    p.add_argument("--allow-deferred", action="store_true",
                   help="allow a `deferred` Scenario (real outcome not driven) to "
                        "PASS rather than BLOCK. Default OFF: observed-or-blocked. "
                        "Use ONLY for a consciously non-user-facing Scenario where a "
                        "recorded, non-blocking gap is the honest call.")
    args = p.parse_args(argv)

    # Resolve the journey source: a hand-built bundle, or the emitted brain graph.
    bundle = None
    loaded = None
    if args.bundle:
        try:
            bundle = json.loads(Path(args.bundle).read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as exc:
            print(f"Couldn't read the Scenario bundle: {exc}", file=sys.stderr)
            return 2
    else:
        base_dir = Path(args.base_dir) if args.base_dir else Path(args.repo_root) / ".brain" / "instances"
        try:
            loaded = load_scenario_journey(base_dir, args.scenario)
        except JourneyNotFound as exc:
            print(f"Couldn't load the Scenario from the brain graph: {exc}", file=sys.stderr)
            return 2
        if loaded.missing_steps:
            # drift: a journey step referenced by the workflow isn't in the store.
            # Surface it (it also runs as 'unresolved' → the verdict won't fake green).
            print(
                "⚠ This journey references steps that aren't in the brain store "
                f"(out of date): {', '.join(loaded.missing_steps)}",
                file=sys.stderr,
            )

    # Resolve the journey's step/tool lookup tables BEFORE the target-URL
    # check so we can ask whether the journey actually needs one (#171).
    if bundle is not None:
        steps_by_id = {s.get("@id"): s for s in (bundle.get("steps") or [])}
        tools_by_id = {t.get("@id"): t for t in (bundle.get("tools") or [])}
        ordered_step_ids = (bundle.get("workflow") or {}).get("steps", []) or []
    else:
        steps_by_id = loaded.steps_by_name
        tools_by_id = loaded.tools_by_id
        ordered_step_ids = (loaded.workflow or {}).get("steps", []) or []
    needs_url = _journey_needs_target_url(steps_by_id, tools_by_id, ordered_step_ids)

    rc = resolve_run_contract(_read_repo_contract(args.repo_root))
    base = target_url(rc, args.target)
    if needs_url and not base:
        print(
            f"No '{args.target}' target URL in the repo-contract "
            f"(targets.{args.target}). Add it (and a commands.standup recipe), "
            f"or run the other leg.",
            file=sys.stderr,
        )
        return 2
    # When no step needs an HTTP target, the runner is happy with an empty
    # base URL — subprocess and human drivers never dereference it.
    base = base or ""

    available = frozenset(
        a.strip() for a in args.available_artifacts.split(",") if a.strip()
    )
    if bundle is not None:
        result = run_bundle(bundle, target_base_url=base, available_artifacts=available)
    else:
        result = run_scenario(
            loaded.scenario, loaded.workflow, loaded.steps_by_name, loaded.tools_by_id,
            target_base_url=base, available_artifacts=available,
        )
    decision = gate_decision([result], require_observed=not args.allow_deferred)

    # Deposit the verification evidence so the requirement-coverage gate sees
    # the Scenario route. Best-effort: an emission failure NEVER changes the
    # verdict or the exit code — a run that proved green stays green even if
    # the brain store is unwritable. Only in --scenario mode (we have a
    # scenario entity + a brain store to write to).
    evidence = None
    if loaded is not None and args.emit_evidence:
        try:
            evidence = emit_scenario_evidence(
                base_dir=base_dir, scenario=loaded.scenario, verdict=result.verdict,
            )
        except Exception as exc:  # noqa: BLE001 — evidence is advisory, never fatal
            print(f"⚠ Couldn't record this run's verification evidence: {exc}",
                  file=sys.stderr)

    if args.json:
        print(json.dumps({
            "scenario": result.scenario_name,
            "verdict": result.verdict,
            "gate": decision.verdict,
            "steps": result.steps,
            "deferred_needs": decision.deferred_needs,
            "blocking": decision.blocking,
            "evidence": evidence,
        }, ensure_ascii=False))
    else:
        print(format_founder_summary(result))
        print(format_gate_message(decision))

    return 0 if decision.verdict == "pass" else 1


if __name__ == "__main__":
    sys.exit(main())
