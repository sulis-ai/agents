#!/usr/bin/env python3
"""wpx-pipeline — run Steps 8-10 (CI poll + merge + deploy poll + health + smoke).

Designed to be invoked by the CALLING SESSION via Bash(run_in_background:true)
— this is the script that owns all the long-running waiting (CI 45m + deploy
30m + health 10m). The calling session blocks on the harness notification when
the script exits.

Subcommands:
  run                   Full pipeline: CI poll → rebase-if-needed → merge → deploy poll → health → smoke.

Outputs structured JSON to stdout on completion (one line, the final `result`
key). Exit codes: 0 success, 1 deterministic blocker, 2 internal error.

Per-WP path. The per-batch sibling is `wpx-train` (sulis-execution v0.11.0+).
All shared shell / gh / poll / git helpers live in `_wpxlib.py`.
"""

from __future__ import annotations

import argparse
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
from _wpxlib import (  # noqa: E402
    CI_DEFAULT_CAP,
    CI_DEFAULT_INTERVAL,
    DEPLOY_DEFAULT_CAP,
    DEPLOY_DEFAULT_INTERVAL,
    HEALTH_DEFAULT_CAP,
    REBASE_BUDGET,
    _detect_branch_ci,
    _extract_health_path_from_smoke,
    _gh_branch_already_merged,
    _gh_ref_sha,
    _join_health_url,
    _log,
    _merge_squash,
    _poll_ci,
    _poll_deploy,
    _poll_health,
    _rebase_on_dev,
    _run_smoke,
    add_common_args,
    back_integrate_change_branch,
    ff_local_change_branch_from_origin,
    cli_main,
    deploy_is_applicable,
    emit_internal_error,
    emit_result,
    paths_from_args,
    read_repo_contract,
)


# --- run subcommand ------------------------------------------------------

def cmd_run(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)

    repo = args.repo or os.environ.get("GITHUB_REPOSITORY")
    if not repo:
        emit_internal_error(
            RuntimeError("Could not determine GitHub repo (--repo or $GITHUB_REPOSITORY)")
        )

    worktree = Path(args.worktree_path).resolve() if args.worktree_path else paths.repo_root
    ci_interval = args.ci_poll_interval or CI_DEFAULT_INTERVAL
    deploy_interval = args.deploy_poll_interval or DEPLOY_DEFAULT_INTERVAL
    deploy_cap = args.deploy_cap or DEPLOY_DEFAULT_CAP
    base_branch = args.base_branch or "main"

    result: dict = {
        "wp": args.wp,
        "outcome": "pending",
        "merge_sha": None,
        "deploy_url": None,
        "deploy_workflow_run": None,
        "health_status": None,
        "smoke_verdict": None,
        "blocker_reason": None,
        "started_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    }

    # Step 8a: CI poll — auto-skip if no branch CI configured
    skip_ci_poll = args.skip_ci_poll
    if not skip_ci_poll and not _detect_branch_ci(worktree):
        _log(
            "WARNING: no branch-CI workflow detected in "
            ".github/workflows/ or .gitlab-ci.yml. Auto-skipping CI "
            "poll (otherwise wpx-pipeline would hang for "
            f"{CI_DEFAULT_CAP}s waiting for check-runs that will "
            "never appear). See plugins/sulis-execution/scripts/"
            "README.md#setting-up-branch-ci for the canonical "
            "workflow snippet."
        )
        skip_ci_poll = True
    result["ci_poll_skipped"] = skip_ci_poll

    try:
        # Step 0: arrival check (Phase 5 #3 — change-as-primitive build).
        # Per lifecycle.md Step 0 + CW-04 auto back-integration: if running
        # in a change context, ensure the change branch is current with dev
        # BEFORE the WP rebases onto it. Defence in depth (the active
        # driver is Step 12.5 after the last WP merged).
        # Skipped if not in a change context (--change-worktree-path unset,
        # or --base-branch doesn't start with "change/" — CW-05 trivial
        # carve-out).
        if args.change_worktree_path and base_branch.startswith("change/"):
            _log(f"Step 0: arrival check — back-integrating {base_branch} from origin/{base_branch}")
            arrival = back_integrate_change_branch(
                Path(args.change_worktree_path),
                base_branch,
                dev_ref="origin/main",
            )
            result["step_0_arrival_check"] = arrival["status"]
            if arrival["status"] == "merge_conflict":
                files_summary = ", ".join(arrival["files"][:3]) + (
                    f" (+ {len(arrival['files']) - 3} more)" if len(arrival["files"]) > 3 else ""
                )
                result.update(
                    outcome="blocker",
                    blocker_reason=(
                        f"Step 0: change branch back-integration conflict in {files_summary}. "
                        f"Per CW-04, do not auto-resolve — founder picks resolve / defer / abort."
                    ),
                )
                emit_result(result, exit_code=1)
            elif arrival["status"] in ("fetch_failed", "internal_error"):
                result.update(
                    outcome="blocker",
                    blocker_reason=f"Step 0 {arrival['status']}: {arrival.get('error', '')}",
                )
                emit_result(result, exit_code=1)
            elif arrival["status"] == "merged_ok":
                _log(f"Step 0: merged {arrival.get('merged_commits', '?')} commits from origin/{base_branch} into {base_branch}")
            else:
                _log(f"Step 0: {base_branch} already current with origin/{base_branch} (no-op)")
        else:
            result["step_0_arrival_check"] = "skipped"

        # Step 8a: CI poll
        if skip_ci_poll:
            _log("Step 8a: skipping CI poll (--skip-ci-poll or auto-detected absence)")
            verdict = "skipped"
        else:
            _log(f"Step 8a: polling CI for {args.branch}")
            verdict = _poll_ci(repo, args.branch, ci_interval, CI_DEFAULT_CAP)
        if verdict == "failed":
            result.update(outcome="blocker", blocker_reason="CI checks failed on branch HEAD")
            emit_result(result, exit_code=1)
        if verdict == "timeout":
            result.update(outcome="blocker", blocker_reason=f"CI did not complete within {CI_DEFAULT_CAP}s")
            emit_result(result, exit_code=1)
        # verdict in {"green", "skipped"} → proceed to rebase/merge

        # Step 8b: rebase if base_branch advanced (default "dev"; the change
        # branch when running inside a change worktree per CW-04)
        for attempt in range(REBASE_BUDGET):
            rebased, new_sha = _rebase_on_dev(
                repo, args.branch, worktree, args.dev_sha_at_creation,
                base_branch=base_branch,
            )
            if not rebased:
                break
            _log(f"Rebased onto {base_branch} (attempt {attempt+1})"
                 + ("" if skip_ci_poll else "; re-polling CI"))
            if skip_ci_poll:
                verdict = "skipped"
            else:
                verdict = _poll_ci(repo, args.branch, ci_interval, CI_DEFAULT_CAP)
            if verdict not in ("green", "skipped"):
                result.update(outcome="blocker",
                              blocker_reason=f"CI {verdict} after rebase attempt {attempt+1}")
                emit_result(result, exit_code=1)
            # update the cursor so the next rebase compares against current base
            args.dev_sha_at_creation = _gh_ref_sha(repo, base_branch)

        # Step 8c: squash-merge — but first check whether the branch is
        # already merged to dev (v0.10.5 Bug 1 fix). Re-running
        # wpx-pipeline on an already-merged branch previously crashed
        # with RuntimeError from _gh_merge (POST /merges → 409). The
        # compare API returns status="identical" / "behind" in that
        # case — skip the merge and proceed with the existing dev SHA.
        already_merged, base_sha = _gh_branch_already_merged(repo, args.branch, base=base_branch)
        if already_merged:
            _log(f"Step 8c: branch already merged to {base_branch}; using existing {base_branch} HEAD {base_sha[:8]} as merge SHA (skip merge step)")
            merge_sha = base_sha or args.dev_sha_at_creation
            result["merge_already_complete"] = True
        else:
            _log(f"Step 8c: squash-merging to {base_branch}")
            merge_sha = _merge_squash(repo, args.branch, args.wp,
                                      base_branch=base_branch)
        result["merge_sha"] = merge_sha

        # Step 8d: #141 fast-forward the LOCAL change worktree from
        # origin/<change_branch>. _merge_squash lands the squash commit on
        # origin via the GitHub API, but the local worktree (where this
        # session and the next agent — e.g. Step 11 security-review — read
        # files) is still at the pre-merge SHA. Without this FF the next
        # agent reads stale files and returns a false "CANNOT REVIEW"
        # verdict (CH-01KT48 trigger). Skip on the already-merged path
        # (the merge happened in a prior run; local state is the founder's
        # to reconcile) and skip when not shipping into a change branch.
        if (
            args.change_worktree_path
            and base_branch.startswith("change/")
            and not result.get("merge_already_complete")
        ):
            ff = ff_local_change_branch_from_origin(
                Path(args.change_worktree_path), base_branch,
            )
            result["step_8d_local_ff"] = ff["status"]
            if ff["status"] == "fast_forwarded":
                _log(
                    f"Step 8d: fast-forwarded {base_branch} by "
                    f"{ff.get('advanced_commits', '?')} commit(s) so post-"
                    f"merge agents read fresh files"
                )
            elif ff["status"] == "already_current":
                _log(f"Step 8d: {base_branch} already current with origin (no FF needed)")
            else:
                # Non-fatal: the merge already landed on origin, defence in
                # depth at next Step 0 reconciles. Log loudly so the
                # session can spot stale-tree symptoms.
                _log(
                    f"WARNING: Step 8d local FF returned {ff['status']!r}: "
                    f"{ff.get('error', '')}. The squash-merge already landed "
                    f"on origin/{base_branch}; subsequent agents reading the "
                    f"local worktree may see pre-merge files until reconciled."
                )
        else:
            result["step_8d_local_ff"] = "skipped"

        # Step 12.5: post-WP back-integration (Phase 5 #3 — change-as-primitive
        # build). Per lifecycle.md Step 12.5 + CW-04 auto back-integration:
        # AFTER the WP successfully merges into the change branch, back-
        # integrate the change branch from dev. This is the ACTIVE DRIVER
        # — keeps the change branch within one WP of dev.
        # Conflict here is non-blocking: the WP already merged successfully.
        # Surface the conflict as a warning and let the founder resolve at
        # next Step 0 (defence in depth).
        if args.change_worktree_path and base_branch.startswith("change/") and not result.get("merge_already_complete"):
            _log(f"Step 12.5: post-WP back-integration of {base_branch} from origin/{base_branch}")
            post_merge = back_integrate_change_branch(
                Path(args.change_worktree_path),
                base_branch,
                dev_ref="origin/main",
            )
            result["step_12_5_back_integration"] = post_merge["status"]
            if post_merge["status"] == "merge_conflict":
                files_summary = ", ".join(post_merge["files"][:3]) + (
                    f" (+ {len(post_merge['files']) - 3} more)" if len(post_merge["files"]) > 3 else ""
                )
                _log(
                    f"WARNING: Step 12.5 conflict in {files_summary}. The WP "
                    f"merged successfully, but the change branch is now stale. "
                    f"Founder action needed at next Step 0."
                )
                result["step_12_5_conflict_files"] = post_merge["files"]
            elif post_merge["status"] in ("fetch_failed", "internal_error"):
                _log(f"WARNING: Step 12.5 {post_merge['status']}: {post_merge.get('error', '')}. Continuing — defence in depth at next Step 0.")
            elif post_merge["status"] == "merged_ok":
                _log(f"Step 12.5: merged {post_merge.get('merged_commits', '?')} commits from origin/{base_branch} into {base_branch}")
            else:
                _log(f"Step 12.5: {base_branch} already current with origin/{base_branch} (no-op)")
        else:
            result["step_12_5_back_integration"] = "skipped"

        # Step 9: deploy poll — gated on the repo contract (L-05).
        # A published-artifact / internal-tool repo (or deploy_target: none)
        # has no staging deploy to poll; the merge IS the ship. A deployable
        # repo with no --deploy-workflow is a config error, not a skip.
        contract = read_repo_contract(paths.repo_root)
        deploy_applies = deploy_is_applicable(contract)
        if not deploy_applies:
            profile = contract.get("profile") or "non-deployable"
            _log(f"Step 9: deploy skipped — {profile} profile (no staging deploy)")
            result["deploy_status"] = f"skipped ({profile} profile)"
            result["deploy_url"] = None
        elif not args.deploy_workflow:
            result.update(
                outcome="blocker",
                blocker_reason=(
                    "Repo is deployable (per .sulis/repo-contract.yml) but no "
                    "--deploy-workflow was given. Pass --deploy-workflow, or "
                    "set profile: published-artifact / deploy_target: none if "
                    "this repo has no staging deploy."
                ),
            )
            emit_result(result, exit_code=1)
        else:
            _log(f"Step 9: polling deploy workflow '{args.deploy_workflow}' for {merge_sha[:8]}")
            deploy_verdict, deploy_url = _poll_deploy(
                repo, args.deploy_workflow, merge_sha,
                deploy_interval, deploy_cap,
            )
            result["deploy_url"] = deploy_url
            if deploy_verdict != "green":
                result.update(outcome="blocker", blocker_reason=f"Deploy {deploy_verdict}")
                emit_result(result, exit_code=1)

        # Step 10a: health check (runs only if a staging URL was supplied —
        # independent of the deploy gate, so a published-artifact repo can
        # still health-check a URL if one is passed).
        if args.staging_url:
            # Resolve health path (v0.10.7+):
            #   1. --health-path explicit flag wins
            #   2. else, extract path from --smoke-cmd URL if present
            #   3. else, fall back to "/" (backward-compatible)
            if args.health_path:
                health_path = args.health_path
                path_source = "--health-path flag"
            else:
                auto = _extract_health_path_from_smoke(args.smoke_cmd)
                if auto and auto != "/":
                    health_path = auto
                    path_source = "auto-detected from --smoke-cmd"
                else:
                    health_path = "/"
                    path_source = "default (root)"
            health_url = _join_health_url(args.staging_url, health_path)
            _log(f"Step 10a: health-checking {health_url} (path: {path_source})")
            health = _poll_health(health_url, HEALTH_DEFAULT_CAP)
            result["health_status"] = health
            result["health_url"] = health_url
            if health != "healthy":
                result.update(outcome="blocker",
                              blocker_reason=f"Staging health check failed within {HEALTH_DEFAULT_CAP}s at {health_url}")
                emit_result(result, exit_code=1)
        else:
            result["health_status"] = "skipped (no --staging-url)"

        # Step 10b: smoke test
        _log("Step 10b: running smoke test")
        smoke_verdict, smoke_output = _run_smoke(args.smoke_cmd or "", worktree)
        result["smoke_verdict"] = smoke_verdict
        if not smoke_verdict.startswith("PASS"):
            result.update(outcome="blocker", blocker_reason=f"Smoke test: {smoke_verdict}; {smoke_output}")
            emit_result(result, exit_code=1)

        result["outcome"] = "success"
        result["completed_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

        # Brain emission — LifecycleRun for the WP-pipeline completion.
        # Best-effort: a failure inside _brain_emit_helper (missing schemas
        # / unwritable .brain dir) MUST NOT unwind the successful pipeline.
        # Per-WP staging deploys are LifecycleRun events, not Deployment
        # entities — Deployments are Release × Environment, cut at
        # dev→main promotion not at per-WP CI.
        try:
            from _brain_emit_helper import emit_lifecycle_step_event
            emit_lifecycle_step_event(
                paths.repo_root,
                step_name=f"wpx-pipeline-success:{args.wp}",
                outcome="completed",
                at=result["completed_at"],
            )
        except Exception:
            pass  # belt-and-braces

        emit_result(result, exit_code=0)

    except RuntimeError as exc:
        result.update(outcome="error", blocker_reason=f"internal: {exc}")
        emit_result(result, exit_code=2)
    except Exception as exc:  # noqa: BLE001
        result.update(outcome="error", blocker_reason=f"unexpected: {type(exc).__name__}: {exc}")
        emit_result(result, exit_code=2)


# --- argparse ------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Steps 8-10 pipeline: CI poll + merge + deploy + health + smoke"
    )
    sub = parser.add_subparsers(dest="subcommand", required=True)

    p_run = sub.add_parser("run", help="Run the full pipeline")
    add_common_args(p_run)
    p_run.add_argument("--wp", required=True)
    p_run.add_argument("--branch", required=True)
    p_run.add_argument("--worktree-path", default=None,
                       help="Path to worktree (defaults to repo root)")
    p_run.add_argument("--dev-sha-at-creation", required=True,
                       help="origin/<base> SHA when worktree was created (from sidecar)")
    p_run.add_argument("--deploy-workflow", default=None,
                       help="Deploy workflow name (e.g. 'Deploy to Dev "
                            "Environment'). Required for a deployable-web-app "
                            "repo; omitted for a published-artifact / "
                            "internal-tool repo (L-05 — the deploy phase is "
                            "skipped per the repo contract).")
    p_run.add_argument("--staging-url", default=None,
                       help="Staging URL for health check (optional)")
    p_run.add_argument(
        "--health-path", default="",
        help="HTTP path to use for the health check (e.g. /health, "
             "/api/health, /healthz). Default empty: auto-detect from "
             "--smoke-cmd if it contains a URL with a path, else fall "
             "back to /. Use this when the smoke command's URL doesn't "
             "match where the health endpoint actually lives.",
    )
    p_run.add_argument("--smoke-cmd", default="",
                       help="Smoke test shell command (run after health check)")
    p_run.add_argument("--repo", default=None,
                       help="GitHub repo (org/name); defaults to $GITHUB_REPOSITORY")
    p_run.add_argument("--ci-poll-interval", type=int, default=None,
                       help=f"CI poll interval (s, default {CI_DEFAULT_INTERVAL})")
    p_run.add_argument("--deploy-poll-interval", type=int, default=None,
                       help=f"Deploy poll interval (s, default {DEPLOY_DEFAULT_INTERVAL})")
    p_run.add_argument("--deploy-cap", type=int, default=None,
                       help=f"Max total deploy-poll time before declaring failure "
                            f"(s, default {DEPLOY_DEFAULT_CAP}). Raise for slow deploys.")
    p_run.add_argument(
        "--skip-ci-poll", action="store_true",
        help="Skip CI polling on the branch and proceed directly to "
             "rebase/merge. Defaults to False; auto-set to True when "
             ".github/workflows/ and .gitlab-ci.yml have no branch-CI "
             "config. Use explicitly when your project has CI you don't "
             "want gated on before merge.",
    )
    p_run.add_argument(
        "--base-branch", default=None,
        help="Base ref for rebase + merge target. Defaults to 'dev'. Per "
             "CW-04, when invoked from inside a change worktree, callers "
             "pass the change branch name (e.g. change/feat-payments) so "
             "WPs ship to the change branch, not directly to dev.",
    )
    p_run.add_argument(
        "--change-worktree-path", default=None,
        help="Path to the parent change worktree (per CW-04 — the worktree "
             "where the change/* branch lives). When set + --base-branch "
             "starts with 'change/', the pipeline runs Step 0 (arrival "
             "check — back-integrate change branch from dev) before the CI "
             "poll, and Step 12.5 (post-WP back-integration) after the "
             "merge succeeds. Both are no-ops when the change branch is "
             "already current. See lifecycle.md Step 0 / Step 12.5 for "
             "the failure-handling OODA. When unset, both steps are "
             "skipped (backward-compatible with pre-Phase-5 callers and "
             "with the CW-05 trivial-change carve-out).",
    )

    return parser


HANDLERS = {"run": cmd_run}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
