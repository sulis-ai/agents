#!/usr/bin/env python3
"""sulis-emit-design — emit a Design entity from `.architecture/{project}/TDD.md`.

Cross-references the parallel SRD (`.specifications/{project}/SRD.md`) to
resolve `dna:requirement:<ulid>` IDs for the FR/NFR markers the TDD body
mentions. Picks up ADRs from `adrs/` next to TDD.md and emits the parallel
`dna:decision:<ulid>` refs.

Usage:
    sulis-emit-design --from-tdd <path>
                      [--srd <path>]   # override SRD inference
                      [--state draft|reviewed|accepted]
                      [--view <view>]   # repeatable
                      [--interface-contract <uri>]   # repeatable
                      [--base-dir <dir>] [--domain <domain>] [--repo-root <dir>]
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _design_emission import emit_design_from_tdd  # noqa: E402
from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402


def _resolve_repo_root(explicit: str | None) -> Path:
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _ok(data: dict) -> int:
    print(json.dumps({"ok": True, "data": data}, indent=2))
    return 0


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(description="Emit a Design entity from a TDD.")
    parser.add_argument("--from-tdd", required=True)
    parser.add_argument("--srd", default=None, help="override SRD path inference")
    parser.add_argument("--state", default="draft")
    parser.add_argument("--view", action="append", default=[], help="repeatable: context|container|component|deployment")
    parser.add_argument("--interface-contract", action="append", default=[], help="repeatable: URI to OpenAPI/JSON-Schema")
    parser.add_argument("--base-dir")
    parser.add_argument("--domain", default="product-development")
    parser.add_argument("--repo-root")
    args = parser.parse_args()

    tdd_path = Path(args.from_tdd).resolve()
    if not tdd_path.exists():
        return _err(f"TDD not found: {tdd_path}")
    srd_path = Path(args.srd).resolve() if args.srd else None

    repo_root = _resolve_repo_root(args.repo_root)
    base_dir = (
        Path(args.base_dir).resolve()
        if args.base_dir
        else repo_root / ".brain" / "instances"
    )
    adapter = LocalFileEntityAdapter(base_dir=base_dir, domain=args.domain)

    try:
        designs = emit_design_from_tdd(
            tdd_path, adapter,
            srd_path=srd_path,
            state=args.state,
            views=args.view or None,
            interface_contracts=args.interface_contract or None,
        )
    except ValueError as exc:
        return _err(str(exc))
    except EntityValidationError as exc:
        return _err(str(exc))

    entries: list[dict] = []
    for d in designs:
        ulid = d["id"].rsplit(":", 1)[-1]
        path = base_dir / args.domain / "design" / f"{ulid}.jsonld"
        entries.append({"id": d["id"], "path": str(path)})

    return _ok({
        "from_tdd": str(tdd_path),
        "count": len(entries),
        "entities": entries,
    })


if __name__ == "__main__":
    sys.exit(main())
