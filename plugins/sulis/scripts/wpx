#!/usr/bin/env bash
# wpx — dispatch to a wpx-<subtool> that lives alongside this script.
#
# `wpx` ships IN scripts/ next to every wpx-* sibling, so it resolves its
# tool directory relative to ITSELF (`realpath` of $0) — never by globbing
# the plugin cache. Globbing + `sort -r` is a lexical sort that mis-ranks
# 0.98.0 above 0.126.0 (#49); self-location sidesteps that entirely and is
# correct whether installed in the cache, symlinked onto $PATH, or run from
# the marketplace repo. It then exec's the requested subtool with the
# remaining arguments.
#
# Usage:
#   wpx <subtool> [args...]
#   wpx resolve              # print the resolved tool directory
#   wpx --help               # print this help
#
# Subtools (one per wpx-* script):
#   journal | index | wp | blocker | findings | worktree | pipeline | step12
#   | render-contract
#
# Exit codes:
#   0    success
#   1    subtool errored (passed through)
#   64   bad usage (no subtool or unrecognised flag)
#   127  tool directory not found / unknown subtool

set -euo pipefail

TOOL="${1:-}"

if [ -z "$TOOL" ] || [ "$TOOL" = "--help" ] || [ "$TOOL" = "-h" ]; then
  cat >&2 <<'EOF'
usage: wpx <subtool> [args...]

Subtools:
  journal     — manage the per-WP executor journal
  index       — manage the WP INDEX.md
  wp          — read WP frontmatter; append acceptance evidence
  blocker     — write/archive BLOCKER records per EL-08
  findings    — register security findings; auto-draft follow-up WPs
  worktree    — manage git worktrees per GIT-07
  pipeline    — run Steps 8-10 (CI poll + merge + deploy + health + smoke)
  step12      — atomic Step 12 wrap (acceptance + INDEX flip + worktree remove)
  render-contract — render a change's data contract into a founder-legible CONTRACT.html
  resolve     — print the resolved wpx-* tool directory (diagnostic)

Run `wpx <subtool> --help` for subtool-specific options.
EOF
  if [ -z "$TOOL" ]; then
    exit 64
  fi
  exit 0
fi

shift  # drop the subtool name from $@

# Resolution — self-locate relative to THIS script (#49). `wpx` lives in
# scripts/ alongside every wpx-* sibling, so the tool dir is simply the
# directory of the resolved (symlink-followed) path of $0. No cache glob,
# no lexical sort. `realpath` follows symlinks on both Linux and modern
# macOS; if it is somehow unavailable we fall back to a Python resolve.
_self="$0"
if command -v realpath >/dev/null 2>&1; then
  _self="$(realpath "$0")"
else
  _self="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")"
fi
WPX_DIR="$(cd "$(dirname "$_self")" && pwd)"

if [ ! -f "$WPX_DIR/wpx-journal" ]; then
  cat >&2 <<EOF
wpx: cannot locate wpx-* scripts next to this dispatcher.

Resolved tool dir: $WPX_DIR
Expected to find: \$WPX_DIR/wpx-journal

This dispatcher resolves its siblings relative to its own path. If you see
this, the install is corrupt or the script was copied away from its
wpx-* siblings. Reinstall:

  claude plugin marketplace add https://github.com/sulis-ai/agents
  claude plugin install sulis@sulis-ai-agents
EOF
  exit 127
fi

if [ "$TOOL" = "resolve" ]; then
  echo "$WPX_DIR"
  exit 0
fi

TOOL_PATH="$WPX_DIR/wpx-$TOOL"
if [ ! -x "$TOOL_PATH" ]; then
  echo "wpx: unknown subtool '$TOOL' (looked for $TOOL_PATH)" >&2
  echo "Run 'wpx --help' for the list of available subtools." >&2
  exit 127
fi

exec "$TOOL_PATH" "$@"
