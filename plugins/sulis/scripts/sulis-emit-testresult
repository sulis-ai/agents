#!/usr/bin/env python3
"""sulis-emit-testresult — emit a TestResult entity (PD).

CLI-direct. Records the verifying result of a TestRun against one or more
Requirements.

Usage:
    sulis-emit-testresult --of-run dna:testrun:<ulid>
                          --verifies dna:requirement:<ulid> [--verifies ...]
                          --type <unit|integration|e2e|contract|security>
                          --outcome <pass|fail|skip>
                          [--evidence <uri>]
                          [--base-dir <dir>] [--domain <domain>] [--repo-root <dir>]
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402
from _testresult_emission import emit_testresult  # noqa: E402


def _resolve_repo_root(explicit: str | None) -> Path:
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _ok(data: dict) -> int:
    print(json.dumps({"ok": True, "data": data}, indent=2))
    return 0


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(description="Emit a TestResult entity (PD).")
    parser.add_argument("--of-run", required=True)
    parser.add_argument("--verifies", action="append", required=True, default=[])
    parser.add_argument("--type", required=True)
    parser.add_argument("--outcome", required=True)
    parser.add_argument("--evidence", default="")
    parser.add_argument("--base-dir")
    parser.add_argument("--domain", default="product-development")
    parser.add_argument("--repo-root")
    args = parser.parse_args()

    repo_root = _resolve_repo_root(args.repo_root)
    base_dir = (
        Path(args.base_dir).resolve()
        if args.base_dir
        else repo_root / ".brain" / "instances"
    )
    adapter = LocalFileEntityAdapter(base_dir=base_dir, domain=args.domain)

    try:
        res = emit_testresult(
            repo=adapter, of_run=args.of_run, verifies=args.verifies,
            type=args.type, outcome=args.outcome, evidence=args.evidence,
        )
    except ValueError as exc:
        return _err(str(exc))
    except EntityValidationError as exc:
        return _err(str(exc))

    ulid = res["id"].rsplit(":", 1)[-1]
    path = base_dir / args.domain / "testresult" / f"{ulid}.jsonld"
    return _ok({"count": 1, "entities": [{"id": res["id"], "path": str(path)}]})


if __name__ == "__main__":
    sys.exit(main())
