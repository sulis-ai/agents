#!/usr/bin/env python3
"""sulis-emit-decision — emit a Decision entity from an ADR markdown file.

The CLI surface for the D1 ADR → Decision wire-up. `/sulis:draft-architecture`
calls this once per ADR it writes, immediately after writing the .md, so
each ADR has a paired structured Decision entity persisted via the
`EntityRepository` port (currently file-backed; Storage Service when Track 2
lands).

Usage:
    sulis-emit-decision --from-adr <path>
                        [--base-dir <dir>]
                        [--domain <domain>]
                        [--repo-root <dir>]

Defaults:
    --base-dir   <repo-root>/.brain/instances
    --domain     product-development
    --repo-root  `git rev-parse --show-toplevel` (or `cwd` if not a git repo)

Output (JSON to stdout, marketplace convention):
    success: {"ok": true, "data": {"decision_id", "path", "from_adr"}}
    failure: {"ok": false, "error": "<reason>"}

Exit code: 0 success, 1 failure.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

# Make sibling scripts importable when invoked as a bin file
_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _decision_emission import emit_decision_from_adr  # noqa: E402
from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402


def _resolve_repo_root(explicit: str | None) -> Path:
    """Resolve the repo root.

    Order of precedence:
      1. `--repo-root` if given.
      2. `git rev-parse --show-toplevel` when inside a git repo.
      3. `cwd`.
    """
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _ok(data: dict) -> int:
    print(json.dumps({"ok": True, "data": data}, indent=2))
    return 0


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Emit a Decision entity from an ADR markdown file.",
    )
    parser.add_argument(
        "--from-adr",
        required=True,
        help="path to the ADR markdown file",
    )
    parser.add_argument(
        "--base-dir",
        help="instance base directory (default: <repo-root>/.brain/instances)",
    )
    parser.add_argument(
        "--domain",
        default="product-development",
        help="entity-schema domain (default: product-development)",
    )
    parser.add_argument(
        "--repo-root",
        help="repo root (default: git toplevel, or cwd if not a git repo)",
    )
    args = parser.parse_args()

    adr_path = Path(args.from_adr).resolve()
    if not adr_path.exists():
        return _err(f"ADR not found: {adr_path}")

    repo_root = _resolve_repo_root(args.repo_root)
    base_dir = (
        Path(args.base_dir).resolve()
        if args.base_dir
        else repo_root / ".brain" / "instances"
    )

    adapter = LocalFileEntityAdapter(base_dir=base_dir, domain=args.domain)

    try:
        decision = emit_decision_from_adr(adr_path, adapter)
    except EntityValidationError as e:
        return _err(str(e))
    except FileNotFoundError as e:
        return _err(str(e))

    ulid = decision["id"].rsplit(":", 1)[-1]
    written_path = base_dir / args.domain / "decision" / f"{ulid}.jsonld"

    return _ok({
        "decision_id": decision["id"],
        "path": str(written_path),
        "from_adr": str(adr_path),
    })


if __name__ == "__main__":
    sys.exit(main())
