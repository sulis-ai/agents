#!/usr/bin/env python3
"""sulis-emit-metric — emit a Metric observation entity (PD).

CLI-direct. Records a measured outcome (DORA / SPACE / product) tied to
either a Release (delivery-health view) or an Opportunity (product view).

Usage:
    sulis-emit-metric --kind <DORA|SPACE|product>
                      --measures dna:release:<ulid> | dna:opportunity:<ulid>
                      --value <number>
                      [--observed-at <iso>] [--window <iso-duration>]
                      [--base-dir <dir>] [--domain <domain>] [--repo-root <dir>]
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402
from _metric_emission import emit_metric  # noqa: E402


def _resolve_repo_root(explicit: str | None) -> Path:
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _ok(data: dict) -> int:
    print(json.dumps({"ok": True, "data": data}, indent=2))
    return 0


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(description="Emit a Metric observation (PD).")
    parser.add_argument("--kind", required=True)
    parser.add_argument("--measures", required=True)
    parser.add_argument("--value", required=True, type=float)
    parser.add_argument("--observed-at", default=None)
    parser.add_argument("--window", default="")
    parser.add_argument("--base-dir")
    parser.add_argument("--domain", default="product-development")
    parser.add_argument("--repo-root")
    args = parser.parse_args()

    repo_root = _resolve_repo_root(args.repo_root)
    base_dir = (
        Path(args.base_dir).resolve()
        if args.base_dir
        else repo_root / ".brain" / "instances"
    )
    adapter = LocalFileEntityAdapter(base_dir=base_dir, domain=args.domain)

    try:
        m = emit_metric(
            repo=adapter, kind=args.kind, measures=args.measures, value=args.value,
            observed_at=args.observed_at, window=args.window,
        )
    except ValueError as exc:
        return _err(str(exc))
    except EntityValidationError as exc:
        return _err(str(exc))

    ulid = m["id"].rsplit(":", 1)[-1]
    path = base_dir / args.domain / "metric" / f"{ulid}.jsonld"
    return _ok({"count": 1, "entities": [{"id": m["id"], "path": str(path)}]})


if __name__ == "__main__":
    sys.exit(main())
