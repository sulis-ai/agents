#!/usr/bin/env python3
"""sulis-resolve-scenario-design — resolve the specify-time Design placeholder.

At `/sulis:specify`, a Scenario's `exercises` is a synthetic Design placeholder
(no Design entity exists yet). When the design stage emits the change's real
Design, this re-points every scenario in the change's durable bundle at it
(a change produces one Design all its scenarios exercise), rewrites the bundle,
and re-emits the updated Scenario entities. Uses the REAL emitted Design id, so
it can't drift on a path-derived recomputation.

Usage:
    sulis-resolve-scenario-design \
      --scenarios {worktree}/.changes/{primitive}-{slug}.scenarios.jsonld \
      --design dna:design:<ulid> [--emit] [--base-dir D] [--repo-root D]

Envelope: {"ok": true, "data": {...}} / {"ok": false, "error": "..."}; exit 0/1.
"""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402
from _scenario_authoring import repoint_scenarios_exercises  # noqa: E402

_DESIGN_RE = re.compile(r"^dna:design:[0-9A-HJKMNP-TV-Z]{26}$")


def _resolve_repo_root(explicit: str | None) -> Path:
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    p = argparse.ArgumentParser(description="Re-point a change's scenarios at the real Design.")
    p.add_argument("--scenarios", required=True, help="path to the change's scenarios.jsonld bundle")
    p.add_argument("--design", required=True, help="the real dna:design:<ulid> the design stage emitted")
    p.add_argument("--emit", action="store_true", help="re-persist the updated Scenario entities")
    p.add_argument("--base-dir")
    p.add_argument("--repo-root")
    args = p.parse_args()

    if not _DESIGN_RE.match(args.design):
        return _err(f"--design must be a dna:design:<ulid>; got {args.design!r}")

    src = Path(args.scenarios).resolve()
    if not src.exists():
        return _err(f"scenarios bundle not found: {src}")
    try:
        bundle = json.loads(src.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, ValueError) as exc:
        return _err(f"scenarios bundle is not valid JSON: {exc}")

    try:
        updated = repoint_scenarios_exercises(bundle, args.design)
    except ValueError as exc:
        return _err(str(exc))

    src.write_text(json.dumps(updated, indent=2, sort_keys=True), encoding="utf-8")

    emitted = 0
    if args.emit:
        repo_root = _resolve_repo_root(args.repo_root)
        base_dir = Path(args.base_dir).resolve() if args.base_dir else repo_root / ".brain" / "instances"
        product = LocalFileEntityAdapter(base_dir=base_dir, domain="product-development")
        try:
            for sc in updated.get("scenarios") or []:
                product.save("scenario", sc); emitted += 1
        except EntityValidationError as exc:
            return _err(f"re-pointed scenario failed validation on emit: {exc}")

    print(json.dumps({
        "ok": True,
        "data": {
            "scenarios": str(src),
            "design": args.design,
            "repointed": len(updated.get("scenarios") or []),
            "emitted": emitted if args.emit else None,
        },
    }, indent=2))
    return 0


if __name__ == "__main__":
    sys.exit(main())
