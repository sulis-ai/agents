#!/usr/bin/env python3
"""sulis-emit-release — emit a Release entity (PD).

CLI-direct. Typical caller: the release-train at tag-push time.

Usage:
    sulis-emit-release --version v0.34.0
                       --comprises dna:component:<ulid> [--comprises ...]
                       --sbom file:///tmp/sbom.spdx.json
                       [--changelog "..."]
                       [--shipped-at <iso>]
                       [--base-dir <dir>] [--domain <domain>] [--repo-root <dir>]
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402
from _release_emission import emit_release  # noqa: E402


def _resolve_repo_root(explicit: str | None) -> Path:
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _ok(data: dict) -> int:
    print(json.dumps({"ok": True, "data": data}, indent=2))
    return 0


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(description="Emit a Release entity (PD).")
    parser.add_argument("--version", required=True, help="SemVer version (e.g. v0.34.0)")
    parser.add_argument("--comprises", action="append", required=True, default=[],
                        help="dna:component:<ulid> (repeatable)")
    parser.add_argument("--sbom", required=True, help="URI to SPDX or CycloneDX")
    parser.add_argument("--changelog", default="")
    parser.add_argument("--shipped-at", default=None)
    parser.add_argument("--base-dir")
    parser.add_argument("--domain", default="product-development")
    parser.add_argument("--repo-root")
    args = parser.parse_args()

    repo_root = _resolve_repo_root(args.repo_root)
    base_dir = (
        Path(args.base_dir).resolve()
        if args.base_dir
        else repo_root / ".brain" / "instances"
    )
    adapter = LocalFileEntityAdapter(base_dir=base_dir, domain=args.domain)

    try:
        rel = emit_release(
            repo=adapter,
            version=args.version,
            comprises=args.comprises,
            sbom=args.sbom,
            changelog=args.changelog,
            shipped_at=args.shipped_at,
        )
    except ValueError as exc:
        return _err(str(exc))
    except EntityValidationError as exc:
        return _err(str(exc))

    ulid = rel["id"].rsplit(":", 1)[-1]
    path = base_dir / args.domain / "release" / f"{ulid}.jsonld"
    return _ok({
        "count": 1,
        "entities": [{"id": rel["id"], "path": str(path)}],
    })


if __name__ == "__main__":
    sys.exit(main())
