#!/usr/bin/env python3
"""sulis-emit-workflow — ingest authored workflow.jsonld into the brain (foundation).

Thin shim over the shared ingest CLI (`_emit_ingest_cli`). Link 3 of the
Scenario-graph chain. Each Workflow entry is the process graph; this validates +
persists them. (Authored envelope key: `workflows`.)

Usage: sulis-emit-workflow --from-instances <path> [--base-dir D] [--domain D] [--repo-root D]
"""

from __future__ import annotations

import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _emit_ingest_cli import run_ingest_cli  # noqa: E402

if __name__ == "__main__":
    sys.exit(run_ingest_cli(entity_type="workflow", domain="foundation", list_key="workflows"))
