#!/usr/bin/env python3
"""sulis-emit-postmortem — emit a PostMortem entity (PD).

CLI-direct. Records the structured record of an Incident (one per incident).
Re-emitting with new findings or additional --action refs updates the
existing record (deterministic ULID from for_incident).

Usage:
    sulis-emit-postmortem --for-incident dna:incident:<ulid>
                          --findings "..."
                          [--blameful]                # default: blameless
                          [--action dna:requirement:<ulid>]  # repeatable
                          [--base-dir <dir>] [--domain <domain>] [--repo-root <dir>]
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402
from _postmortem_emission import emit_postmortem  # noqa: E402


def _resolve_repo_root(explicit: str | None) -> Path:
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _ok(data: dict) -> int:
    print(json.dumps({"ok": True, "data": data}, indent=2))
    return 0


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(description="Emit a PostMortem entity (PD).")
    parser.add_argument("--for-incident", required=True)
    parser.add_argument("--findings", required=True)
    parser.add_argument("--blameful", action="store_true",
                        help="opt out of blameless default (records blameless=false)")
    parser.add_argument("--action", action="append", default=[], dest="actions",
                        help="dna:requirement|opportunity ref (repeatable)")
    parser.add_argument("--base-dir")
    parser.add_argument("--domain", default="product-development")
    parser.add_argument("--repo-root")
    args = parser.parse_args()

    repo_root = _resolve_repo_root(args.repo_root)
    base_dir = (
        Path(args.base_dir).resolve()
        if args.base_dir
        else repo_root / ".brain" / "instances"
    )
    adapter = LocalFileEntityAdapter(base_dir=base_dir, domain=args.domain)

    try:
        p = emit_postmortem(
            repo=adapter, for_incident=args.for_incident,
            findings=args.findings, blameless=not args.blameful,
            actions=args.actions or None,
        )
    except ValueError as exc:
        return _err(str(exc))
    except EntityValidationError as exc:
        return _err(str(exc))

    ulid = p["id"].rsplit(":", 1)[-1]
    path = base_dir / args.domain / "postmortem" / f"{ulid}.jsonld"
    return _ok({"count": 1, "entities": [{"id": p["id"], "path": str(path)}]})


if __name__ == "__main__":
    sys.exit(main())
