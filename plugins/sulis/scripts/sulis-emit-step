#!/usr/bin/env python3
"""sulis-emit-step — ingest authored steps.jsonld into the brain (foundation).

Thin shim over the shared ingest CLI (`_emit_ingest_cli`). Link 2 of the
Scenario-graph chain. Each Step entry is the IDEF0/ICOM box; this validates +
persists them.

Usage: sulis-emit-step --from-instances <path> [--base-dir D] [--domain D] [--repo-root D]
"""

from __future__ import annotations

import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _emit_ingest_cli import run_ingest_cli  # noqa: E402

if __name__ == "__main__":
    sys.exit(run_ingest_cli(entity_type="step", domain="foundation", list_key="steps"))
