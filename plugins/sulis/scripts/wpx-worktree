#!/usr/bin/env python3
"""wpx-worktree — manage git worktrees per GIT-07.

Subcommands:
  create                Create worktree off origin/dev + record dev SHA.
  remove                Remove a worktree (Step 12 cleanup).

Exit codes: 0 success, 1 user/data error, 2 internal error.
"""

from __future__ import annotations

import argparse
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
from _wpxlib import (  # noqa: E402
    add_common_args,
    cli_main,
    emit_error,
    emit_ok,
    paths_from_args,
)


def _run(cmd: list[str], cwd: Path | None = None) -> tuple[int, str, str]:
    proc = subprocess.run(cmd, capture_output=True, text=True, cwd=cwd)  # noqa: S603
    return proc.returncode, proc.stdout, proc.stderr


def cmd_create(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    worktree_path = Path(args.worktree_path).resolve()
    base_branch = getattr(args, "base_branch", None) or "dev"

    if worktree_path.exists():
        emit_error(f"Worktree path already exists: {worktree_path}")

    # Resolve the base ref (L-04, CW-04). Prefer the freshest shared state:
    # fetch origin/<base> and branch off it — this keeps the default `dev`
    # behaviour identical to pre-L-04 (always the latest integration line).
    # A CW-04 change branch (`change/{primitive}-{slug}`) usually lives only
    # locally (origin doesn't have it yet), so the fetch fails to find the
    # remote ref; we then fall back to the LOCAL branch with no further fetch.
    fetch_rc, _, fetch_err = _run(
        ["git", "fetch", "origin", base_branch], cwd=paths.repo_root,
    )
    if fetch_rc == 0:
        base_ref = f"origin/{base_branch}"
    else:
        # origin has no such branch (or fetch failed) — try the local ref.
        local_rc, _, _ = _run(
            ["git", "rev-parse", "--verify", "--quiet", f"refs/heads/{base_branch}"],
            cwd=paths.repo_root,
        )
        if local_rc != 0:
            emit_error(
                f"base branch {base_branch!r} not found on origin "
                f"(fetch: {fetch_err.strip()}) or locally"
            )
        base_ref = base_branch

    # Capture the base SHA at creation (drift baseline for Step 8b rebase)
    rc, base_sha, err = _run(["git", "rev-parse", base_ref], cwd=paths.repo_root)
    if rc != 0:
        emit_error(f"git rev-parse {base_ref} failed: {err}")
    base_sha = base_sha.strip()

    # Create worktree off the resolved base ref
    rc, _, err = _run(
        ["git", "worktree", "add", str(worktree_path), "-b", args.branch, base_ref],
        cwd=paths.repo_root,
    )
    if rc != 0:
        emit_error(f"git worktree add failed: {err}")

    # Record the base SHA in a sidecar file (the journal complement).
    # NOTE: the filename keeps the historical `-dev-sha` suffix for back-compat
    # — cmd_remove and wpx-pipeline read it by exact name. It is the base SHA
    # regardless of which base branch was used (see `base_branch` field below).
    sidecar = paths.wp_dir / f".executor-{args.wp}-dev-sha"
    sidecar.parent.mkdir(parents=True, exist_ok=True)
    sidecar.write_text(base_sha + "\n", encoding="utf-8")

    emit_ok(data={
        "wp": args.wp,
        "worktree_path": str(worktree_path),
        "branch": args.branch,
        "base_branch": base_branch,
        "base_ref": base_ref,
        "dev_sha_at_creation": base_sha,  # kept key name for back-compat
        "sidecar": str(sidecar),
    })


def cmd_remove(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    worktree_path = Path(args.worktree_path).resolve()
    if not worktree_path.exists() and not args.tolerate_missing:
        emit_error(f"Worktree path does not exist: {worktree_path}")

    if worktree_path.exists():
        cmd = ["git", "worktree", "remove", str(worktree_path)]
        if args.force:
            cmd.insert(-1, "--force")
        rc, _, err = _run(cmd, cwd=paths.repo_root)
        if rc != 0:
            emit_error(f"git worktree remove failed: {err}")

    # Clean up sidecar
    sidecar = paths.wp_dir / f".executor-{args.wp}-dev-sha"
    if sidecar.exists():
        sidecar.unlink()

    emit_ok(data={"wp": args.wp, "removed": str(worktree_path)})


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Manage worktrees per GIT-07")
    sub = parser.add_subparsers(dest="subcommand", required=True)

    p_create = sub.add_parser("create", help="Create a worktree off origin/dev")
    add_common_args(p_create)
    p_create.add_argument("--wp", required=True)
    p_create.add_argument("--branch", required=True,
                          help="Branch name (e.g. feat/wp-007-cancel-flow)")
    p_create.add_argument("--worktree-path", required=True,
                          help="Path for the worktree (e.g. ../wp-007-worktree)")
    p_create.add_argument(
        "--base-branch", default="dev",
        help="Branch to create the worktree from (default: dev). A local "
             "`change/*` branch is used directly with no fetch (CW-04); any "
             "other base is taken from origin/<base> after a fetch.",
    )

    p_remove = sub.add_parser("remove", help="Remove a worktree")
    add_common_args(p_remove)
    p_remove.add_argument("--wp", required=True)
    p_remove.add_argument("--worktree-path", required=True)
    p_remove.add_argument("--force", action="store_true",
                          help="Force-remove (passes --force to git worktree remove)")
    p_remove.add_argument("--tolerate-missing", action="store_true",
                          help="Don't fail if worktree path doesn't exist")

    return parser


HANDLERS = {
    "create": cmd_create,
    "remove": cmd_remove,
}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
