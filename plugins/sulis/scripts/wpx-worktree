#!/usr/bin/env python3
"""wpx-worktree — manage git worktrees per GIT-07.

Subcommands:
  create                Create worktree off origin/dev + record dev SHA.
  remove                Remove a worktree (Step 12 cleanup).

Exit codes: 0 success, 1 user/data error, 2 internal error.
"""

from __future__ import annotations

import argparse
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
from _wpxlib import (  # noqa: E402
    add_common_args,
    cli_main,
    emit_error,
    emit_ok,
    git_worktree_remove,
    paths_from_args,
)


def _run(cmd: list[str], cwd: Path | None = None) -> tuple[int, str, str]:
    proc = subprocess.run(cmd, capture_output=True, text=True, cwd=cwd)  # noqa: S603
    return proc.returncode, proc.stdout, proc.stderr


def _resolve_change_branch_base_ref(
    repo_root: Path, base_branch: str, *,
    fetch_succeeded: bool, fetch_err: str,
) -> str:
    """Pick LOCAL vs origin for a `change/*` base branch (#167).

    The change branch is the calling session's working state. When the local
    ref is ahead of (or equal to) origin — the common run-all case where
    prior WPs have been merged locally but not yet pushed — branching from
    origin/<branch> drops those merges and forces every executor to
    hard-reset by hand. Prefer local in that case. If origin is ahead
    (someone else pushed), use origin/<branch> so the worktree gets the
    freshest shared tip.

    Precedence:
      1. Both exist + local is ancestor of nothing-newer-than-itself, i.e.
         origin/<branch> is an ancestor of local/<branch> → LOCAL wins.
      2. Both exist + origin is ahead → origin/<branch>.
      3. Only local exists (origin had no ref) → LOCAL wins.
      4. Only origin exists (no local checkout) → origin/<branch>.
      5. Neither → error.
    """
    local_rc, _, _ = _run(
        ["git", "rev-parse", "--verify", "--quiet", f"refs/heads/{base_branch}"],
        cwd=repo_root,
    )
    has_local = local_rc == 0
    has_origin = fetch_succeeded
    if has_local and has_origin:
        # is origin/<branch> an ancestor of local/<branch>?
        anc_rc, _, _ = _run(
            ["git", "merge-base", "--is-ancestor",
             f"origin/{base_branch}", f"refs/heads/{base_branch}"],
            cwd=repo_root,
        )
        return base_branch if anc_rc == 0 else f"origin/{base_branch}"
    if has_local:
        return base_branch
    if has_origin:
        return f"origin/{base_branch}"
    emit_error(
        f"base branch {base_branch!r} not found on origin "
        f"(fetch: {fetch_err.strip()}) or locally"
    )


def _normalise_base_branch(raw: str) -> str:
    """Strip `origin/` or `refs/heads/` prefixes so both spellings resolve.

    #105: callers (executors, run-all batches, manual scripts) reasonably
    spell the same ref three ways — `dev`, `origin/dev`, or `refs/heads/dev`.
    Without normalisation the prefixed forms double-prefix to
    `origin/origin/dev` at the `base_ref = f"origin/{base_branch}"` step.
    """
    bb = raw.strip()
    for prefix in ("refs/heads/", "origin/"):
        if bb.startswith(prefix):
            bb = bb[len(prefix):]
            break
    return bb


def cmd_create(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    # #309 — resolve a RELATIVE --worktree-path against --repo-root (the TARGET
    # change's repo), NOT the process cwd. A run-all executor passes a relative
    # `../wp-NNN-worktree`; `Path(...).resolve()` would anchor it to the
    # CALLING SESSION's cwd (which may be bound to a DIFFERENT change), landing
    # the worktree under the wrong change's parent. Anchoring to repo_root
    # makes the relative path land beside the target change regardless of where
    # the session's cwd is. Absolute paths are honoured as-is.
    wt_arg = Path(args.worktree_path)
    worktree_path = (
        wt_arg.resolve() if wt_arg.is_absolute()
        else (paths.repo_root / wt_arg).resolve()
    )
    base_branch = _normalise_base_branch(
        getattr(args, "base_branch", None) or "main"
    )

    if worktree_path.exists():
        emit_error(f"Worktree path already exists: {worktree_path}")

    # Resolve the base ref (L-04, CW-04). Prefer the freshest shared state:
    # fetch origin/<base> and branch off it — this keeps the default `main`
    # behaviour identical to pre-L-04 (always the latest integration line).
    # A CW-04 change branch (`change/{primitive}-{slug}`) usually lives only
    # locally (origin doesn't have it yet), so the fetch fails to find the
    # remote ref; we then fall back to the LOCAL branch with no further fetch.
    #
    # #167 — for `change/*` bases specifically, prefer the LOCAL ref when it
    # is ahead of or equal to origin. The change branch is the calling
    # session's working state: WPs that landed locally but haven't been
    # pushed yet (run-all integrates each merge into the local change branch
    # before the next wave) MUST appear in the next executor's worktree, or
    # every executor independently hard-resets onto the local tip (the
    # 13-times-repeated CH-01KT61 friction). For non-change bases (main /
    # dev), origin remains the source of truth.
    fetch_rc, _, fetch_err = _run(
        ["git", "fetch", "origin", base_branch], cwd=paths.repo_root,
    )

    if base_branch.startswith("change/"):
        base_ref = _resolve_change_branch_base_ref(
            paths.repo_root, base_branch,
            fetch_succeeded=(fetch_rc == 0),
            fetch_err=fetch_err,
        )
    elif fetch_rc == 0:
        base_ref = f"origin/{base_branch}"
    else:
        # origin has no such branch (or fetch failed) — try the local ref.
        local_rc, _, _ = _run(
            ["git", "rev-parse", "--verify", "--quiet", f"refs/heads/{base_branch}"],
            cwd=paths.repo_root,
        )
        if local_rc != 0:
            emit_error(
                f"base branch {base_branch!r} not found on origin "
                f"(fetch: {fetch_err.strip()}) or locally"
            )
        base_ref = base_branch

    # Capture the base SHA at creation (drift baseline for Step 8b rebase)
    rc, base_sha, err = _run(["git", "rev-parse", base_ref], cwd=paths.repo_root)
    if rc != 0:
        emit_error(f"git rev-parse {base_ref} failed: {err}")
    base_sha = base_sha.strip()

    # Create worktree off the resolved base ref
    rc, _, err = _run(
        ["git", "worktree", "add", str(worktree_path), "-b", args.branch, base_ref],
        cwd=paths.repo_root,
    )
    if rc != 0:
        emit_error(f"git worktree add failed: {err}")

    # Record the base SHA in a sidecar file (the journal complement).
    # NOTE: the filename keeps the historical `-dev-sha` suffix for back-compat
    # — cmd_remove and wpx-pipeline read it by exact name. It is the base SHA
    # regardless of which base branch was used (see `base_branch` field below).
    sidecar = paths.wp_dir / f".executor-{args.wp}-dev-sha"
    sidecar.parent.mkdir(parents=True, exist_ok=True)
    sidecar.write_text(base_sha + "\n", encoding="utf-8")

    emit_ok(data={
        "wp": args.wp,
        "worktree_path": str(worktree_path),
        "branch": args.branch,
        "base_branch": base_branch,
        "base_ref": base_ref,
        "dev_sha_at_creation": base_sha,  # kept key name for back-compat
        "sidecar": str(sidecar),
    })


def cmd_remove(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)
    worktree_path = Path(args.worktree_path).resolve()
    if not worktree_path.exists() and not args.tolerate_missing:
        emit_error(f"Worktree path does not exist: {worktree_path}")

    # #130 — SCOPE-GUARDED removal. The change-id (explicit, else the bound
    # session's SULIS_CHANGE_ID) keys the guard: the target MUST be within that
    # change's own dir, or the removal is refused. This makes the destructive
    # cross-change glob-sweep (`git worktree list | grep wp-006` matching another
    # change's worktree) structurally impossible — route through the guarded
    # primitive, never raw `git worktree remove`.
    change_id = getattr(args, "change_id", None) or os.environ.get("SULIS_CHANGE_ID")
    if worktree_path.exists():
        ok, msg = git_worktree_remove(
            paths.repo_root, worktree_path,
            force=bool(getattr(args, "force", False)),
            change_id=change_id,
        )
        if not ok:
            emit_error(msg)

    # Clean up sidecar
    sidecar = paths.wp_dir / f".executor-{args.wp}-dev-sha"
    if sidecar.exists():
        sidecar.unlink()

    emit_ok(data={"wp": args.wp, "removed": str(worktree_path)})


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Manage worktrees per GIT-07")
    sub = parser.add_subparsers(dest="subcommand", required=True)

    p_create = sub.add_parser("create", help="Create a worktree off origin/dev")
    add_common_args(p_create)
    p_create.add_argument("--wp", required=True)
    p_create.add_argument("--branch", required=True,
                          help="Branch name (e.g. feat/wp-007-cancel-flow)")
    p_create.add_argument("--worktree-path", required=True,
                          help="Path for the worktree (e.g. ../wp-007-worktree)")
    p_create.add_argument(
        "--base-branch", default="main",
        help="Branch to create the worktree from (default: dev). A local "
             "`change/*` branch is used directly with no fetch (CW-04); any "
             "other base is taken from origin/<base> after a fetch.",
    )

    p_remove = sub.add_parser("remove", help="Remove a worktree")
    add_common_args(p_remove)
    p_remove.add_argument("--wp", required=True)
    p_remove.add_argument("--worktree-path", required=True)
    p_remove.add_argument("--change-id", default=None,
                          help="The owning change (#130 scope guard); defaults to "
                               "SULIS_CHANGE_ID. The target must be within this "
                               "change's dir or removal is refused.")
    p_remove.add_argument("--force", action="store_true",
                          help="Force-remove (passes --force to git worktree remove)")
    p_remove.add_argument("--tolerate-missing", action="store_true",
                          help="Don't fail if worktree path doesn't exist")

    return parser


HANDLERS = {
    "create": cmd_create,
    "remove": cmd_remove,
}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
