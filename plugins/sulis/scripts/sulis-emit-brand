#!/usr/bin/env python3
"""sulis-emit-brand — ingest authored brands.jsonld into the brain (brand-identity).

Thin shim over the shared ingest CLI (`_emit_ingest_cli`). The Brand entries in
an authored brands.jsonld are already complete entities (real ULIDs + name +
discovery-lifecycle state + the soft element_schema_v0.3 elements); this
validates them against the vendored brand schema (DR-030, sulis-brain v0.15.0)
and persists them — rejecting-without-persisting on a malformed entity.

The `ux-designer` agent calls this when it establishes a design language: it
authors the Brand instance (the founder-owned identity — voice/values/
positioning/...) and emits it, so the paired DesignSystem can resolve
`realizes_identity → brand`.

Usage: sulis-emit-brand --from-instances <path> [--base-dir D] [--domain D] [--repo-root D]
"""

from __future__ import annotations

import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _emit_ingest_cli import run_ingest_cli  # noqa: E402

if __name__ == "__main__":
    sys.exit(run_ingest_cli(entity_type="brand", domain="brand-identity", list_key="brands"))
