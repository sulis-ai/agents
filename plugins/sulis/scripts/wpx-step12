#!/usr/bin/env python3
"""wpx-step12 — atomic Step 12 bookkeeping wrap.

Combines three operations into one transactional call:
  1. Append ## Acceptance Evidence to the WP file (via wpx-wp append-evidence).
  2. Flip INDEX status to done (via wpx-index flip-status --expected in_progress).
  3. Remove the worktree (via wpx-worktree remove).

If any step fails, prior steps are not rolled back automatically (Markdown
file edits are not transactional); the failure is surfaced so the calling
session can recover manually. In practice, step 1 is durable, step 2 is
the atomic guard (status flip), and step 3 is idempotent (worktree may
already be gone).

Exit codes: 0 success, 1 user/data error, 2 internal error.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
from _wpxlib import (  # noqa: E402
    add_common_args,
    cli_main,
    emit_error,
    emit_ok,
    paths_from_args,
)


SCRIPTS_DIR = Path(__file__).parent


def _call_tool(tool: str, args: list[str]) -> dict:
    """Invoke a sibling wpx-* tool; parse JSON response.

    Fails-fast (emit_error → exit 1) if the sub-tool crashes
    unexpectedly (exit 2+), emits non-JSON, or returns ok:false.
    This preserves wpx-step12's atomic-wrap semantics: if any
    sub-call reports failure, downstream steps are not attempted
    and the partial state is surfaced clearly via emit_error.
    """
    cmd = [str(SCRIPTS_DIR / tool), *args]
    proc = subprocess.run(cmd, capture_output=True, text=True)  # noqa: S603
    if proc.returncode not in (0, 1):
        # exit 2 = internal error in child tool
        emit_error(
            f"{tool} failed (exit {proc.returncode}): "
            f"stdout={proc.stdout!r} stderr={proc.stderr!r}"
        )
    try:
        # All wpx-* tools emit pretty-printed multi-line JSON via
        # `json.dumps(..., indent=2)` in _wpxlib.emit_ok/emit_error.
        # Parse the whole stdout — not just the last line — so the
        # closing `}` on its own line doesn't fail the parse.
        parsed = json.loads(proc.stdout.strip())
    except json.JSONDecodeError as e:
        emit_error(f"{tool} did not emit JSON: {e}; stdout={proc.stdout!r}")
        return {}  # unreachable; for type checker
    if not parsed.get("ok", False):
        # Sub-tool returned a structured failure (ok:false). Fail-fast.
        emit_error(
            f"{tool} reported failure: "
            f"{parsed.get('error', 'unknown error')}"
        )
    return parsed


def _read_textish(value: str) -> str:
    if value.startswith("@"):
        return Path(value[1:]).read_text(encoding="utf-8")
    return value


def _run_seam_close_gate(args: argparse.Namespace, paths) -> dict:
    """Step 12.2a — the seam-close DoD gate at the WP done-transition (ADR-003).

    Called immediately AFTER the in_progress→done flip (step 12.2): the
    seam-close predicate ("are all WPs on both sides of this seam now done?")
    must read post-flip INDEX state. Returns a dict threaded into the wrap
    envelope under ``seam_close``. On a ``blocked`` verdict the caller also
    surfaces a ``gate_block`` so the calling session halts seam-close as
    "not done" — WITHOUT rolling back the flip (the WP genuinely reached done;
    it is the *seam* that is not done, mirroring the ship gate).

    Best-effort-never-fatal for EVIDENCE, decisive for the VERDICT. The gate's
    runner already inherits never-fatal evidence semantics (a brain-store write
    failure does not change the wrap's success). The two are not conflated: a
    ``blocked`` *decision* DOES set ``gate_block``; an evidence-deposit hiccup
    inside the runner does NOT. If the gate machinery itself cannot run at all
    (module absent, INDEX unreadable beyond the gate's own degrade-open), that
    is a detection failure, not a seam block — degrade-open to ``not-closed`` so
    the wrap still succeeds and never fabricates a block or a green.
    """
    try:
        from _seam_close_gate import evaluate  # local import: keeps wrap import-light

        brain_base_dir = paths.repo_root / ".brain" / "instances"
        result = evaluate(
            args.wp,
            index_path=paths.index_md,
            brain_base_dir=brain_base_dir,
            repo_root=paths.repo_root,
            allow_deferred=args.allow_deferred,
        )
        return {
            "verdict": result.verdict,   # observed | blocked | not-closed
            "seam": result.seam_title,   # founder-facing title; "" when not-closed
            "reason": result.reason,     # founder-English; empty when silent
        }
    except Exception as exc:  # noqa: BLE001 — machinery failure must never fail the wrap
        # The gate machinery itself could not run (module absent, an unexpected
        # error past the gate's own degrade-open). This is a DETECTION failure,
        # not a seam decision: degrade-open to `not-closed` so the wrap still
        # succeeds. We never fabricate `blocked` (a false halt) or `observed`
        # (a false green) on a machinery error — the seam is simply re-evaluated
        # at the next WP done-transition (and the ship gate is the backstop).
        return {
            "verdict": "not-closed",
            "seam": "",
            "reason": "",
            "gate_error": f"{type(exc).__name__}: {exc}",
        }


def cmd_wrap(args: argparse.Namespace) -> None:
    paths = paths_from_args(args)

    # Build evidence JSON from pipeline result + (optional) security verdict
    pipeline_json = json.loads(_read_textish(args.pipeline_result))
    pipeline_data = pipeline_json.get("result", pipeline_json)

    evidence: dict = {
        "branch": args.branch,
        "merge_sha": pipeline_data.get("merge_sha"),
        "deploy_url": pipeline_data.get("deploy_url"),
        "health_status": pipeline_data.get("health_status"),
        "smoke_verdict": pipeline_data.get("smoke_verdict"),
    }
    if args.pre_squash_sha:
        evidence["pre_squash_sha"] = args.pre_squash_sha
    if args.post_deploy_verification:
        evidence["post_deploy_verification"] = args.post_deploy_verification

    # Drop None values so the WP file's evidence block stays clean
    evidence = {k: v for k, v in evidence.items() if v is not None}

    summary: dict = {"wp": args.wp, "steps": {}}

    # Step 12.1 — append acceptance evidence
    evidence_path = paths.wp_dir / f".step12-evidence-{args.wp}.json"
    evidence_path.parent.mkdir(parents=True, exist_ok=True)
    evidence_path.write_text(json.dumps(evidence, indent=2), encoding="utf-8")
    result_1 = _call_tool("wpx-wp", [
        "append-evidence",
        "--wp", args.wp,
        "--project", paths.project,
        "--repo-root", str(paths.repo_root),
        "--evidence-json", f"@{evidence_path}",
    ])
    summary["steps"]["append_evidence"] = result_1.get("data", {})

    # Step 12.2 — flip INDEX status to done, atomic with --expected.
    # #267: the gate-handoff train path (`--enable-gate-handoff`) flips WPs to
    # `step-7-complete` before the train, so the wrap's prior status is
    # step-7-complete, not the legacy per-WP `in_progress`. Without the right
    # --expected, flip-status rejected the transition and the calling session
    # had to do the wrap's three jobs by hand for every WP. Pick the expected
    # prior status from the path. (flip-status is idempotent when already at
    # `done` per #142, so a replay is still safe either way.)
    expected_prior = "step-7-complete" if args.from_gate_handoff else "in_progress"
    result_2 = _call_tool("wpx-index", [
        "flip-status",
        "--wp", args.wp,
        "--project", paths.project,
        "--repo-root", str(paths.repo_root),
        "--to", "done",
        "--expected", expected_prior,
    ])
    summary["steps"]["flip_status"] = result_2.get("data", {})

    # Step 12.2a — seam-close DoD gate (ADR-003), AFTER the flip so the
    # seam-close predicate reads post-flip INDEX state. A `blocked` seam emits
    # a `gate_block` the calling session reads to halt seam-close as "not done"
    # — the flip is NOT rolled back (the WP reached done; the *seam* did not).
    seam_close = _run_seam_close_gate(args, paths)
    summary["seam_close"] = seam_close
    if seam_close["verdict"] == "blocked":
        summary["gate_block"] = {
            "stage": "seam-close",
            "message": seam_close["reason"],
        }

    # Step 12.3 — remove worktree (tolerate-missing for idempotency; force so
    # executor-left untracked sidecars — journal/code-review bundles under the
    # worktree — don't strand the wrap at step-7-held: the WP is already merged,
    # so those artifacts are disposable and must not block teardown. #337)
    if args.worktree_path:
        result_3 = _call_tool("wpx-worktree", [
            "remove",
            "--wp", args.wp,
            "--project", paths.project,
            "--repo-root", str(paths.repo_root),
            "--worktree-path", args.worktree_path,
            "--tolerate-missing",
            "--force",
        ])
        summary["steps"]["worktree_remove"] = result_3.get("data", {})
    else:
        summary["steps"]["worktree_remove"] = {"skipped": "no --worktree-path"}

    # Cleanup the temp evidence file
    try:
        evidence_path.unlink()
    except OSError:
        pass

    emit_ok(data=summary)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Atomic Step 12 wrap: evidence + INDEX flip + worktree remove"
    )
    sub = parser.add_subparsers(dest="subcommand", required=True)

    p_wrap = sub.add_parser("wrap", help="Run all three Step 12 operations")
    add_common_args(p_wrap)
    p_wrap.add_argument("--wp", required=True)
    p_wrap.add_argument("--branch", required=True,
                        help="Branch name (for evidence block)")
    p_wrap.add_argument("--pipeline-result", required=True,
                        help="JSON output from wpx-pipeline (or @/path/to/file)")
    p_wrap.add_argument("--pre-squash-sha", default=None,
                        help="Pre-squash SHA on the branch (optional)")
    p_wrap.add_argument("--worktree-path", default=None,
                        help="Worktree path to remove (omit to skip removal)")
    p_wrap.add_argument("--post-deploy-verification", default=None,
                        help="Optional post-deploy verification string for WP frontmatter compatibility")
    p_wrap.add_argument("--allow-deferred", action="store_true", default=False,
                        help="Seam-close gate (12.2a): treat a knowingly-deferred "
                             "seam as passing (recorded) instead of blocking. "
                             "Default OFF = observed-or-blocked. Mirrors "
                             "sulis-verify-acceptance's conscious, logged escape.")
    p_wrap.add_argument("--from-gate-handoff", action="store_true", default=False,
                        help="The WP's prior status is `step-7-complete`, not "
                             "`in_progress` (#267). The `--enable-gate-handoff` "
                             "train path flips WPs to step-7-complete before the "
                             "train, and mark-gates-complete's pending_step12 "
                             "checklist drives the wrap from there. With this "
                             "flag the 12.2 flip expects step-7-complete; "
                             "without it, in_progress (the legacy per-WP path).")

    return parser


HANDLERS = {"wrap": cmd_wrap}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
