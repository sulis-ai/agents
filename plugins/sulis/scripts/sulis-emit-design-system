#!/usr/bin/env python3
"""sulis-emit-design-system — ingest authored design-systems.jsonld into the brain (brand-identity).

Thin shim over the shared ingest CLI (`_emit_ingest_cli`). Each DesignSystem
entry is a complete entity (real ULID + name + state + `realizes_identity →
brand` (required) + W3C-DTCG `tokens` (an object OR a URI string) + optional
WCAG pairs / token tiers / version); this validates them against the vendored
design-system schema (DR-030, sulis-brain v0.15.0) and persists them —
rejecting-without-persisting on a malformed entity.

The `ux-designer` agent calls this when it establishes a design language: after
emitting the Brand, it authors the DesignSystem (the three-tier tokens as DTCG)
with `realizes_identity` pointing at that Brand's ULID, and emits it. The
shape-valid `realizes_identity` is checked at schema time here; full lineage
(the Brand instance actually existing) is the brain's C4b runtime check.

Usage: sulis-emit-design-system --from-instances <path> [--base-dir D] [--domain D] [--repo-root D]
"""

from __future__ import annotations

import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _emit_ingest_cli import run_ingest_cli  # noqa: E402

if __name__ == "__main__":
    sys.exit(run_ingest_cli(entity_type="design-system", domain="brand-identity", list_key="design-systems"))
