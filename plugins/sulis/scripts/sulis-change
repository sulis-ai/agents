#!/usr/bin/env python3
"""sulis-change — manage change branches and worktrees (CW-01..CW-08).

A change is the unit of work in the Sulis marketplace: a dedicated git
branch + worktree, named `change/{primitive}-{slug}` where `primitive`
is one of SEA's 22 change primitives. All artifacts for the change live
on that branch; multiple changes run in parallel on separate branches;
merge to dev ends the change.

This CLI manages the lifecycle:

  start        Create a new change branch + worktree off the current dev
  adopt        Retrofit in-flight work (uncommitted / unpushed commits)
               into a change branch
  finish       Rebase the change onto dev, merge or open a PR, clean up
               the worktree
  list         Enumerate active change branches
  status       One change's summary (SHA, ahead/behind dev, WPs queued)

Reads + writes change metadata at `.changes/{primitive}-{slug}.yaml`
on the change branch.

Outputs structured JSON to stdout. Exit codes: 0 success, 1 expected
failure (slug taken, etc.), 2 internal error.

Specification: plugins/sulis/references/change-work-standard.md
"""

from __future__ import annotations

import argparse
import os
import shutil
import sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
from _change_context import write_change_context  # noqa: E402
from _change_state import (  # noqa: E402
    WORKFLOW_STAGES,
    change_dir,
    change_record_is_unreadable,
    changes_base,
    is_valid_stage,
    list_all_changes,
    mark_change_shipped,
    read_change_record,
    session_is_live,
    write_change_record,
    write_change_stage,
)
from _terminal_launcher import launch_change_terminal  # noqa: E402
from _wpxlib import (  # noqa: E402
    ALLOWED_CHANGE_PRIMITIVES,
    _apply_worktree_changes,
    _capture_worktree_changes,
    _clean_source_worktree,
    _gh_ref_sha,
    _log,
    _run,
    add_common_args,
    adopt_local_commits_into_change,
    adopt_uncommitted_into_change,
    change_worktree_path,
    cli_main,
    compose_change_branch,
    detect_adopt_state,
    discard_persisted_capture,
    emit_error,
    emit_internal_error,
    emit_ok,
    find_change_branches,
    persist_capture_durably,
    generate_change_ulid,
    git_worktree_add,
    git_worktree_remove,
    parse_change_branch,
    read_change_metadata,
    ulid_handle,
    validate_change_primitive,
    validate_change_slug,
    write_change_metadata,
)

# Heredoc tag the terminal launcher uses for pre-prompt delivery (ADR-003).
# Mirrored here so the pre-prompt builder can defensively assert it never
# leaks into the body (which would break the launcher's _validate_pre_prompt).
_PRE_PROMPT_HEREDOC_TAG = "SULIS_PROMPT_EOF"


# ─── Helpers ─────────────────────────────────────────────────────────────

def _resolve_repo_root(args: argparse.Namespace) -> Path:
    """Resolve the repo root from --repo-root or cwd."""
    repo_root = Path(getattr(args, "repo_root", None) or os.getcwd()).resolve()
    if not (repo_root / ".git").exists():
        emit_error(
            f"Not a git repo: {repo_root}",
            context={"hint": "Run from inside a git repo or pass --repo-root."},
        )
    return repo_root


def _dedouble_slug(primitive: str, slug: str) -> str:
    """Strip a redundant leading ``{primitive}-`` from a slug (#56 Part 4).

    The `/sulis:change` skill derives a slug from an intent that leads with
    the verb — "fix the login bug" → slug ``fix-login-bug`` — and pairs it
    with primitive ``fix``. ``compose_change_branch`` would then produce
    ``change/fix-fix-login-bug`` (the doubling the founder kept hitting) and
    a matching ``…-change-fix-fix-login-bug`` worktree.

    The fix is canonical (applied once, at resolution) so EVERY downstream
    consumer — branch compose, worktree path, metadata, parse round-trip —
    agrees. Conservative: only strip when what remains is STILL a valid slug
    (2-5 kebab words). A degenerate 1-word remainder (``fix-login`` →
    ``login``) is left doubled rather than produce an invalid slug.
    """
    prefix = f"{primitive}-"
    if slug.startswith(prefix):
        candidate = slug[len(prefix):]
        cand_ok, _ = validate_change_slug(candidate)
        if cand_ok:
            return candidate
    return slug


def _resolve_primitive_and_slug(args: argparse.Namespace) -> tuple[str, str]:
    """Validate and return (primitive, slug), de-doubled (#56 Part 4)."""
    primitive = (args.primitive or "feat").lower()
    slug = args.slug.lower()
    ok, reason = validate_change_primitive(primitive)
    if not ok:
        emit_error(reason)
    slug = _dedouble_slug(primitive, slug)
    ok, reason = validate_change_slug(slug)
    if not ok:
        emit_error(reason)
    return primitive, slug


def _worktree_for_branch(repo_root: Path, branch_ref: str) -> Path | None:
    """Return the worktree path that has ``branch_ref`` checked out, or None.

    The keystone of the #56 fix. git forbids the same branch in two
    worktrees BY DESIGN (independent indexes can't reconcile), so the ship
    path must never blind-``git checkout {base}`` in ``repo_root`` — base may
    be checked out in a sibling worktree. This parses ``git worktree list
    --porcelain`` to find where ``branch_ref`` actually lives so the squash-
    merge runs THERE.

    ``branch_ref`` is a short name like ``dev``; git reports the full
    ``refs/heads/dev`` in the ``branch`` line of each worktree block.
    Returns None when ``branch_ref`` is not checked out in any worktree
    (then the caller may safely check it out in ``repo_root``).
    """
    rc, out, _ = _run(["git", "worktree", "list", "--porcelain"],
                      cwd=repo_root, timeout=10)
    if rc != 0:
        return None
    target = f"refs/heads/{branch_ref}"
    current_path: str | None = None
    for line in out.splitlines():
        if line.startswith("worktree "):
            current_path = line[len("worktree "):].strip()
        elif line.startswith("branch ") and current_path is not None:
            if line[len("branch "):].strip() == target:
                return Path(current_path)
    return None


def _compose_squash_message(primitive: str, slug: str, metadata: dict) -> str:
    """Conventional-Commit squash message (#56 Part 3).

    ``{primitive}: {slug}`` subject (the change primitive IS the commit
    type — most are real CC types: feat/fix/refactor/chore; the rest degrade
    cleanly to a custom type), the change's plain-English intent in the body,
    and the Sulis co-author trailer. Replaces the old hardcoded
    ``feat({branch}): squash-merge {branch}`` which ignored the primitive and
    duplicated the branch name into both scope and body.
    """
    subject = f"{primitive}: {slug}"
    body_parts: list[str] = []
    intent = str(metadata.get("intent") or "").strip()
    if intent:
        body_parts.append(intent)
    body_parts.append("Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>")
    return subject + "\n\n" + "\n\n".join(body_parts)


# Uncommitted paths under these prefixes are sulis-managed metadata, not
# founder work: `start` writes `.changes/{...}.yaml` into the worktree and
# never commits it (the canonical copy lives in the branch-independent global
# store). They are safe to discard when removing a shipped worktree.
_SULIS_MANAGED_UNCOMMITTED: tuple[str, ...] = (".changes/",)


def _worktree_blocking_changes(worktree: Path) -> list[str]:
    """Uncommitted paths in ``worktree`` that are NOT sulis-managed metadata.

    ``git worktree remove`` (no ``--force``) refuses on ANY uncommitted or
    untracked content — and ``start`` always leaves ``.changes/{...}.yaml``
    uncommitted, so a blanket no-force remove would NEVER fire and #56 Part 2
    would be a silent no-op. This returns the genuinely-at-risk paths:
    anything dirty that isn't sulis-managed. An empty list means removal is
    safe (only regenerable metadata is dirty → force-remove); a non-empty
    list means there's real uncommitted founder work → KEEP + report it.
    """
    rc, out, _ = _run(["git", "status", "--porcelain"],
                      cwd=worktree, timeout=10)
    if rc != 0:
        return ["<could not read worktree git status>"]
    blocking: list[str] = []
    for line in out.splitlines():
        path = line[3:].strip()  # porcelain line: 'XY <path>'
        if not path:
            continue
        if " -> " in path:  # rename: 'old -> new'
            path = path.split(" -> ", 1)[1]
        if not any(path.startswith(p) for p in _SULIS_MANAGED_UNCOMMITTED):
            blocking.append(path)
    return blocking


def _remove_shipped_worktree(repo_root: Path, change_id: str,
                             worktree_dest: Path) -> dict:
    """Remove a shipped change's redundant worktree, safely (#56 Part 2).

    Gated: never remove the worktree the caller's shell is standing in; never
    remove a worktree with a live bound session (#32); never discard genuine
    uncommitted work (only regenerable `.changes/` metadata is safe).
    Force-removes only when the worktree is clean-enough. Returns a dict with
    ``worktree_removed`` + (when kept) ``worktree_kept_reason``.
    """
    # Never remove the worktree the caller is currently inside — that would
    # leave their shell in a deleted directory. This is independent of
    # session_is_live (which only catches spawned-terminal sessions, not a
    # manual `cd` into the worktree before running ship).
    try:
        cwd = Path.cwd().resolve()
        wt_resolved = worktree_dest.resolve()
        if cwd == wt_resolved or wt_resolved in cwd.parents:
            return {"worktree_removed": False,
                    "worktree_kept_reason": "the current shell is inside this "
                                            "worktree"}
    except OSError:
        pass
    if session_is_live(str(change_id)):
        return {"worktree_removed": False,
                "worktree_kept_reason": "a live session is bound to this change"}
    if not worktree_dest.exists():
        return {"worktree_removed": False,
                "worktree_kept_reason": "worktree already absent"}
    blocking = _worktree_blocking_changes(worktree_dest)
    if blocking:
        return {"worktree_removed": False,
                "worktree_kept_reason": (
                    "uncommitted work present (not part of the ship): "
                    + ", ".join(blocking[:5]))}
    # Only regenerable sulis metadata is dirty → safe to force-remove (the
    # global store holds the canonical record; shipped_sha pins the committed
    # state; `recreate` restores the worktree on demand).
    ok, msg = git_worktree_remove(repo_root, worktree_dest, force=True)
    out = {"worktree_removed": ok}
    if not ok:
        out["worktree_kept_reason"] = msg
    return out


def _archive_after_ship(repo_root: Path, change_id: str, branch: str,
                        worktree_dest: Path, *, remove_worktree: bool) -> dict:
    """Mark a change shipped (+ pin shipped_sha) and optionally remove its
    worktree. The SINGLE source both ship paths share — `finish --merge`
    (this script) and `mark-shipped` (the gh-based `/sulis:change ship`
    skill) — so the post-ship state can never drift between them.

    Pins ``shipped_sha`` = the change-branch tip ("the state it was in when
    we shipped"). Keeps the branch + record (the audit trail). Returns the
    ``archived`` dict for the command's JSON output.
    """
    rc, sha_out, _ = _run(["git", "rev-parse", f"refs/heads/{branch}"],
                          cwd=repo_root, timeout=10)
    shipped_sha = sha_out.strip() if rc == 0 else ""
    record_path = mark_change_shipped(str(change_id),
                                      shipped_sha=shipped_sha or None)
    archived = {
        "archived": record_path is not None,
        "change_id": change_id,
        "stage": "shipped",
        "shipped_sha": shipped_sha,
    }
    if remove_worktree:
        archived.update(
            _remove_shipped_worktree(repo_root, change_id, worktree_dest))
    return archived


def _metadata_path(repo_root: Path, primitive: str, slug: str) -> Path:
    return repo_root / ".changes" / f"{primitive}-{slug}.yaml"


def _build_change_pre_prompt(
    change_id: str,
    handle: str,
    slug: str,
    intent: str,
    primitive: str,
    context_md_path: Path | None,
) -> str:
    """Assemble the HERE-DOC body briefing Sulis on the change.

    Shape per the change-as-primitive design § "Session binding" step 5.
    Contains only the change identity + the absolute recon path — never
    secrets, never the heredoc tag (the launcher's _validate_pre_prompt
    rejects bodies containing it). Reading the recon file is the spawned
    Claude's job.

    ``context_md_path`` may be None when recon could not be written (best-
    effort); in that case the brief omits the recon-file reference.
    """
    if context_md_path is not None:
        recon_line = (
            f"Pre-spawn recon is at {context_md_path} — read it for git state "
            f"and the suggested next step, then greet me in change-context mode."
        )
    else:
        recon_line = (
            "Pre-spawn recon was unavailable (the recon file could not be "
            "written); greet me in change-context mode and run `/sulis:status` "
            "to orient."
        )
    body = (
        f"You are Sulis, focused on change {handle}: \"{intent}\".\n"
        f"This is a '{primitive}' change (slug: {slug}, id: {change_id}).\n"
        f"Your working directory is the change worktree.\n"
        f"{recon_line}"
    )
    # Defence in depth: never let the reserved tag into the body.
    if _PRE_PROMPT_HEREDOC_TAG in body:
        body = body.replace(_PRE_PROMPT_HEREDOC_TAG, "[redacted-tag]")
    return body


def _has_origin_remote(repo_root: Path) -> bool:
    """True when an ``origin`` remote is configured in ``repo_root``.

    Used by `start` to decide whether to even attempt the publish-at-creation
    push (#61). A missing origin is the normal local-only / offline case, not
    an error — it degrades to ``pushed_to_origin: false`` rather than a failed
    push attempt with noisy git stderr.
    """
    rc, out, _ = _run(["git", "remote"], cwd=repo_root, timeout=10)
    if rc != 0:
        return False
    return "origin" in out.split()


def _push_change_branch_to_origin(repo_root: Path, branch: str) -> bool:
    """Publish the freshly-created change branch to origin (#61, best-effort).

    The integration train merges via the GitHub API, so the change branch (the
    train's --base-branch) MUST exist on origin or the first train run 404s.
    `start` publishes it at creation so the founder never has to run a manual
    `git push -u origin <branch>` first.

    Graceful-degrade contract: the push is an ENHANCEMENT to `start`, never a
    new precondition. No origin remote, or a failed push (offline / auth /
    unreachable), must NOT crash `start` or unwind the local branch + worktree
    — it logs a clear warning and returns False so the caller can report
    ``pushed_to_origin: false``. Returns True only when the branch is genuinely
    published to origin.
    """
    if not _has_origin_remote(repo_root):
        _log(f"No 'origin' remote configured; change branch {branch} was NOT "
             f"published. The integration train will need it pushed first "
             f"(`git push -u origin {branch}`).")
        return False

    rc, _, err = _run(["git", "push", "-u", "origin", branch],
                      cwd=repo_root, timeout=60)
    if rc != 0:
        _log(f"Could not publish change branch {branch} to origin "
             f"(push failed: {err.strip() or 'unknown error'}). `start` "
             f"succeeded locally; push the branch before the integration "
             f"train runs (`git push -u origin {branch}`).")
        return False

    _log(f"Published change branch {branch} to origin.")
    return True


# ─── Subcommand: start ────────────────────────────────────────────────────

def cmd_start(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)
    primitive, slug = _resolve_primitive_and_slug(args)
    branch = compose_change_branch(primitive, slug)
    base_ref = args.base or "dev"

    # Check the branch doesn't already exist
    rc, _, _ = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                   cwd=repo_root, timeout=10)
    if rc == 0:
        emit_error(
            f"Change branch already exists: {branch}",
            context={"hint": f"Run `sulis-change list` to see active changes, "
                             f"or `sulis-change finish --slug {slug}` to ship it."},
        )

    # Determine worktree path
    worktree_dest = change_worktree_path(repo_root, primitive, slug)

    # Create the worktree + branch
    ok, msg = git_worktree_add(repo_root, branch, worktree_dest, base_ref)
    if not ok:
        emit_error(f"Worktree creation failed: {msg}")

    # Get the SHA we branched off
    rc, base_sha_out, _ = _run(["git", "rev-parse", base_ref],
                               cwd=repo_root, timeout=10)
    base_sha = base_sha_out.strip() if rc == 0 else ""

    # Generate ULID + handle (Phase 5 of change-as-primitive build —
    # WORK_PACKAGE_STANDARD v1.1.0 `change_id:` field).
    change_id = generate_change_ulid()
    handle = ulid_handle(change_id)

    # Write metadata into the worktree (it lives on the change branch)
    metadata = {
        "change_id": change_id,
        "handle": handle,
        "slug": slug,
        "primitive": primitive,
        "intent": getattr(args, "intent", "") or "",
        "branch": branch,
        "worktree_path": str(worktree_dest),
        "base_branch": base_ref,
        "base_sha": base_sha,
        "started_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    }
    write_change_metadata(_metadata_path(worktree_dest, primitive, slug),
                          metadata)

    # Pre-spawn recon — unconditional (cheap, useful artefact; nothing
    # downstream is harmed). Produces ~/.sulis/changes/{change_id}/CONTEXT.md.
    # Best-effort: write_change_context returns None if the path is unwritable
    # (permission / read-only FS / disk full). A recon-write failure degrades
    # gracefully — the spawn proceeds without CONTEXT.md rather than crashing.
    context_path = write_change_context(
        change_id=change_id,
        metadata=metadata,
        repo_root=repo_root,
    )
    if context_path is None:
        _log("Pre-spawn recon could not be written (path unwritable); "
             "continuing without CONTEXT.md")

    # Stamp the initial workflow stage (recon) into the per-change local
    # state.json. The stage skills advance it later (slice B); here we just
    # seed the starting position. Best-effort like recon: an unwritable path
    # degrades inside write_change_stage (returns None) without crashing.
    stage_path = write_change_stage(change_id, "recon")
    if stage_path is None:
        _log("Initial stage (recon) could not be written (path unwritable); "
             "continuing without state.json")

    # Write the full per-change record (change.json) — the branch-independent
    # global-index entry the dashboard + `sulis-change list` read. git is
    # per-branch, so the committed manifest on the change branch can't be
    # enumerated from dev; this local record can. Best-effort like recon/stage:
    # an unwritable path degrades inside write_change_record (returns None).
    record_path = write_change_record(change_id, {
        "change_id": change_id,
        "handle": handle,
        "slug": slug,
        "primitive": primitive,
        "branch": branch,
        "worktree_path": str(worktree_dest),
        "intent": metadata.get("intent", ""),
        "base_branch": base_ref,
        # base_sha is the git ref the cockpit diffs the worktree against
        # (L-11 / #44 — its absence left diffs dead for every change).
        "base_sha": base_sha,
        "created_at": metadata["started_at"],
        "stage": "recon",
    })
    if record_path is None:
        _log("Global change record could not be written (path unwritable); "
             "continuing without change.json")

    # Optional terminal spawn (WP-004). Spawn failure does NOT unwind the
    # change-creation work — the JSON surfaces spawn_result.status so the
    # founder can fall back to `cd worktree && claude --agent sulis`.
    spawn_result = None
    if getattr(args, "spawn", False):
        pre_prompt = _build_change_pre_prompt(
            change_id=change_id,
            handle=handle,
            slug=slug,
            intent=metadata.get("intent", ""),
            primitive=metadata.get("primitive", ""),
            context_md_path=context_path,
        )
        spawn_result = launch_change_terminal(
            change_id=change_id,
            worktree_path=worktree_dest,
            visible=True,
            pre_prompt=pre_prompt,
        )

    # Publish the change branch to origin (#61) — best-effort, graceful-degrade.
    # The branch ref already exists (git_worktree_add created it), so this just
    # publishes it. A no/unreachable remote degrades to pushed_to_origin=False
    # with a logged warning; it never unwinds the local branch + worktree.
    pushed_to_origin = _push_change_branch_to_origin(repo_root, branch)

    _log(f"Change started: {branch} ({handle}) at {worktree_dest}")
    emit_ok(data={
        "change_id": change_id,
        "handle": handle,
        "branch": branch,
        "primitive": primitive,
        "slug": slug,
        "worktree_path": str(worktree_dest),
        "base_branch": base_ref,
        "base_sha": base_sha,
        "metadata_path": str(_metadata_path(worktree_dest, primitive, slug)),
        "context_md_path": str(context_path) if context_path is not None else None,
        "spawn_result": spawn_result,
        "pushed_to_origin": pushed_to_origin,
    })


# ─── Subcommand: adopt ────────────────────────────────────────────────────

def cmd_adopt(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)
    primitive, slug = _resolve_primitive_and_slug(args)
    branch = compose_change_branch(primitive, slug)
    base_ref = args.base or "dev"
    mode = (args.mode or "forward").lower()
    remote_ref = args.remote_ref or "origin/dev"

    if mode not in ("forward", "rewrite"):
        emit_error(f"--mode must be 'forward' or 'rewrite' (got '{mode}')")

    # Check the branch doesn't already exist
    rc, _, _ = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                   cwd=repo_root, timeout=10)
    if rc == 0:
        emit_error(f"Change branch already exists: {branch}")

    # Inspect current state
    state = detect_adopt_state(repo_root, remote_ref=remote_ref)
    worktree_dest = change_worktree_path(repo_root, primitive, slug)

    has_uncommitted = state["has_uncommitted"]
    local_commits = state["local_commits_ahead"]

    # Mode handling
    if mode == "rewrite" and not args.force:
        emit_error(
            "--mode rewrite is destructive (rewrites history on the source "
            "branch). Re-run with --force to confirm.",
            context={"local_commits_ahead": len(local_commits)},
        )

    # Case 1: uncommitted only — worktree + worktree-safe file transfer
    # Case 2: local commits (and maybe uncommitted) — cherry-pick path
    # Case 3 (rewrite): same as case 2 but with --force semantics

    moved_what: list[str] = []

    if local_commits:
        # Case 2 / 3: relocate local commits onto the change branch.
        # The change branch starts at the REMOTE ref (clean state), not
        # the local ref (which already has the commits we want to
        # relocate — cherry-picking onto it would produce empty commits).
        #
        # Worktree-safe transfer (issue #53): we do NOT use `git stash` to
        # park the trailing uncommitted work, because the stash stack is
        # shared per-repo and a positional pop can grab a sibling worktree's
        # stash. Instead we capture the uncommitted delta + untracked files
        # explicitly, clean the source tree so the cherry-pick runs clean,
        # then re-apply the captured work into the worktree after the
        # cherry-pick. No shared-stack pop anywhere.
        capture: dict = {}
        recovery_dir = None
        if has_uncommitted:
            ok, msg, capture = _capture_worktree_changes(repo_root)
            if not ok:
                emit_error(f"capturing uncommitted work failed: {msg}")
            # DURABILITY (data-loss window): the source tree is about to be
            # cleaned while the ONLY copy of the founder's uncommitted work
            # is the in-memory `capture`. A cherry-pick or apply failure
            # after the clean would discard it on exit — silent loss. Persist
            # to a durable on-disk location FIRST (mirrors the old
            # `git stash push -u`'s recoverable on-disk park), surface it on
            # any failure leg, and discard it only once apply succeeds.
            ok, msg, recovery_dir = persist_capture_durably(capture)
            if not ok:
                emit_error(
                    f"persisting uncommitted work durably failed: {msg}. "
                    f"Source tree NOT cleaned; your work is intact."
                )
            # Clear the source tree so adopt_local_commits_into_change's
            # cherry-pick + reset operate on a clean working tree.
            ok, msg = _clean_source_worktree(repo_root, capture)
            if not ok:
                discard_persisted_capture(recovery_dir)
                emit_error(f"clearing source tree failed: {msg}")
            moved_what.append(
                f"{len(state['uncommitted_files'])} uncommitted change(s) "
                f"captured for worktree-safe transfer"
            )

        ok, msg = adopt_local_commits_into_change(
            repo_root, branch, remote_ref, worktree_dest, local_commits,
        )
        if not ok:
            # Source tree already cleaned; the durable copy is the founder's
            # only recovery path. Surface it loudly — never lose it silently.
            if recovery_dir is not None:
                emit_error(
                    f"adopt local-commits failed: {msg}. Your uncommitted "
                    f"work was saved before the source tree was cleaned and "
                    f"is recoverable at: {recovery_dir}",
                    context={"recovery_dir": str(recovery_dir)},
                )
            emit_error(f"adopt local-commits failed: {msg}")
        moved_what.append(msg)

        if has_uncommitted:
            # Re-apply the captured work into the worktree (where it belongs
            # now) — explicit file movement, never the shared stash stack.
            ok, msg = _apply_worktree_changes(repo_root, worktree_dest, capture)
            if not ok:
                # HARD ERROR (never success-with-WARN): the source tree is
                # cleaned, so a swallowed warning would report success while
                # the founder's work is gone from the source. Fail loudly and
                # point at the durable recovery copy.
                emit_error(
                    f"applying captured work to worktree failed: {msg}. Your "
                    f"uncommitted work is recoverable at: {recovery_dir}",
                    context={"recovery_dir": str(recovery_dir)},
                )
            # Success: the work is now safely in the worktree. Discard the
            # durable recovery copy — it was only a failure safety net.
            discard_persisted_capture(recovery_dir)

    elif has_uncommitted:
        # Case 1: uncommitted only
        ok, msg = adopt_uncommitted_into_change(
            repo_root, branch, base_ref, worktree_dest,
            state["uncommitted_files"],
        )
        if not ok:
            emit_error(f"adopt uncommitted failed: {msg}")
        moved_what.append(msg)

    else:
        # Nothing to adopt — but still create the branch + worktree (forward-only)
        ok, msg = git_worktree_add(repo_root, branch, worktree_dest, base_ref)
        if not ok:
            emit_error(f"worktree creation failed: {msg}")
        moved_what.append("nothing to retrofit; change branch + worktree created forward-only")

    # Get the SHA we branched off
    rc, base_sha_out, _ = _run(["git", "rev-parse", base_ref],
                               cwd=repo_root, timeout=10)
    base_sha = base_sha_out.strip() if rc == 0 else ""

    metadata = {
        "slug": slug,
        "primitive": primitive,
        "branch": branch,
        "worktree_path": str(worktree_dest),
        "base_branch": base_ref,
        "base_sha": base_sha,
        "started_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "adopted_from_sha": state["base_sha"],
        "adopt_mode": mode,
    }
    write_change_metadata(_metadata_path(worktree_dest, primitive, slug),
                          metadata)

    emit_ok(data={
        "branch": branch,
        "primitive": primitive,
        "slug": slug,
        "worktree_path": str(worktree_dest),
        "adopt_mode": mode,
        "moved": moved_what,
        "uncommitted_count": len(state["uncommitted_files"]),
        "local_commits_count": len(local_commits),
    })


# ─── Subcommand: finish ───────────────────────────────────────────────────

def cmd_finish(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)
    primitive, slug = _resolve_primitive_and_slug(args)
    branch = compose_change_branch(primitive, slug)
    base_ref = args.base or "dev"

    # Verify the branch exists
    rc, _, _ = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                   cwd=repo_root, timeout=10)
    if rc != 0:
        emit_error(f"Change branch not found: {branch}")

    worktree_dest = change_worktree_path(repo_root, primitive, slug)

    # Read the change metadata ONCE, up front — before any worktree removal
    # (#56 Part 2 may remove the worktree on a happy ship, and the metadata
    # lives inside it). Reused for the PR body, the squash commit message,
    # and the archive step.
    metadata = read_change_metadata(_metadata_path(worktree_dest, primitive, slug))

    # Fetch latest origin/{base_ref}
    rc, _, err = _run(["git", "fetch", "origin", base_ref],
                     cwd=repo_root, timeout=60)
    if rc != 0:
        emit_error(f"git fetch origin {base_ref} failed: {err}")

    # Decide path: --merge (squash-merge to dev, push) or --pr (open PR via gh)
    if args.pr:
        # Push the branch; open a PR
        rc, _, err = _run(["git", "push", "-u", "origin", branch],
                         cwd=repo_root, timeout=60)
        if rc != 0:
            emit_error(f"git push origin {branch} failed: {err}")

        # Compose PR body from metadata
        pr_body = (
            f"Change: `{branch}`\n\n"
            f"Primitive: {metadata.get('primitive', primitive)}\n"
            f"Started at: {metadata.get('started_at', 'unknown')}\n"
        )
        rc, out, err = _run(
            ["gh", "pr", "create",
             "--base", base_ref,
             "--head", branch,
             "--title", f"{branch}",
             "--body", pr_body],
            cwd=repo_root, timeout=60,
        )
        if rc != 0:
            emit_error(f"gh pr create failed: {err}")
        pr_url = out.strip().splitlines()[-1] if out.strip() else ""
        outcome = {"mode": "pr", "pr_url": pr_url}

    elif args.merge:
        # Squash-merge locally — WORKTREE-AWARE (#56 Part 1).
        # git forbids the same branch in two worktrees, so we must perform the
        # merge in WHATEVER worktree already holds {base_ref} — never blindly
        # `git checkout {base_ref}` in repo_root (the recurring #56 fatal when
        # dev lives in a sibling worktree).
        base_dir = _worktree_for_branch(repo_root, base_ref)
        if base_dir is None:
            # base isn't checked out anywhere → safe to check it out here.
            rc, _, err = _run(["git", "checkout", base_ref],
                             cwd=repo_root, timeout=30)
            if rc != 0:
                emit_error(
                    f"git checkout {base_ref} failed: {err}",
                    context={"hint": f"'{base_ref}' could not be checked out "
                                     f"in {repo_root}. If it is checked out in "
                                     f"another worktree, run the ship from "
                                     f"that worktree, or free it there first."},
                )
            base_dir = repo_root
        elif not base_dir.exists():
            emit_error(
                f"'{base_ref}' is registered to a worktree that no longer "
                f"exists on disk: {base_dir}",
                context={"hint": "Run `git worktree prune`, then retry — or "
                                 f"check out {base_ref} somewhere first."},
            )
        # From here, operate in base_dir (the worktree that holds base_ref).
        # 1. Pull latest base.
        rc, _, err = _run(["git", "pull", "origin", base_ref],
                         cwd=base_dir, timeout=60)
        if rc != 0:
            emit_error(f"git pull origin {base_ref} failed: {err}")

        # 2. Squash-merge the change branch into base.
        rc, _, err = _run(["git", "merge", "--squash", branch],
                         cwd=base_dir, timeout=30)
        if rc != 0:
            emit_error(f"git merge --squash {branch} failed: {err}")

        # 3. Commit (only if there's anything staged) — Conventional-Commit
        #    message derived from the change (#56 Part 3).
        rc, status_out, _ = _run(["git", "status", "--porcelain"],
                                 cwd=base_dir, timeout=10)
        if status_out.strip():
            commit_msg = _compose_squash_message(primitive, slug, metadata)
            rc, _, err = _run(["git", "commit", "-m", commit_msg],
                             cwd=base_dir, timeout=30)
            if rc != 0:
                emit_error(f"git commit (merge) failed: {err}")

        # 4. Push base.
        rc, _, err = _run(["git", "push", "origin", base_ref],
                         cwd=base_dir, timeout=60)
        if rc != 0:
            emit_error(f"git push origin {base_ref} failed: {err}")

        outcome = {"mode": "merge", "merged_in": str(base_dir)}
    else:
        emit_error("Pass --merge (squash-merge locally) or --pr (open a PR).")

    # Archive, never delete the BRANCH or RECORD (#38). On a successful merge:
    #   - mark the change shipped (stage='shipped' + shipped_at + shipped_sha),
    #   - pin the change-branch tip as the shipped state (#56 Part 2),
    #   - remove the now-redundant WORKTREE (gated on no live session, #32),
    #   - KEEP the branch + record — the audit trail. `sulis-change recreate`
    #     re-materialises the worktree on demand from the pinned sha.
    # Claim-3 (validated): the cockpit uses worktree_path only for `.exists()`;
    # retrace/diff is git-based (base_sha + branch). So removing the worktree
    # preserves full visibility while ending worktree sprawl.
    # Archive ONLY on a real merge ship. A --pr opens a PR but does NOT merge,
    # so the change is not shipped yet — it gets marked shipped later, when the
    # PR lands and the skill calls `mark-shipped`. (Pre-#56, --pr wrongly
    # flipped the change to 'shipped'; this corrects it.)
    archived: dict = {"archived": False}
    if outcome.get("mode") == "merge":
        change_id = metadata.get("change_id")
        if change_id:
            # The shared helper applies the safety gates (cwd, live session,
            # uncommitted work). Both this path and the gh-based `mark-shipped`
            # path go through it so they can't drift (the same DRY discipline
            # that fixed the L-02 parser split). --no-cleanup keeps the worktree.
            archived = _archive_after_ship(
                repo_root, str(change_id), branch, worktree_dest,
                remove_worktree=not args.no_cleanup)
            if args.no_cleanup:
                archived["no_cleanup_flag"] = (
                    "set — worktree removal skipped; the worktree is kept")
        else:
            # The merge is real, but with no change_id we can't advance the
            # record — surface it rather than silently returning archived=False.
            archived["warning"] = (
                "no change_id in the change manifest — the merge succeeded but "
                "the change record was not advanced to 'shipped'")

    emit_ok(data={
        "branch": branch,
        "primitive": primitive,
        "slug": slug,
        "outcome": outcome,
        "archived": archived,
    })


# ─── Subcommand: list ────────────────────────────────────────────────────

def cmd_list(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)

    # The local records are the branch-independent global index — this is what
    # the dashboard reads too. git is per-branch, so enumerating change/*
    # branches only sees what's checked out from here; the records see every
    # change regardless of branch. We cross-reference the live branch list to
    # flag records whose branch has gone (merged/deleted/pruned).
    records = list_all_changes()
    rc, branch_out, _ = _run(["git", "branch", "--list", "change/*"],
                             cwd=repo_root, timeout=10)
    live_branches = set()
    if rc == 0:
        for line in branch_out.splitlines():
            # git marks the current branch with "* " and a worktree-checked-out
            # branch with "+ "; strip either marker plus leading whitespace.
            name = line.lstrip("*+ ").strip()
            if name:
                live_branches.add(name)

    enriched: list[dict] = []
    for record in records:
        branch = record.get("branch", "")
        item = dict(record)
        item["branch_present"] = branch in live_branches
        wt = record.get("worktree_path", "")
        dest = Path(wt) if wt else None
        item["worktree_present"] = bool(dest and dest.exists())
        if item["worktree_present"]:
            rc, status_out, _ = _run(
                ["git", "status", "--porcelain"],
                cwd=dest, timeout=10,
            )
            item["dirty"] = bool(rc == 0 and status_out.strip())
        else:
            item["dirty"] = False
        enriched.append(item)

    emit_ok(data={
        "active_count": len(enriched),
        "changes": enriched,
    })


# ─── Subcommand: status ──────────────────────────────────────────────────

def cmd_status(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)
    primitive, slug = _resolve_primitive_and_slug(args)
    branch = compose_change_branch(primitive, slug)
    base_ref = args.base or "dev"

    rc, _, _ = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                   cwd=repo_root, timeout=10)
    if rc != 0:
        emit_error(f"Change branch not found: {branch}")

    worktree_dest = change_worktree_path(repo_root, primitive, slug)
    metadata = read_change_metadata(_metadata_path(worktree_dest, primitive, slug))

    # SHAs + ahead/behind
    rc, branch_sha_out, _ = _run(["git", "rev-parse", branch],
                                 cwd=repo_root, timeout=10)
    branch_sha = branch_sha_out.strip() if rc == 0 else ""
    rc, base_sha_out, _ = _run(["git", "rev-parse", base_ref],
                               cwd=repo_root, timeout=10)
    base_sha = base_sha_out.strip() if rc == 0 else ""

    # ahead / behind
    rc, ahead_out, _ = _run(
        ["git", "rev-list", "--count", f"{base_ref}..{branch}"],
        cwd=repo_root, timeout=10,
    )
    ahead = int(ahead_out.strip()) if rc == 0 and ahead_out.strip().isdigit() else 0
    rc, behind_out, _ = _run(
        ["git", "rev-list", "--count", f"{branch}..{base_ref}"],
        cwd=repo_root, timeout=10,
    )
    behind = int(behind_out.strip()) if rc == 0 and behind_out.strip().isdigit() else 0

    emit_ok(data={
        "branch": branch,
        "primitive": primitive,
        "slug": slug,
        "worktree_path": str(worktree_dest),
        "worktree_present": worktree_dest.exists(),
        "branch_sha": branch_sha,
        "base_sha": base_sha,
        "ahead_of_base": ahead,
        "behind_base": behind,
        "metadata": metadata,
    })


# ─── Subcommand: stage ────────────────────────────────────────────────────

def cmd_stage(args: argparse.Namespace) -> None:
    """Stamp the workflow stage a change has reached.

    Each stage skill (recon / specify / design / run-all / review) calls this
    on completion so the dashboard reflects where the change is in the
    six-stage workflow. The stage is written to the branch-independent local
    store (`{state_base}/changes/{change_id}/state.json`), so it survives
    branch switches and is visible to the global cross-change view.

    Resolves the change_id from `--change-id` if given, else from the
    `SULIS_CHANGE_ID` environment variable (set in every change-bound
    session). Validates the stage against WORKFLOW_STAGES before writing.
    """
    stage = args.stage
    if not is_valid_stage(stage):
        emit_error(
            f"Unknown workflow stage: {stage!r}. "
            f"Valid stages: {', '.join(WORKFLOW_STAGES)}.",
            context={"given_stage": stage, "valid_stages": list(WORKFLOW_STAGES)},
        )

    change_id = args.change_id or os.environ.get("SULIS_CHANGE_ID")
    if not change_id:
        emit_error(
            "No change to stamp: pass --change-id, or run inside a "
            "change-bound session (SULIS_CHANGE_ID is unset).",
            context={"stage": stage},
        )

    state_path = write_change_stage(change_id, stage)
    if state_path is None:
        # Best-effort write failed (unwritable state dir) — surface honestly
        # rather than claiming success.
        emit_error(
            f"Couldn't record the {stage!r} stage for {change_id} "
            f"(state store not writable).",
            context={"change_id": change_id, "stage": stage},
        )

    emit_ok(data={
        "change_id": change_id,
        "stage": stage,
        "state_path": str(state_path),
    })


# ─── Subcommand: nuke ─────────────────────────────────────────────────────

def _local_state_base() -> Path:
    """The base dir holding per-change local state: {state_base}/changes/.

    Delegates to _change_state.changes_base so the SULIS_STATE_DIR override
    (and the ~/.sulis production default) resolve identically everywhere.
    """
    return changes_base()


def _scan_state_dir_by_prefix(prefix: str) -> tuple[str, str | None]:
    """Resolve a change_id by scanning ~/.sulis/changes/* for a dir whose name
    starts with the 6-char handle prefix.

    `prefix` is the first 6 chars of the ULID (the part after "CH-"). The
    local state dir is named with the full ULID, so a unique prefix match
    yields the change_id. Returns (resolution_note, change_id_or_None):

      - exactly one match  → (matched-via-prefix, <change_id>)
      - zero matches       → (no-prefix-match, None)
      - >1 match           → ("AMBIGUOUS:...", None)  (caller surfaces error)

    Best-effort: an unreadable base dir yields (no-prefix-match, None).
    """
    base = _local_state_base()
    try:
        candidates = [d for d in base.iterdir()
                      if d.is_dir() and d.name.startswith(prefix)]
    except OSError:
        return "no-prefix-match", None
    if len(candidates) == 1:
        return "matched-via-prefix", candidates[0].name
    if len(candidates) > 1:
        names = ", ".join(sorted(d.name for d in candidates))
        return f"AMBIGUOUS:{names}", None
    return "no-prefix-match", None


def _resolve_change_id(repo_root: Path, primitive: str, slug: str,
                       worktree_dest: Path,
                       handle: str | None) -> tuple[str, str]:
    """Resolve a change's change_id via the fallback chain (stop at first hit).

    0. Local record → scan {state_base}/changes/*/change.json for one whose
       slug matches (or whose handle matches, when --handle was given). This
       is the preferred, branch-independent resolver: the record is the global
       index and doesn't depend on a manifest living in a worktree.
    1. --handle CH-XXXXXX given → scan {state_base}/changes/* for a dir whose
       name starts with the 6-char prefix. Unique in practice; >1 match is an
       error the caller surfaces (returned as a "AMBIGUOUS:" resolution note).
    2. Worktree manifest → read {worktree}/.changes/{primitive}-{slug}.yaml
       (the manifest is committed on the change branch, so it lives in the
       WORKTREE, not the dev checkout where nuke runs).
    3. Dev-checkout manifest → read <repo-root>/.changes/{primitive}-{slug}.yaml
       (rare — only if a copy happens to exist locally, e.g. on dev).
    4. Honest-degrade → "" (state_dir stays null; the caller reports it
       truthfully and removes branch + worktree + manifest only).

    Returns (change_id_or_empty, resolution_note). resolution_note records
    which rung of the chain hit, for the JSON + the ambiguity error path.
    """
    # 0. Local record (change.json) — preferred, branch-independent. Match on
    # the branch slug; the records carry the change_id directly.
    for record in list_all_changes():
        if record.get("slug") == slug and len(record.get("change_id", "")) == 26:
            return record["change_id"], "matched-via-record"

    # 1. Handle-prefix scan of local state dirs.
    if handle and handle.startswith("CH-") and len(handle) == 9:
        prefix = handle[len("CH-"):]
        note, change_id = _scan_state_dir_by_prefix(prefix)
        if change_id:
            return change_id, note
        if note.startswith("AMBIGUOUS:"):
            matches = note[len("AMBIGUOUS:"):]
            emit_error(
                f"Handle {handle} matches more than one local change state "
                f"dir under ~/.sulis/changes/ ({matches}). Disambiguate with "
                f"--slug, or remove the stale dir(s) by hand.",
                context={"handle": handle, "matches": matches},
            )
        # else: no prefix match — fall through to the manifest rungs.

    # 2. Worktree manifest (the common case — manifest committed on the branch).
    wt_manifest = _metadata_path(worktree_dest, primitive, slug)
    meta = read_change_metadata(wt_manifest)
    change_id = meta.get("change_id", "") or ""
    if len(change_id) == 26:
        return change_id, "matched-via-worktree-manifest"

    # 3. Dev-checkout manifest (rare local copy).
    dev_manifest = _metadata_path(repo_root, primitive, slug)
    if dev_manifest != wt_manifest:
        meta = read_change_metadata(dev_manifest)
        change_id = meta.get("change_id", "") or ""
        if len(change_id) == 26:
            return change_id, "matched-via-dev-manifest"

    # 4. Honest-degrade: unresolved. state_dir stays null downstream.
    return "", "unresolved"


def _resolve_nuke_target(repo_root: Path, args: argparse.Namespace) -> dict:
    """Resolve --slug or --handle to a change-branch descriptor.

    Reuses find_change_branches (the same enumeration list/status use) to find
    the branch + worktree. The change_id (hence the local state dir) is then
    resolved via the _resolve_change_id fallback chain — robust to the manifest
    living only in the worktree (the production case) rather than the dev
    checkout where nuke runs.

    Matching:
      --slug  → match the branch slug.
      --handle → match a change whose change_id (resolved via the fallback
                 chain) has handle CH-<first-6-of-ULID> == the given handle.
                 The handle-prefix scan of local state dirs is the primary
                 resolver; for branches whose state dir is gone we still match
                 on the handle prefix against the branch's resolved change_id.

    Returns a dict {branch, primitive, slug, current, change_id,
    change_id_resolution, worktree_path, manifest_path}. Calls emit_error
    (exits) when no selector is given or no matching change is found.
    """
    slug = getattr(args, "slug", None)
    handle = getattr(args, "handle", None)
    if not slug and not handle:
        emit_error(
            "Pass a selector: --slug SLUG or --handle CH-XXXXXX.",
            context={"hint": "Run `sulis-change list` to see active changes."},
        )

    candidates = find_change_branches(repo_root)
    for c in candidates:
        dest = change_worktree_path(repo_root, c["primitive"], c["slug"])
        change_id, resolution = _resolve_change_id(
            repo_root, c["primitive"], c["slug"], dest, handle,
        )
        change_handle = ulid_handle(change_id) if len(change_id) == 26 else ""

        matched = False
        if slug and c["slug"] == slug.lower():
            matched = True
        if handle and change_handle and change_handle == handle:
            matched = True
        if matched:
            return {
                "branch": c["branch"],
                "primitive": c["primitive"],
                "slug": c["slug"],
                "current": c["current"],
                "change_id": change_id,
                "change_id_resolution": resolution,
                # The state dir lives under ~/.sulis/changes/, NOT in the
                # worktree; nuke removes the dev-side manifest copy if present.
                "worktree_path": dest,
                "manifest_path": _metadata_path(repo_root, c["primitive"],
                                                c["slug"]),
            }

    selector = f"--slug {slug}" if slug else f"--handle {handle}"
    emit_error(
        f"No active change matches {selector}.",
        context={"hint": "Run `sulis-change list` to see active changes."},
    )


def _branch_has_unmerged_commits(repo_root: Path, branch: str,
                                  base_ref: str = "dev") -> int:
    """Return the count of commits on `branch` not yet on `base_ref`.

    0 means fully merged (or branch/base unresolvable — treated as nothing
    to lose). Best-effort: a git failure returns 0 rather than blocking nuke.
    """
    rc, out, _ = _run(
        ["git", "rev-list", "--count", f"{base_ref}..{branch}"],
        cwd=repo_root, timeout=10,
    )
    if rc == 0 and out.strip().isdigit():
        return int(out.strip())
    return 0


def cmd_nuke(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)
    target = _resolve_nuke_target(repo_root, args)
    branch = target["branch"]
    worktree_dest = target["worktree_path"]
    manifest = target["manifest_path"]
    change_id = target["change_id"]

    # Safety 1: never nuke the change you're currently on. Check the current
    # branch of the repo_root we were pointed at (which, when run from inside
    # the change worktree, IS the change branch).
    rc, cur_out, _ = _run(["git", "branch", "--show-current"],
                          cwd=repo_root, timeout=10)
    current_branch = cur_out.strip() if rc == 0 else ""
    if current_branch == branch:
        emit_error(
            f"Can't nuke the change you're currently on ({branch}) — "
            f"switch to dev first (`git checkout dev`), then re-run.",
            context={"current_branch": current_branch},
        )

    # Safety 1.4 (#22): refuse to nuke when the change record EXISTS but
    # can't be read (corrupt JSON, truncated write, OS error). Without
    # this guard, `read_change_record` returns None for BOTH 'file absent'
    # (benign) and 'file unreadable' (load-bearing), so Safety 1.5's
    # shipped check below would silently fail open on a corrupt record
    # and the nuke would destroy the audit trail #38 was designed to
    # preserve. --force still overrides (same refusal-by-default
    # semantics as Safety 1.5).
    if change_id and change_record_is_unreadable(change_id) and not args.force:
        emit_error(
            f"Refusing to nuke {branch}: the change record exists but "
            f"can't be read (corrupt or unreadable). I can't verify "
            f"this isn't a shipped change, so I won't risk destroying "
            f"its audit trail. Run with `--force` if you really mean "
            f"to remove it.",
            context={"branch": branch, "change_id": change_id,
                     "reason": "record_unreadable"},
        )

    # Safety 1.5 (#38): refuse to nuke a SHIPPED change unless --force. The
    # archive is the audit trail — destroying it loses the retrace path for a
    # change the founder may need to inspect later (this is exactly the
    # premature-nuke incident class). --force still works for genuine cleanup.
    if change_id:
        record = read_change_record(change_id)
        if record and str(record.get("stage", "")).strip().lower() == "shipped" and not args.force:
            emit_error(
                f"Refusing to nuke a shipped change ({branch}) — the worktree "
                f"and branch are the audit trail (#38). The cockpit + future "
                f"sessions read them. Use `--force` to override if you really "
                f"mean to destroy the archive.",
                context={"branch": branch, "change_id": change_id, "stage": "shipped"},
            )

    state_dir = change_dir(change_id) if change_id else None

    # Safety 2: refuse to nuke a branch with unmerged commits unless --force.
    # (--force is also the mechanical delete switch; without it we dry-run.)
    unmerged = _branch_has_unmerged_commits(repo_root, branch)

    footprint = {
        "worktree": str(worktree_dest),
        "branch": branch,
        "state_dir": str(state_dir) if state_dir else None,
        "manifest": str(manifest),
    }

    if not args.force:
        # Dry-run: list what WOULD be removed; delete nothing; exit 0.
        warnings = []
        if unmerged:
            warnings.append(
                f"branch {branch} has {unmerged} unmerged commit(s) — "
                f"these would be LOST. Re-run with --force to confirm."
            )
        if state_dir is None:
            warnings.append(
                "couldn't locate local state for this change; removing "
                "branch + worktree + manifest only (no ~/.sulis/changes/ dir)."
            )
        emit_ok(data={
            "dry_run": True,
            "branch": branch,
            "primitive": target["primitive"],
            "slug": target["slug"],
            "change_id": change_id or None,
            "change_id_resolution": target.get("change_id_resolution"),
            "would_remove": footprint,
            "unmerged_commits": unmerged,
        }, warnings=warnings or None)
        return

    # --force path: tear down the full footprint. Each step is idempotent —
    # a half-cleaned change (worktree already gone, no state dir, etc.) must
    # not crash; report truthfully what was actually removed this run.
    removed: dict = {}

    # 1. Worktree (force — untracked manifest lives inside; work is abandoned).
    ok, detail = git_worktree_remove(repo_root, worktree_dest, force=True)
    removed["worktree"] = ok
    removed["worktree_detail"] = detail
    # Prune stale refs before deleting the branch.
    _run(["git", "worktree", "prune"], cwd=repo_root, timeout=10)

    # 2. Branch (-D: forced, since the work is being abandoned).
    rc, _, err = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                      cwd=repo_root, timeout=10)
    if rc == 0:
        rc, out, err = _run(["git", "branch", "-D", branch],
                            cwd=repo_root, timeout=10)
        removed["branch"] = rc == 0
        if rc != 0:
            removed["branch_detail"] = (err or out or "branch delete failed").strip()
    else:
        removed["branch"] = False
        removed["branch_detail"] = "branch already absent"

    # 3. Local state dir (~/.sulis/changes/{change_id}/).
    if state_dir is not None and state_dir.exists():
        try:
            shutil.rmtree(state_dir)
            removed["state_dir"] = True
        except OSError as exc:
            removed["state_dir"] = False
            removed["state_dir_detail"] = str(exc)
    else:
        removed["state_dir"] = False
        removed["state_dir_detail"] = "state dir already absent"

    # 4. Committed manifest (.changes/{primitive}-{slug}.yaml). Removing it is
    # a working-tree change the founder commits separately (or, on dev, just a
    # file removal). nuke only removes the file; it never commits.
    if manifest.exists():
        try:
            manifest.unlink()
            removed["manifest"] = True
        except OSError as exc:
            removed["manifest"] = False
            removed["manifest_detail"] = str(exc)
    else:
        removed["manifest"] = False
        removed["manifest_detail"] = "manifest already absent"

    _log(f"Change nuked: {branch} ({change_id or 'no-id'})")
    nuke_warnings = []
    if state_dir is None:
        nuke_warnings.append(
            "couldn't locate local state for this change; removed "
            "branch + worktree + manifest only (no ~/.sulis/changes/ dir)."
        )
    emit_ok(data={
        "dry_run": False,
        "branch": branch,
        "primitive": target["primitive"],
        "slug": target["slug"],
        "change_id": change_id or None,
        "change_id_resolution": target.get("change_id_resolution"),
        "removed": removed,
        "unmerged_commits_discarded": unmerged,
    }, warnings=nuke_warnings or None)


# ─── argparse ────────────────────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description=(
            "sulis-change — manage change branches and worktrees (CW-01..CW-08). "
            "A change is the unit of work: change/{primitive}-{slug} branch + "
            "dedicated worktree. See plugins/sulis/references/change-work-standard.md."
        ),
    )
    sub = parser.add_subparsers(dest="subcommand", required=True)

    def _common(p: argparse.ArgumentParser, include_slug: bool = True) -> None:
        p.add_argument("--repo-root", default=os.getcwd(),
                       help="Path to the repo root (default: cwd)")
        if include_slug:
            p.add_argument("--slug", required=True,
                           help="Change slug, kebab-case, 2-5 words "
                                "(e.g. introduce-payments)")
            p.add_argument("--primitive", default="feat",
                           help=f"Change primitive (default: feat). "
                                f"Allowed: {', '.join(ALLOWED_CHANGE_PRIMITIVES)}")
        p.add_argument("--base", default=None,
                       help="Base ref for the change (default: dev)")

    p_start = sub.add_parser("start", help="Create a new change branch + worktree")
    _common(p_start)
    p_start.add_argument(
        "--intent", default="",
        help="One-line plain-English intent for the change (briefs the "
             "spawned Sulis session via the pre-prompt + recon).",
    )
    p_start.add_argument(
        "--spawn", action="store_true",
        help="After creating the change branch + worktree + metadata, write "
             "the recon CONTEXT.md and spawn a new terminal in the worktree "
             "with SULIS_CHANGE_ID set, running `claude --agent sulis` with "
             "a HERE-DOC pre-prompt briefing the agent on the change. "
             "Default off. See plugins/sulis/docs/change-as-primitive-design.md "
             "§ Session binding.",
    )

    p_adopt = sub.add_parser("adopt", help="Retrofit in-flight work into a change")
    _common(p_adopt)
    p_adopt.add_argument("--mode", default="forward",
                         choices=["forward", "rewrite"],
                         help="forward (default): create branch from current "
                              "dev, leave existing commits where they are. "
                              "rewrite: destructive — relocates commits.")
    p_adopt.add_argument("--remote-ref", default="origin/dev",
                         help="Remote ref to compare local against "
                              "(default: origin/dev)")
    p_adopt.add_argument("--force", action="store_true",
                         help="Required for --mode rewrite (history rewrite confirmation)")

    p_finish = sub.add_parser("finish", help="Rebase + merge/PR + cleanup")
    _common(p_finish)
    p_finish.add_argument("--merge", action="store_true",
                          help="Squash-merge to base locally + push")
    p_finish.add_argument("--pr", action="store_true",
                          help="Push branch + open PR via gh")
    p_finish.add_argument("--no-cleanup", action="store_true",
                          help="Skip worktree + branch cleanup")

    p_list = sub.add_parser("list", help="List active change branches")
    _common(p_list, include_slug=False)

    p_status = sub.add_parser("status", help="Show one change's state")
    _common(p_status)

    p_stage = sub.add_parser(
        "stage",
        help="Stamp the workflow stage a change has reached "
             "(recon/specify/design/implement/review/ship)",
    )
    p_stage.add_argument(
        "stage",
        help="The workflow stage now reached: "
             + " / ".join(WORKFLOW_STAGES),
    )
    p_stage.add_argument(
        "--change-id", default=None,
        help="Change ULID to stamp (default: the SULIS_CHANGE_ID env var)",
    )

    # `mark-shipped` is the terminal-stage transition (#38). Called by the
    # `/sulis:change ship` skill after `gh pr merge` succeeds: flips
    # stage='shipped' + records shipped_at on the change record. Idempotent;
    # never deletes anything (archive, not delete). Distinct from the `stage`
    # subcommand which only updates state.json.
    p_mark_shipped = sub.add_parser(
        "mark-shipped",
        help="Mark a change as shipped (archive, no deletion) — #38.",
    )
    p_mark_shipped.add_argument("--change-id", default=None,
                                help="Change ULID (default: SULIS_CHANGE_ID env var)")
    p_mark_shipped.add_argument("--handle", default=None,
                                help="Change handle (e.g. CH-01HYQC) to resolve the ULID")
    p_mark_shipped.add_argument("--repo-root", default=os.getcwd(),
                                help="Path to the repo root (default: cwd)")

    p_nuke = sub.add_parser(
        "nuke",
        help="Abandon + delete a change and its full footprint "
             "(worktree, branch, local state, manifest)",
    )
    p_nuke.add_argument("--repo-root", default=os.getcwd(),
                        help="Path to the repo root (default: cwd)")
    p_nuke.add_argument("--slug", default=None,
                        help="Change slug to nuke (e.g. introduce-payments)")
    p_nuke.add_argument("--handle", default=None,
                        help="Change handle to nuke (e.g. CH-01HYQC)")
    p_nuke.add_argument(
        "--force", action="store_true",
        help="Actually delete. Without --force, nuke dry-runs: it lists the "
             "footprint that WOULD be removed and exits without deleting. "
             "--force is also required to discard a branch with unmerged "
             "commits.",
    )

    # `recreate` re-materialises a shipped change's worktree on demand (#56
    # Part 2). After ship the worktree is removed but the branch + record
    # (with the pinned shipped_sha) are kept; this brings the worktree back.
    p_recreate = sub.add_parser(
        "recreate",
        help="Re-materialise a shipped change's worktree from its pinned "
             "state (on the branch if present, else detached at shipped_sha).",
    )
    p_recreate.add_argument("--repo-root", default=os.getcwd(),
                            help="Path to the repo root (default: cwd)")
    p_recreate.add_argument("--handle", default=None,
                            help="Change handle (e.g. CH-01HYQC)")
    p_recreate.add_argument("--slug", default=None,
                            help="Change slug (alternative to --handle)")
    p_recreate.add_argument(
        "--primitive", default="feat",
        help="Change primitive (used with --slug; default: feat)")

    return parser


def cmd_mark_shipped(args: argparse.Namespace) -> None:
    """#38/#56 — flip stage='shipped', pin shipped_sha, remove the worktree.

    Called by the `/sulis:change ship` skill after `gh pr merge` succeeds (the
    founder-facing ship path; the local `finish --merge` path is the other).
    Both go through `_archive_after_ship` so the post-ship state is identical:
    branch + record kept (audit trail), shipped_sha pinned, redundant worktree
    removed (gated on no live session + no uncommitted work). Idempotent: a
    repeat call preserves the first shipped_at + shipped_sha.
    """
    repo_root = Path(getattr(args, "repo_root", None) or os.getcwd()).resolve()
    change_id = args.change_id or os.environ.get("SULIS_CHANGE_ID")
    if not change_id and args.handle:
        # Resolve a handle → change_id via the global store.
        handle = args.handle.upper()
        for record in list_all_changes():
            if str(record.get("handle", "")).upper() == handle:
                change_id = record.get("change_id")
                break
        if not change_id:
            emit_error(f"no change found for handle {args.handle!r}")
    if not change_id:
        emit_error("--change-id, --handle, or SULIS_CHANGE_ID required")
    record = read_change_record(str(change_id))
    if record is None:
        emit_error(f"no change record found for change_id={change_id!r}")
        return  # for type checker
    primitive = str(record.get("primitive") or "feat")
    slug = str(record.get("slug") or "")
    branch = str(record.get("branch")
                 or compose_change_branch(primitive, slug))
    worktree_dest = Path(record.get("worktree_path")
                         or change_worktree_path(repo_root, primitive, slug))

    archived = _archive_after_ship(repo_root, str(change_id), branch,
                                   worktree_dest, remove_worktree=True)
    record = read_change_record(str(change_id)) or {}
    emit_ok(data={
        "change_id": change_id,
        "stage": "shipped",
        "shipped_at": record.get("shipped_at"),
        "shipped_sha": record.get("shipped_sha"),
        "archived": archived,
    })


def cmd_recreate(args: argparse.Namespace) -> None:
    """Re-materialise a shipped change's worktree on demand (#56 Part 2).

    After a successful ship the worktree is removed but the branch + record
    (with the pinned ``shipped_sha``) are kept. This brings the worktree
    back — ON the branch if it still exists (founder resumes work), else
    DETACHED at the pinned ``shipped_sha`` (view the exact shipped state).
    Resolved by ``--handle`` (preferred) or ``--slug [--primitive]``.
    """
    repo_root = _resolve_repo_root(args)

    record: dict | None = None
    if args.handle:
        handle = args.handle.upper()
        for r in list_all_changes():
            if str(r.get("handle", "")).upper() == handle:
                record = r
                break
        if record is None:
            emit_error(f"no change found for handle {args.handle!r}")
            return  # for type checker
        primitive = str(record.get("primitive") or "feat")
        slug = str(record.get("slug") or "")
        branch = str(record.get("branch")
                     or compose_change_branch(primitive, slug))
    else:
        if not args.slug:
            emit_error("--handle or --slug is required")
        primitive, slug = _resolve_primitive_and_slug(args)
        branch = compose_change_branch(primitive, slug)
        for r in list_all_changes():
            if str(r.get("branch", "")) == branch:
                record = r
                break

    worktree_dest = change_worktree_path(repo_root, primitive, slug)
    if worktree_dest.exists():
        emit_ok(data={
            "recreated": False,
            "reason": "worktree already exists",
            "worktree": str(worktree_dest),
            "branch": branch,
        })
        return

    # Prefer the branch (attached → resume work). Fall back to the pinned
    # shipped_sha (detached → view the exact shipped state) if it's gone.
    rc, _, _ = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                    cwd=repo_root, timeout=10)
    branch_exists = rc == 0

    if branch_exists:
        ok, msg = git_worktree_add(repo_root, branch, worktree_dest)
        if not ok:
            emit_error(f"could not recreate worktree: {msg}")
        ref_used, detached = branch, False
    else:
        shipped_sha = str((record or {}).get("shipped_sha") or "").strip()
        if not shipped_sha:
            emit_error(
                f"branch {branch} is gone and no shipped_sha is recorded — "
                f"cannot recreate the worktree",
                context={"hint": "This change predates shipped_sha recording; "
                                 "the exact shipped state is unavailable."},
            )
        rc, _, err = _run(["git", "worktree", "add", "--detach",
                           str(worktree_dest), shipped_sha],
                          cwd=repo_root, timeout=60)
        if rc != 0:
            emit_error(f"git worktree add --detach failed: {err}")
        ref_used, detached = shipped_sha, True

    emit_ok(data={
        "recreated": True,
        "worktree": str(worktree_dest),
        "branch": branch,
        "ref": ref_used,
        "detached": detached,
    })


HANDLERS = {
    "start": cmd_start,
    "adopt": cmd_adopt,
    "finish": cmd_finish,
    "list": cmd_list,
    "status": cmd_status,
    "stage": cmd_stage,
    "mark-shipped": cmd_mark_shipped,
    "nuke": cmd_nuke,
    "recreate": cmd_recreate,
}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
