# ─── Helpers ─────────────────────────────────────────────────────────────

def _resolve_repo_root(args: argparse.Namespace) -> Path:
    """Resolve the repo root from --repo-root or cwd."""
    repo_root = Path(getattr(args, "repo_root", None) or os.getcwd()).resolve()
    if not (repo_root / ".git").exists():
        emit_error(
            f"Not a git repo: {repo_root}",
            context={"hint": "Run from inside a git repo or pass --repo-root."},
        )
    return repo_root


def _dedouble_slug(primitive: str, slug: str) -> str:
    """Strip a redundant leading ``{primitive}-`` from a slug (#56 Part 4).

    The `/sulis:change` skill derives a slug from an intent that leads with
    the verb — "fix the login bug" → slug ``fix-login-bug`` — and pairs it
    with primitive ``fix``. ``compose_change_branch`` would then produce
    ``change/fix-fix-login-bug`` (the doubling the founder kept hitting) and
    a matching ``…-change-fix-fix-login-bug`` worktree.

    The fix is canonical (applied once, at resolution) so EVERY downstream
    consumer — branch compose, worktree path, metadata, parse round-trip —
    agrees. Conservative: only strip when what remains is STILL a valid slug
    (2-5 kebab words). A degenerate 1-word remainder (``fix-login`` →
    ``login``) is left doubled rather than produce an invalid slug.
    """
    prefix = f"{primitive}-"
    if slug.startswith(prefix):
        candidate = slug[len(prefix):]
        cand_ok, _ = validate_change_slug(candidate)
        if cand_ok:
            return candidate
    return slug


def _resolve_primitive_and_slug(args: argparse.Namespace) -> tuple[str, str]:
    """Validate and return (primitive, slug), de-doubled (#56 Part 4)."""
    primitive = (args.primitive or "feat").lower()
    slug = args.slug.lower()
    ok, reason = validate_change_primitive(primitive)
    if not ok:
        emit_error(reason)
    slug = _dedouble_slug(primitive, slug)
    ok, reason = validate_change_slug(slug)
    if not ok:
        emit_error(reason)
    return primitive, slug


def _worktree_for_branch(repo_root: Path, branch_ref: str) -> Path | None:
    """Return the worktree path that has ``branch_ref`` checked out, or None.

    The keystone of the #56 fix. git forbids the same branch in two
    worktrees BY DESIGN (independent indexes can't reconcile), so the ship
    path must never blind-``git checkout {base}`` in ``repo_root`` — base may
    be checked out in a sibling worktree. This parses ``git worktree list
    --porcelain`` to find where ``branch_ref`` actually lives so the squash-
    merge runs THERE.

    ``branch_ref`` is a short name like ``dev``; git reports the full
    ``refs/heads/dev`` in the ``branch`` line of each worktree block.
    Returns None when ``branch_ref`` is not checked out in any worktree
    (then the caller may safely check it out in ``repo_root``).
    """
    rc, out, _ = _run(["git", "worktree", "list", "--porcelain"],
                      cwd=repo_root, timeout=10)
    if rc != 0:
        return None
    target = f"refs/heads/{branch_ref}"
    current_path: str | None = None
    for line in out.splitlines():
        if line.startswith("worktree "):
            current_path = line[len("worktree "):].strip()
        elif line.startswith("branch ") and current_path is not None:
            if line[len("branch "):].strip() == target:
                return Path(current_path)
    return None


def _resolve_change_worktree(repo_root: Path, branch: str,
                             primitive: str, slug: str) -> Path:
    """Return where ``branch``'s worktree actually lives.

    Single resolution path for every read/inspect command (status, recreate,
    finish). Asks git where the branch is checked out — which honours the
    co-located convention (``~/.sulis/changes/{id}/worktree``) AND legacy
    sibling worktrees — and falls back to the legacy sibling path only when
    the branch isn't checked out anywhere (the branch-gone edge case, where
    the caller materialises a fresh worktree there).
    """
    return (_worktree_for_branch(repo_root, branch)
            or change_worktree_path(repo_root, primitive, slug))


def _compose_squash_message(primitive: str, slug: str, metadata: dict) -> str:
    """Conventional-Commit squash message (#56 Part 3).

    ``{primitive}: {slug}`` subject (the change primitive IS the commit
    type — most are real CC types: feat/fix/refactor/chore; the rest degrade
    cleanly to a custom type), the change's plain-English intent in the body,
    and the Sulis co-author trailer. Replaces the old hardcoded
    ``feat({branch}): squash-merge {branch}`` which ignored the primitive and
    duplicated the branch name into both scope and body.
    """
    subject = f"{primitive}: {slug}"
    body_parts: list[str] = []
    intent = str(metadata.get("intent") or "").strip()
    if intent:
        body_parts.append(intent)
    body_parts.append("Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>")
    return subject + "\n\n" + "\n\n".join(body_parts)


def _emit_changeset_for_ship(
    *,
    base_dir: Path,
    metadata: dict,
    touches_plugin: bool,
) -> Path | None:
    """Drop one `.changesets/*.yaml` for this ship, or None if tier is None.

    The keystone of the changeset-based release train at the ship boundary
    (the producer side of the `.changesets/` contract). Called from
    `cmd_finish` between the squash-merge and the squash commit so the
    changeset lands on `dev` in the SAME commit as the change itself.

    Returns the written path on success, or None when the primitive maps
    to no tier (admin / docs-only / unknown) — per `.changesets/README.md`
    those changes write **no** changeset. Returning None is meaningful,
    not an error.

    Raises ValueError when the change manifest is missing `primitive` or
    `change_id` — these are non-negotiable parts of the changeset YAML, and
    a missing field is a contract breach worth surfacing (the caller turns
    this into `emit_error` so the ship halts and the founder fixes the
    metadata, rather than silently dropping an incomplete changeset).
    """
    primitive = metadata.get("primitive")
    if not primitive:
        raise ValueError(
            "change manifest is missing `primitive` — cannot derive release "
            "tier; ship cannot drop a changeset")
    change_id = metadata.get("change_id")
    if not change_id:
        raise ValueError(
            "change manifest is missing `change_id` — every changeset MUST "
            "carry its parent change's id (`.changesets/README.md`)")

    tier = tier_for_primitive(primitive)
    if tier is None:
        # admin / docs-only / unknown primitive → no changeset (the README
        # contract; the release-train sees these via the dev↔main diff but
        # they don't bump the version).
        return None

    slug = metadata.get("slug") or change_id
    intent = str(metadata.get("intent") or "").strip()
    summary = intent if intent else f"{primitive}: {slug}"

    return write_changeset(
        changesets_dir=base_dir / ".changesets",
        change_id=change_id,
        primitive=primitive,
        tier=tier,
        touches_plugin=touches_plugin,
        summary=summary,
        slug=slug,
    )


# Uncommitted paths under these prefixes are sulis-managed metadata, not
# founder work: `start` writes `.changes/{...}.yaml` into the worktree and
# never commits it (the canonical copy lives in the branch-independent global
# store). They are safe to discard when removing a shipped worktree.
_SULIS_MANAGED_UNCOMMITTED: tuple[str, ...] = (".changes/",)


def _worktree_blocking_changes(worktree: Path) -> list[str]:
    """Uncommitted paths in ``worktree`` that are NOT sulis-managed metadata.

    ``git worktree remove`` (no ``--force``) refuses on ANY uncommitted or
    untracked content — and ``start`` always leaves ``.changes/{...}.yaml``
    uncommitted, so a blanket no-force remove would NEVER fire and #56 Part 2
    would be a silent no-op. This returns the genuinely-at-risk paths:
    anything dirty that isn't sulis-managed. An empty list means removal is
    safe (only regenerable metadata is dirty → force-remove); a non-empty
    list means there's real uncommitted founder work → KEEP + report it.
    """
    rc, out, _ = _run(["git", "status", "--porcelain"],
                      cwd=worktree, timeout=10)
    if rc != 0:
        return ["<could not read worktree git status>"]
    blocking: list[str] = []
    for line in out.splitlines():
        path = line[3:].strip()  # porcelain line: 'XY <path>'
        if not path:
            continue
        if " -> " in path:  # rename: 'old -> new'
            path = path.split(" -> ", 1)[1]
        if not any(path.startswith(p) for p in _SULIS_MANAGED_UNCOMMITTED):
            blocking.append(path)
    return blocking


def _remove_shipped_worktree(repo_root: Path, change_id: str,
                             worktree_dest: Path) -> dict:
    """Remove a shipped change's redundant worktree, safely (#56 Part 2).

    Gated: never remove the worktree the caller's shell is standing in; never
    remove a worktree with a live bound session (#32); never discard genuine
    uncommitted work (only regenerable `.changes/` metadata is safe).
    Force-removes only when the worktree is clean-enough. Returns a dict with
    ``worktree_removed`` + (when kept) ``worktree_kept_reason``.
    """
    # Never remove the worktree the caller is currently inside — that would
    # leave their shell in a deleted directory. This is independent of
    # session_is_live (which only catches spawned-terminal sessions, not a
    # manual `cd` into the worktree before running ship).
    try:
        cwd = Path.cwd().resolve()
        wt_resolved = worktree_dest.resolve()
        if cwd == wt_resolved or wt_resolved in cwd.parents:
            return {"worktree_removed": False,
                    "worktree_kept_reason": "the current shell is inside this "
                                            "worktree"}
    except OSError:
        pass
    if session_is_live(str(change_id)):
        return {"worktree_removed": False,
                "worktree_kept_reason": "a live session is bound to this change"}
    if not worktree_dest.exists():
        return {"worktree_removed": False,
                "worktree_kept_reason": "worktree already absent"}
    blocking = _worktree_blocking_changes(worktree_dest)
    if blocking:
        return {"worktree_removed": False,
                "worktree_kept_reason": (
                    "uncommitted work present (not part of the ship): "
                    + ", ".join(blocking[:5]))}
    # Only regenerable sulis metadata is dirty → safe to force-remove (the
    # global store holds the canonical record; shipped_sha pins the committed
    # state; `recreate` restores the worktree on demand).
    ok, msg = git_worktree_remove(repo_root, worktree_dest, force=True)
    out = {"worktree_removed": ok}
    if not ok:
        out["worktree_kept_reason"] = msg
    return out


def _change_own_commit_count(repo_root: Path, base_sha: str,
                             branch: str) -> int | None:
    """Number of commits the change branch carries of its OWN, beyond its base.

    `git rev-list --count <base_sha>..<branch>` — commits reachable from the
    branch tip but not from the fork point. Returns the count, or ``None`` when
    it can't be determined (no ``base_sha`` recorded, or the rev-list fails —
    e.g. the branch or base is gone). ``None`` means "undeterminable", which the
    caller treats as "don't block" — the guard only fires on a POSITIVE zero.
    """
    if not base_sha:
        return None
    rc, out, _ = _run(
        ["git", "rev-list", "--count", f"{base_sha}..refs/heads/{branch}"],
        cwd=repo_root, timeout=10)
    if rc != 0:
        return None
    try:
        return int(out.strip())
    except ValueError:
        return None


def _confirm_merged_to_main(
    repo_root: Path,
    branch: str,
    *,
    merge_sha: str | None,
    run=None,
) -> str | None:
    """Confirm ``branch`` actually landed on ``main`` (#111 ship-integrity).

    Returns the MERGE COMMIT sha on ``main`` (the true shipped state) when the
    merge is confirmed, else ``None``. Never raises and never mutates anything —
    a pure confirmation probe.

    Why not ``git merge-base --is-ancestor <branchtip> origin/main``: the ship
    flow squash-merges (``gh pr merge --squash``), which creates a brand-new
    commit on ``main`` with NO ancestry link back to the change-branch tip. So
    the branch tip is never an ancestor of ``main`` even when the work landed —
    that check would reject every squash-merged change. Two reliable signals:

    1. Primary (authoritative): a merged PR for this branch into ``main``
       (``gh pr list --head <branch> --base main --state merged``). GitHub
       records the real merge; its ``mergeCommit.oid`` IS the shipped state.
    2. Alternate (manual merges): an explicit ``--merge-sha`` that is an
       ancestor of ``origin/main`` (``git merge-base --is-ancestor``). Here the
       caller supplies the merge commit directly, so the ancestry check is
       valid (a real merge/ff commit, not a squashed branch tip).

    The ``run`` seam (default ``_run``) is injectable so tests stub it without
    touching the network. Resolved at call time (not bound as a default) so a
    monkeypatched module-level ``_run`` is honoured.
    """
    if run is None:
        run = _run
    # 1. Authoritative: a merged PR for this branch into main.
    rc, out, _err = run(
        ["gh", "pr", "list", "--head", branch, "--base", "main",
         "--state", "merged", "--json", "number,mergeCommit,mergedAt"],
        cwd=repo_root, timeout=30,
    )
    if rc == 0 and out.strip():
        try:
            prs = json.loads(out)
        except (json.JSONDecodeError, ValueError):
            prs = []
        for pr in prs if isinstance(prs, list) else []:
            oid = ((pr or {}).get("mergeCommit") or {}).get("oid")
            if oid:
                return str(oid)

    # 2. Alternate: an explicit merge sha that landed on origin/main.
    if merge_sha:
        rc, _out, _err = run(
            ["git", "merge-base", "--is-ancestor", merge_sha, "origin/main"],
            cwd=repo_root, timeout=10,
        )
        if rc == 0:
            return merge_sha

    return None


# ─── #118 — ship-time observed-verdict gate ─────────────────────────────────
# The Definition-of-Done verdict (every touched Requirement has a passing
# TestResult) was enforced ONLY as prose in change/SKILL.md gate 4.9 — the ship
# script ran it zero times. So a change could be marked *shipped* with no
# observed verdict: an agent skipping the prose step, or a hand-merge bypassing
# the skill entirely. This moves the check from prose into the ship MECHANISM —
# `mark-shipped` refuses unless every touched SRD's DoD verdict is `pass`,
# escapable only by a conscious, logged `--force` (sibling of the #111 merge
# guard above). Completion stops being self-asserted: the recorded verdict, not
# the agent, decides whether a change may ship.


def evaluate_observed_verdict(touched_srds, *, verify_fn):
    """Pure decision: given the SRDs a change touched and a verdict function
    (``srd_path -> 'pass' | 'partial' | 'fail'``), decide whether the change may
    be marked shipped w.r.t. the Definition of Done.

    Observed-or-blocked: ship proceeds only when EVERY touched SRD verifies
    ``pass`` (every FR/NFR has a passing TestResult). Any ``partial`` / ``fail``
    (an unverified requirement) BLOCKS — the conscious escape is ``--force`` at
    the call site. No SRD touched → out of scope (lite/standard specs + trivial
    changes carry no FR-NN blocks) → ``ok``, never blocks. Returns
    ``(ok: bool, reason: str)``."""
    if not touched_srds:
        return (True, "no SRD touched — DoD verdict not applicable")
    unverified = []
    for srd in touched_srds:
        verdict = verify_fn(srd)
        if verdict != "pass":
            unverified.append((srd, verdict))
    if unverified:
        detail = "; ".join(f"{srd} ({v})" for srd, v in unverified)
        return (
            False,
            "Definition of Done not met — these touched requirements have no "
            f"observed verdict: {detail}. Every FR/NFR needs a passing "
            "TestResult (a @verifies unit test or a green Scenario run) before "
            "this ships. Drive the verification, or override consciously with "
            "--force.",
        )
    return (True, "all touched SRDs verified (DoD pass)")


def evaluate_scenario_verdict(scenario_ids, *, observed_fn):
    """Pure decision (Phase 2): the scenario route, for founder-facing changes
    whose verification lives in Scenarios rather than (or as well as) an SRD's
    FR-NN blocks. Given the change's EMITTED scenario ids and an observed
    function (``dna:scenario:<ulid> -> bool``, "has a passing TestResult"),
    decide whether the change may ship.

    Observed-or-blocked: ship proceeds only when EVERY emitted scenario is
    observed green. Any unobserved scenario BLOCKS — the conscious escape is
    ``--force``. No emitted scenarios → scenario route not applicable (the SRD
    route + the #301 presence gate cover those cases) → ``ok``. Returns
    ``(ok: bool, reason: str)``."""
    if not scenario_ids:
        return (True, "no emitted scenarios — scenario route not applicable")
    unobserved = [s for s in scenario_ids if not observed_fn(s)]
    if unobserved:
        return (
            False,
            "Definition of Done not met — these scenarios have no observed "
            f"verdict (no passing TestResult): {', '.join(unobserved)}. Drive "
            "them for real (sulis-verify-acceptance) or attest them "
            "(sulis-attest-scenario), or override consciously with --force.",
        )
    return (True, "all emitted scenarios observed")


def _touched_srds(repo_root: Path, base: str = "origin/main", *, run=None) -> list[str]:
    """SRD paths changed on this branch vs ``base`` (three-dot — the branch's
    own work). Best-effort: an unresolvable base / git error returns ``[]``
    (the gate degrades open on inability-to-evaluate, never fabricates a
    block). The ``run`` seam (default ``_run``) is injectable for tests."""
    if run is None:
        run = _run
    rc, out, _err = run(
        ["git", "diff", "--name-only", f"{base}...HEAD"],
        cwd=repo_root, timeout=30,
    )
    if rc != 0:
        return []
    srds = []
    for line in out.splitlines():
        p = line.strip()
        if p.startswith(".specifications/") and p.endswith("/SRD.md"):
            srds.append(p)
    return srds


def _scenario_ids_for_change(repo_root: Path, stem: str) -> list[str]:
    """The EMITTED scenario ids for a change, read from
    ``{repo_root}/.changes/{stem}.scenarios.jsonld``. The authored file records
    each scenario's emitted ``dna:scenario:<ulid>`` id directly (the brain id
    the acceptance run's TestResults back-link to), so the scenario route needs
    no seed recomputation or journey resolution.

    Returns only ``dna:scenario:`` ids — a pre-emit file carrying bare ``SC-NN``
    ids has no emitted scenarios to gate on (those are covered by the SRD route
    + the #301 presence gate; authored-not-emitted is a separate state).
    Missing / malformed file → ``[]``."""
    f = Path(repo_root) / ".changes" / f"{stem}.scenarios.jsonld"
    if not f.exists():
        return []
    try:
        data = json.loads(f.read_text(encoding="utf-8"))
    except (ValueError, OSError):
        return []
    nodes = data.get("scenarios") if isinstance(data, dict) else data
    if not isinstance(nodes, list):
        return []
    ids = []
    for n in nodes:
        if isinstance(n, dict):
            sid = str(n.get("id", "") or n.get("@id", ""))
            if sid.startswith("dna:scenario:"):
                ids.append(sid)
    return ids


def _confirm_observed_verdict(repo_root: Path, *, stem: str | None = None,
                              base: str = "origin/main", run=None):
    """The combined ship-time observed-verdict gate. Two routes, blocked if
    EITHER blocks:

    - **SRD route** — git-diff for touched SRDs → ``verify_requirements`` →
      ``evaluate_observed_verdict``.
    - **Scenario route (#118 Phase 2)** — the change's emitted scenarios →
      passing-TestResult check → ``evaluate_scenario_verdict``. Requires
      ``stem`` ({primitive}-{slug}); skipped when ``stem`` is None.

    Returns ``(ok: bool, reason: str)``. Degrades open only when the gate
    genuinely cannot evaluate (no touched SRDs / no emitted scenarios / a
    git/brain error) — it never fabricates a pass it did not verify."""
    from _verify_requirements import verify_requirements
    from _brain_query import find_passing_testresults_for_scenario

    base_dir = Path(repo_root) / ".brain" / "instances"

    def _verify(srd_path: str) -> str:
        try:
            res = verify_requirements(Path(repo_root) / srd_path, base_dir=base_dir)
            return res.verdict
        except FileNotFoundError:
            # Listed in the diff but absent at HEAD (deleted SRD) — nothing to
            # verify against; out of scope for that file.
            return "pass"

    srd_ok, srd_reason = evaluate_observed_verdict(
        _touched_srds(repo_root, base, run=run), verify_fn=_verify)
    if not srd_ok:
        return (srd_ok, srd_reason)

    if stem is None:
        return (srd_ok, srd_reason)

    def _observed(scenario_id: str) -> bool:
        try:
            return bool(find_passing_testresults_for_scenario(base_dir, scenario_id))
        except (ValueError, OSError):
            return False

    scen_ok, scen_reason = evaluate_scenario_verdict(
        _scenario_ids_for_change(repo_root, stem), observed_fn=_observed)
    if not scen_ok:
        return (scen_ok, scen_reason)
    # Both routes ok — report whichever was the substantive one.
    if not srd_reason.startswith("no SRD"):
        return (True, srd_reason)
    return (True, scen_reason)


def _archive_after_ship(repo_root: Path, change_id: str, branch: str,
                        worktree_dest: Path, *, remove_worktree: bool,
                        shipped_sha_override: str | None = None) -> dict:
    """Mark a change shipped (+ pin shipped_sha) and optionally remove its
    worktree. The SINGLE source both ship paths share — `finish --merge`
    (this script) and `mark-shipped` (the gh-based `/sulis:change ship`
    skill) — so the post-ship state can never drift between them.

    Pins ``shipped_sha`` = the change-branch tip ("the state it was in when
    we shipped"), UNLESS ``shipped_sha_override`` is given — then it pins that
    (the merge commit on ``main``, the true shipped state; #111). Keeps the
    branch + record (the audit trail). Returns the ``archived`` dict for the
    command's JSON output.
    """
    # #272 — refuse to ship an EMPTY change. A change whose branch carries zero
    # commits of its own beyond its base built nothing; marking it shipped (and
    # removing its worktree) is never right. This is the harm a stacked change
    # hit when its base merged. Guard on a POSITIVE zero only — an undeterminable
    # count (no base_sha, branch gone) never blocks a legitimate ship.
    record = read_change_record(str(change_id)) or {}
    base_sha = str(record.get("base_sha") or "").strip()
    own_commits = _change_own_commit_count(repo_root, base_sha, branch)
    if own_commits == 0:
        emit_error(
            f"Refusing to mark change {change_id} shipped: its branch "
            f"({branch}) has no commits of its own beyond its base "
            f"({base_sha[:8]}) — nothing was built, so there is nothing to "
            f"ship. (An empty change is never 'shipped' — this guards the "
            f"stacked-change false-shipped case, #272.)",
            context={"change_id": change_id, "branch": branch,
                     "base_sha": base_sha, "own_commits": own_commits},
        )

    if shipped_sha_override:
        # #111 — pin the MERGE COMMIT on main (the true shipped state), not the
        # local branch tip (which a squash-merge orphans).
        shipped_sha = shipped_sha_override.strip()
    else:
        rc, sha_out, _ = _run(["git", "rev-parse", f"refs/heads/{branch}"],
                              cwd=repo_root, timeout=10)
        shipped_sha = sha_out.strip() if rc == 0 else ""
    record_path = mark_change_shipped(str(change_id),
                                      shipped_sha=shipped_sha or None)
    archived = {
        "archived": record_path is not None,
        "change_id": change_id,
        "stage": "shipped",
        "shipped_sha": shipped_sha,
    }
    if remove_worktree:
        archived.update(
            _remove_shipped_worktree(repo_root, change_id, worktree_dest))
    return archived


def _metadata_path(repo_root: Path, primitive: str, slug: str) -> Path:
    return repo_root / ".changes" / f"{primitive}-{slug}.yaml"


def _resolve_change_branch(repo_root: Path, primitive: str, slug: str) -> str:
    """Resolve the branch for an EXISTING change (#112).

    Change identity is store-backed: the recorded ``branch`` field is the
    source of truth, so a change started under a host ``branch_convention``
    (e.g. ``feature/...``) resolves to the SAME branch it was created on — not
    a freshly-recomposed (possibly-different) name. Falls back to composing
    with the repo's convention when no stored record matches (e.g. a brand-new
    change before its record is written, or a legacy change predating the
    record), which still yields the byte-for-byte legacy default when the
    contract declares no convention.
    """
    for record in list_all_changes():
        if (str(record.get("primitive") or "") == primitive
                and str(record.get("slug") or "") == slug):
            stored = record.get("branch")
            if stored:
                return str(stored)
            break
    convention = read_repo_contract(repo_root).get("branch_convention")
    return compose_change_branch(primitive, slug, convention=convention)


def _build_change_pre_prompt(
    change_id: str,
    handle: str,
    slug: str,
    intent: str,
    primitive: str,
    context_md_path: Path | None,
) -> str:
    """Assemble the HERE-DOC body briefing Sulis on the change.

    Shape per the change-as-primitive design § "Session binding" step 5.
    Contains only the change identity + the absolute recon path — never
    secrets, never the heredoc tag (the launcher's _validate_pre_prompt
    rejects bodies containing it). Reading the recon file is the spawned
    Claude's job.

    ``context_md_path`` may be None when recon could not be written (best-
    effort); in that case the brief omits the recon-file reference.
    """
    if context_md_path is not None:
        recon_line = (
            f"Pre-spawn recon is at {context_md_path} — read it for git state "
            f"and the suggested next step, then greet me in change-context mode."
        )
    else:
        recon_line = (
            "Pre-spawn recon was unavailable (the recon file could not be "
            "written); greet me in change-context mode and run `/sulis:status` "
            "to orient."
        )
    body = (
        f"You are Sulis, focused on change {handle}: \"{intent}\".\n"
        f"This is a '{primitive}' change (slug: {slug}, id: {change_id}).\n"
        f"Your working directory is the change worktree.\n"
        f"{recon_line}"
    )
    # Defence in depth: never let the reserved tag into the body.
    if _PRE_PROMPT_HEREDOC_TAG in body:
        body = body.replace(_PRE_PROMPT_HEREDOC_TAG, "[redacted-tag]")
    return body


def _has_origin_remote(repo_root: Path) -> bool:
    """True when an ``origin`` remote is configured in ``repo_root``.

    Used by `start` to decide whether to even attempt the publish-at-creation
    push (#61). A missing origin is the normal local-only / offline case, not
    an error — it degrades to ``pushed_to_origin: false`` rather than a failed
    push attempt with noisy git stderr.
    """
    rc, out, _ = _run(["git", "remote"], cwd=repo_root, timeout=10)
    if rc != 0:
        return False
    return "origin" in out.split()


def _push_change_branch_to_origin(repo_root: Path, branch: str) -> bool:
    """Publish the freshly-created change branch to origin (#61, best-effort).

    The integration train merges via the GitHub API, so the change branch (the
    train's --base-branch) MUST exist on origin or the first train run 404s.
    `start` publishes it at creation so the founder never has to run a manual
    `git push -u origin <branch>` first.

    Graceful-degrade contract: the push is an ENHANCEMENT to `start`, never a
    new precondition. No origin remote, or a failed push (offline / auth /
    unreachable), must NOT crash `start` or unwind the local branch + worktree
    — it logs a clear warning and returns False so the caller can report
    ``pushed_to_origin: false``. Returns True only when the branch is genuinely
    published to origin.
    """
    if not _has_origin_remote(repo_root):
        _log(f"No 'origin' remote configured; change branch {branch} was NOT "
             f"published. The integration train will need it pushed first "
             f"(`git push -u origin {branch}`).")
        return False

    rc, _, err = _run(["git", "push", "-u", "origin", branch],
                      cwd=repo_root, timeout=60)
    if rc != 0:
        _log(f"Could not publish change branch {branch} to origin "
             f"(push failed: {err.strip() or 'unknown error'}). `start` "
             f"succeeded locally; push the branch before the integration "
             f"train runs (`git push -u origin {branch}`).")
        return False

    _log(f"Published change branch {branch} to origin.")
    return True


# ─── Subcommand: start ────────────────────────────────────────────────────

# ─── #123 — cross-session context-carry ─────────────────────────────────────
# When change B is started from inside change A's session (a parent
# SULIS_CHANGE_ID is set), the LINK + A's reasoning travel into B as durable
# state — B discovers them through the CONTEXT.md it already reads at startup.
# No live inter-session wire (the critical-thinking call: a state gap, not a
# transport gap; Agent Teams was wrong-fit). Best-effort throughout: a carry
# problem must never block `start`.

_CARRY_RELATIONSHIPS = ("builds_on", "depends_on")


def _excerpt_working_set(text, *, max_chars: int = 1500) -> str:
    """A capped excerpt of a parent Working Set for carry. Its most useful
    sections (Problem / Current best solution) sit at the top, so the leading
    slice captures them. Empty / whitespace / None → ``''``."""
    if not text or not str(text).strip():
        return ""
    t = str(text).strip()
    if len(t) <= max_chars:
        return t
    return t[:max_chars].rstrip() + "\n\n…(excerpt truncated — follow the link to read the rest)"


def _read_working_set(record) -> str | None:
    """Read a change's Working Set from its record (worktree_path +
    {primitive}-{slug}.WORKING-SET.md). Best-effort: any miss → None."""
    try:
        pw = record.get("worktree_path")
        prim = str(record.get("primitive", "") or "")
        slug = str(record.get("slug", "") or "")
        if pw and prim and slug:
            ws = Path(pw) / ".changes" / f"{prim}-{slug}.WORKING-SET.md"
            if ws.exists():
                return ws.read_text(encoding="utf-8")
    except Exception:
        return None
    return None


def _walk_ancestry(immediate_id, read_record_fn, *, max_depth: int = 12) -> list:
    """Follow ``parent_change`` from the immediate parent to the origin change
    (#124). Returns ``[immediate_record, …, origin_record]`` (only records that
    resolve), immediate-first. Cycle- and depth-bounded so a malformed loop or
    a very deep chain can never hang `start`. ``read_record_fn(id) -> record |
    None`` is injectable for tests."""
    chain: list = []
    seen: set = set()
    cur = (immediate_id or "").strip() or None
    while cur and cur not in seen and len(chain) < max_depth:
        seen.add(cur)
        try:
            rec = read_record_fn(cur)
        except Exception:
            rec = None
        if not rec:
            break
        chain.append(rec)
        cur = str(rec.get("parent_change") or "").strip() or None
    return chain


def _carried_context_section(parent: dict, relationship: str,
                             working_set_text, *, ancestry=None,
                             origin_working_set=None) -> str:
    """The 'Carried from {parent}' CONTEXT.md section (#123): the durable link
    + an excerpt of the parent's Working Set. The link is ALWAYS present (B can
    follow it to read the parent's full Working Set + brain); the excerpt is a
    starting point, not the whole picture.

    ``ancestry`` (#124) is the chain BEYOND the immediate parent, origin-ward
    (i.e. the immediate parent's parent … the origin). When non-empty, the
    section also renders the full **lineage to origin** (each ancestor's
    handle + id, so the session can navigate back any number of hops) and the
    **origin's** Working-Set excerpt — because context two-plus changes back
    was being lost, and the origin idea is often the one that matters most."""
    handle = parent.get("handle") or parent.get("change_id", "?")
    slug = str(parent.get("slug", "") or "")
    cid = str(parent.get("change_id", "") or "")
    rel = relationship if relationship in _CARRY_RELATIONSHIPS else "builds_on"
    excerpt = _excerpt_working_set(working_set_text)
    out = [
        "",
        f"## Carried from {handle} ({rel})",
        "",
        ("This change was started from change **" + str(handle) + "**"
         + (f" — *{slug}*" if slug else "")
         + (f" (`{cid}`)" if cid else "")
         + f". Relationship: `{rel}`. Read that change's full reasoning in its "
           "Working Set and the brain — the excerpt below is a starting point, "
           "not the whole picture."),
        "",
    ]
    if excerpt:
        out += ["### Carried Working Set excerpt", "", excerpt, ""]
    else:
        out += [
            "_The parent change had no populated Working Set at spawn time — "
            "follow the link above and read its artifacts (SPEC / brain "
            "Opportunity + Decision) directly._",
            "",
        ]

    # #124 — render the full lineage to origin when this change is more than
    # one hop deep, so the session can navigate back to the original idea.
    if ancestry:
        def _lbl(rec):
            h = rec.get("handle") or rec.get("change_id", "?")
            c = str(rec.get("change_id", "") or "")
            return f"{h}" + (f" (`{c}`)" if c and c != h else "")
        full_chain = [parent] + list(ancestry)  # immediate → origin
        lineage = " ← ".join(_lbl(r) for r in full_chain)
        origin = ancestry[-1]
        out += [
            "### Lineage to origin",
            "",
            f"This change is {len(full_chain)} hops deep. Full chain "
            f"(this change's parent ← … ← origin): {lineage}. Follow any link "
            "to read that change's Working Set / brain.",
            "",
        ]
        origin_excerpt = _excerpt_working_set(origin_working_set)
        if origin_excerpt and origin is not parent:
            out += [f"### Origin ({_lbl(origin)}) Working Set excerpt",
                    "", origin_excerpt, ""]
    return "\n".join(out)


def _resolve_parent_carry(relationship):
    """If a parent change is bound in the env (`SULIS_CHANGE_ID`), resolve its
    record + Working Set and build the carried-context section.

    Returns ``(parent_id | None, section | None, relationship)``. Best-effort:
    any resolution/read failure degrades to ``(parent_id or None, None, rel)``
    so a carry problem never blocks `start`. The link is recorded even when the
    Working Set can't be read (the section's fallback tells B to follow it)."""
    parent_id = (os.environ.get("SULIS_CHANGE_ID") or "").strip()
    rel = relationship if relationship in _CARRY_RELATIONSHIPS else "builds_on"
    if not parent_id:
        return (None, None, rel)
    # #124 — walk the full ancestry chain to origin (immediate → … → origin),
    # so a change two-plus hops deep surfaces its whole lineage, not just one
    # hop. Cycle/depth-bounded; degrades to (parent_id, None) if the immediate
    # parent's record can't even be read.
    chain = _walk_ancestry(parent_id, read_change_record)
    if not chain:
        return (parent_id, None, rel)
    immediate = chain[0]
    ancestry = chain[1:]                       # beyond the immediate parent
    origin = chain[-1] if len(chain) > 1 else None
    section = _carried_context_section(
        immediate, rel, _read_working_set(immediate),
        ancestry=ancestry,
        origin_working_set=_read_working_set(origin) if origin is not None else None,
    )
    return (parent_id, section, rel)


def _change_service_for(repo_root: Path):
    """A ChangeService bound to the MAIN repo's brain (#128 slice 2).

    The single handler the lifecycle commands route through — start→open,
    mark-shipped→ship, nuke→nuke. Writes off the change branch (the #127
    global-store direction). Raises only on a genuine import/IO failure; the
    callers wrap it best-effort so entity handling never blocks the command.
    """
    from _brain_location import brain_base_dir
    from _change_service import ChangeService
    from _entity_adapter_local import LocalFileEntityAdapter

    return ChangeService(LocalFileEntityAdapter(
        base_dir=brain_base_dir(repo_root),       # #127: user-configurable location
        domain="product-development",
    ))


def _emit_change_entity(repo_root: Path, metadata: dict) -> None:
    """Best-effort: open the change as a first-class brain entity (#128, DR-031).

    A change becomes a NODE in the brain (a prov:Activity, sibling to
    LifecycleRun), not just a manifest beside it — routed through ChangeService
    (slice 2). ``for_product`` is an OPTIONAL link: set when a single product
    resolves, omitted otherwise (product-less changes still land in the brain).
    NON-FATAL by construction: any failure (incl. an import error) is logged and
    swallowed — entity handling must never block change creation.
    """
    try:
        from _change_emission import resolve_for_product

        _change_service_for(repo_root).open(
            metadata, for_product=resolve_for_product(repo_root))
    except Exception:  # noqa: BLE001 — best-effort; entity handling never blocks start
        _log("Change entity could not be opened; continuing without it")


def _transition_change_entity(repo_root: Path, change_id: str, to_state: str) -> None:
    """Best-effort: transition the Change entity on ship/nuke (#128 slice 2).

    ``mark-shipped`` → ship (state=shipped, the commit point); ``nuke`` → nuke
    (state=nuked + valid_to, the rollback point). A change with no emitted
    entity (started on an older plugin) → the transition finds nothing and
    no-ops. NON-FATAL: any failure is logged and swallowed — the entity state is
    an audit record, never a gate on the git-side command.
    """
    try:
        svc = _change_service_for(repo_root)
        if to_state == "shipped":
            svc.ship(str(change_id))      # commit: the produced entities stay live
        elif to_state == "nuked":
            svc.nuke(str(change_id))      # the Change entity → nuked
            svc.rollback(str(change_id))  # #67 3c: soft-delete the entities it produced
    except Exception:  # noqa: BLE001 — best-effort; never block ship/nuke
        _log(f"Change entity could not be transitioned to {to_state}; continuing")


def cmd_start(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)
    primitive, slug = _resolve_primitive_and_slug(args)
    # #123 — if launched from INSIDE a parent change session (SULIS_CHANGE_ID
    # set), carry its durable link + a Working-Set excerpt into this change.
    # Resolved up front so the link lands in the manifest + record and the
    # excerpt is appended to CONTEXT.md below. Best-effort (never blocks start).
    parent_change, carried_section, carry_relationship = _resolve_parent_carry(
        getattr(args, "relationship", "builds_on"))
    # #112 — honour the host repo's branch convention if it declares one.
    # Absent → compose_change_branch returns the byte-for-byte legacy
    # change/{primitive}-{slug}.
    convention = read_repo_contract(repo_root).get("branch_convention")
    branch = compose_change_branch(primitive, slug, convention=convention)
    base_ref = args.base or "main"

    # Check the branch doesn't already exist
    rc, _, _ = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                   cwd=repo_root, timeout=10)
    if rc == 0:
        emit_error(
            f"Change branch already exists: {branch}",
            context={"hint": f"Run `sulis-change list` to see active changes, "
                             f"or `sulis-change finish --slug {slug}` to ship it."},
        )

    # Fetch the latest base ref from origin and branch off the FETCHED tip, so
    # a local `{base_ref}` that lags `origin/{base_ref}` never produces a stale
    # base. Mirrors the `finish` subcommand's `git fetch origin {base_ref}` and
    # `wpx-worktree`'s prefer-remote / fall-back-to-local resolution — but,
    # unlike `finish`, degrades gracefully on fetch failure rather than
    # `emit_error`-ing: a founder starting a change offline (no remote / no
    # network) must still get a local branch + worktree off the local ref.
    branch_base = base_ref
    fetch_rc, _, fetch_err = _run(["git", "fetch", "origin", base_ref],
                                  cwd=repo_root, timeout=60)
    if fetch_rc == 0:
        # Prefer the freshly-fetched remote tip when it resolves cleanly.
        remote_rc, _, _ = _run(
            ["git", "rev-parse", "--verify", "--quiet", f"origin/{base_ref}"],
            cwd=repo_root, timeout=10,
        )
        if remote_rc == 0:
            branch_base = f"origin/{base_ref}"
    else:
        _log(f"Could not fetch origin/{base_ref} "
             f"({fetch_err.strip() or 'no remote/offline?'}); starting from "
             f"the local {base_ref}.")

    # Generate ULID + handle FIRST (Phase 5 of change-as-primitive build —
    # WORK_PACKAGE_STANDARD v1.1.0 `change_id:` field). The worktree is now
    # co-located under the change's own state dir
    # (~/.sulis/changes/{change_id}/worktree), so the id must exist before we
    # can compute the worktree path (ADE worktree relocation).
    change_id = generate_change_ulid()
    handle = ulid_handle(change_id)

    # Determine worktree path — co-located with the change's state dir, out of
    # the user's working dirs (no more sibling <repo>-change-<slug>/ dirs).
    worktree_dest = change_worktree_dir(change_id)
    worktree_dest.parent.mkdir(parents=True, exist_ok=True)

    # Create the worktree + branch off the resolved base (remote tip on the
    # happy path; local ref on the offline fallback).
    ok, msg = git_worktree_add(repo_root, branch, worktree_dest, branch_base)
    if not ok:
        emit_error(f"Worktree creation failed: {msg}")

    # Pin base_sha to the SAME ref the branch was actually cut from.
    rc, base_sha_out, _ = _run(["git", "rev-parse", branch_base],
                               cwd=repo_root, timeout=10)
    base_sha = base_sha_out.strip() if rc == 0 else ""

    # Write metadata into the worktree (it lives on the change branch)
    metadata = {
        "change_id": change_id,
        "handle": handle,
        "slug": slug,
        "primitive": primitive,
        "intent": getattr(args, "intent", "") or "",
        "branch": branch,
        "worktree_path": str(worktree_dest),
        "base_branch": base_ref,
        "base_sha": base_sha,
        "started_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    }
    if parent_change:
        # #123 — the durable link the founder was hand-relaying becomes a
        # first-class field on the change (manifest + record below).
        metadata["parent_change"] = parent_change
        metadata["relationship"] = carry_relationship
    write_change_metadata(_metadata_path(worktree_dest, primitive, slug),
                          metadata)

    # Pre-spawn recon — unconditional (cheap, useful artefact; nothing
    # downstream is harmed). Produces ~/.sulis/changes/{change_id}/CONTEXT.md.
    # Best-effort: write_change_context returns None if the path is unwritable
    # (permission / read-only FS / disk full). A recon-write failure degrades
    # gracefully — the spawn proceeds without CONTEXT.md rather than crashing.
    context_path = write_change_context(
        change_id=change_id,
        metadata=metadata,
        repo_root=repo_root,
    )
    if context_path is None:
        _log("Pre-spawn recon could not be written (path unwritable); "
             "continuing without CONTEXT.md")
    elif carried_section:
        # #123 — append the 'Carried from {parent}' section so the spawned
        # session DISCOVERS the link + the parent's reasoning through the
        # CONTEXT.md it already reads at startup. Best-effort: an append
        # failure must not block start.
        try:
            with open(context_path, "a", encoding="utf-8") as _fh:
                _fh.write(carried_section)
        except OSError:
            _log("Carried-context section could not be appended to CONTEXT.md")

    # Stamp the initial workflow stage (recon) into the per-change local
    # state.json. The stage skills advance it later (slice B); here we just
    # seed the starting position. Best-effort like recon: an unwritable path
    # degrades inside write_change_stage (returns None) without crashing.
    stage_path = write_change_stage(change_id, "recon")
    if stage_path is None:
        _log("Initial stage (recon) could not be written (path unwritable); "
             "continuing without state.json")

    # Write the full per-change record (change.json) — the branch-independent
    # global-index entry the dashboard + `sulis-change list` read. git is
    # per-branch, so the committed manifest on the change branch can't be
    # enumerated from dev; this local record can. Best-effort like recon/stage:
    # an unwritable path degrades inside write_change_record (returns None).
    record_path = write_change_record(change_id, {
        "change_id": change_id,
        "handle": handle,
        "slug": slug,
        "primitive": primitive,
        "branch": branch,
        "worktree_path": str(worktree_dest),
        "intent": metadata.get("intent", ""),
        "base_branch": base_ref,
        # base_sha is the git ref the cockpit diffs the worktree against
        # (L-11 / #44 — its absence left diffs dead for every change).
        "base_sha": base_sha,
        "created_at": metadata["started_at"],
        "stage": "recon",
        # #123 — the durable parent link, also on the global record the
        # dashboard / `list` read (omitted entirely when there's no parent).
        **({"parent_change": parent_change,
            "relationship": carry_relationship} if parent_change else {}),
    })
    if record_path is None:
        _log("Global change record could not be written (path unwritable); "
             "continuing without change.json")

    # Emit the change as a first-class brain entity (#128) — best-effort,
    # non-fatal. Starting a change now creates a Change node in the brain, not
    # just a manifest beside it.
    _emit_change_entity(repo_root, metadata)

    # Optional terminal spawn (WP-004). Spawn failure does NOT unwind the
    # change-creation work — the JSON surfaces spawn_result.status so the
    # founder can fall back to `cd worktree && claude --agent sulis`.
    spawn_result = None
    if getattr(args, "spawn", False):
        pre_prompt = _build_change_pre_prompt(
            change_id=change_id,
            handle=handle,
            slug=slug,
            intent=metadata.get("intent", ""),
            primitive=metadata.get("primitive", ""),
            context_md_path=context_path,
        )
        spawn_result = launch_change_terminal(
            change_id=change_id,
            worktree_path=worktree_dest,
            visible=True,
            pre_prompt=pre_prompt,
        )

    # Publish the change branch to origin (#61) — best-effort, graceful-degrade.
    # The branch ref already exists (git_worktree_add created it), so this just
    # publishes it. A no/unreachable remote degrades to pushed_to_origin=False
    # with a logged warning; it never unwinds the local branch + worktree.
    pushed_to_origin = _push_change_branch_to_origin(repo_root, branch)

    # Brain emission — record this change-start as a LifecycleRun event in
    # the brain graph. Best-effort: failure (missing schemas / no .brain dir
    # / jsonschema absent) is silently absorbed by _brain_emit_helper. The
    # change-start operation has already succeeded by this point; emission
    # is a side-effect and never blocks.
    try:
        from _brain_emit_helper import emit_change_started_event
        emit_change_started_event(
            repo_root, change_id=change_id, handle=handle,
            slug=slug, primitive=primitive,
        )
    except Exception:
        pass  # belt-and-braces — helper already swallows; this guards an import failure

    _log(f"Change started: {branch} ({handle}) at {worktree_dest}")
    emit_ok(data={
        "change_id": change_id,
        "handle": handle,
        "branch": branch,
        "primitive": primitive,
        "slug": slug,
        "worktree_path": str(worktree_dest),
        "base_branch": base_ref,
        "base_sha": base_sha,
        "metadata_path": str(_metadata_path(worktree_dest, primitive, slug)),
        "context_md_path": str(context_path) if context_path is not None else None,
        "spawn_result": spawn_result,
        "pushed_to_origin": pushed_to_origin,
    })


# ─── Subcommand: adopt ────────────────────────────────────────────────────

def cmd_adopt(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)
    primitive, slug = _resolve_primitive_and_slug(args)
    # #112 — adopt MINTS a new change branch, so honour the host convention
    # (like cmd_start). Absent → byte-for-byte change/{primitive}-{slug}.
    convention = read_repo_contract(repo_root).get("branch_convention")
    branch = compose_change_branch(primitive, slug, convention=convention)
    base_ref = args.base or "main"
    mode = (args.mode or "forward").lower()
    remote_ref = args.remote_ref or "origin/dev"

    if mode not in ("forward", "rewrite"):
        emit_error(f"--mode must be 'forward' or 'rewrite' (got '{mode}')")

    # Check the branch doesn't already exist
    rc, _, _ = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                   cwd=repo_root, timeout=10)
    if rc == 0:
        emit_error(f"Change branch already exists: {branch}")

    # Inspect current state
    state = detect_adopt_state(repo_root, remote_ref=remote_ref)
    worktree_dest = change_worktree_path(repo_root, primitive, slug)

    has_uncommitted = state["has_uncommitted"]
    local_commits = state["local_commits_ahead"]

    # Mode handling
    if mode == "rewrite" and not args.force:
        emit_error(
            "--mode rewrite is destructive (rewrites history on the source "
            "branch). Re-run with --force to confirm.",
            context={"local_commits_ahead": len(local_commits)},
        )

    # Case 1: uncommitted only — worktree + worktree-safe file transfer
    # Case 2: local commits (and maybe uncommitted) — cherry-pick path
    # Case 3 (rewrite): same as case 2 but with --force semantics

    moved_what: list[str] = []

    if local_commits:
        # Case 2 / 3: relocate local commits onto the change branch.
        # The change branch starts at the REMOTE ref (clean state), not
        # the local ref (which already has the commits we want to
        # relocate — cherry-picking onto it would produce empty commits).
        #
        # Worktree-safe transfer (issue #53): we do NOT use `git stash` to
        # park the trailing uncommitted work, because the stash stack is
        # shared per-repo and a positional pop can grab a sibling worktree's
        # stash. Instead we capture the uncommitted delta + untracked files
        # explicitly, clean the source tree so the cherry-pick runs clean,
        # then re-apply the captured work into the worktree after the
        # cherry-pick. No shared-stack pop anywhere.
        capture: dict = {}
        recovery_dir = None
        if has_uncommitted:
            ok, msg, capture = _capture_worktree_changes(repo_root)
            if not ok:
                emit_error(f"capturing uncommitted work failed: {msg}")
            # DURABILITY (data-loss window): the source tree is about to be
            # cleaned while the ONLY copy of the founder's uncommitted work
            # is the in-memory `capture`. A cherry-pick or apply failure
            # after the clean would discard it on exit — silent loss. Persist
            # to a durable on-disk location FIRST (mirrors the old
            # `git stash push -u`'s recoverable on-disk park), surface it on
            # any failure leg, and discard it only once apply succeeds.
            ok, msg, recovery_dir = persist_capture_durably(capture)
            if not ok:
                emit_error(
                    f"persisting uncommitted work durably failed: {msg}. "
                    f"Source tree NOT cleaned; your work is intact."
                )
            # Clear the source tree so adopt_local_commits_into_change's
            # cherry-pick + reset operate on a clean working tree.
            ok, msg = _clean_source_worktree(repo_root, capture)
            if not ok:
                discard_persisted_capture(recovery_dir)
                emit_error(f"clearing source tree failed: {msg}")
            moved_what.append(
                f"{len(state['uncommitted_files'])} uncommitted change(s) "
                f"captured for worktree-safe transfer"
            )

        ok, msg = adopt_local_commits_into_change(
            repo_root, branch, remote_ref, worktree_dest, local_commits,
        )
        if not ok:
            # Source tree already cleaned; the durable copy is the founder's
            # only recovery path. Surface it loudly — never lose it silently.
            if recovery_dir is not None:
                emit_error(
                    f"adopt local-commits failed: {msg}. Your uncommitted "
                    f"work was saved before the source tree was cleaned and "
                    f"is recoverable at: {recovery_dir}",
                    context={"recovery_dir": str(recovery_dir)},
                )
            emit_error(f"adopt local-commits failed: {msg}")
        moved_what.append(msg)

        if has_uncommitted:
            # Re-apply the captured work into the worktree (where it belongs
            # now) — explicit file movement, never the shared stash stack.
            ok, msg = _apply_worktree_changes(repo_root, worktree_dest, capture)
            if not ok:
                # HARD ERROR (never success-with-WARN): the source tree is
                # cleaned, so a swallowed warning would report success while
                # the founder's work is gone from the source. Fail loudly and
                # point at the durable recovery copy.
                emit_error(
                    f"applying captured work to worktree failed: {msg}. Your "
                    f"uncommitted work is recoverable at: {recovery_dir}",
                    context={"recovery_dir": str(recovery_dir)},
                )
            # Success: the work is now safely in the worktree. Discard the
            # durable recovery copy — it was only a failure safety net.
            discard_persisted_capture(recovery_dir)

    elif has_uncommitted:
        # Case 1: uncommitted only
        ok, msg = adopt_uncommitted_into_change(
            repo_root, branch, base_ref, worktree_dest,
            state["uncommitted_files"],
        )
        if not ok:
            emit_error(f"adopt uncommitted failed: {msg}")
        moved_what.append(msg)

    else:
        # Nothing to adopt — but still create the branch + worktree (forward-only)
        ok, msg = git_worktree_add(repo_root, branch, worktree_dest, base_ref)
        if not ok:
            emit_error(f"worktree creation failed: {msg}")
        moved_what.append("nothing to retrofit; change branch + worktree created forward-only")

    # Get the SHA we branched off
    rc, base_sha_out, _ = _run(["git", "rev-parse", base_ref],
                               cwd=repo_root, timeout=10)
    base_sha = base_sha_out.strip() if rc == 0 else ""

    metadata = {
        "slug": slug,
        "primitive": primitive,
        "branch": branch,
        "worktree_path": str(worktree_dest),
        "base_branch": base_ref,
        "base_sha": base_sha,
        "started_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "adopted_from_sha": state["base_sha"],
        "adopt_mode": mode,
    }
    write_change_metadata(_metadata_path(worktree_dest, primitive, slug),
                          metadata)

    emit_ok(data={
        "branch": branch,
        "primitive": primitive,
        "slug": slug,
        "worktree_path": str(worktree_dest),
        "adopt_mode": mode,
        "moved": moved_what,
        "uncommitted_count": len(state["uncommitted_files"]),
        "local_commits_count": len(local_commits),
    })


# ─── Subcommand: finish ───────────────────────────────────────────────────

def cmd_finish(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)
    primitive, slug = _resolve_primitive_and_slug(args)
    # #112 — resolve the EXISTING change's recorded branch (store-backed), so a
    # change started under a host convention finishes on the SAME branch.
    branch = _resolve_change_branch(repo_root, primitive, slug)
    base_ref = args.base or "main"

    # Verify the branch exists
    rc, _, _ = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                   cwd=repo_root, timeout=10)
    if rc != 0:
        emit_error(f"Change branch not found: {branch}")

    # Resolve the worktree location-agnostically (see _resolve_change_worktree):
    # ask git where the branch is checked out so finish never recomputes a
    # stale sibling path.
    worktree_dest = _resolve_change_worktree(repo_root, branch, primitive, slug)

    # Read the change metadata ONCE, up front — before any worktree removal
    # (#56 Part 2 may remove the worktree on a happy ship, and the metadata
    # lives inside it). Reused for the PR body, the squash commit message,
    # and the archive step.
    metadata = read_change_metadata(_metadata_path(worktree_dest, primitive, slug))

    # Fetch latest origin/{base_ref}
    rc, _, err = _run(["git", "fetch", "origin", base_ref],
                     cwd=repo_root, timeout=60)
    if rc != 0:
        emit_error(f"git fetch origin {base_ref} failed: {err}")

    # Decide path: --merge (squash-merge to dev, push) or --pr (open PR via gh)
    if args.pr:
        # Push the branch; open a PR
        rc, _, err = _run(["git", "push", "-u", "origin", branch],
                         cwd=repo_root, timeout=60)
        if rc != 0:
            emit_error(f"git push origin {branch} failed: {err}")

        # Compose PR body from metadata
        pr_body = (
            f"Change: `{branch}`\n\n"
            f"Primitive: {metadata.get('primitive', primitive)}\n"
            f"Started at: {metadata.get('started_at', 'unknown')}\n"
        )
        rc, out, err = _run(
            ["gh", "pr", "create",
             "--base", base_ref,
             "--head", branch,
             "--title", f"{branch}",
             "--body", pr_body],
            cwd=repo_root, timeout=60,
        )
        if rc != 0:
            emit_error(f"gh pr create failed: {err}")
        pr_url = out.strip().splitlines()[-1] if out.strip() else ""
        outcome = {"mode": "pr", "pr_url": pr_url}

    elif args.merge:
        # Squash-merge locally — WORKTREE-AWARE (#56 Part 1).
        # git forbids the same branch in two worktrees, so we must perform the
        # merge in WHATEVER worktree already holds {base_ref} — never blindly
        # `git checkout {base_ref}` in repo_root (the recurring #56 fatal when
        # dev lives in a sibling worktree).
        base_dir = _worktree_for_branch(repo_root, base_ref)
        if base_dir is None:
            # base isn't checked out anywhere → safe to check it out here.
            rc, _, err = _run(["git", "checkout", base_ref],
                             cwd=repo_root, timeout=30)
            if rc != 0:
                emit_error(
                    f"git checkout {base_ref} failed: {err}",
                    context={"hint": f"'{base_ref}' could not be checked out "
                                     f"in {repo_root}. If it is checked out in "
                                     f"another worktree, run the ship from "
                                     f"that worktree, or free it there first."},
                )
            base_dir = repo_root
        elif not base_dir.exists():
            emit_error(
                f"'{base_ref}' is registered to a worktree that no longer "
                f"exists on disk: {base_dir}",
                context={"hint": "Run `git worktree prune`, then retry — or "
                                 f"check out {base_ref} somewhere first."},
            )
        # From here, operate in base_dir (the worktree that holds base_ref).
        # 1. Pull latest base.
        rc, _, err = _run(["git", "pull", "origin", base_ref],
                         cwd=base_dir, timeout=60)
        if rc != 0:
            emit_error(f"git pull origin {base_ref} failed: {err}")

        # 2. Squash-merge the change branch into base.
        rc, _, err = _run(["git", "merge", "--squash", branch],
                         cwd=base_dir, timeout=30)
        if rc != 0:
            emit_error(f"git merge --squash {branch} failed: {err}")

        # 3. Drop the changeset (the producer side of .changesets/, ADR-002)
        #    BEFORE the commit so it lands on `dev` in the same squash commit
        #    as the change itself. Detect `touches_plugin` from the staged
        #    diff; the helper short-circuits on tier=None (admin/docs-only).
        rc, staged_paths, _ = _run(
            ["git", "diff", "--cached", "--name-only"],
            cwd=base_dir, timeout=10)
        touches_plugin = any(
            p.startswith("plugins/sulis/")
            for p in staged_paths.splitlines() if p
        )
        try:
            cs_path = _emit_changeset_for_ship(
                base_dir=base_dir, metadata=metadata,
                touches_plugin=touches_plugin,
            )
        except ValueError as exc:
            emit_error(
                f"cannot drop changeset for ship: {exc}",
                context={"hint": "Fix the .changes/*.yaml manifest "
                                 "(missing `primitive` or `change_id`), "
                                 "then re-run `sulis-change finish --merge`."},
            )
        if cs_path is not None:
            rc, _, err = _run(["git", "add", str(cs_path)],
                              cwd=base_dir, timeout=10)
            if rc != 0:
                emit_error(f"git add {cs_path.name} failed: {err}")

        # 4. Commit (only if there's anything staged) — Conventional-Commit
        #    message derived from the change (#56 Part 3).
        rc, status_out, _ = _run(["git", "status", "--porcelain"],
                                 cwd=base_dir, timeout=10)
        if status_out.strip():
            commit_msg = _compose_squash_message(primitive, slug, metadata)
            rc, _, err = _run(["git", "commit", "-m", commit_msg],
                             cwd=base_dir, timeout=30)
            if rc != 0:
                emit_error(f"git commit (merge) failed: {err}")

        # 4. Push base.
        rc, _, err = _run(["git", "push", "origin", base_ref],
                         cwd=base_dir, timeout=60)
        if rc != 0:
            emit_error(f"git push origin {base_ref} failed: {err}")

        outcome = {"mode": "merge", "merged_in": str(base_dir)}
    else:
        emit_error("Pass --merge (squash-merge locally) or --pr (open a PR).")

    # Archive, never delete the BRANCH or RECORD (#38). On a successful merge:
    #   - mark the change shipped (stage='shipped' + shipped_at + shipped_sha),
    #   - pin the change-branch tip as the shipped state (#56 Part 2),
    #   - remove the now-redundant WORKTREE (gated on no live session, #32),
    #   - KEEP the branch + record — the audit trail. `sulis-change recreate`
    #     re-materialises the worktree on demand from the pinned sha.
    # Claim-3 (validated): the cockpit uses worktree_path only for `.exists()`;
    # retrace/diff is git-based (base_sha + branch). So removing the worktree
    # preserves full visibility while ending worktree sprawl.
    # Archive ONLY on a real merge ship. A --pr opens a PR but does NOT merge,
    # so the change is not shipped yet — it gets marked shipped later, when the
    # PR lands and the skill calls `mark-shipped`. (Pre-#56, --pr wrongly
    # flipped the change to 'shipped'; this corrects it.)
    archived: dict = {"archived": False}
    if outcome.get("mode") == "merge":
        change_id = metadata.get("change_id")
        if change_id:
            # The shared helper applies the safety gates (cwd, live session,
            # uncommitted work). Both this path and the gh-based `mark-shipped`
            # path go through it so they can't drift (the same DRY discipline
            # that fixed the L-02 parser split). --no-cleanup keeps the worktree.
            archived = _archive_after_ship(
                repo_root, str(change_id), branch, worktree_dest,
                remove_worktree=not args.no_cleanup)
            if args.no_cleanup:
                archived["no_cleanup_flag"] = (
                    "set — worktree removal skipped; the worktree is kept")
        else:
            # The merge is real, but with no change_id we can't advance the
            # record — surface it rather than silently returning archived=False.
            archived["warning"] = (
                "no change_id in the change manifest — the merge succeeded but "
                "the change record was not advanced to 'shipped'")

    emit_ok(data={
        "branch": branch,
        "primitive": primitive,
        "slug": slug,
        "outcome": outcome,
        "archived": archived,
    })


# ─── Subcommand: list ────────────────────────────────────────────────────

def cmd_list(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)

    # The local records are the branch-independent global index — this is what
    # the dashboard reads too. git is per-branch, so enumerating change/*
    # branches only sees what's checked out from here; the records see every
    # change regardless of branch. We cross-reference the live branch list to
    # flag records whose branch has gone (merged/deleted/pruned).
    records = list_all_changes()
    rc, branch_out, _ = _run(["git", "branch", "--list", "change/*"],
                             cwd=repo_root, timeout=10)
    live_branches = set()
    if rc == 0:
        for line in branch_out.splitlines():
            # git marks the current branch with "* " and a worktree-checked-out
            # branch with "+ "; strip either marker plus leading whitespace.
            name = line.lstrip("*+ ").strip()
            if name:
                live_branches.add(name)

    enriched: list[dict] = []
    for record in records:
        branch = record.get("branch", "")
        item = dict(record)
        item["branch_present"] = branch in live_branches
        wt = record.get("worktree_path", "")
        dest = Path(wt) if wt else None
        item["worktree_present"] = bool(dest and dest.exists())
        if item["worktree_present"]:
            rc, status_out, _ = _run(
                ["git", "status", "--porcelain"],
                cwd=dest, timeout=10,
            )
            item["dirty"] = bool(rc == 0 and status_out.strip())
        else:
            item["dirty"] = False
        enriched.append(item)

    emit_ok(data={
        "active_count": len(enriched),
        "changes": enriched,
    })


# ─── Subcommand: status ──────────────────────────────────────────────────

def cmd_status(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)
    primitive, slug = _resolve_primitive_and_slug(args)
    # #112 — resolve the EXISTING change's recorded branch (store-backed).
    branch = _resolve_change_branch(repo_root, primitive, slug)
    base_ref = args.base or "main"

    rc, _, _ = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                   cwd=repo_root, timeout=10)
    if rc != 0:
        emit_error(f"Change branch not found: {branch}")

    worktree_dest = _resolve_change_worktree(repo_root, branch, primitive, slug)
    metadata = read_change_metadata(_metadata_path(worktree_dest, primitive, slug))

    # SHAs + ahead/behind
    rc, branch_sha_out, _ = _run(["git", "rev-parse", branch],
                                 cwd=repo_root, timeout=10)
    branch_sha = branch_sha_out.strip() if rc == 0 else ""
    rc, base_sha_out, _ = _run(["git", "rev-parse", base_ref],
                               cwd=repo_root, timeout=10)
    base_sha = base_sha_out.strip() if rc == 0 else ""

    # ahead / behind
    rc, ahead_out, _ = _run(
        ["git", "rev-list", "--count", f"{base_ref}..{branch}"],
        cwd=repo_root, timeout=10,
    )
    ahead = int(ahead_out.strip()) if rc == 0 and ahead_out.strip().isdigit() else 0
    rc, behind_out, _ = _run(
        ["git", "rev-list", "--count", f"{branch}..{base_ref}"],
        cwd=repo_root, timeout=10,
    )
    behind = int(behind_out.strip()) if rc == 0 and behind_out.strip().isdigit() else 0

    emit_ok(data={
        "branch": branch,
        "primitive": primitive,
        "slug": slug,
        "worktree_path": str(worktree_dest),
        "worktree_present": worktree_dest.exists(),
        "branch_sha": branch_sha,
        "base_sha": base_sha,
        "ahead_of_base": ahead,
        "behind_base": behind,
        "metadata": metadata,
    })


# ─── Subcommand: stage ────────────────────────────────────────────────────

def cmd_stage(args: argparse.Namespace) -> None:
    """Stamp the workflow stage a change has reached.

    Each stage skill (recon / specify / design / run-all / review) calls this
    on completion so the dashboard reflects where the change is in the
    six-stage workflow. The stage is written to the branch-independent local
    store (`{state_base}/changes/{change_id}/state.json`), so it survives
    branch switches and is visible to the global cross-change view.

    Resolves the change_id from `--change-id` if given, else from the
    `SULIS_CHANGE_ID` environment variable (set in every change-bound
    session). Validates the stage against WORKFLOW_STAGES before writing.
    """
    stage = args.stage
    if not is_valid_stage(stage):
        emit_error(
            f"Unknown workflow stage: {stage!r}. "
            f"Valid stages: {', '.join(WORKFLOW_STAGES)}.",
            context={"given_stage": stage, "valid_stages": list(WORKFLOW_STAGES)},
        )

    change_id = args.change_id or os.environ.get("SULIS_CHANGE_ID")
    if not change_id:
        emit_error(
            "No change to stamp: pass --change-id, or run inside a "
            "change-bound session (SULIS_CHANGE_ID is unset).",
            context={"stage": stage},
        )

    state_path = write_change_stage(change_id, stage)
    if state_path is None:
        # Best-effort write failed (unwritable state dir) — surface honestly
        # rather than claiming success.
        emit_error(
            f"Couldn't record the {stage!r} stage for {change_id} "
            f"(state store not writable).",
            context={"change_id": change_id, "stage": stage},
        )

    emit_ok(data={
        "change_id": change_id,
        "stage": stage,
        "state_path": str(state_path),
    })


# ─── Subcommand: nuke ─────────────────────────────────────────────────────

def _local_state_base() -> Path:
    """The base dir holding per-change local state: {state_base}/changes/.

    Delegates to _change_state.changes_base so the SULIS_STATE_DIR override
    (and the ~/.sulis production default) resolve identically everywhere.
    """
    return changes_base()


def _resolve_change_id(repo_root: Path, primitive: str, slug: str,
                       worktree_dest: Path) -> tuple[str, str]:
    """Resolve a change's change_id from its slug, via the fallback chain.

    This is the SLUG-path resolver: it maps a (primitive, slug) branch to its
    change_id. Handle resolution does NOT live here — it goes through the shared
    safe matcher (``_changes_matching_handle`` over ``list_all_changes()``),
    which refuses on ambiguity rather than silently picking a first match (#101).
    The former head-prefix rung (scan {state_base}/changes/* for a dir whose
    name starts with the handle's 6-char prefix) was dead post-#101 — handles
    are minted from the ULID's random TAIL, but state dirs are named by the full
    ULID whose HEAD is the timestamp, so a tail-minted prefix never matched a
    head-named dir. WP-002 retired it.

    0. Local record → scan {state_base}/changes/*/change.json for one whose
       slug matches. The preferred, branch-independent resolver: the record is
       the global index and doesn't depend on a manifest living in a worktree.
    1. Worktree manifest → read {worktree}/.changes/{primitive}-{slug}.yaml
       (the manifest is committed on the change branch, so it lives in the
       WORKTREE, not the dev checkout where nuke runs).
    2. Dev-checkout manifest → read <repo-root>/.changes/{primitive}-{slug}.yaml
       (rare — only if a copy happens to exist locally, e.g. on dev).
    3. Honest-degrade → "" (state_dir stays null; the caller reports it
       truthfully and removes branch + worktree + manifest only).

    Returns (change_id_or_empty, resolution_note). resolution_note records
    which rung of the chain hit, for the JSON + the ambiguity error path.
    """
    # 0. Local record (change.json) — preferred, branch-independent. Match on
    # the branch slug; the records carry the change_id directly.
    for record in list_all_changes():
        if record.get("slug") == slug and len(record.get("change_id", "")) == 26:
            return record["change_id"], "matched-via-record"

    # 1. Worktree manifest (the common case — manifest committed on the branch).
    wt_manifest = _metadata_path(worktree_dest, primitive, slug)
    meta = read_change_metadata(wt_manifest)
    change_id = meta.get("change_id", "") or ""
    if len(change_id) == 26:
        return change_id, "matched-via-worktree-manifest"

    # 3. Dev-checkout manifest (rare local copy).
    dev_manifest = _metadata_path(repo_root, primitive, slug)
    if dev_manifest != wt_manifest:
        meta = read_change_metadata(dev_manifest)
        change_id = meta.get("change_id", "") or ""
        if len(change_id) == 26:
            return change_id, "matched-via-dev-manifest"

    # 4. Honest-degrade: unresolved. state_dir stays null downstream.
    return "", "unresolved"


def _changes_matching_handle(handle: str, records: list) -> list:
    """Every record whose handle matches `handle` (case-insensitive).

    Matches on the STORED handle OR a recomputed ``ulid_handle(change_id)`` —
    migration-robust across the head→tail handle derivation change (#101), so a
    pre-change record (head-derived stored handle) and a post-change record
    (tail-derived) both resolve. Returns ALL matches so callers REFUSE on
    ambiguity rather than silently picking the first (the #101 danger:
    resolving a handle to the WRONG change).
    """
    h = (handle or "").strip().upper()
    if not h:
        return []
    out = []
    for r in records:
        cid = str(r.get("change_id") or "")
        stored = str(r.get("handle") or "").upper()
        recomputed = ulid_handle(cid).upper() if len(cid) == 26 else ""
        if h == stored or (recomputed and h == recomputed):
            out.append(r)
    return out


def _candidate_name(record: dict) -> str:
    """The readable name for an ambiguity candidate: the record's ``intent``
    (the founder's own words for the change), falling back to the slug.

    Lets a founder choosing between colliding handles see WHICH change is which
    (SPEC Scenario 5) rather than just two opaque ULIDs.
    """
    intent = str(record.get("intent") or "").strip()
    return intent or str(record.get("slug") or "")


def _emit_ambiguous_match(selector: str, matches: list) -> None:
    """REFUSE rather than guess when a selector matches >1 change (#101).

    The whole point of the safe-resolution fix: never silently act on one of
    several candidates. Surface the candidates (full id / readable name / branch
    / stage) and make the operator disambiguate. The readable ``name`` (off the
    record's intent/slug) lets the founder tell colliding handles apart (SPEC
    Scenario 5).
    """
    emit_error(
        f"{selector} matches {len(matches)} changes — refusing to guess which "
        f"one. Disambiguate with --change-id <full ULID> or --slug <slug>.",
        context={
            "hint": "Run `sulis-change list` to see the full ids.",
            "candidates": [
                {
                    "change_id": m.get("change_id"),
                    "name": _candidate_name(m),
                    "branch": m.get("branch"),
                    "slug": m.get("slug"),
                    "stage": m.get("stage"),
                }
                for m in matches
            ],
        },
    )


def _resolve_record_by_id(change_id: str) -> "dict | None":
    """Resolve a change's full record by its exact 26-char ULID.

    The single record-lookup-by-id authority shared by the unambiguous
    selectors (``recreate --change-id`` and ``mark-shipped`` — ADR-001).
    Tries the direct per-change store read first (``change.json`` under
    ``{state_base}/changes/{change_id}/``), then falls back to scanning
    ``list_all_changes()`` for a record whose ``change_id`` matches exactly
    — robust to a record whose store dir name diverges from its id. Returns
    the record dict, or ``None`` when no change carries that id.
    """
    record = read_change_record(change_id)
    if record is not None:
        return record
    for r in list_all_changes():
        if str(r.get("change_id") or "") == change_id:
            return r
    return None


def _select_change_id_refusing_conflict(
    *,
    explicit_change_id: "str | None",
    explicit_handle: "str | None",
    env_change_id: "str | None",
    records: list,
) -> str:
    """Resolve the change id for a session-bindable command (ship/mark-shipped),
    refusing on ambiguity (#101) and on an explicit-vs-session conflict (#274).

    Precedence is NOT "session silently wins" (the #274 bug) and NOT "explicit
    silently wins" — when an explicit selector and the session binding disagree
    we REFUSE and make the operator resolve it (founder-chosen). Returns the
    resolved 26-char change id, or calls ``emit_error`` (exits) on
    not-found / ambiguous / conflict / nothing-given.
    """
    resolved_explicit = explicit_change_id
    if not resolved_explicit and explicit_handle:
        matches = _changes_matching_handle(explicit_handle, records)
        if not matches:
            emit_error(f"no change found for handle {explicit_handle!r}")
        if len(matches) > 1:
            _emit_ambiguous_match(f"Handle {explicit_handle.upper()}", matches)
        resolved_explicit = str(matches[0].get("change_id") or "")

    # #274: an explicit selector must never be silently overridden by the
    # session's active change. Disagreement → refuse, operator resolves.
    if resolved_explicit and env_change_id and resolved_explicit != env_change_id:
        sel = (f"--handle {explicit_handle.upper()}" if explicit_handle
               else f"--change-id {resolved_explicit}")
        env_h = (ulid_handle(env_change_id)
                 if len(env_change_id) == 26 else env_change_id)
        emit_error(
            f"{sel} conflicts with the session's active change ({env_h}).",
            context={
                "hint": "Re-run without the session binding (unset "
                        "SULIS_CHANGE_ID), or pass the session's own change.",
            },
        )

    change_id = resolved_explicit or env_change_id
    if not change_id:
        emit_error("--change-id, --handle, or SULIS_CHANGE_ID required")
    return str(change_id)


def _resolve_nuke_target(repo_root: Path, args: argparse.Namespace) -> dict:
    """Resolve --slug, --handle, or --change-id to a change-branch descriptor.

    Reuses find_change_branches (the same enumeration list/status use) to find
    the branch + worktree. Each branch's change_id (hence the local state dir)
    is resolved by slug via the _resolve_change_id chain — robust to the manifest
    living only in the worktree (the production case) rather than the dev
    checkout where nuke runs.

    Matching:
      --slug      → match the branch slug.
      --handle    → resolve the handle through the SHARED safe matcher
                    (_changes_matching_handle over list_all_changes()); a handle
                    shared by >1 change REFUSES (lists handle + readable name +
                    branch) rather than nuking the wrong one (#101). The matched
                    record change_id(s) are then matched against the enumerated
                    branches. This is the same matcher recreate / mark-shipped
                    use, so all four verbs resolve a handle identically.
      --change-id → match the exact ULID directly (symmetry with recreate /
                    mark-shipped). No ambiguity is possible — a full id is unique.

    Returns a dict {branch, primitive, slug, current, change_id,
    change_id_resolution, worktree_path, manifest_path}. Calls emit_error
    (exits) when no selector is given or no matching change is found.
    """
    slug = getattr(args, "slug", None)
    handle = getattr(args, "handle", None)
    change_id_arg = getattr(args, "change_id", None)
    if not slug and not handle and not change_id_arg:
        emit_error(
            "Pass a selector: --slug SLUG, --handle CH-XXXXXX, or "
            "--change-id <full ULID>.",
            context={"hint": "Run `sulis-change list` to see active changes."},
        )

    # Validate an explicit --change-id up front (symmetry with recreate): a
    # malformed id can never name a real change, so fail early with a precise
    # reason rather than fall through to the generic "no match".
    if change_id_arg:
        ok, reason = validate_change_ulid(change_id_arg)
        if not ok:
            emit_error(f"invalid --change-id {change_id_arg!r}: {reason}")

    # #112 — dual-prefix discovery: a change renamed under the host's
    # branch_convention (e.g. feature/...) is still nuke-targetable, and
    # legacy change/* changes keep resolving. Build one descriptor per branch,
    # resolving its change_id by slug (record → worktree/dev manifest) so the
    # safe matcher (below) has a change_id even when no global change.json
    # exists (the manifest-only production case).
    convention = read_repo_contract(repo_root).get("branch_convention")
    candidates = find_change_branches(repo_root, convention=convention)
    # Readable name per change_id, off the global record's intent (Scenario 5).
    intents = {str(r.get("change_id") or ""): str(r.get("intent") or "")
               for r in list_all_changes()}
    descriptors = []
    for c in candidates:
        dest = change_worktree_path(repo_root, c["primitive"], c["slug"])
        change_id, resolution = _resolve_change_id(
            repo_root, c["primitive"], c["slug"], dest,
        )
        descriptors.append({
            "branch": c["branch"],
            "primitive": c["primitive"],
            "slug": c["slug"],
            "current": c["current"],
            "change_id": change_id,
            "change_id_resolution": resolution,
            # The readable name lets a founder tell colliding handles apart.
            "intent": intents.get(change_id, ""),
            # The state dir lives under ~/.sulis/changes/, NOT in the worktree;
            # nuke removes the dev-side manifest copy if present.
            "worktree_path": dest,
            "manifest_path": _metadata_path(repo_root, c["primitive"],
                                            c["slug"]),
        })

    # Select the matching descriptor(s) per selector. The handle path goes
    # through the SHARED safe matcher (_changes_matching_handle), the same one
    # recreate / mark-shipped use — so all four verbs resolve a handle
    # identically and REFUSE on a colliding handle rather than guessing (#101).
    if handle:
        matches = _changes_matching_handle(handle, descriptors)
    elif change_id_arg:
        target = str(change_id_arg).strip()
        matches = [d for d in descriptors if d["change_id"] == target]
    else:
        target = slug.lower()
        matches = [d for d in descriptors if d["slug"] == target]

    def _selector_label(*, handle_as_flag: bool) -> str:
        """Human label for the active selector. ``handle_as_flag`` chooses the
        CLI-flag form (``--handle CH-X``, for a 'not found' error) vs the
        readable form (``Handle CH-X``, for the ambiguity refusal message)."""
        if slug:
            return f"--slug {slug}"
        if handle:
            return (f"--handle {handle}" if handle_as_flag
                    else f"Handle {handle.strip().upper()}")
        return f"--change-id {change_id_arg}"

    # REFUSE on ambiguity rather than nuking the WRONG change (#101). A handle
    # collision — or a slug shared across primitives — must never resolve to a
    # silent first-match for a destructive op.
    if len(matches) > 1:
        _emit_ambiguous_match(_selector_label(handle_as_flag=False), matches)
    if matches:
        return matches[0]

    emit_error(
        f"No active change matches {_selector_label(handle_as_flag=True)}.",
        context={"hint": "Run `sulis-change list` to see active changes."},
    )


def _branch_has_unmerged_commits(repo_root: Path, branch: str,
                                  base_ref: str = "main") -> int:
    """Return the count of commits on `branch` not yet on `base_ref`.

    0 means fully merged (or branch/base unresolvable — treated as nothing
    to lose). Best-effort: a git failure returns 0 rather than blocking nuke.
    """
    rc, out, _ = _run(
        ["git", "rev-list", "--count", f"{base_ref}..{branch}"],
        cwd=repo_root, timeout=10,
    )
    if rc == 0 and out.strip().isdigit():
        return int(out.strip())
    return 0


def cmd_nuke(args: argparse.Namespace) -> None:
    repo_root = _resolve_repo_root(args)
    target = _resolve_nuke_target(repo_root, args)
    branch = target["branch"]
    worktree_dest = target["worktree_path"]
    manifest = target["manifest_path"]
    change_id = target["change_id"]

    # Safety 1: never nuke the change you're currently on. Check the current
    # branch of the repo_root we were pointed at (which, when run from inside
    # the change worktree, IS the change branch).
    rc, cur_out, _ = _run(["git", "branch", "--show-current"],
                          cwd=repo_root, timeout=10)
    current_branch = cur_out.strip() if rc == 0 else ""
    if current_branch == branch:
        emit_error(
            f"Can't nuke the change you're currently on ({branch}) — "
            f"switch to dev first (`git checkout dev`), then re-run.",
            context={"current_branch": current_branch},
        )

    # Safety 1.4 (#22): refuse to nuke when the change record EXISTS but
    # can't be read (corrupt JSON, truncated write, OS error). Without
    # this guard, `read_change_record` returns None for BOTH 'file absent'
    # (benign) and 'file unreadable' (load-bearing), so Safety 1.5's
    # shipped check below would silently fail open on a corrupt record
    # and the nuke would destroy the audit trail #38 was designed to
    # preserve. --force still overrides (same refusal-by-default
    # semantics as Safety 1.5).
    if change_id and change_record_is_unreadable(change_id) and not args.force:
        emit_error(
            f"Refusing to nuke {branch}: the change record exists but "
            f"can't be read (corrupt or unreadable). I can't verify "
            f"this isn't a shipped change, so I won't risk destroying "
            f"its audit trail. Run with `--force` if you really mean "
            f"to remove it.",
            context={"branch": branch, "change_id": change_id,
                     "reason": "record_unreadable"},
        )

    # Safety 1.5 (#38): refuse to nuke a SHIPPED change unless --force. The
    # archive is the audit trail — destroying it loses the retrace path for a
    # change the founder may need to inspect later (this is exactly the
    # premature-nuke incident class). --force still works for genuine cleanup.
    if change_id:
        record = read_change_record(change_id)
        if record and str(record.get("stage", "")).strip().lower() == "shipped" and not args.force:
            emit_error(
                f"Refusing to nuke a shipped change ({branch}) — the worktree "
                f"and branch are the audit trail (#38). The cockpit + future "
                f"sessions read them. Use `--force` to override if you really "
                f"mean to destroy the archive.",
                context={"branch": branch, "change_id": change_id, "stage": "shipped"},
            )

    state_dir = change_dir(change_id) if change_id else None

    # Safety 2: refuse to nuke a branch with unmerged commits unless --force.
    # (--force is also the mechanical delete switch; without it we dry-run.)
    unmerged = _branch_has_unmerged_commits(repo_root, branch)

    footprint = {
        "worktree": str(worktree_dest),
        "branch": branch,
        "state_dir": str(state_dir) if state_dir else None,
        "manifest": str(manifest),
    }

    if not args.force:
        # Dry-run: list what WOULD be removed; delete nothing; exit 0.
        warnings = []
        if unmerged:
            warnings.append(
                f"branch {branch} has {unmerged} unmerged commit(s) — "
                f"these would be LOST. Re-run with --force to confirm."
            )
        if state_dir is None:
            warnings.append(
                "couldn't locate local state for this change; removing "
                "branch + worktree + manifest only (no ~/.sulis/changes/ dir)."
            )
        emit_ok(data={
            "dry_run": True,
            "branch": branch,
            "primitive": target["primitive"],
            "slug": target["slug"],
            "change_id": change_id or None,
            "change_id_resolution": target.get("change_id_resolution"),
            "would_remove": footprint,
            "unmerged_commits": unmerged,
        }, warnings=warnings or None)
        return

    # --force path: tear down the full footprint. Each step is idempotent —
    # a half-cleaned change (worktree already gone, no state dir, etc.) must
    # not crash; report truthfully what was actually removed this run.
    removed: dict = {}

    # 1. Worktree (force — untracked manifest lives inside; work is abandoned).
    ok, detail = git_worktree_remove(repo_root, worktree_dest, force=True)
    removed["worktree"] = ok
    removed["worktree_detail"] = detail
    # Prune stale refs before deleting the branch.
    _run(["git", "worktree", "prune"], cwd=repo_root, timeout=10)

    # 2. Branch (-D: forced, since the work is being abandoned).
    rc, _, err = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                      cwd=repo_root, timeout=10)
    if rc == 0:
        rc, out, err = _run(["git", "branch", "-D", branch],
                            cwd=repo_root, timeout=10)
        removed["branch"] = rc == 0
        if rc != 0:
            removed["branch_detail"] = (err or out or "branch delete failed").strip()
    else:
        removed["branch"] = False
        removed["branch_detail"] = "branch already absent"

    # 3. Local state dir (~/.sulis/changes/{change_id}/).
    if state_dir is not None and state_dir.exists():
        try:
            shutil.rmtree(state_dir)
            removed["state_dir"] = True
        except OSError as exc:
            removed["state_dir"] = False
            removed["state_dir_detail"] = str(exc)
    else:
        removed["state_dir"] = False
        removed["state_dir_detail"] = "state dir already absent"

    # 4. Committed manifest (.changes/{primitive}-{slug}.yaml). Removing it is
    # a working-tree change the founder commits separately (or, on dev, just a
    # file removal). nuke only removes the file; it never commits.
    if manifest.exists():
        try:
            manifest.unlink()
            removed["manifest"] = True
        except OSError as exc:
            removed["manifest"] = False
            removed["manifest_detail"] = str(exc)
    else:
        removed["manifest"] = False
        removed["manifest_detail"] = "manifest already absent"

    # #128 slice 2 — transition the Change ENTITY to nuked (the transaction
    # rollback point). The entity lives in the MAIN repo's brain, so it SURVIVES
    # the branch/worktree teardown above — leaving a nuked-state audit record.
    # Best-effort; a change with no emitted entity simply no-ops.
    if change_id:
        _transition_change_entity(repo_root, str(change_id), "nuked")

    _log(f"Change nuked: {branch} ({change_id or 'no-id'})")
    nuke_warnings = []
    if state_dir is None:
        nuke_warnings.append(
            "couldn't locate local state for this change; removed "
            "branch + worktree + manifest only (no ~/.sulis/changes/ dir)."
        )
    emit_ok(data={
        "dry_run": False,
        "branch": branch,
        "primitive": target["primitive"],
        "slug": target["slug"],
        "change_id": change_id or None,
        "change_id_resolution": target.get("change_id_resolution"),
        "removed": removed,
        "unmerged_commits_discarded": unmerged,
    }, warnings=nuke_warnings or None)


# ─── argparse ────────────────────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description=(
            "sulis-change — manage change branches and worktrees (CW-01..CW-08). "
            "A change is the unit of work: change/{primitive}-{slug} branch + "
            "dedicated worktree. See plugins/sulis/references/change-work-standard.md."
        ),
    )
    sub = parser.add_subparsers(dest="subcommand", required=True)

    def _common(p: argparse.ArgumentParser, include_slug: bool = True) -> None:
        p.add_argument("--repo-root", default=os.getcwd(),
                       help="Path to the repo root (default: cwd)")
        if include_slug:
            p.add_argument("--slug", required=True,
                           help="Change slug, kebab-case, 2-5 words "
                                "(e.g. introduce-payments)")
            p.add_argument("--primitive", default="feat",
                           help=f"Change primitive (default: feat). "
                                f"Allowed: {', '.join(ALLOWED_CHANGE_PRIMITIVES)}")
        p.add_argument("--base", default=None,
                       help="Base ref for the change (default: main)")

    p_start = sub.add_parser("start", help="Create a new change branch + worktree")
    _common(p_start)
    p_start.add_argument(
        "--intent", default="",
        help="One-line plain-English intent for the change (briefs the "
             "spawned Sulis session via the pre-prompt + recon).",
    )
    p_start.add_argument(
        "--spawn", action="store_true",
        help="After creating the change branch + worktree + metadata, write "
             "the recon CONTEXT.md and spawn a new terminal in the worktree "
             "with SULIS_CHANGE_ID set, running `claude --agent sulis` with "
             "a HERE-DOC pre-prompt briefing the agent on the change. "
             "Default off. See plugins/sulis/docs/change-as-primitive-design.md "
             "§ Session binding.",
    )
    p_start.add_argument(
        "--relationship", default="builds_on",
        choices=["builds_on", "depends_on"],
        help="When started from inside a parent change session "
             "(SULIS_CHANGE_ID set), how this change relates to the parent: "
             "`builds_on` (default — extends the parent's idea) or "
             "`depends_on` (the parent is a dependency). Records a durable link "
             "+ carries the parent's context into this change's CONTEXT.md "
             "(#123).",
    )

    p_adopt = sub.add_parser("adopt", help="Retrofit in-flight work into a change")
    _common(p_adopt)
    p_adopt.add_argument("--mode", default="forward",
                         choices=["forward", "rewrite"],
                         help="forward (default): create branch from current "
                              "dev, leave existing commits where they are. "
                              "rewrite: destructive — relocates commits.")
    p_adopt.add_argument("--remote-ref", default="origin/dev",
                         help="Remote ref to compare local against "
                              "(default: origin/dev)")
    p_adopt.add_argument("--force", action="store_true",
                         help="Required for --mode rewrite (history rewrite confirmation)")

    p_finish = sub.add_parser("finish", help="Rebase + merge/PR + cleanup")
    _common(p_finish)
    p_finish.add_argument("--merge", action="store_true",
                          help="Squash-merge to base locally + push")
    p_finish.add_argument("--pr", action="store_true",
                          help="Push branch + open PR via gh")
    p_finish.add_argument("--no-cleanup", action="store_true",
                          help="Skip worktree + branch cleanup")

    p_list = sub.add_parser("list", help="List active change branches")
    _common(p_list, include_slug=False)

    p_status = sub.add_parser("status", help="Show one change's state")
    _common(p_status)

    p_stage = sub.add_parser(
        "stage",
        help="Stamp the workflow stage a change has reached "
             "(recon/specify/design/implement/review/ship)",
    )
    p_stage.add_argument(
        "stage",
        help="The workflow stage now reached: "
             + " / ".join(WORKFLOW_STAGES),
    )
    p_stage.add_argument(
        "--change-id", default=None,
        help="Change ULID to stamp (default: the SULIS_CHANGE_ID env var)",
    )

    # `mark-shipped` is the terminal-stage transition (#38). Called by the
    # `/sulis:change ship` skill after `gh pr merge` succeeds: flips
    # stage='shipped' + records shipped_at on the change record. Idempotent;
    # never deletes anything (archive, not delete). Distinct from the `stage`
    # subcommand which only updates state.json.
    p_mark_shipped = sub.add_parser(
        "mark-shipped",
        help="Mark a change as shipped (archive, no deletion) — #38.",
    )
    p_mark_shipped.add_argument("--change-id", default=None,
                                help="Change ULID (default: SULIS_CHANGE_ID env var)")
    p_mark_shipped.add_argument("--handle", default=None,
                                help="Change handle (e.g. CH-01HYQC) to resolve the ULID")
    p_mark_shipped.add_argument("--repo-root", default=os.getcwd(),
                                help="Path to the repo root (default: cwd)")
    p_mark_shipped.add_argument(
        "--merge-sha", default=None,
        help="The merge commit on main (for a manual merge with no PR). "
             "Verified to be an ancestor of origin/main before shipping (#111).")
    p_mark_shipped.add_argument(
        "--force", action="store_true",
        help="Override the #111 ship-integrity guard and mark shipped even "
             "without a confirmed merge to main. Records the override on the "
             "change record + stderr. For genuine edge cases only; never the "
             "default.")

    p_nuke = sub.add_parser(
        "nuke",
        help="Abandon + delete a change and its full footprint "
             "(worktree, branch, local state, manifest)",
    )
    p_nuke.add_argument("--repo-root", default=os.getcwd(),
                        help="Path to the repo root (default: cwd)")
    p_nuke.add_argument("--slug", default=None,
                        help="Change slug to nuke (e.g. introduce-payments)")
    p_nuke.add_argument("--handle", default=None,
                        help="Change handle to nuke (e.g. CH-01HYQC). Resolved "
                             "through the safe matcher; a colliding handle "
                             "refuses + lists candidates rather than guessing.")
    p_nuke.add_argument("--change-id", default=None,
                        help="Exact change ULID to nuke (unambiguous; symmetry "
                             "with recreate / mark-shipped).")
    p_nuke.add_argument(
        "--force", action="store_true",
        help="Actually delete. Without --force, nuke dry-runs: it lists the "
             "footprint that WOULD be removed and exits without deleting. "
             "--force is also required to discard a branch with unmerged "
             "commits.",
    )

    # `verify-verdict` (#122) is the PRE-merge observed-verdict gate the ship
    # flow runs before `gh pr merge` (read-only; mark-shipped is the post-merge
    # backstop). Same selectors as mark-shipped/recreate.
    p_verify_verdict = sub.add_parser(
        "verify-verdict",
        help="Pre-merge gate: refuse (exit 1) unless the change's Definition "
             "of Done verdict is met (read-only; #122).",
    )
    p_verify_verdict.add_argument("--change-id", default=None,
                                  help="Change ULID — the unambiguous selector")
    p_verify_verdict.add_argument("--handle", default=None,
                                  help="Change handle (e.g. CH-01HYQC)")
    p_verify_verdict.add_argument("--repo-root", default=os.getcwd(),
                                  help="Path to the repo root (default: cwd)")

    # `recreate` re-materialises a shipped change's worktree on demand (#56
    # Part 2). After ship the worktree is removed but the branch + record
    # (with the pinned shipped_sha) are kept; this brings the worktree back.
    p_recreate = sub.add_parser(
        "recreate",
        help="Re-materialise a shipped change's worktree from its pinned "
             "state (on the branch if present, else detached at shipped_sha).",
    )
    p_recreate.add_argument("--repo-root", default=os.getcwd(),
                            help="Path to the repo root (default: cwd)")
    p_recreate.add_argument("--change-id", default=None,
                            help="Change ULID — the unambiguous selector "
                                 "(matches nuke/mark-shipped; the cockpit "
                                 "passes the id it already holds)")
    p_recreate.add_argument("--handle", default=None,
                            help="Change handle (e.g. CH-01HYQC) — a display "
                                 "label; ambiguous handles refuse + disambiguate")
    p_recreate.add_argument("--slug", default=None,
                            help="Change slug (alternative to --handle)")
    p_recreate.add_argument(
        "--primitive", default="feat",
        help="Change primitive (used with --slug; default: feat)")

    return parser


def cmd_verify_verdict(args: argparse.Namespace) -> None:
    """#122 — the PRE-merge observed-verdict gate. Read-only.

    The ship flow runs this BEFORE `gh pr merge`, and refuses the merge on a
    non-zero exit. This gates the *merge* (and therefore the release the robot
    cuts on merge), not just the post-merge `shipped` flag — closing the seam
    where #118's mark-shipped check (post-merge) let unverified work merge +
    release before refusing the flag. `mark-shipped` keeps the same check as
    the post-merge backstop (defense-in-depth).

    Reads the *recorded* verdict (deposited TestResults) — it does NOT re-drive
    scenarios, so it needs no standing app. Exit: 0 ok (merge may proceed),
    1 blocked (refuse the merge — surface the reason; the founder owns any
    conscious override at the ship step), 3 invocation/resolution error.
    """
    repo_root = Path(getattr(args, "repo_root", None) or os.getcwd()).resolve()
    change_id = _select_change_id_refusing_conflict(
        explicit_change_id=getattr(args, "change_id", None),
        explicit_handle=getattr(args, "handle", None),
        env_change_id=os.environ.get("SULIS_CHANGE_ID"),
        records=list_all_changes(),
    )
    record = _resolve_record_by_id(str(change_id))
    if record is None:
        emit_error(f"no change record found for change_id={change_id!r}")
        return  # for type checker (emit_error exits)
    primitive = str(record.get("primitive") or "feat")
    slug = str(record.get("slug") or "")

    ok, reason = _confirm_observed_verdict(repo_root, stem=f"{primitive}-{slug}")
    if not ok:
        emit_error(
            f"change {change_id} has not met its Definition of Done — refusing "
            f"the merge. {reason}",
            context={"change_id": change_id},
        )
        return  # for type checker (emit_error exits)
    print(f"OK: {change_id} — {reason}")


def cmd_mark_shipped(args: argparse.Namespace) -> None:
    """#38/#56 — flip stage='shipped', pin shipped_sha, remove the worktree.

    Called by the `/sulis:change ship` skill after `gh pr merge` succeeds (the
    founder-facing ship path; the local `finish --merge` path is the other).
    Both go through `_archive_after_ship` so the post-ship state is identical:
    branch + record kept (audit trail), shipped_sha pinned, redundant worktree
    removed (gated on no live session + no uncommitted work). Idempotent: a
    repeat call preserves the first shipped_at + shipped_sha.
    """
    repo_root = Path(getattr(args, "repo_root", None) or os.getcwd()).resolve()
    # Safe resolution (#101 + #274): an explicit --handle resolves through the
    # ambiguity-refusing matcher, and an explicit selector that disagrees with
    # the session's SULIS_CHANGE_ID is REFUSED (never silently overridden).
    change_id = _select_change_id_refusing_conflict(
        explicit_change_id=args.change_id,
        explicit_handle=getattr(args, "handle", None),
        env_change_id=os.environ.get("SULIS_CHANGE_ID"),
        records=list_all_changes(),
    )
    # Shared record-lookup-by-id authority (ADR-001) — the same helper
    # `recreate --change-id` uses, so both unambiguous selectors resolve a
    # record identically (the #56-style scan fallback included).
    record = _resolve_record_by_id(str(change_id))
    if record is None:
        emit_error(f"no change record found for change_id={change_id!r}")
        return  # for type checker
    primitive = str(record.get("primitive") or "feat")
    slug = str(record.get("slug") or "")
    branch = str(record.get("branch")
                 or compose_change_branch(primitive, slug))
    worktree_dest = Path(record.get("worktree_path")
                         or change_worktree_path(repo_root, primitive, slug))

    # #111 — ship-integrity guard. 'shipped' MUST be impossible without a
    # confirmed merge to `main`. This guard lives INSIDE the tool so it holds
    # regardless of caller (a flailing/reaped session can't mark a non-merged
    # change shipped + delete its branch, as happened to CH-7BF1VZ in #110).
    force = bool(getattr(args, "force", False))
    merge_sha = getattr(args, "merge_sha", None)
    confirmed_sha = _confirm_merged_to_main(
        repo_root, branch, merge_sha=merge_sha)
    if confirmed_sha is None and not force:
        emit_error(
            f"change {change_id} is not merged to main — refusing to mark "
            f"shipped. The squash-merge into main could not be confirmed "
            f"(no merged PR for branch {branch!r}). If you merged manually, "
            f"re-run with --merge-sha <the merge commit on main>; to override "
            f"the guard anyway, pass --force.",
            context={"change_id": change_id, "branch": branch,
                     "merge_sha": merge_sha},
        )
        return  # for type checker (emit_error exits)

    # #118 — observed-verdict gate. 'shipped' MUST be impossible without a
    # recorded Definition-of-Done verdict for every touched SRD. Like the merge
    # guard above, it lives INSIDE the tool so it holds regardless of caller —
    # an agent that skips the SKILL's gate-4.9 prose, or a hand-merge that
    # bypasses the skill entirely, cannot mark a change shipped with unverified
    # requirements. Completion is owned by the recorded verdict, not asserted.
    verdict_ok, verdict_reason = _confirm_observed_verdict(
        repo_root, stem=f"{primitive}-{slug}")
    verdict_override_note = None
    if not verdict_ok:
        if not force:
            emit_error(
                f"change {change_id} has not met its Definition of Done — "
                f"refusing to mark shipped. {verdict_reason}",
                context={"change_id": change_id, "branch": branch},
            )
            return  # for type checker (emit_error exits)
        verdict_override_note = (
            f"--force override: marked shipped despite an unmet Definition of "
            f"Done — {verdict_reason}"
        )
        print(f"WARNING: {verdict_override_note}", file=sys.stderr)

    # The state we PIN as shipped: the confirmed merge commit on main (the
    # true shipped state). On a --force override with no confirmation we have
    # no merge commit, so _archive_after_ship falls back to the branch tip.
    override_note = None
    if confirmed_sha is None and force:
        override_note = (
            f"--force override: marked shipped WITHOUT a confirmed merge to "
            f"main (branch {branch!r}). No merged PR was found and no valid "
            f"--merge-sha was supplied. This bypasses the #111 ship-integrity "
            f"guard — use only for genuine edge cases."
        )
        print(f"WARNING: {override_note}", file=sys.stderr)

    archived = _archive_after_ship(repo_root, str(change_id), branch,
                                   worktree_dest, remove_worktree=True,
                                   shipped_sha_override=confirmed_sha)
    # Record any override(s) on the change record for the audit trail.
    if override_note is not None or verdict_override_note is not None:
        rec_for_note = read_change_record(str(change_id)) or {}
        if override_note is not None:
            rec_for_note["ship_override"] = override_note
        if verdict_override_note is not None:
            rec_for_note["dod_override"] = verdict_override_note
        write_change_record(str(change_id), rec_for_note)
    record = read_change_record(str(change_id)) or {}

    # Brain emission — LifecycleRun for the ship event. Best-effort
    # (see cmd_start for the same pattern + rationale).
    try:
        from _brain_emit_helper import emit_change_shipped_event
        emit_change_shipped_event(
            repo_root, change_id=str(change_id), handle=str(record.get("handle") or ""),
            slug=slug, primitive=primitive,
            shipped_sha=str(record.get("shipped_sha") or ""),
        )
    except Exception:
        pass

    # #128 slice 2 — transition the Change ENTITY to shipped (the transaction
    # commit point). Best-effort; the git-side ship already succeeded above.
    _transition_change_entity(repo_root, str(change_id), "shipped")

    emit_ok(data={
        "change_id": change_id,
        "stage": "shipped",
        "shipped_at": record.get("shipped_at"),
        "shipped_sha": record.get("shipped_sha"),
        "archived": archived,
    })


def cmd_recreate(args: argparse.Namespace) -> None:
    """Re-materialise a shipped change's worktree on demand (#56 Part 2).

    After a successful ship the worktree is removed but the branch + record
    (with the pinned ``shipped_sha``) are kept. This brings the worktree
    back — ON the branch if it still exists (founder resumes work), else
    DETACHED at the pinned ``shipped_sha`` (view the exact shipped state).

    Resolved by ``--change-id`` (the unambiguous selector — the cockpit
    passes the id it already holds, ADR-001), or ``--handle``, or
    ``--slug [--primitive]``. The handle is a non-unique display label; an
    ambiguous handle refuses + disambiguates via the safe matcher (#101).
    The id path is first-class and mirrors ``nuke``/``mark-shipped``.
    """
    repo_root = _resolve_repo_root(args)

    record: dict | None = None
    change_id = getattr(args, "change_id", None)
    if change_id:
        # Unambiguous resolution: the full ULID names exactly one change. The
        # cockpit drives this path (WP-003) with record.changeId in hand.
        ok, reason = validate_change_ulid(change_id)
        if not ok:
            emit_error(f"invalid --change-id {change_id!r}: {reason}")
            return  # for type checker
        record = _resolve_record_by_id(change_id)
        if record is None:
            emit_error(
                f"no change found for change-id {change_id!r}",
                context={"hint": "Run `sulis-change list` to see active "
                                 "changes (the `change_id` column)."},
            )
            return  # for type checker
        primitive = str(record.get("primitive") or "feat")
        slug = str(record.get("slug") or "")
        branch = str(record.get("branch")
                     or compose_change_branch(primitive, slug))
    elif args.handle:
        # Safe resolution (#101): refuse on ambiguity rather than recreating the
        # WRONG change's workspace from a silent first-match.
        matches = _changes_matching_handle(args.handle, list_all_changes())
        if not matches:
            emit_error(f"no change found for handle {args.handle!r}")
            return  # for type checker
        if len(matches) > 1:
            _emit_ambiguous_match(f"Handle {args.handle.upper()}", matches)
        record = matches[0]
        primitive = str(record.get("primitive") or "feat")
        slug = str(record.get("slug") or "")
        branch = str(record.get("branch")
                     or compose_change_branch(primitive, slug))
    else:
        if not args.slug:
            emit_error("--handle or --slug is required")
        primitive, slug = _resolve_primitive_and_slug(args)
        # #112 — resolve the stored branch (store-backed) so a change started
        # under a host convention recreates on the SAME branch.
        branch = _resolve_change_branch(repo_root, primitive, slug)
        for r in list_all_changes():
            if str(r.get("branch", "")) == branch:
                record = r
                break

    # Resolve via git (see _resolve_change_worktree): if the branch is already
    # checked out — at the co-located OR a legacy sibling path — recreate is a
    # no-op. Only when git reports the branch checked out nowhere do we fall
    # back to the legacy sibling path and materialise a fresh worktree below.
    worktree_dest = _resolve_change_worktree(repo_root, branch, primitive, slug)
    if worktree_dest.exists():
        emit_ok(data={
            "recreated": False,
            "reason": "worktree already exists",
            "worktree": str(worktree_dest),
            "branch": branch,
        })
        return

    # Prefer the branch (attached → resume work). Fall back to the pinned
    # shipped_sha (detached → view the exact shipped state) if it's gone.
    rc, _, _ = _run(["git", "rev-parse", "--verify", f"refs/heads/{branch}"],
                    cwd=repo_root, timeout=10)
    branch_exists = rc == 0

    if branch_exists:
        ok, msg = git_worktree_add(repo_root, branch, worktree_dest)
        if not ok:
            emit_error(f"could not recreate worktree: {msg}")
        ref_used, detached = branch, False
    else:
        shipped_sha = str((record or {}).get("shipped_sha") or "").strip()
        if not shipped_sha:
            emit_error(
                f"branch {branch} is gone and no shipped_sha is recorded — "
                f"cannot recreate the worktree",
                context={"hint": "This change predates shipped_sha recording; "
                                 "the exact shipped state is unavailable."},
            )
        rc, _, err = _run(["git", "worktree", "add", "--detach",
                           str(worktree_dest), shipped_sha],
                          cwd=repo_root, timeout=60)
        if rc != 0:
            emit_error(f"git worktree add --detach failed: {err}")
        ref_used, detached = shipped_sha, True

    emit_ok(data={
        "recreated": True,
        "worktree": str(worktree_dest),
        "branch": branch,
        "ref": ref_used,
        "detached": detached,
    })


HANDLERS = {
    "start": cmd_start,
    "adopt": cmd_adopt,
    "finish": cmd_finish,
    "list": cmd_list,
    "status": cmd_status,
    "stage": cmd_stage,
    "mark-shipped": cmd_mark_shipped,
    "verify-verdict": cmd_verify_verdict,
    "nuke": cmd_nuke,
    "recreate": cmd_recreate,
}


if __name__ == "__main__":
    cli_main(build_parser(), HANDLERS)
