{
  "mcpServers": {
    "mobbin": {
      "type": "http",
      "url": "https://api.mobbin.com/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "sulis-safe-tools": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}/scripts",
        "python",
        "${CLAUDE_PLUGIN_ROOT}/scripts/sulis-safe-tools-mcp"
      ]
    },
    "sulis-thread-context": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}/scripts",
        "python",
        "${CLAUDE_PLUGIN_ROOT}/scripts/sulis-thread-context-mcp"
      ]
    }
  }
}
