{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/tenant/1.0.0",
  "title": "Tenant",
  "description": "the customer organisation that owns this DNA \u2014 the namespace boundary for everything in their entity graph. Every other entity in every domain (Opportunity, Requirement, Product, Submission, Policy, \u2026) is implicitly or explicitly scoped to a Tenant.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "name",
    "kind",
    "state",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "instance reliability score"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:tenant:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "name": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "company",
        "partnership",
        "sole-trader",
        "nonprofit",
        "government",
        "individual",
        "other"
      ]
    },
    "legal_name": {
      "type": "string",
      "description": "formal registered name; differs from `name` which is the display/brand"
    },
    "jurisdiction": {
      "type": "string",
      "description": "ISO 3166-1 alpha-2 country code; supplement with state/province via colon if needed, e.g. 'GB' or 'US:CA'"
    },
    "state": {
      "enum": [
        "onboarding",
        "active",
        "suspended",
        "offboarded"
      ]
    }
  },
  "x-schema-org-extends": "schema:Organization"
}