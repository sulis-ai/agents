{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/credential/1.0.0",
  "title": "Credential",
  "description": "a holder's right to authenticate or be granted scope, addressable independently of any single use \u2014 issued by an Actor, held by an Actor, referenced by other entities (TestRun, Deployment, SanctionsScreen, \u2026)",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "holder",
    "kind",
    "token_ref",
    "state",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "instance reliability score"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:credential:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "holder": {
      "type": "string",
      "pattern": "^dna:(actor):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "issuer": {
      "type": "string",
      "pattern": "^dna:(actor):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "kind": {
      "enum": [
        "oauth",
        "api-key",
        "service-account",
        "certificate",
        "password",
        "mfa-token",
        "webhook-signing-key",
        "other"
      ]
    },
    "scope": {
      "type": "string"
    },
    "token_ref": {
      "type": "string",
      "description": "URI to the secret store \u2014 secret value NEVER in this record",
      "x-sensitive": true
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "state": {
      "enum": [
        "active",
        "expired",
        "revoked",
        "rotated"
      ]
    }
  },
  "x-schema-org-extends": "custom"
}