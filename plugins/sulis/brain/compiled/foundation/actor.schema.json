{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/actor/1.0.0",
  "title": "Actor",
  "description": "the responsible party a provenance edge resolves to \u2014 a person, team, automation, or LLM. Belongs to a Tenant.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "kind",
    "belongs_to_tenant",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "instance reliability score"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:actor:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "name": {
      "type": "string",
      "description": "person/org name \u2014 PII",
      "x-sensitive": true
    },
    "kind": {
      "enum": [
        "person",
        "team",
        "automation",
        "llm"
      ]
    },
    "belongs_to_tenant": {
      "type": "string",
      "pattern": "^dna:(tenant):[0-9A-HJKMNP-TV-Z]{26}$"
    }
  },
  "x-schema-org-extends": "schema:Person | schema:Organization"
}