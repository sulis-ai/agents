{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/step/1.2.0",
  "title": "Step",
  "description": "the definition of a single transformation in a process \u2014 the IDEF0 box (Inputs + Controls + Outputs + Mechanism). The CONTRACT for what a step requires before it can run + what it must produce when it does. Belongs to a Tenant (each business's process definitions are tenant-scoped). When the transformation is a typed deterministic operation, the Step points at a Tool via `tool_ref`.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "name",
    "for_domain",
    "input_artifacts",
    "output_artifacts",
    "mechanism",
    "state",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "instance reliability score"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:step:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "name": {
      "type": "string"
    },
    "for_domain": {
      "type": "string",
      "pattern": "^dna:(tenant):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "for_process": {
      "type": "string"
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "mechanism": {
      "enum": [
        "deterministic",
        "probabilistic",
        "human",
        "mixed"
      ]
    },
    "mechanism_detail": {
      "type": "string"
    },
    "tool_ref": {
      "type": "string",
      "pattern": "^dna:(tool):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "postconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "agent_instructions": {
      "type": "string"
    },
    "criticality": {
      "enum": [
        "critical",
        "important",
        "optional"
      ]
    },
    "handles_failures": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:(failuremode):[0-9A-HJKMNP-TV-Z]{26}$"
      }
    },
    "state": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    }
  },
  "x-schema-org-extends": "schema:Action"
}