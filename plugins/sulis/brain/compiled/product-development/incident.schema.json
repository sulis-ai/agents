{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/incident/1.0.0",
  "title": "Incident",
  "description": "an unplanned operational disruption \u2014 the event",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "severity",
    "detected_at",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:incident:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "severity": {
      "enum": [
        "sev1",
        "sev2",
        "sev3"
      ]
    },
    "detected_at": {
      "type": "string",
      "format": "date-time"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time"
    },
    "mttr": {
      "type": "string",
      "pattern": "^-?P(?=.)((\\d+)Y)?((\\d+)M)?((\\d+)D)?(T(?=.)((\\d+)H)?((\\d+)M)?((\\d+(\\.\\d+)?)S)?)?$"
    }
  },
  "x-schema-org-extends": "schema:Event"
}