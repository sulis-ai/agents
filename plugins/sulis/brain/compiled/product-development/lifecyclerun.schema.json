{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/lifecyclerun/1.0.0",
  "title": "LifecycleRun",
  "description": "the running of a named lifecycle step (build, release, measurement, \u2026) \u2014 a prov:Activity that consumes inputs and produces outputs",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "step_name",
    "at",
    "outcome",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:lifecyclerun:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "step_name": {
      "type": "string"
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "by_actor": {
      "type": "string",
      "pattern": "^dna:(actor):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "outcome": {
      "enum": [
        "completed",
        "failed",
        "in-progress",
        "cancelled"
      ]
    }
  },
  "x-schema-org-extends": "schema:Action"
}