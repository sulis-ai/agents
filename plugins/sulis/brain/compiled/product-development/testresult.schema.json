{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/testresult/1.1.0",
  "title": "TestResult",
  "description": "the verifying result a TestRun produced for one or more Requirements",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "of_run",
    "verifies",
    "type",
    "outcome",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "produced_by_change": {
      "type": "string",
      "pattern": "^dna:change:[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "the Change that created this entity (prov:wasGeneratedBy); reverse-query gives a change's creation set (#67)"
    },
    "evolved_by_change": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:change:[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "description": "the Changes that revised this entity, in order (prov:wasRevisionOf); reverse-query gives a change's revision set (#67)"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:testresult:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "of_run": {
      "type": "string",
      "pattern": "^dna:(testrun):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "verifies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:(requirement):[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "minItems": 1
    },
    "type": {
      "enum": [
        "unit",
        "integration",
        "e2e",
        "contract",
        "security"
      ]
    },
    "outcome": {
      "enum": [
        "pass",
        "fail",
        "skip"
      ]
    },
    "evidence": {
      "type": "string",
      "description": "URI to artifact \u2014 may contain test PII",
      "x-sensitive": true
    },
    "scenario": {
      "type": "string",
      "pattern": "^dna:(scenario):[0-9A-HJKMNP-TV-Z]{26}$"
    }
  },
  "x-schema-org-extends": "custom"
}