{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/finding/1.0.0",
  "title": "Finding",
  "description": "a recorded observation about code, security, operability, performance, or accessibility quality",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "kind",
    "severity",
    "summary",
    "observed_at",
    "state",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "produced_by_change": {
      "type": "string",
      "pattern": "^dna:change:[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "the Change that created this entity (prov:wasGeneratedBy); reverse-query gives a change's creation set (#67)"
    },
    "evolved_by_change": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:change:[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "description": "the Changes that revised this entity, in order (prov:wasRevisionOf); reverse-query gives a change's revision set (#67)"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:finding:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "kind": {
      "enum": [
        "code-quality",
        "security",
        "operability",
        "performance",
        "accessibility",
        "other"
      ]
    },
    "severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "summary": {
      "type": "string"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "observed_in": {
      "type": "string",
      "pattern": "^dna:(component|release|deployment):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "state": {
      "enum": [
        "open",
        "triaged",
        "fixing",
        "resolved",
        "wontfix",
        "deferred"
      ]
    }
  },
  "x-schema-org-extends": "custom"
}