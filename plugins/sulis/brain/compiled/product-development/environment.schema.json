{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/environment/1.0.0",
  "title": "Environment",
  "description": "the named target where a Release runs \u2014 production, staging, test, dev, preview-N, etc.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "name",
    "kind",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:environment:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "name": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "production",
        "staging",
        "test",
        "dev",
        "preview",
        "other"
      ]
    },
    "region": {
      "type": "string"
    },
    "retired_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "x-schema-org-extends": "custom"
}