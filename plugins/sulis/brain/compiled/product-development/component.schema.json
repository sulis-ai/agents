{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/component/1.0.0",
  "title": "Component / Code",
  "description": "a unit of the implementation (file / module / package)",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "repo",
    "path",
    "version",
    "license",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:component:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "repo": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "description": "git SHA / SemVer"
    },
    "implements": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:(design|requirement):[0-9A-HJKMNP-TV-Z]{26}$"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "purl or SPDX-id"
      }
    },
    "license": {
      "type": "string",
      "description": "SPDX id"
    }
  },
  "x-schema-org-extends": "schema:SoftwareSourceCode"
}