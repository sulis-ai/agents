{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/metric/1.0.0",
  "title": "Metric",
  "description": "a measured outcome \u2014 delivery health or product outcome",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "kind",
    "measures",
    "value",
    "observed_at",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:metric:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "kind": {
      "enum": [
        "DORA",
        "SPACE",
        "product"
      ]
    },
    "measures": {
      "type": "string",
      "pattern": "^dna:(release|opportunity):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "value": {
      "type": "number"
    },
    "window": {
      "type": "string",
      "pattern": "^-?P(?=.)((\\d+)Y)?((\\d+)M)?((\\d+)D)?(T(?=.)((\\d+)H)?((\\d+)M)?((\\d+(\\.\\d+)?)S)?)?$"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "x-schema-org-extends": "schema:Observation"
}