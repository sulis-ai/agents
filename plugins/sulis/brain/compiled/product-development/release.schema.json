{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/release/1.0.0",
  "title": "Release",
  "description": "a versioned, immutable shipped unit",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "version",
    "comprises",
    "sbom",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:release:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "version": {
      "type": "string",
      "description": "SemVer"
    },
    "comprises": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:(component):[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "minItems": 1
    },
    "changelog": {
      "type": "string"
    },
    "sbom": {
      "type": "string",
      "description": "URI to SPDX or CycloneDX"
    },
    "shipped_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "x-schema-org-extends": "schema:SoftwareApplication"
}