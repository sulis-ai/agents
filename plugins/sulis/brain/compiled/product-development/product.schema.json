{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/product/1.1.0",
  "title": "Product",
  "description": "the product-line a Tenant has built or is building. A Tenant has many Products (or one, for single-product businesses); each Product has its own Opportunities, Requirements, and Releases. The 'product' in product-development.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "name",
    "belongs_to_tenant",
    "state",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:product:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "name": {
      "type": "string"
    },
    "belongs_to_tenant": {
      "type": "string",
      "pattern": "^dna:(tenant):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "description": "e.g. 'b2b-saas', 'consumer-mobile', 'internal-tool', 'platform-api' \u2014 informal"
    },
    "state": {
      "enum": [
        "planning",
        "active",
        "maintenance",
        "sunset",
        "discontinued"
      ]
    },
    "launched_at": {
      "type": "string",
      "format": "date-time"
    },
    "sunsetted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "x-schema-org-extends": "schema:SoftwareApplication"
}