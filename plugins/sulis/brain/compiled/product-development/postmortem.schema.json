{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/postmortem/1.0.0",
  "title": "PostMortem",
  "description": "the structured record of an Incident \u2014 findings + corrective actions",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "for_incident",
    "findings",
    "blameless",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:postmortem:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "for_incident": {
      "type": "string",
      "pattern": "^dna:(incident):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "findings": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:(requirement|opportunity):[0-9A-HJKMNP-TV-Z]{26}$"
      }
    },
    "blameless": {
      "type": "boolean"
    }
  },
  "x-schema-org-extends": "custom"
}