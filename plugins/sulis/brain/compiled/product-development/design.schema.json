{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/design/1.0.0",
  "title": "Design",
  "description": "how the solution will meet the requirements \u2014 architecture + interface decisions",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "satisfies",
    "state",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "produced_by_change": {
      "type": "string",
      "pattern": "^dna:change:[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "the Change that created this entity (prov:wasGeneratedBy); reverse-query gives a change's creation set (#67)"
    },
    "evolved_by_change": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:change:[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "description": "the Changes that revised this entity, in order (prov:wasRevisionOf); reverse-query gives a change's revision set (#67)"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:design:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "views": {
      "type": "array",
      "items": {
        "enum": [
          "context",
          "container",
          "component",
          "deployment"
        ],
        "description": "per 42010"
      },
      "minItems": 1
    },
    "satisfies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:(requirement):[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "minItems": 1
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:(decision):[0-9A-HJKMNP-TV-Z]{26}$"
      }
    },
    "interface_contracts": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "URI to external OpenAPI / JSON-Schema"
      }
    },
    "state": {
      "enum": [
        "draft",
        "reviewed",
        "accepted"
      ]
    }
  },
  "x-schema-org-extends": "custom"
}