{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/opportunity/2.0.0",
  "title": "Opportunity",
  "description": "a validated need or problem worth solving \u2014 for a specific Product within a Tenant",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "for_product",
    "job_statement",
    "state",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:opportunity:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "for_product": {
      "type": "string",
      "pattern": "^dna:(product):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "job_statement": {
      "type": "string",
      "description": "JTBD: when\u2026 I want\u2026 so I can\u2026"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "citation or link"
      }
    },
    "impact": {
      "type": "string"
    },
    "state": {
      "enum": [
        "hypothesis",
        "validated",
        "defined",
        "dropped"
      ]
    }
  },
  "x-schema-org-extends": "custom"
}