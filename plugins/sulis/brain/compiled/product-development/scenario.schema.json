{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/scenario/1.0.0",
  "title": "Scenario",
  "description": "a living, reusable verification scenario \u2014 a named journey of steps that proves one or more Requirements against a Design",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "name",
    "verifies",
    "exercises",
    "journey",
    "state",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:scenario:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "verifies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:(requirement):[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "minItems": 1
    },
    "exercises": {
      "type": "string",
      "pattern": "^dna:(design):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "journey": {
      "type": "string",
      "pattern": "^dna:(workflow):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "state": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "isolation": {
      "enum": [
        "reset",
        "process",
        "env"
      ],
      "description": "cheapest-sufficient state-isolation rung for a run; default reset (reset fixture/state in the existing worktree). NOT a new workspace per run."
    },
    "verdict_invariant": {
      "type": "object",
      "unevaluatedProperties": false,
      "description": "how the runner checks the saved record → observed|blocked (distinct from the run's aggregate disposition). The field #95's gate reads.",
      "properties": {
        "kind": {
          "enum": [
            "equality",
            "property"
          ]
        },
        "expected_ref": {
          "type": "string"
        },
        "poll": {
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "attempts": {
              "type": "integer",
              "minimum": 1
            },
            "interval_ms": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "attempts"
          ]
        }
      },
      "required": [
        "kind"
      ]
    }
  },
  "x-schema-org-extends": "schema:HowTo"
}