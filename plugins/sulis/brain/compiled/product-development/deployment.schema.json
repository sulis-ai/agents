{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/deployment/1.0.0",
  "title": "Deployment",
  "description": "the act of pushing a Release into an Environment",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "of_release",
    "to_environment",
    "at",
    "outcome",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "produced_by_change": {
      "type": "string",
      "pattern": "^dna:change:[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "the Change that created this entity (prov:wasGeneratedBy); reverse-query gives a change's creation set (#67)"
    },
    "evolved_by_change": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^dna:change:[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "description": "the Changes that revised this entity, in order (prov:wasRevisionOf); reverse-query gives a change's revision set (#67)"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:deployment:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "of_release": {
      "type": "string",
      "pattern": "^dna:(release):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "to_environment": {
      "type": "string",
      "pattern": "^dna:(environment):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "by_actor": {
      "type": "string",
      "pattern": "^dna:(actor):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "outcome": {
      "enum": [
        "succeeded",
        "failed",
        "rolled-back",
        "in-progress"
      ]
    }
  },
  "x-schema-org-extends": "schema:Action"
}