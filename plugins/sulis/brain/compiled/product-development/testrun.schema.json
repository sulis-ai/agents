{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulis.co/dna/schema/testrun/1.0.0",
  "title": "TestRun",
  "description": "the EVENT of running a test \u2014 an activity that produces a TestResult",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "id",
    "ran_at",
    "sys_status"
  ],
  "properties": {
    "sys_status": {
      "enum": [
        "active",
        "archived",
        "deleted",
        "purged"
      ]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window start \u2014 when this fact became true in the world; null = since-forever"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "business-truth window end \u2014 when this fact stopped being true; null = still valid"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "reliability score for this instance; 1.0 = certain, 0 = no confidence"
    },
    "id": {
      "type": "string",
      "pattern": "^dna:testrun:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "ran_at": {
      "type": "string",
      "format": "date-time"
    },
    "in_run": {
      "type": "string",
      "pattern": "^dna:(component):[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "harness": {
      "type": "string"
    }
  },
  "x-schema-org-extends": "schema:Action"
}