  "@id": "dna:release-train:workflow",
  "@type": "workflow-instances",
  "for_tenant": "dna:tenant:6XBZ93FSHN5TRX8MCS5R66FNCM",
  "_about": "The apex canonical entity for the sulis-plugins-marketplace release-train, re-modelled to the trunk-based (main-only) shape (CH-01KT4K). Defines the directed graph of 10 Steps (authored in steps.jsonld) that compose the per-Project release pipeline: detect -> preflight-version-drift -> compute -> confirm -> bump -> changelog -> commit -> tag -> publish -> emit. The release is a bump + tag on the trunk, not a merge between branches — the five dev->main-PR Steps (preflight-cross-branch-drift, draft-pr-body-and-changelog, open-release-pr, wait-for-checks-and-mergeability, squash-merge) were deleted, and with them the JT-7 back-edge cycle that existed only to recover from release-PR conflicts; the transition graph is now strictly linear. Definition-level scope is unscoped (no for_project) - Projects bind to this Workflow per-invocation via Project.release_workflow_ref. Workflow ULID dna:workflow:01KT0RTRA1NWFW00000000000A is deterministic and reused across every release-train canonical entity (Triggers, Steps - see triggers.jsonld and steps.jsonld for_workflow). Tenant ULID dna:tenant:6XBZ93FSHN5TRX8MCS5R66FNCM is canonical for the marketplace tenant (derivation recipe documented in failuremodes.jsonld's _about). Schema: plugins/sulis/brain/compiled/foundation/workflow.schema.json (vendored upstream sulis-brain Workflow v1.1.0). Path A per ADR-001 - the imperative release-on-merge.yml implements this canonical (verified via the drift detector in WP-007); the LLM-driven brain executor walks it for /sulis:release-train --dry-run preview.",
  "captured_on": "2026-06-01",

  "workflows": [
    {
      "id": "dna:workflow:01KT0RTRA1NWFW00000000000A",
      "sys_status": "active",
      "name": "release-train",
      "for_domain": "dna:tenant:6XBZ93FSHN5TRX8MCS5R66FNCM",
      "for_process": "release-train",
      "description": "Per-Project trunk-based release pipeline: detect pending changesets (on main) -> pre-flight version-drift -> compute next version -> founder confirmation -> bump version files -> write changelog entry -> commit bump on main -> tag and push -> publish GitHub release -> emit Release entity. Strictly linear — no release PR, no promotion, no back-merge (trunk re-model, CH-01KT4K). Definition unscoped (no for_project); Projects bind via Project.release_workflow_ref per-invocation.",
      "type": "other",
      "state_contract": [
        "target_branch:string",
        "source_branch:string",
        "pending_changesets:list",
        "tier:enum[patch|minor|major|null]",
        "next_plugin_version:semver",
        "next_umbrella_version:semver",
        "pr_url:url",
        "merge_sha:sha",
        "tag_pushed:bool",
        "release_url:url",
        "final-outcome:enum[shipped|no-changesets|blocked|aborted]"
      ],
      "steps": [
        "detect-pending-changesets",
        "preflight-version-drift",
        "compute-next-version",
        "gate-founder-confirmation",
        "bump-version-files",
        "write-changelog-entry",
        "commit-bump-on-main",
        "tag-and-push",
        "publish-github-release",
        "emit-release-entity"
      ],
      "initial_steps": ["detect-pending-changesets"],
      "terminal_steps": ["emit-release-entity", "gate-founder-confirmation"],
      "transitions": [
        "detect-pending-changesets -> preflight-version-drift [if pending_changesets.non_empty]",
        "detect-pending-changesets -> [terminal:no-changesets] [if pending_changesets.empty]",
        "preflight-version-drift -> compute-next-version",
        "compute-next-version -> gate-founder-confirmation",
        "gate-founder-confirmation -> bump-version-files [if confirm=yes]",
        "gate-founder-confirmation -> [terminal:aborted] [if confirm=no]",
        "bump-version-files -> write-changelog-entry",
        "write-changelog-entry -> commit-bump-on-main",
        "commit-bump-on-main -> tag-and-push",
        "tag-and-push -> publish-github-release",
        "publish-github-release -> emit-release-entity",
        "emit-release-entity -> [terminal:shipped]"
      ],
      "state": "active",
      "valid_from": "2026-06-01T00:00:00Z",
      "confidence": 0.9
    }
  ]
}
