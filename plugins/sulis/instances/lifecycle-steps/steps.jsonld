      "sys_status": "active",
      "name": "unclassified-lifecycle-step",
      "for_domain": "dna:tenant:6XBZ93FSHN5TRX8MCS5R66FNCM",
      "for_process": "lifecycle",
      "input_artifacts": ["unmapped-step-name"],
      "output_artifacts": ["unclassified-lifecycle-record"],
      "mechanism": "mixed",
      "mechanism_detail": "The catch-all definition for a free step_name string with no known mapping. The emitter's name-to-Step resolution falls back here when a run names a step that isn't change-started or change-shipped, so every run resolves to a real Step rather than an inline-minted one. The original free string, where trace grouping is needed, is carried by the run's run_id field.",
