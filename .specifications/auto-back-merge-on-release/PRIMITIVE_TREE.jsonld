  "nodes": [
    {
      "id": "node-reusable-workflow",
      "type": "integration",
      "name": "Reusable release-and-back-merge workflow",
      "definition": "GitHub Actions reusable workflow at plugins/sulis/templates/workflows/release-on-merge.yml that performs release-bump + back-integration as a single atomic unit. Inputs: none required (operates on the calling repo's git state via GITHUB_TOKEN).",
      "success_criterion": "On push to caller's main, workflow bumps versions, tags, pushes to main, then either fast-forwards caller's dev to main OR opens a back-merge PR. Never force-pushes dev.",
      "source": "user",
      "health_status": "testing",
      "leaf_category": "primitive-component",
      "artifactAffinity": ["use-case", "sequence-diagram", "integration"],
      "depends_on": [],
      "attack_patterns": [
        "What happens if the bot token can't push to dev (branch protection blocks direct push)?",
        "What happens if dev is at a different SHA than when the release PR was opened?",
        "What happens if a previous back-merge PR is still open?"
      ]
    },
    {
      "id": "node-consumer-shim",
      "type": "integration",
      "name": "Fork-consumer shim workflow",
      "definition": "A ~10-line GitHub Actions workflow file at the consumer's .github/workflows/release-on-merge.yml that uses: the plugin's reusable workflow at a version-pinned reference.",
      "success_criterion": "Consumer's release flow inherits back-merge behaviour transparently; deleting the shim opts out cleanly without breaking the consumer's repo.",
      "source": "user",
      "health_status": "testing",
      "leaf_category": "primitive-component",
      "artifactAffinity": ["use-case", "integration"],
      "depends_on": ["node-reusable-workflow"],
      "attack_patterns": [
        "What happens if the consumer pins to a plugin version that no longer exists?",
        "What happens if the consumer customises the shim and breaks the contract?"
      ]
    },
    {
      "id": "node-fast-forward-path",
      "type": "action",
      "name": "Fast-forward dev to main (clean release path)",
      "definition": "After release commit + tag have been pushed to main, the workflow checks whether dev's current SHA matches the SHA recorded when the release PR was opened. If yes, perform `git push origin main:dev` (fast-forward) and emit a status log.",
      "success_criterion": "Dev's HEAD equals main's HEAD; no merge commit created; idempotent if re-run.",
      "source": "user",
      "health_status": "testing",
      "leaf_category": "primitive-component",
      "artifactAffinity": ["use-case", "process-flow", "sequence-diagram"],
      "depends_on": ["node-reusable-workflow"],
      "attack_patterns": [
        "What if dev has moved by even one commit since the release PR was opened?",
        "What if `push origin main:dev` is rejected by branch protection (non-fast-forward)?"
      ]
    },
    {
      "id": "node-raced-pr-path",
      "type": "action",
      "name": "Open back-merge PR (raced release path)",
      "definition": "When the fast-forward check fails (dev has moved), the workflow opens a PR with base=dev, head=main, title `chore: back-integrate main → dev (post-release vX.Y.Z)`, body referencing the release tag. Auto-merge enabled if CI green. Never force-pushes dev.",
      "success_criterion": "A PR exists in `open` or `merged` state; dev's existing history is never overwritten; the PR closes the back-merge requirement once merged.",
      "source": "user",
      "health_status": "testing",
      "leaf_category": "primitive-component",
      "artifactAffinity": ["use-case", "process-flow", "sequence-diagram"],
      "depends_on": ["node-reusable-workflow"],
      "attack_patterns": [
        "What if two back-merge PRs end up open at once (two releases close together)?",
        "What if the PR's CI fails on the merge-resolution itself?"
      ]
    },
    {
      "id": "node-dev-sha-pin",
      "type": "data-store",
      "name": "Dev SHA snapshot at release-PR-open",
      "definition": "The SHA of dev's HEAD at the moment the release PR was opened, recorded as a field in the release PR body (machine-readable line). The release robot reads this to detect raced state.",
      "success_criterion": "The pin is queryable from the release PR; absence of the pin causes the workflow to default to the raced path (safe default).",
      "source": "user",
      "health_status": "testing",
      "leaf_category": "primitive-component",
      "artifactAffinity": ["data-flow", "use-case"],
      "depends_on": [],
      "attack_patterns": [
        "What if the pin is missing or malformed?",
        "What if someone tampers with the PR body to forge the pin?"
      ]
    },
    {
      "id": "node-drift-detection",
      "type": "policy",
      "name": "Drift detection in release-train and change-start",
      "definition": "Both `/sulis:release-train` (before drafting a new release PR) and `/sulis:change start` (before creating a new change branch) run `git merge-base --is-ancestor origin/main origin/dev`. If main is NOT an ancestor of dev, refuse with a clear error pointing at the recovery procedure.",
      "success_criterion": "The two skills refuse to operate on a drifted dev; the error message names the back-merge mechanism and the recovery procedure.",
      "source": "user",
      "health_status": "testing",
      "leaf_category": "primitive-component",
      "artifactAffinity": ["business-rule", "use-case", "process-flow"],
      "depends_on": [],
      "attack_patterns": [
        "What if the user wants to override the check (e.g., during an incident)?",
        "What if `git fetch` fails and the local refs are stale?"
      ]
    },
