      "name": "Verification-Plan feed (#138)",
      "type": "action",
      "source": "user",
      "health_status": "validated",
      "leaf_category": null,
      "definition": "Each Platform Contract constraint maps to a test assertion or a named post-ship observable in the consuming change's ## Verification Plan.",
      "success_criterion": "A change with a Platform Contract carries, per load-bearing constraint, an assertion or observable.",
      "artifactAffinity": ["process-flow", "use-case"],
