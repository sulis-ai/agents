  "@id": "spec:platform-contract-standard/primitive-tree",
  "@type": "PrimitiveTree",
  "spec": "platform-contract-standard",
  "synthesised_at": "2026-06-02",
  "facilitation_phase": "verify",
  "scale_constraints": { "depth_cap": 5, "fan_out_cap": 7 },
  "nodes": [
    {
      "@id": "node:platform-contract-standard",
      "name": "Platform Contract Standard",
      "type": "policy",
      "source": "user",
      "health_status": "validated",
      "leaf_category": null,
      "definition": "The reference standard defining the discipline, the contract artifact shape, the gate, and the mandated harness mechanism for third-party platform integrations.",
      "success_criterion": "PLATFORM_CONTRACT_STANDARD.md exists, mirrors the sibling standards' shape, and cites all three.",
      "artifactAffinity": ["business-rule", "use-case"],
      "dependsOn": ["node:harness-invocation", "node:contract-artifact", "node:design-gate"],
      "attack_patterns": ["Is the discipline mandatory or advisory?", "Does it cross-reference the three siblings?"],
      "fr_refs": ["FR-001", "FR-016"]
    },
    {
      "@id": "node:design-gate",
      "name": "The design-stage gate",
      "type": "policy",
      "source": "user",
      "health_status": "validated",
      "leaf_category": null,
      "definition": "A change touching a gated third-party platform cannot proceed past design without a Platform Contract. Enforced in skill prose AND mechanically by the rubric P-PLAT phase.",
      "success_criterion": "An uncovered gated-platform design blocks; a covered one proceeds.",
      "artifactAffinity": ["use-case", "process-flow"],
      "dependsOn": ["node:rubric-check", "node:gate-scope"],
      "attack_patterns": ["What stops a prose edit from bypassing the gate?", "Does the gate fire for read-only touches?"],
      "fr_refs": ["FR-002", "FR-014"]
    },
    {
      "@id": "node:gate-scope",
      "name": "Gate trigger scope (write/deploy vs read-only)",
      "type": "policy",
      "source": "user",
      "health_status": "testing",
      "leaf_category": "primitive-component",
      "definition": "Hard-gate write/deploy third-party touches; soft-recommend a lightweight contract for read-only touches. Proposed default resolving Open Question 3.",
      "success_criterion": "Gate logic distinguishes write/deploy (hard) from read-only (soft).",
      "artifactAffinity": ["business-rule"],
      "dependsOn": [],
      "attack_patterns": ["What if a read-only integration later writes?"],
      "fr_refs": ["FR-014"],
      "note": "Open Question 3 — proposed default, confirmed at standard-authoring."
    },
    {
      "@id": "node:harness-invocation",
      "name": "Harness-invocation requirement",
      "type": "action",
      "source": "user",
      "health_status": "validated",
      "leaf_category": null,
      "definition": "A Platform Contract MUST be produced by running the faithful-generation-harness against the platform's official docs as the closed manifest, not by ad-hoc authored prose.",
      "success_criterion": "The contract records a harness-run reference; a hand-authored doc is rejected.",
      "artifactAffinity": ["use-case", "sequence"],
      "dependsOn": ["node:faithful-generation-harness"],
      "attack_patterns": ["What records that the harness was actually run?", "Can a hand-waved doc substitute?"],
      "fr_refs": ["FR-003", "FR-006", "FR-007"]
    },
    {
      "@id": "node:faithful-generation-harness",
      "name": "faithful-generation-harness (brain Workflow)",
      "type": "integration",
      "source": "inferred",
      "health_status": "validated",
      "leaf_category": "existing-impl",
      "definition": "The existing brain Workflow instance at plugins/sulis-brain/instances/faithful-generation-harness/. Five steps: observe-manifest, orient-select-relevant, decide-commit-bindings, act-generate-from-bindings, self-critique-grounding.",
      "success_criterion": "A harness dispatch against a fixture manifest produces a binding table and refuses an ungrounded load-bearing claim.",
      "artifactAffinity": ["sequence", "use-case"],
      "dependsOn": [],
      "attack_patterns": ["Is the instance already authored?", "Does the refusal path fire on an ungrounded load-bearing claim?"],
      "fr_refs": ["FR-003"],
      "note": "Leaf: existing-impl — consumed, not built by this change."
    },
    {
      "@id": "node:contract-artifact",
      "name": "The contract artifact shape",
      "type": "data-store",
      "source": "user",
      "health_status": "validated",
      "leaf_category": null,
      "definition": "A Platform Contract is a set of claim entries {claim, source, quote, retrieval-date, inferred?, probe?, probe-result?}, stored durably and reviewably.",
      "success_criterion": "inferred:false ⇒ source+quote+retrieval-date present; inferred:true ⇒ no fabricated source; load-bearing ⇒ probe+probe-result (or justified deferral).",
      "artifactAffinity": ["data-flow", "business-rule"],
      "dependsOn": ["node:claim-grounding", "node:probe", "node:storage-location", "node:freshness"],
      "attack_patterns": ["Can a claim lack a source and still pass?", "Is an inference distinguishable from a fact?"],
      "fr_refs": ["FR-004", "FR-005"]
    },
    {
      "@id": "node:claim-grounding",
      "name": "Claim grounding + refusal + meaning-check",
      "type": "policy",
      "source": "user",
      "health_status": "validated",
      "leaf_category": "primitive-component",
      "definition": "Each claim is bound to an official source, re-read against the source's meaning, and refused (manifest-insufficient) if load-bearing and ungrounded.",
      "success_criterion": "Zero false citations; zero plausible-by-shape claims passing without the meaning-check; ungrounded load-bearing claims refused.",
      "artifactAffinity": ["business-rule", "state-diagram"],
      "dependsOn": [],
      "attack_patterns": ["Does a real-URL-but-wrong-meaning claim get caught?"],
      "fr_refs": ["FR-005", "FR-006", "FR-007"]
    },
    {
      "@id": "node:probe",
      "name": "Probe (real sandbox exercise) for load-bearing claims",
      "type": "action",
      "source": "user",
      "health_status": "accepted-as-risk",
      "leaf_category": "primitive-component",
      "definition": "A real sandbox exercise confirming doc-says-X AND platform-does-X for a load-bearing claim, with probe-result + evidence recorded.",
      "success_criterion": "Every load-bearing claim has probe-result or a justified deferral with a canonical need identifier.",
      "artifactAffinity": ["use-case", "process-flow"],
      "dependsOn": [],
      "attack_patterns": ["Can a probe be recorded without being run?", "Is the per-platform probe mechanism defined?"],
      "fr_refs": ["FR-008"],
      "risk_note": "Open Question 4 — the per-platform probe mechanism (scratch repo / credentials / dry-run) is deferred to SEA. The GitHub Actions reusable-workflow probe is run manually once in this change; repeatable automation and the branch-protection probe (needs a paid private repo) are deferred infrastructure needs."
    },
    {
      "@id": "node:storage-location",
      "name": "Durable storage + reuse location",
      "type": "data-store",
      "source": "user",
      "health_status": "testing",
      "leaf_category": "primitive-component",
      "definition": "Platform Contracts live in plugins/sulis/references/platform-contracts/<platform>.md — version-controlled, reused across changes, not regenerated.",
      "success_criterion": "The directory exists; a second change touching the same platform triggers zero new full harness runs.",
      "artifactAffinity": ["data-flow"],
      "dependsOn": [],
      "attack_patterns": ["How are contracts indexed for reuse?"],
      "fr_refs": ["FR-010", "FR-011"],
      "note": "Open Question 1 — indexing mechanism deferred to SEA."
    },
    {
      "@id": "node:freshness",
      "name": "Freshness via retrieval date",
      "type": "policy",
      "source": "user",
      "health_status": "accepted-as-risk",
      "leaf_category": "primitive-component",
      "definition": "Every claim carries a retrieval-date; the reuse path surfaces claims past the staleness threshold for re-grounding.",
      "success_criterion": "Claims carry retrieval-date; stale claims are flagged on reuse.",
      "artifactAffinity": ["business-rule", "state-diagram"],
      "dependsOn": [],
      "attack_patterns": ["How is staleness detected when the platform changes silently?"],
      "fr_refs": ["FR-013"],
      "risk_note": "Open Question 2 — automated re-probe explicitly Out of Scope. Date + manual flag ship now; automation deferred (flagged as platform-contract-staleness-reprobe)."
    },
    {
      "@id": "node:github-actions-instance",
      "name": "GitHub Actions Platform Contract (n=1 dogfood)",
      "type": "data-store",
      "source": "user",
      "health_status": "validated",
      "leaf_category": null,
      "definition": "The first durable Platform Contract: plugins/sulis/references/platform-contracts/github-actions.md capturing reusable-workflow-location, bot-token-no-downstream-trigger, and branch-protection-on-free-plan, each grounded with a real GitHub-docs URL.",
      "success_criterion": "The file exists, conforms to the artifact shape, and the reusable-workflow-location rule is cited and probed.",
      "artifactAffinity": ["data-flow", "use-case"],
      "dependsOn": ["node:contract-artifact", "node:harness-invocation"],
      "attack_patterns": ["Are all three rules cited?", "Is the reusable-workflow rule probed?"],
      "fr_refs": ["FR-009"]
    },
    {
      "@id": "node:rubric-check",
      "name": "Decompose-rubric check (P-PLAT, new phase)",
      "type": "policy",
      "source": "user",
      "health_status": "validated",
      "leaf_category": null,
      "definition": "A new rubric phase, sibling to Phase 7 (ServiceSpec) and Phase 9 (P-VER), that fails a cross-kind/integration WP set touching a gated third party without a referenced Platform Contract.",
      "success_criterion": "A synthetic no-contract integration WP set triggers P-PLAT FAIL → GAPS_FOUND.",
      "artifactAffinity": ["business-rule", "process-flow"],
      "dependsOn": ["node:decompose-validation-rubric"],
      "attack_patterns": ["Does it collapse the overall verdict?", "Does it grandfather pre-merge changes?"],
      "fr_refs": ["FR-015"]
    },
    {
