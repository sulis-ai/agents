    },

    {
      "id": "node:tool-git-read",
      "name": "Git-read Tool",
      "type": "tool",
      "source": "user",
      "health_status": "testing",
      "definition": "Typed deterministic Tool for reading git remote and branch state. May reuse existing tools from release-train.",
      "success_criterion": "Schema defined; ULID assigned; bound to git-integration.",
