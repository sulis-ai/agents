+    {"type": "null"}
+  ]
+}
diff --git a/plugins/sulis/instances/release-train/schemas/tools/changeset-next-version-input.schema.json b/plugins/sulis/instances/release-train/schemas/tools/changeset-next-version-input.schema.json
