+  "required": ["tag"],
+  "additionalProperties": false,
+  "properties": {
+    "tag": {
+      "type": "string",
+      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$",
+      "description": "the existing tag to attach the release to; the workflow has already created + pushed it"
+    },
+    "title": {
+      "type": "string",
+      "description": "release title (e.g. 'sulis v0.86.0')"
+    },
+    "notes": {
+      "type": "string",
+      "description": "release notes body — markdown"
+    },
+    "generate_notes": {
+      "type": "boolean",
+      "description": "fall back to `gh release create --generate-notes` (GitHub auto-generates from commits since last tag); defaults to false"
+    }
+  }
+}
