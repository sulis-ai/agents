+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://sulis.co/release-train/tool/changeset-next-version/input/1.0.0",
+  "title": "_changeset.next_version — input",
+  "description": "Input for the semver bump. Mirrors plugins/sulis/scripts/_changeset.py::next_version(current, tier). Series-agnostic — works identically for plugin (0.x) and marketplace (1.x) series per ADR-003 of release-train.",
+  "type": "object",
+  "required": ["current", "tier"],
+  "additionalProperties": false,
+  "properties": {
+    "current": {
+      "type": "string",
+      "description": "current dotted SemVer string (e.g. '0.85.0', '1.131.0')",
+      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
+    },
+    "tier": {
+      "description": "the bump tier; null means 'no bump' and returns current unchanged",
+      "oneOf": [
+        {"enum": ["patch", "minor", "major"]},
+        {"type": "null"}
+      ]
+    }
+  }
+}
