+  "$id": "https://sulis.co/release-train/tool/changeset-cumulative-tier/output/1.0.0",
+  "title": "_changeset.cumulative_tier — output",
+  "description": "Output: the SemVer max-tier (patch < minor < major) over the input batch, or null when the batch is empty or no items carried a tier.",
