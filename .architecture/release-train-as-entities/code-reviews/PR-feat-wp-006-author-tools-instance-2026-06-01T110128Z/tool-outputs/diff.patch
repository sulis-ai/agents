diff --git a/plugins/sulis/brain/compiled/foundation/tool.schema.json b/plugins/sulis/brain/compiled/foundation/tool.schema.json
new file mode 100644
index 0000000..8de1533
--- /dev/null
+++ b/plugins/sulis/brain/compiled/foundation/tool.schema.json
@@ -0,0 +1,114 @@
+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://sulis.co/dna/schema/tool/1.1.0",
+  "title": "Tool",
+  "description": "the declaration of a typed deterministic operation that a Step may invoke \u2014 name + kind + inputs schema reference + outputs schema reference + error catalogue + implementation_kind (the transport binding) + implementation_detail (kind-specific shape). The CONTRACT for one operation, independent of the workflow or step that calls it. Reuse: many Steps across many Workflows reference the same Tool. Belongs to a Tenant (each business's tool catalogue is tenant-scoped). When implementation_kind is `workflow_dispatch`, the Tool's invocation fires another Workflow (same-repo or cross-repo) \u2014 the composition primitive for multi-Workflow orchestration.",
+  "type": "object",
+  "unevaluatedProperties": false,
+  "required": [
+    "id",
+    "name",
+    "for_domain",
+    "kind",
+    "inputs_schema_ref",
+    "outputs_schema_ref",
+    "implementation_kind",
+    "version",
+    "state",
+    "sys_status"
+  ],
+  "properties": {
+    "sys_status": {
+      "enum": [
+        "active",
+        "archived",
+        "deleted",
+        "purged"
+      ]
+    },
+    "valid_from": {
+      "type": "string",
+      "format": "date-time",
+      "description": "business-truth window start"
+    },
+    "valid_to": {
+      "type": "string",
+      "format": "date-time",
+      "description": "business-truth window end"
+    },
+    "confidence": {
+      "type": "number",
+      "minimum": 0,
+      "maximum": 1,
+      "description": "instance reliability score"
+    },
+    "id": {
+      "type": "string",
+      "pattern": "^dna:tool:[0-9A-HJKMNP-TV-Z]{26}$"
+    },
+    "name": {
+      "type": "string",
+      "description": "the operationId such as gh-pr-create, sanctions-screen, stripe-charge"
+    },
+    "for_domain": {
+      "type": "string",
+      "pattern": "^dna:(tenant):[0-9A-HJKMNP-TV-Z]{26}$"
+    },
+    "kind": {
+      "enum": [
+        "query",
+        "mutation",
+        "side-effect",
+        "hybrid"
+      ],
+      "description": "OpenAPI-style classification \u2014 query is read-only, mutation is local state change, side-effect is external effect, hybrid is both"
+    },
+    "inputs_schema_ref": {
+      "type": "string",
+      "description": "URI or path to a JSON Schema 2020-12 document defining the operation input payload"
+    },
+    "outputs_schema_ref": {
+      "type": "string",
+      "description": "URI or path to a JSON Schema 2020-12 document defining the operation output payload"
+    },
+    "error_catalogue": {
+      "type": "array",
+      "items": {
+        "type": "string",
+        "pattern": "^dna:(failuremode):[0-9A-HJKMNP-TV-Z]{26}$"
+      }
+    },
+    "implementation_kind": {
+      "enum": [
+        "mcp_server",
+        "subprocess",
+        "python_import",
+        "http_call",
+        "claude_code_tool",
+        "skill_invocation",
+        "workflow_dispatch"
+      ]
+    },
+    "implementation_detail": {
+      "type": "string",
+      "description": "a JSON-encoded kind-specific object \u2014 for mcp_server has server_id and tool_name; for subprocess has command, args, env_keys; for python_import has module and function; for http_call has endpoint, method, auth_kind; for claude_code_tool has tool_name; for skill_invocation has plugin and skill_name; for workflow_dispatch has target_workflow_ref required as the Workflow to invoke, target_project_ref optional Project scope, target_repo optional owner-slash-name for cross-repo dispatch via gh repository_dispatch or gh workflow run, wait_for_completion bool to block until target Workflow terminates, inputs_ref text content-addressed reference to inputs payload mirroring LifecycleRun.inputs_ref convention from v2.1.0",
+      "x-sensitive": true
+    },
+    "version": {
+      "type": "string",
+      "description": "semver \u2014 the Tool implementation version, independent of schema_version which is the entity-schema version"
+    },
+    "deprecated_for": {
+      "type": "string",
+      "pattern": "^dna:(tool):[0-9A-HJKMNP-TV-Z]{26}$"
+    },
+    "state": {
+      "enum": [
+        "draft",
+        "active",
+        "deprecated"
+      ]
+    }
+  },
+  "x-schema-org-extends": "schema:Action"
+}
\ No newline at end of file
diff --git a/plugins/sulis/instances/release-train/schemas/tools/changeset-cumulative-tier-input.schema.json b/plugins/sulis/instances/release-train/schemas/tools/changeset-cumulative-tier-input.schema.json
