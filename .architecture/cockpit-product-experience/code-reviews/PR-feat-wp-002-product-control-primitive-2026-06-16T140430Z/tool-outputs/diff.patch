+
+const ASSIGN_ROWS: ProductRow[] = [
+  {
+    productId: "dna:product:01CLINIC0000000000000000000",
+    name: "Clinics",
+    glyph: "monogram",
+  },
+  {
+    productId: "dna:product:01FOUNDER000000000000000000",
+    name: "Founder Web",
+    glyph: "monogram",
