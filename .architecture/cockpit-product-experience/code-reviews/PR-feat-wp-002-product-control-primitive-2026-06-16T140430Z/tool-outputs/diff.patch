+            {(isAssigned && onRemove) ||
+            onSetUpNew ||
+            (mode === "scope" && onManageProducts) ? (
+              <div className={styles.pmsep} role="separator" />
+            ) : null}
+
+            {mode === "assign" && isAssigned && onRemove && (
