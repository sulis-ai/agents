+    name: "Founder Web",
+    count: 5,
+    glyph: "monogram",
+  },
+];
+
+// Assign-mode rows: the founder's products (monogram tiles), no synthetic rows.
+const ASSIGN_ROWS: ProductRow[] = [
+  {
+    productId: "dna:product:01CLINIC0000000000000000000",
+    name: "Clinics",
+    glyph: "monogram",
