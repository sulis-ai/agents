+def _commit_via_rebase_loop(
+    *,
+    args: argparse.Namespace,
+    paths,
+    repo: str,
+    train_id: str,
+    plan: PlanResult,
+    record: dict,
+    clone_dir: Path,
+) -> CommitResult:
+    """Legacy commit strategy — today's sequential squash-merge loop.
+
+    HD-003: each per-entry merge is wrapped in try/except so a failure on
+    entry N — after entries 1..N-1 landed on the base branch — routes
+    through the ADR-212 revert path with the partial bundle. The outer
+    handler writes outcome=error and exits without reverting, which would
+    leave the base in a half-state. _handle_post_merge_failure already
+    filters the bundle to merged entries (those with a populated
+    merge_sha_on_dev), so passing the partial bundle here is correct.
+    """
+    merge_shas: dict[str, str] = {}
+    final_merge_sha = None
+    for entry in plan.bundle:
+        _log(f"Squash-merging {entry['wp']} ({entry['branch']}) to {plan.base_branch}")
+        try:
+            sha = _merge_squash(repo, entry["branch"], entry["wp"],
+                                base_branch=plan.base_branch)
+        except Exception as exc:  # noqa: BLE001
+            _log(
+                f"MERGE FAILURE: {entry['wp']} ({entry['branch']}) "
+                f"failed mid-batch: {exc}"
+            )
+            record["bundle"] = plan.bundle
+            _handle_post_merge_failure(
+                record=record, bundle=plan.bundle,
+                reason=f"merge of {entry['wp']} failed: {exc}",
+                clone_dir=clone_dir, repo=repo, paths=paths,
+                train_id=train_id,
+                failure_text=(
+                    f"_merge_squash raised on {entry['wp']} "
+                    f"({entry['branch']}): {exc}"
+                ),
+            )
+        entry["merge_sha_on_dev"] = sha
+        merge_shas[entry["wp"]] = sha
+        final_merge_sha = sha
+
+    return CommitResult(
+        merge_shas=merge_shas,
+        final_merge_sha=final_merge_sha,
+    )
+
+
+def _commit_phase(
+    *,
+    args: argparse.Namespace,
+    paths,
+    repo: str,
+    train_id: str,
+    plan: PlanResult,
+    record: dict,
+    clone_dir: Path,
+) -> CommitResult:
+    """HD-001 commit phase — only phase that mutates the base branch.
+
+    Strategy dispatcher: the merge-queue spike's PARTIAL recommendation
+    introduces a second strategy `_commit_via_merge_queue` in a follow-up
+    delta. Today there is only `legacy` (the sequential squash-merge loop).
+    The dispatcher's RuntimeError on unknown strategy is the explicit
+    extension seam.
+    """
+    update_train_phase(
+        train_state_path(paths.train_runs_dir, train_id), "merging",
+    )
+
+    strategy = getattr(args, "commit_strategy", None) or "legacy"
+    if strategy == "legacy":
+        result = _commit_via_rebase_loop(
+            args=args, paths=paths, repo=repo, train_id=train_id,
+            plan=plan, record=record, clone_dir=clone_dir,
+        )
+    else:
+        raise RuntimeError(
+            f"Unknown commit strategy {strategy!r}; expected 'legacy' "
+            f"(follow-up delta adds 'mq')."
+        )
+
+    record["bundle"] = plan.bundle  # refresh with merge_sha_on_dev populated
+    return result
+
