+        record["smoke_verdict"] = smoke_verdict
+        if not smoke_verdict.startswith("PASS"):
+            _handle_post_merge_failure(
+                record=record, bundle=plan.bundle,
+                reason=f"smoke {smoke_verdict}",
+                clone_dir=clone_dir, repo=repo, paths=paths,
+                train_id=train_id,
+                failure_text=f"Smoke output:\n{smoke_out}",
+            )
+    else:
+        smoke_verdict = "skipped (no --smoke-cmd)"
+        record["smoke_verdict"] = smoke_verdict
+
+    return VerifyResult(
+        deploy_url=deploy_url,
+        deploy_verdict=deploy_verdict,
+        health_status=health,
+        smoke_verdict=smoke_verdict,
+        ready_for_gates=bool(getattr(args, "enable_gate_handoff", False)),
+    )
