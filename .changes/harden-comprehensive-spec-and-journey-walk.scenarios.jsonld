          "mechanism_detail": {"cmd": "python3 plugins/sulis/scripts/_drive_scenario.py --scenario tool-needs-sandbox --out /tmp/sc11-result.json", "expect_exit": 0},
          "asserts": ["the scenario is NOT marked green", "it is recorded as a deferred infrastructure need with an identifier", "it is not silently dropped"]
        }
      ]
    },
    {
