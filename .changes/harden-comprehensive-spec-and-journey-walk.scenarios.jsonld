    {
      "id": "SC-17",
      "name": "A business decision is recorded as a BDR, distinct from an ADR",
      "surface": "tool",
      "verifies": ["FR-17"],
      "covers_flow": "UC-02 main (Phase 3)",
      "seed": "comprehensive-spec-and-journey-walk:SC-17",
