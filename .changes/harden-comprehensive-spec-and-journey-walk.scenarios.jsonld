          "instruction": "Enumerate every flow (main/alternate/exception) of the fixture's use cases and the scenarios derived from them",
          "mechanism": "deterministic",
          "mechanism_detail": {"cmd": "python3 plugins/sulis/scripts/_assert_flow_scenario_map.py --fixture sample-user-facing --require-each-flow-covered", "expect_exit": 0},
          "asserts": ["each main flow maps to >= 1 scenario", "each alternate flow maps to >= 1 scenario", "each exception flow maps to >= 1 scenario"]
        }
      ]
    },
    {
