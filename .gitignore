# SEA probe / architecture outputs — generated artifacts, not source.
# At the marketplace root: ignore contents EXCEPT sulis-checkup/ which is
# the durable architectural design for the founder-facing code-health
# system (TDD + ADRs + CTS analysis; source-of-truth, not generated).
/.architecture/*
!/.architecture/sulis-checkup/
# Inside plugins: ignore contents except hardening-deltas/ (which ARE
# source-of-truth audit records for structural fixes to the plugin code).
# Pattern note: we must ignore the CONTENTS rather than the directory itself,
# otherwise git can't recurse into it to find the re-included paths.
plugins/*/.architecture/*
!plugins/*/.architecture/hardening-deltas/

# Specification artifacts — generated by SRD facilitation
.specifications/

# Concierge journey state — per-project, not tracked at the marketplace level
.concierge/

# Context discovery output — per-project
.context/

# Security review output — per-project
.security/

# Worktrees (defensive — should never be inside the repo)
wp-*-worktree/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*~

# Python (for marketplace tooling)
__pycache__/
*.pyc
.venv/
venv/

# Node (for marketplace tooling)
node_modules/

# Logs / scratch
*.log
.scratch/
