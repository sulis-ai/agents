{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "plugins": ["@typescript-eslint", "import"],
  "settings": {
    "import/resolver": {
      "node": { "extensions": [".ts", ".tsx", ".js", ".jsx"] },
      "typescript": { "alwaysTryTypes": true }
    }
  },
  "rules": {
    "import/no-restricted-paths": [
      "error",
      {
        "zones": [
          {
            "target": "./",
            "from": "../..",
            "except": ["./"],
            "message": "Cross-import boundary violation — apps/cockpit/ must not import from outside its own tree (TDD §9, ADR-008)."
          }
        ]
      }
    ],
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["../../../../*", "../../../../../*", "../../../../../../*"],
            "message": "Cross-import boundary violation — relative imports of 4+ levels up escape apps/cockpit/ (the deepest in-tree source is client/src/api/, three levels up from which is apps/cockpit/ itself). See TDD §9, ADR-008."
          }
        ]
      }
    ]
  },
  "ignorePatterns": ["dist/", "node_modules/", "**/*.d.ts"]
}
