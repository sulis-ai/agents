{
  "name": "@sulis/cockpit",
  "version": "0.0.0",
  "private": true,
  "description": "Sulis local cockpit — read-only localhost web app over the change store + worktrees + Claude Code transcripts (TDD §1).",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names server,client --prefix-colors blue,green 'tsx watch server/index.ts' 'vite client'",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite client",
    "typecheck": "tsc --noEmit -p server && tsc --noEmit -p client",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "check:read-only": "bash scripts/check-read-only.sh",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:terminal": "playwright test --config e2e/live-terminal.config.ts",
    "test:e2e:terminal-real": "playwright test --config e2e/live-terminal-real.config.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.100.14",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "supertest": "^7.1.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "ws": "^8.18.0"
  }
}
