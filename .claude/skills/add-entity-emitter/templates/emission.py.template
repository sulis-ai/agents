def emit___entity___from___source__(
    source_path: Path,
    repo: EntityRepository,
) -> list[dict]:
    """Read the source artifact file and emit each detected __ENTITY__
    through `repo`.

    Returns the list of persisted entity dicts. Raises
    `EntityValidationError` (propagated from the adapter) on a malformed
    entity; the adapter never persists an invalid instance.
    """
    source_text = Path(source_path).read_text(encoding="utf-8")
    entities = compose___entity___from___source__(
        source_text, source_path=str(source_path)
    )
    for entity in entities:
        repo.save("__entity__", entity)
    return entities
