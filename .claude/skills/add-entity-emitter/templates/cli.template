#!/usr/bin/env python3
"""sulis-emit-__entity__ — emit __ENTITY_PLURAL__ from a __SOURCE_NOUN__.

GENERATED by `.claude/skills/add-entity-emitter`. Pairs with the n=1
(sulis-emit-decision, CH-01KSWB) and n=2 (sulis-emit-requirements,
CH-01KSWQ) CLI shapes. JSON envelope per the marketplace convention.

Usage:
    sulis-emit-__entity__ __SOURCE_FLAG__ <path>
                          [--base-dir <dir>]
                          [--domain <domain>]
                          [--repo-root <dir>]

Defaults:
    --base-dir   <repo-root>/.brain/instances
    --domain     product-development
    --repo-root  `git rev-parse --show-toplevel` (or `cwd` if not a git repo)

Output (JSON to stdout):
    success: {"ok": true, "data": {"from___source__", "count", "entities": [...]}}
    failure: {"ok": false, "error": "<reason>"}

Each entity entry: {"id", "path"} — the emitted entity id and on-disk
`.jsonld` location.

Exit code: 0 on success (including 0-entity success); 1 on failure.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

from _entity_adapter_local import LocalFileEntityAdapter  # noqa: E402
from _entity_repository import EntityValidationError  # noqa: E402
from ___entity___emission import emit___entity___from___source__  # noqa: E402


def _resolve_repo_root(explicit: str | None) -> Path:
    if explicit:
        return Path(explicit).resolve()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True, timeout=10,
        )
        return Path(out.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return Path.cwd()


def _ok(data: dict) -> int:
    print(json.dumps({"ok": True, "data": data}, indent=2))
    return 0


def _err(message: str) -> int:
    print(json.dumps({"ok": False, "error": message}, indent=2))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Emit __ENTITY_PLURAL__ from a __SOURCE_NOUN__.",
    )
    parser.add_argument(
        "__SOURCE_FLAG__", required=True,
        help="path to the __SOURCE_NOUN__",
    )
    parser.add_argument(
        "--base-dir",
        help="instance base directory (default: <repo-root>/.brain/instances)",
    )
    parser.add_argument(
        "--domain", default="product-development",
        help="entity-schema domain (default: product-development)",
    )
    parser.add_argument(
        "--repo-root",
        help="repo root (default: git toplevel, or cwd if not a git repo)",
    )
    args = parser.parse_args()

    # argparse turns `__SOURCE_FLAG__` (e.g. `--from-srd`) into
    # `args.from_srd`; rename here for clarity.
    source_path = Path(getattr(args, "__SOURCE_FLAG_ATTR__")).resolve()
    if not source_path.exists():
        return _err(f"__SOURCE_NOUN__ not found: {source_path}")

    repo_root = _resolve_repo_root(args.repo_root)
    base_dir = (
        Path(args.base_dir).resolve()
        if args.base_dir
        else repo_root / ".brain" / "instances"
    )

    adapter = LocalFileEntityAdapter(base_dir=base_dir, domain=args.domain)

    try:
        entities = emit___entity___from___source__(source_path, adapter)
    except EntityValidationError as exc:
        return _err(str(exc))
    except FileNotFoundError as exc:
        return _err(str(exc))

    entries: list[dict] = []
    for entity in entities:
        ulid = entity["id"].rsplit(":", 1)[-1]
        path = base_dir / args.domain / "__entity__" / f"{ulid}.jsonld"
        entries.append({"id": entity["id"], "path": str(path)})

    return _ok({
        "from___source__": str(source_path),
        "count": len(entries),
        "entities": entries,
    })


if __name__ == "__main__":
    sys.exit(main())
