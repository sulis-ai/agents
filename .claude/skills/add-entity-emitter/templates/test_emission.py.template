class TestEmitContract:
    """Standard contract the emit orchestrator MUST satisfy."""

    @pytest.fixture
    def adapter(self, tmp_path: Path) -> LocalFileEntityAdapter:
        return LocalFileEntityAdapter(
            base_dir=tmp_path / ".brain" / "instances",
            domain="product-development",
        )

    @pytest.mark.skipif(
        "TODO" in _GOOD_SOURCE, reason="Maintainer: fill in _GOOD_SOURCE"
    )
    def test_persists_each_entity_as_a_validated_jsonld(
        self, adapter: LocalFileEntityAdapter, tmp_path: Path
    ) -> None:
        source_path = tmp_path / "source__SOURCE_EXT__"
        source_path.write_text(_GOOD_SOURCE)

        emitted = emit___entity___from___source__(source_path, adapter)

        assert len(emitted) >= 1
        for entity in emitted:
            ulid = entity["id"].split(":")[-1]
            path = (
                tmp_path
                / ".brain"
                / "instances"
                / "product-development"
                / "__entity__"
                / f"{ulid}.jsonld"
            )
            assert path.exists(), f"expected file at {path}"

    @pytest.mark.skipif(
        "TODO" in _GOOD_SOURCE, reason="Maintainer: fill in _GOOD_SOURCE"
    )
    def test_emit_is_idempotent_under_re_run(
        self, adapter: LocalFileEntityAdapter, tmp_path: Path
    ) -> None:
        source_path = tmp_path / "source__SOURCE_EXT__"
        source_path.write_text(_GOOD_SOURCE)

        first = emit___entity___from___source__(source_path, adapter)
        second = emit___entity___from___source__(source_path, adapter)

        assert [e["id"] for e in first] == [e["id"] for e in second]

    def test_validation_propagates_for_a_schema_invalid_entity(
        self, adapter: LocalFileEntityAdapter, tmp_path: Path, monkeypatch
    ) -> None:
        """Pin that the adapter's rejection bubbles through emit_*.

        The compose function naturally produces valid entities; we monkey-patch
        it to inject a malformed id so the schema rejects.
        """
        if "TODO" in _GOOD_SOURCE:
            pytest.skip("Maintainer: fill in _GOOD_SOURCE")

        from ___entity___emission import compose___entity___from___source__ as _orig
        import ___entity___emission

        def _bad(source_text: str, *, source_path: str) -> list[dict]:
            result = _orig(source_text, source_path=source_path)
            for e in result:
                e["id"] = "not-a-valid-dna-id"
            return result

        monkeypatch.setattr(
            ___entity___emission,
            "compose___entity___from___source__",
            _bad,
        )

        source_path = tmp_path / "source__SOURCE_EXT__"
        source_path.write_text(_GOOD_SOURCE)

        with pytest.raises(EntityValidationError):
            emit___entity___from___source__(source_path, adapter)


