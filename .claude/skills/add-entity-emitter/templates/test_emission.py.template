        assert isinstance(result, list)
        assert all(isinstance(e, dict) for e in result)

    @pytest.mark.skipif(
        "TODO" in _GOOD_SOURCE, reason="Maintainer: fill in _GOOD_SOURCE"
    )
    def test_every_entity_id_matches_schema_pattern(self) -> None:
        # The compiled schema pins the id pattern as `^dna:__entity__:<26 Crockford-base32 chars>$`.
