        source_path = tmp_path / "source__SOURCE_EXT__"
        source_path.write_text(_VALID_SOURCE)

        result = run_tool(
            "sulis-emit-__entity__",
            "__SOURCE_FLAG__", str(source_path),
            "--repo-root", str(tmp_path),
